# ===== Cloudflare =====
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# ===== Database =====
D1_DATABASE_ID=your_d1_database_id
DATABASE_URL=./dev.db

# ===== Authentication =====
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRY=24h

# ===== Payment Gateway - DompetX =====
DOMPETX_API_KEY=your_dompetx_api_key
DOMPETX_BASE_URL=https://api.dompetx.com/v1
DOMPETX_WEBHOOK_SECRET=your_webhook_secret

# ===== Email - Resend =====
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=noreply@asridigital.com
RESEND_FROM_NAME=Asri Digital

# ===== App =====
APP_URL=https://asridigital.com
APP_ENV=production
