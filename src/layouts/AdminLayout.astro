---
import '../styles/global.css';
import AdminSidebar from '../components/layout/AdminSidebar.astro';
import AdminHeader from '../components/layout/AdminHeader.astro';

interface Props {
  title?: string;
  activePage?: string;
}

const {
  title = 'Admin - Asri Digital',
  activePage = 'dashboard',
} = Astro.props;

// Get token from cookie
const token = Astro.cookies.get('token')?.value;

// Helper function to verify JWT
async function verifyJWT(token: string): Promise<any> {
  try {
    const [headerB64, payloadB64, signatureB64] = token.split('.');

    // Decode header
    const header = JSON.parse(atob(headerB64.replace(/-/g, '+').replace(/_/g, '/')));

    // Decode payload
    const payload = JSON.parse(atob(payloadB64.replace(/-/g, '+').replace(/_/g, '/')));

    // Check expiration
    if (payload.exp && payload.exp < Math.floor(Date.now() / 1000)) {
      return null;
    }

    return payload;
  } catch (e) {
    return null;
  }
}

// Verify token and get user info
let user: any = null;
let isValid = false;

if (token) {
  const payload = await verifyJWT(token);
  if (payload && payload.userId) {
    // Check if user has admin role
    if (payload.role !== 'admin') {
      return Astro.redirect('/dashboard?error=unauthorized');
    }
    isValid = true;
    user = payload;
  }
}

// Redirect to login if not authenticated
if (!isValid) {
  return Astro.redirect('/dashboard?redirect=/admin');
}
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title}</title>
  <style is:global>
    @import '../styles/global.css';
  </style>
  <script define:vars={{ user }}>
    window.__ADMIN_USER__ = JSON.stringify({ userId: user?.userId, email: user?.email, name: user?.name, role: user?.role });
  </script>
</head>
<body class="h-screen overflow-hidden bg-background text-text-primary">
  <div class="flex h-full">
    <!-- SIDEBAR - Fixed left, collapsible on mobile -->
    <AdminSidebar activePage={activePage} />

    <!-- MAIN CONTENT -->
    <div class="flex flex-1 flex-col overflow-hidden">
      <!-- Top Header -->
      <AdminHeader />

      <!-- Page Content -->
      <main class="flex-1 overflow-y-auto p-4 sm:p-6">
        <slot />
      </main>
    </div>
  </div>

  <!-- Sidebar toggle script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const toggle = document.getElementById('sidebar-toggle');
      const sidebar = document.getElementById('admin-sidebar');
      const overlay = document.getElementById('sidebar-overlay');

      if (toggle && sidebar && overlay) {
        toggle.addEventListener('click', () => {
          sidebar.classList.toggle('-translate-x-full');
          overlay.classList.toggle('hidden');
        });

        overlay.addEventListener('click', () => {
          sidebar.classList.add('-translate-x-full');
          overlay.classList.add('hidden');
        });
      }

      // Collapsible menu groups
      document.querySelectorAll('[data-collapse-trigger]').forEach(trigger => {
        trigger.addEventListener('click', () => {
          const targetId = trigger.getAttribute('data-collapse-trigger');
          const target = document.getElementById(targetId || '');
          if (target) {
            target.classList.toggle('hidden');
            const icon = trigger.querySelector('[data-collapse-icon]');
            if (icon) {
              icon.classList.toggle('rotate-180');
            }
          }
        });
      });
    });
  </script>
</body>
</html>