---
interface Props {
  activePage?: string;
}

const { activePage = 'dashboard' } = Astro.props;

const menuItems = [
  {
    id: 'dashboard',
    label: 'Dashboard',
    href: '/admin',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
  },
  {
    id: 'products',
    label: 'Produk',
    href: '/admin/products',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>`,
    children: [
      { id: 'products', label: 'Daftar Produk', href: '/admin/products' },
      { id: 'categories', label: 'Kategori', href: '/admin/categories' },
    ],
  },
  {
    id: 'orders',
    label: 'Pesanan',
    href: '/admin/orders',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" /></svg>`,
  },
  {
    id: 'customers',
    label: 'Pelanggan',
    href: '/admin/subscribers',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
    children: [
      { id: 'subscribers', label: 'Subscribers', href: '/admin/subscribers' },
    ],
  },
  {
    id: 'coupons',
    label: 'Kupon',
    href: '/admin/coupons',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" /></svg>`,
  },
  {
    id: 'marketing',
    label: 'Konten',
    href: '/admin/hero-slides',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z" /></svg>`,
    children: [
      { id: 'hero-slides', label: 'Hero Slides', href: '/admin/hero-slides' },
      { id: 'blog', label: 'Blog', href: '/admin/blog' },
      { id: 'affiliates', label: 'Affiliate', href: '/admin/affiliates' },
    ],
  },
  {
    id: 'settings',
    label: 'Pengaturan',
    href: '/admin/settings',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
  },
];

// Check if a parent item has an active child
function isParentActive(item: any): boolean {
  if (!item.children) return activePage === item.id;
  return item.children.some((child: any) => activePage === child.id);
}
---

<!-- Mobile Overlay -->
<div id="sidebar-overlay" class="hidden fixed inset-0 bg-black/50 z-30 lg:hidden"></div>

<!-- Sidebar -->
<aside 
  id="admin-sidebar"
  class:list={[
    "fixed inset-y-0 left-0 z-40 bg-surface border-r border-border flex flex-col transition-transform duration-300 lg:translate-x-0 -translate-x-full lg:relative",
    "w-full sm:w-64",
  ]}
>
  <!-- Logo -->
  <div class="flex items-center justify-between h-16 px-4 border-b border-border shrink-0">
    <a href="/admin" class="flex items-center gap-2">
      <img src="https://res.cloudinary.com/daj8fzinf/image/upload/w_40/q_auto/f_auto/v1779951905/fav_icon_asri_digital_rktguz.png" alt="Asri Digital" class="h-8 w-auto rounded-lg" />
      <span class="text-xs text-text-muted font-medium">Admin</span>
    </a>
    <button id="sidebar-toggle" class="lg:hidden p-1.5 rounded-lg hover:bg-background text-text-muted">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 overflow-y-auto p-4 space-y-0.5">
    {menuItems.map(item => {
      const parentActive = isParentActive(item);
      const hasChildren = item.children && item.children.length > 0;
      
      return hasChildren ? (
        <div class="mb-1">
          <button
            data-menu-toggle={item.id}
            class:list={[
              "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 w-full text-left",
              parentActive
                ? "bg-primary/10 text-primary"
                : "text-text-secondary hover:bg-background hover:text-text-primary"
            ]}
          >
            <Fragment set:html={item.icon} />
            <span class="flex-1">{item.label}</span>
            <svg class="w-4 h-4 transition-transform duration-200" data-chevron={item.id} fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class:list={["ml-4 mt-0.5 space-y-0.5", parentActive ? "block" : "hidden"]} data-submenu={item.id}>
            {item.children.map((child: any) => (
              <a
                href={child.href}
                class:list={[
                  "flex items-center gap-3 px-3 py-2 rounded-lg text-sm transition-all duration-200",
                  activePage === child.id
                    ? "text-primary font-medium bg-primary/5"
                    : "text-text-muted hover:text-text-primary hover:bg-background"
                ]}
              >
                <span class:list={["w-1.5 h-1.5 rounded-full shrink-0", activePage === child.id ? "bg-primary" : "bg-border"]} />
                {child.label}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <a 
          href={item.href}
          class:list={[
            "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200",
            activePage === item.id 
              ? "bg-primary/10 text-primary" 
              : "text-text-secondary hover:bg-background hover:text-text-primary"
          ]}
        >
          <Fragment set:html={item.icon} />
          <span class="flex-1">{item.label}</span>
          {activePage === item.id && (
            <div class="w-1.5 h-1.5 rounded-full bg-primary shrink-0"></div>
          )}
        </a>
      );
    })}
  </nav>

  <!-- Footer -->
  <div class="p-4 border-t border-border shrink-0 space-y-1">
    <a href="/" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-background transition-colors text-sm text-text-muted">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
      <span>Lihat Website</span>
    </a>
    <button id="admin-logout-btn" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-red-50 transition-colors text-sm text-red-500 w-full text-left">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
      </svg>
      <span>Logout</span>
    </button>
  </div>
</aside>

<script is:inline>
  // Sidebar toggle for mobile
  document.addEventListener('DOMContentLoaded', () => {
    const sidebar = document.getElementById('admin-sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    function openSidebar() {
      if (!sidebar || !overlay) return;
      sidebar.classList.remove('-translate-x-full');
      overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
      if (!sidebar || !overlay) return;
      sidebar.classList.add('-translate-x-full');
      overlay.classList.add('hidden');
      document.body.style.overflow = '';
    }

    // Close button (X) inside sidebar
    document.getElementById('sidebar-toggle')?.addEventListener('click', closeSidebar);

    // Overlay click closes sidebar
    overlay?.addEventListener('click', closeSidebar);

    // Expose openSidebar globally for hamburger buttons in pages
    window.__openSidebar = openSidebar;
    window.__closeSidebar = closeSidebar;

    // Submenu toggles
    document.querySelectorAll('[data-menu-toggle]').forEach(btn => {
      const id = btn.getAttribute('data-menu-toggle');
      const submenu = document.querySelector(`[data-submenu="${id}"]`);
      const chevron = document.querySelector(`[data-chevron="${id}"]`);
      
      // If submenu has active child, expand by default
      if (submenu && !submenu.classList.contains('hidden')) {
        chevron?.classList.add('rotate-180');
      }

      btn.addEventListener('click', () => {
        if (!submenu) return;
        submenu.classList.toggle('hidden');
        chevron?.classList.toggle('rotate-180');
      });
    });

    // Logout
    document.getElementById('admin-logout-btn')?.addEventListener('click', () => {
      localStorage.removeItem('admin_token');
      window.location.href = '/admin/login';
    });
  });
</script>
