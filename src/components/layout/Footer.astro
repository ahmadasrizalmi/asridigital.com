---
import Icon from '../ui/Icon.astro';

const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    title: 'Produk',
    links: [
      { label: 'Semua GPT', href: '/#produk' },
      { label: 'All-Access Pass', href: '/#all-access' },
      { label: 'Promo Hari Ini', href: '/#promo' },
    ],
  },
  {
    title: 'Perusahaan',
    links: [
      { label: 'Blog', href: '/blog' },
      { label: 'Tentang Kami', href: '/about' },
      { label: 'Kontak', href: '/contact' },
    ],
  },
  {
    title: 'Dukungan',
    links: [
      { label: 'FAQ', href: '/faq' },
      { label: 'Cara Pembelian', href: '/guide' },
      { label: 'Kebijakan Privasi', href: '/privacy' },
    ],
  },
];
---

<footer class="bg-surface border-t border-border mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 sm:gap-8 lg:gap-12">
      <!-- Brand Section -->
      <div class="lg:col-span-2 space-y-6">
        <a href="/" class="flex items-center gap-2.5 group">
          <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
            <Icon name="sparkles" size={18} class="text-white" />
          </div>
          <span class="text-xl font-bold text-text-primary group-hover:text-primary transition-colors">
            Asri Digital
          </span>
        </a>
        
        <p class="text-text-secondary text-sm leading-relaxed max-w-sm">
          Custom GPT untuk Profesional Indonesia. Akses instant, bayar sekali, pakai selamanya.
        </p>
        
        <div class="flex items-center gap-2 text-sm text-text-muted">
          <Icon name="mail" size={16} />
          <span>support@asridigital.com</span>
        </div>
        
        <!-- Social Proof -->
        <div class="flex items-center gap-4 pt-2">
          <div class="flex -space-x-2">
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-xs font-bold text-primary border-2 border-surface">S</div>
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-xs font-bold text-primary border-2 border-surface">A</div>
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-xs font-bold text-primary border-2 border-surface">B</div>
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-xs font-bold text-primary border-2 border-surface">R</div>
          </div>
          <div class="text-xs text-text-muted">
            <span class="text-text-primary font-bold">500+</span> pengguna aktif
          </div>
        </div>
      </div>

      <!-- Footer Links -->
      {footerLinks.map((section) => (
        <div>
          <h3 class="font-semibold text-text-primary mb-4">{section.title}</h3>
          <ul class="space-y-3">
            {section.links.map((link) => (
              <li>
                <a 
                  href={link.href} 
                  class="text-sm text-text-secondary hover:text-primary transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-border mt-12 pt-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-text-muted">
          &copy; {currentYear} Asri Digital. All rights reserved.
        </p>
        
        <div class="flex items-center gap-6 text-sm text-text-muted">
          <a href="/privacy" class="hover:text-primary transition-colors">Privacy Policy</a>
          <a href="/terms" class="hover:text-primary transition-colors">Terms of Service</a>
        </div>
        
        <!-- Payment Methods -->
        <div class="flex items-center gap-2">
          <span class="text-xs text-text-muted">Powered by</span>
          <span class="text-sm font-semibold text-primary">DompetX</span>
        </div>
      </div>
    </div>
  </div>
</footer>
