---
const currentYear = new Date().getFullYear();
---

<footer class="bg-white pt-12 pb-8 border-t border-slate-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- MOBILE + SMALL TABLET: simplified layout (< 1024px) -->
    <div class="lg:hidden">
      <!-- Logo + Tagline -->
      <div class="flex items-center gap-3 mb-4">
        <img id="footer-logo-mobile" class="h-8 w-auto" src="https://res.cloudinary.com/daj8fzinf/image/upload/w_200/q_auto/f_auto/v1779951905/logo_asri_digital_resize_mgkdqj.png" alt="Asri Digital Logo" />
      </div>
      <p class="text-slate-500 text-sm mb-6 leading-relaxed" id="footer-tagline-mobile">
        Solusi Bisnis Digital & AI untuk Profesional Indonesia.
      </p>
      
      <!-- Links: 2-column grid -->
      <div class="grid grid-cols-2 gap-x-6 gap-y-3 mb-8 text-sm">
        <a href="/products" class="text-slate-600 hover:text-slate-900 transition-colors">Produk</a>
        <a href="/contact" class="text-slate-600 hover:text-slate-900 transition-colors">Kontak</a>
        <a href="/guide" class="text-slate-600 hover:text-slate-900 transition-colors">Panduan</a>
        <a href="/about" class="text-slate-600 hover:text-slate-900 transition-colors">About</a>
        <a href="/faq" class="text-slate-600 hover:text-slate-900 transition-colors">FAQ</a>
        <a href="/terms" class="text-slate-600 hover:text-slate-900 transition-colors">Terms</a>
      </div>

      <!-- Social + Copyright -->
      <div class="flex items-center justify-between pt-6 border-t border-slate-100">
        <p class="text-xs text-slate-400">&copy; {currentYear} Asri Digital</p>
        <div class="flex gap-2" id="footer-social-mobile">
          <a href="https://www.linkedin.com/company/asridigital" target="_blank" rel="noopener noreferrer" class="w-8 h-8 bg-carbon rounded-md flex items-center justify-center text-white hover:bg-carbon-hover transition" aria-label="LinkedIn">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" /></svg>
          </a>
          <a href="https://x.com/asridigital" target="_blank" rel="noopener noreferrer" class="w-8 h-8 bg-carbon rounded-md flex items-center justify-center text-white hover:bg-carbon-hover transition" aria-label="X (Twitter)">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- DESKTOP: full layout (>= 1024px) -->
    <div class="hidden lg:block">
      <div class="grid grid-cols-4 gap-12 mb-16">
        
        <!-- Brand -->
        <div class="col-span-1">
          <div class="flex items-center gap-3 mb-4">
            <img id="footer-logo-desktop" class="h-8 w-auto" src="https://res.cloudinary.com/daj8fzinf/image/upload/w_200/q_auto/f_auto/v1779951905/logo_asri_digital_resize_mgkdqj.png" alt="Asri Digital Logo" />
          </div>
          <p class="text-slate-500 text-sm mb-6 leading-relaxed pr-4" id="footer-tagline-desktop">
            Dapatkan inspirasi alur kerja, update software, dan tips produktivitas harian.
          </p>
          <div class="relative w-full">
            <input type="email" placeholder="Enter your email" class="w-full pl-4 pr-12 py-3 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-slate-400 text-slate-900 transition-colors" />
            <button class="absolute right-1.5 top-1.5 bottom-1.5 bg-carbon text-white px-3 rounded-md hover:bg-carbon-hover transition flex items-center justify-center">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
            </button>
          </div>
        </div>
        
        <!-- Produk -->
        <div>
          <h5 class="font-bold text-slate-900 text-sm mb-5">Produk</h5>
          <ul class="space-y-4 text-sm">
            <li><a href="/products" class="text-slate-500 hover:text-slate-900 transition-colors">Semua Produk</a></li>
            <li><a href="/guide" class="text-slate-500 hover:text-slate-900 transition-colors">Panduan</a></li>
            <li><a href="/faq" class="text-slate-500 hover:text-slate-900 transition-colors">FAQ</a></li>
          </ul>
        </div>

        <!-- Bantuan -->
        <div>
          <h5 class="font-bold text-slate-900 text-sm mb-5">Bantuan</h5>
          <ul class="space-y-4 text-sm">
            <li><a href="/contact" class="text-slate-500 hover:text-slate-900 transition-colors">Kontak</a></li>
            <li><a href="/about" class="text-slate-500 hover:text-slate-900 transition-colors">About</a></li>
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h5 class="font-bold text-slate-900 text-sm mb-5">Legal</h5>
          <ul class="space-y-4 text-sm">
            <li><a href="/terms" class="text-slate-500 hover:text-slate-900 transition-colors">Terms</a></li>
            <li><a href="/privacy" class="text-slate-500 hover:text-slate-900 transition-colors">Privacy</a></li>
          </ul>
        </div>
      </div>

      <!-- Bottom Footer -->
      <div class="flex justify-between items-center pt-8 border-t border-slate-100">
        <p class="text-sm text-slate-400">
          &copy; {currentYear} Asri Digital by Creator. All rights reserved.
        </p>
        <div class="flex space-x-3" id="footer-social-desktop">
          <a href="https://www.linkedin.com/company/asridigital" target="_blank" rel="noopener noreferrer" class="w-8 h-8 bg-carbon rounded-md flex items-center justify-center text-white hover:bg-carbon-hover transition" aria-label="LinkedIn">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" /></svg>
          </a>
          <a href="https://x.com/asridigital" target="_blank" rel="noopener noreferrer" class="w-8 h-8 bg-carbon rounded-md flex items-center justify-center text-white hover:bg-carbon-hover transition" aria-label="X (Twitter)">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
(function() {
  fetch('/api/site-settings')
    .then(function(r) { return r.json(); })
    .then(function(s) {
      // Update logo in footer (both mobile + desktop)
      if (s.logo_url) {
        ['footer-logo-mobile', 'footer-logo-desktop'].forEach(function(id) {
          var el = document.getElementById(id);
          if (el) el.setAttribute('src', s.logo_url);
        });
      }
      // Update site name alt text
      if (s.site_name) {
        ['footer-logo-mobile', 'footer-logo-desktop'].forEach(function(id) {
          var el = document.getElementById(id);
          if (el) el.setAttribute('alt', s.site_name + ' Logo');
        });
      }
      // Update tagline
      if (s.footer_tagline || s.site_description) {
        var tagline = s.footer_tagline || s.site_description;
        ['footer-tagline-mobile', 'footer-tagline-desktop'].forEach(function(id) {
          var el = document.getElementById(id);
          if (el) el.textContent = tagline;
        });
      }
      // Update copyright text
      if (s.copyright_text) {
        document.querySelectorAll('footer p').forEach(function(p) {
          if (p.textContent.indexOf('\u00A9') !== -1 && p.textContent.indexOf('Asri Digital') !== -1) {
            p.textContent = p.textContent.replace(/Asri Digital.*$/, s.copyright_text);
          }
        });
      }

      // Dynamic social links
      if (!s.instagram && !s.tiktok && !s.youtube) return;
      var containers = ['footer-social-mobile', 'footer-social-desktop'];
      containers.forEach(function(id) {
        var el = document.getElementById(id);
        if (!el) return;
        var icons = {
          instagram: { label: 'Instagram', svg: '<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>' },
          tiktok: { label: 'TikTok', svg: '<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.48V13.2a8.16 8.16 0 005.58 2.17v-3.45a4.85 4.85 0 01-2-.91V6.69h2.01z"/></svg>' },
          youtube: { label: 'YouTube', svg: '<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>' }
        };
        ['instagram','tiktok','youtube'].forEach(function(key) {
          if (s[key]) {
            var a = document.createElement('a');
            a.href = s[key]; a.target = '_blank'; a.rel = 'noopener noreferrer';
            a.className = 'w-8 h-8 bg-carbon rounded-md flex items-center justify-center text-white hover:bg-carbon-hover transition';
            a.setAttribute('aria-label', icons[key].label);
            a.innerHTML = icons[key].svg;
            el.appendChild(a);
          }
        });
      });
    })
    .catch(function() {});
})();
</script>
