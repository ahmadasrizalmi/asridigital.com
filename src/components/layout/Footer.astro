---
const currentYear = new Date().getFullYear();
---

<footer class="bg-white pt-12 sm:pt-20 pb-8 sm:pb-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- MOBILE: simplified layout -->
    <div class="sm:hidden">
      <h4 class="font-bold text-slate-900 text-lg mb-3">Asri Digital</h4>
      <p class="text-slate-500 text-sm mb-5 leading-relaxed">
        Solusi Bisnis Digital & AI untuk Profesional Indonesia.
      </p>
      
      <!-- Quick links horizontal -->
      <div class="flex flex-wrap gap-x-5 gap-y-2 mb-6 text-sm">
        <a href="/about" class="text-slate-500 hover:text-slate-900">About</a>
        <a href="/blog" class="text-slate-500 hover:text-slate-900">Blog</a>
        <a href="/faq" class="text-slate-500 hover:text-slate-900">FAQ</a>
        <a href="/contact" class="text-slate-500 hover:text-slate-900">Support</a>
        <a href="/terms" class="text-slate-500 hover:text-slate-900">Terms</a>
        <a href="/privacy" class="text-slate-500 hover:text-slate-900">Privacy</a>
      </div>

      <!-- Newsletter -->
      <div class="relative mb-6">
        <input type="email" placeholder="Enter your email" class="w-full pl-4 pr-12 py-3 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-slate-400 text-slate-900" />
        <button class="absolute right-1.5 top-1.5 bottom-1.5 bg-carbon text-white px-3 rounded-md transition flex items-center justify-center">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
        </button>
      </div>

      <!-- Social + Copyright -->
      <div class="flex items-center justify-between pt-5 border-t border-slate-100">
        <p class="text-xs text-slate-400">&copy; {currentYear} Asri Digital</p>
        <div class="flex space-x-2">
          <a href="#" class="w-8 h-8 bg-carbon rounded-md flex items-center justify-center text-white hover:bg-carbon-hover transition">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
          <a href="#" class="w-8 h-8 bg-carbon rounded-md flex items-center justify-center text-white hover:bg-carbon-hover transition">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- TABLET + DESKTOP: full layout -->
    <div class="hidden sm:block">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 mb-16">
        
        <!-- Brand & Newsletter -->
        <div class="lg:col-span-1">
          <h4 class="font-bold text-slate-900 text-lg mb-4">Asri Digital</h4>
          <p class="text-slate-500 text-sm mb-6 leading-relaxed pr-4">
            Dapatkan inspirasi alur kerja, update software, dan tips produktivitas harian.
          </p>
          <div class="relative w-full">
            <input type="email" placeholder="Enter your email" class="w-full pl-4 pr-12 py-3 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-slate-400 text-slate-900 transition-colors" />
            <button class="absolute right-1.5 top-1.5 bottom-1.5 bg-carbon text-white px-3 rounded-md hover:bg-carbon-hover transition flex items-center justify-center">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
            </button>
          </div>
        </div>
        
        <!-- Links Company -->
        <div class="lg:ml-12">
          <h5 class="font-bold text-slate-900 text-sm mb-5">Company</h5>
          <ul class="space-y-4 text-sm">
            <li><a href="/about" class="text-slate-500 hover:text-slate-900 transition-colors">About</a></li>
            <li><a href="/terms" class="text-slate-500 hover:text-slate-900 transition-colors">Terms</a></li>
            <li><a href="/privacy" class="text-slate-500 hover:text-slate-900 transition-colors">Privacy</a></li>
          </ul>
        </div>
        
        <!-- Links Product -->
        <div>
          <h5 class="font-bold text-slate-900 text-sm mb-5">Product</h5>
          <ul class="space-y-4 text-sm">
            <li><a href="/#produk" class="text-slate-500 hover:text-slate-900 transition-colors">Features</a></li>
            <li><a href="/#harga" class="text-slate-500 hover:text-slate-900 transition-colors">Pricing</a></li>
            <li><a href="/faq" class="text-slate-500 hover:text-slate-900 transition-colors">FAQ</a></li>
          </ul>
        </div>
        
        <!-- Links Resources -->
        <div>
          <h5 class="font-bold text-slate-900 text-sm mb-5">Resources</h5>
          <ul class="space-y-4 text-sm">
            <li><a href="/blog" class="text-slate-500 hover:text-slate-900 transition-colors">Blog</a></li>
            <li><a href="/contact" class="text-slate-500 hover:text-slate-900 transition-colors">Support</a></li>
          </ul>
        </div>
      </div>

      <!-- Bottom Footer -->
      <div class="flex flex-col md:flex-row justify-between items-center pt-8 border-t border-slate-100">
        <p class="text-sm text-slate-400 mb-4 md:mb-0">
          &copy; {currentYear} Asri Digital by Creator. All rights reserved.
        </p>
        <div class="flex space-x-3">
          <a href="#" class="w-8 h-8 bg-carbon rounded-md flex items-center justify-center text-white hover:bg-carbon-hover transition">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
          <a href="#" class="w-8 h-8 bg-carbon rounded-md flex items-center justify-center text-white hover:bg-carbon-hover transition">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
