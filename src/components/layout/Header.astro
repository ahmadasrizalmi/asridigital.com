---
import Icon from '../ui/Icon.astro';

const navLinks = [
  { label: 'Produk', href: '/#produk' },
  { label: 'Blog', href: '/blog' },
  { label: 'Harga', href: '/#harga' },
];
---

<header class="navbar sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 sm:gap-2.5 group">
        <div class="w-8 h-8 sm:w-9 sm:h-9 bg-primary rounded-lg flex items-center justify-center shadow-btn-primary">
          <Icon name="sparkles" size={16} class="sm:w-[18px] text-white" />
        </div>
        <span class="text-lg sm:text-xl font-bold text-text-primary group-hover:text-primary transition-colors">
          Asri Digital
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6 lg:gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-text-secondary hover:text-text-primary transition-colors relative group"
          >
            {link.label}
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all group-hover:w-full"></span>
          </a>
        ))}
      </nav>

      <!-- Auth Buttons - Desktop -->
      <div class="hidden md:flex items-center gap-3">
        <a href="/dashboard" class="btn-tertiary text-sm px-4 py-2">
          <Icon name="user" size={16} />
          Login
        </a>
        <a href="/#produk" class="btn-primary text-sm px-4 py-2">
          Mulai Gratis
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-toggle" class="md:hidden p-2 text-text-secondary hover:text-text-primary transition-colors rounded-lg hover:bg-background">
        <Icon name="menu" size={24} />
      </button>
    </div>
  </div>

  <!-- Mobile Menu - Responsive width -->
  <div id="mobile-menu" class="hidden md:hidden" style="position:fixed;inset:0;z-index:9999;">
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);" id="mobile-menu-overlay"></div>
    <div style="position:absolute;right:0;top:0;height:100%;width:280px;background:#FFFFFF;border-left:1px solid #E5E5E5;padding:24px;box-shadow:0 20px 25px -5px rgba(0,0,0,0.1);">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:32px;">
        <span style="font-weight:700;font-size:20px;color:#171717;">Menu</span>
        <button id="mobile-menu-close" style="padding:8px;border-radius:8px;background:transparent;border:none;cursor:pointer;">
          <Icon name="x" size={24} />
        </button>
      </div>

      <nav style="display:flex;flex-direction:column;gap:8px;">
        {navLinks.map((link) => (
          <a
            href={link.href}
            style="display:block;padding:12px 16px;color:#262626;font-weight:500;font-size:16px;text-decoration:none;border-radius:8px;"
          >
            {link.label}
          </a>
        ))}

        <hr style="border:none;border-top:1px solid #E5E5E5;margin:16px 0;" />

        <a href="/dashboard" class="btn-tertiary justify-center w-full">
          <Icon name="user" size={18} />
          Login
        </a>
        <a href="/#produk" class="btn-primary justify-center w-full">
          Mulai Gratis
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');
  const close = document.getElementById('mobile-menu-close');

  function closeMenu() {
    menu?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function openMenu() {
    menu?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  toggle?.addEventListener('click', () => openMenu());
  overlay?.addEventListener('click', closeMenu);
  close?.addEventListener('click', closeMenu);

  // Close menu when clicking on links
  menu?.querySelectorAll('a[href]').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>