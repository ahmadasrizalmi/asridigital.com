---
import Icon from '../ui/Icon.astro';

const navLinks = [
  { label: 'Produk', href: '/#produk' },
  { label: 'Blog', href: '/blog' },
  { label: 'Harga', href: '/#harga' },
];
---

<header class="sticky top-0 z-50 glass">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-8 h-8 bg-gradient-to-br from-primary to-secondary rounded-lg flex items-center justify-center">
          <Icon name="sparkles" size={18} class="text-white" />
        </div>
        <span class="text-xl font-bold group-hover:text-primary transition-colors">
          Asri <span class="text-gradient">Digital</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a 
            href={link.href} 
            class="text-sm font-medium text-text-secondary hover:text-text-primary transition-colors relative group"
          >
            {link.label}
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all group-hover:w-full"></span>
          </a>
        ))}
      </nav>

      <!-- Auth Buttons -->
      <div class="hidden md:flex items-center gap-3">
        <a href="/api/auth/login" class="btn-secondary text-sm">
          <Icon name="user" size={16} />
          Login
        </a>
        <a href="/api/auth/register" class="btn-primary text-sm">
          Daftar
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-toggle" class="md:hidden p-2 text-text-secondary hover:text-text-primary transition-colors">
        <Icon name="menu" size={24} />
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden fixed inset-0 z-50">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="mobile-menu-overlay"></div>
    <div class="absolute right-0 top-0 h-full w-80 bg-surface border-l border-border p-6 transform transition-transform">
      <div class="flex justify-between items-center mb-10">
        <span class="font-bold text-xl">Menu</span>
        <button id="mobile-menu-close" class="p-2 hover:bg-background rounded-lg transition-colors">
          <Icon name="x" size={24} />
        </button>
      </div>
      
      <nav class="flex flex-col gap-2">
        {navLinks.map((link) => (
          <a 
            href={link.href} 
            class="px-4 py-3 text-text-secondary hover:text-text-primary hover:bg-background rounded-xl transition-colors flex items-center gap-3"
          >
            <Icon name="chevron-right" size={16} />
            {link.label}
          </a>
        ))}
        
        <hr class="border-border my-4" />
        
        <a href="/api/auth/login" class="btn-secondary justify-center">
          <Icon name="user" size={18} />
          Login
        </a>
        <a href="/api/auth/register" class="btn-primary justify-center">
          Daftar Sekarang
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');
  const close = document.getElementById('mobile-menu-close');

  function closeMenu() {
    menu?.classList.add('hidden');
  }

  toggle?.addEventListener('click', () => menu?.classList.remove('hidden'));
  overlay?.addEventListener('click', closeMenu);
  close?.addEventListener('click', closeMenu);
</script>
