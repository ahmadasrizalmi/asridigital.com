---
// Header component with sticky blur background
const currentPath = Astro.url.pathname;
const token = Astro.cookies.get('token')?.value;
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-background/80 border-b border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <svg class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
        </svg>
        <span class="text-xl font-bold group-hover:text-primary transition-colors">
          Asri <span class="text-primary">Digital</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/" class:list={["text-sm font-medium transition-colors hover:text-primary", currentPath === '/' ? 'text-primary' : 'text-text-secondary']}>
          Produk
        </a>
        <a href="/blog" class:list={["text-sm font-medium transition-colors hover:text-primary", currentPath.startsWith('/blog') ? 'text-primary' : 'text-text-secondary']}>
          Blog
        </a>
        <a href="/#harga" class="text-sm font-medium text-text-secondary transition-colors hover:text-primary">
          Harga
        </a>
      </nav>

      <!-- Auth Buttons -->
      <div class="hidden md:flex items-center gap-3">
        {token ? (
          <a href="/dashboard" class="flex items-center gap-2 px-4 py-2 bg-primary hover:bg-primary-hover text-white rounded-lg text-sm font-medium transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Dashboard
          </a>
        ) : (
          <>
            <a href="/api/auth/login" class="px-4 py-2 text-sm font-medium text-text-secondary hover:text-text-primary border border-border rounded-lg hover:bg-surface transition-colors">
              Login
            </a>
            <a href="/api/auth/register" class="px-4 py-2 text-sm font-medium bg-primary hover:bg-primary-hover text-white rounded-lg transition-colors">
              Daftar
            </a>
          </>
        )}
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-toggle" class="md:hidden p-2 text-text-secondary hover:text-text-primary">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Drawer -->
  <div id="mobile-menu" class="hidden md:hidden fixed inset-0 z-50">
    <div class="absolute inset-0 bg-black/50" id="mobile-menu-overlay"></div>
    <div class="absolute right-0 top-0 h-full w-64 bg-surface border-l border-border p-4">
      <div class="flex justify-between items-center mb-8">
        <span class="font-bold text-lg">Menu</span>
        <button id="mobile-menu-close" class="p-2 text-text-secondary hover:text-text-primary">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <nav class="flex flex-col gap-4">
        <a href="/" class="px-4 py-2 text-text-secondary hover:text-primary hover:bg-background rounded-lg transition-colors">Produk</a>
        <a href="/blog" class="px-4 py-2 text-text-secondary hover:text-primary hover:bg-background rounded-lg transition-colors">Blog</a>
        <a href="/#harga" class="px-4 py-2 text-text-secondary hover:text-primary hover:bg-background rounded-lg transition-colors">Harga</a>
        <hr class="border-border" />
        {token ? (
          <a href="/dashboard" class="px-4 py-2 bg-primary text-white rounded-lg text-center">Dashboard</a>
        ) : (
          <>
            <a href="/api/auth/login" class="px-4 py-2 text-text-secondary hover:text-primary border border-border rounded-lg text-center">Login</a>
            <a href="/api/auth/register" class="px-4 py-2 bg-primary text-white rounded-lg text-center">Daftar</a>
          </>
        )}
      </nav>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');
  const close = document.getElementById('mobile-menu-close');

  function closeMenu() {
    menu?.classList.add('hidden');
  }

  toggle?.addEventListener('click', () => menu?.classList.remove('hidden'));
  overlay?.addEventListener('click', closeMenu);
  close?.addEventListener('click', closeMenu);
</script>
