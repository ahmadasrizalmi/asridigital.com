---
import Icon from '../ui/Icon.astro';
import type { Product } from '../../types';
import { formatIDR, parseTags } from '../../lib/utils';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const tags = parseTags(product.tags);
const hasDiscount = product.compareAtPrice && product.compareAtPrice > product.price;
const discount = hasDiscount 
  ? Math.round((1 - product.price / product.compareAtPrice!) * 100) 
  : 0;
---

<div class="card-hover group">
  {/* Product Image */}
  <div class="relative h-48 overflow-hidden bg-background">
    <img 
      src={product.imageIcon || '/images/placeholder.jpg'} 
      alt={product.title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
    
    {/* Badges */}
    <div class="absolute top-3 left-3 flex gap-2">
      {hasDiscount && (
        <span class="badge-danger">
          HEMAT {discount}%
        </span>
      )}
      {product.isFeatured && (
        <span class="badge-warning">
          <Icon name="star" size={12} />
          POPULER
        </span>
      )}
    </div>
    
    {/* Category Badge */}
    <div class="absolute bottom-3 left-3">
      <span class="badge-muted">
        {product.category}
      </span>
    </div>
  </div>
  
  {/* Product Info */}
  <div class="p-5">
    {/* Tags */}
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {tags.slice(0, 3).map((tag) => (
          <span class="text-xs text-text-muted">
            #{tag}
          </span>
        ))}
      </div>
    )}
    
    {/* Title */}
    <h3 class="font-semibold text-lg mb-2 text-text-primary group-hover:text-primary transition-colors line-clamp-2">
      {product.title}
    </h3>
    
    {/* Description */}
    <p class="text-sm text-text-secondary mb-4 line-clamp-2">
      {product.shortDescription || product.description}
    </p>
    
    {/* Price & Actions */}
    <div class="mt-auto pt-4 border-t border-border">
      <div class="flex items-baseline gap-2 mb-4">
        <span class="text-2xl font-bold text-text-primary">
          {formatIDR(product.price)}
        </span>
        {hasDiscount && (
          <span class="text-sm text-text-muted line-through">
            {formatIDR(product.compareAtPrice!)}
          </span>
        )}
      </div>
      
      <div class="flex gap-2">
        <a 
          href={`/product/${product.slug}`}
          class="btn-tertiary flex-1 justify-center text-sm"
        >
          <Icon name="eye" size={16} />
          Detail
        </a>
        
        <a 
          href={`/checkout?product=${product.slug}`}
          class="btn-primary flex-1 justify-center text-sm"
        >
          <Icon name="shopping-cart" size={16} />
          Beli
        </a>
        
        {product.gptUrl && (
          <a 
            href={product.gptUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-tertiary px-3"
            title="Preview GPT"
          >
            <Icon name="external-link" size={16} />
          </a>
        )}
      </div>
      
      {/* All-Access Badge */}
      <div class="mt-3 flex items-center gap-1.5 text-xs text-text-muted">
        <Icon name="crown" size={14} class="text-amber-500" />
        <span>Tersedia di All-Access Pass</span>
      </div>
    </div>
  </div>
</div>

<style>
  /* Add card hover effect if not already present */
  .card-hover {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .card-hover:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px -8px rgba(0, 0, 0, 0.15);
  }
</style>
