---
import Icon from '../ui/Icon.astro';
import type { Product } from '../../types';
import { formatIDR, parseTags } from '../../lib/utils';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const tags = parseTags(product.tags);
const hasDiscount = product.compareAtPrice && product.compareAtPrice > product.price;
const discount = hasDiscount 
  ? Math.round((1 - product.price / product.compareAtPrice!) * 100) 
  : 0;
---

<div class="card-hover group">
  {/* Product Image */}
  <div class="relative h-48 overflow-hidden bg-gradient-to-br from-primary/10 to-secondary/10">
    <img 
      src={product.imageIcon || '/images/placeholder.jpg'} 
      alt={product.title}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
      loading="lazy"
    />
    
    {/* Featured Badge */}
    {product.isFeatured && (
      <div class="absolute top-3 right-3">
        <span class="badge-accent">
          <Icon name="star" size={12} />
          POPULER
        </span>
      </div>
    )}
    
    {/* Discount Badge */}
    {hasDiscount && (
      <div class="absolute top-3 left-3">
        <span class="badge bg-danger/20 text-danger">
          HEMAT {discount}%
        </span>
      </div>
    )}
    
    {/* Category Badge */}
    <div class="absolute bottom-3 left-3">
      <span class="badge bg-background/80 text-text-secondary backdrop-blur-sm">
        {product.category}
      </span>
    </div>
  </div>
  
  {/* Product Info */}
  <div class="p-5">
    {/* Tags */}
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {tags.slice(0, 3).map((tag) => (
          <span class="px-2 py-0.5 text-xs bg-background/50 text-text-muted rounded-full">
            {tag}
          </span>
        ))}
      </div>
    )}
    
    {/* Title */}
    <h3 class="font-semibold text-lg mb-2 line-clamp-2 group-hover:text-primary transition-colors">
      {product.title}
    </h3>
    
    {/* Description */}
    <p class="text-sm text-text-muted mb-4 line-clamp-2">
      {product.shortDescription || product.description}
    </p>
    
    {/* Price & Actions */}
    <div class="mt-auto">
      <div class="flex items-baseline gap-2 mb-4">
        <span class="text-2xl font-bold text-primary">
          {formatIDR(product.price)}
        </span>
        {hasDiscount && (
          <span class="text-sm text-text-muted line-through">
            {formatIDR(product.compareAtPrice!)}
          </span>
        )}
      </div>
      
      <div class="flex gap-2">
        <a 
          href={`/checkout?product=${product.slug}`}
          class="btn-primary flex-1 justify-center"
        >
          <Icon name="shopping-cart" size={16} />
          Beli Sekarang
        </a>
        
        {product.gptUrl && (
          <a 
            href={product.gptUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary px-3"
            title="Preview GPT"
          >
            <Icon name="external-link" size={16} />
          </a>
        )}
      </div>
      
      {/* All-Access Badge */}
      <div class="mt-3 flex items-center gap-1.5 text-xs text-text-muted">
        <Icon name="crown" size={14} class="text-accent" />
        <span>Tersedia di All-Access Pass</span>
      </div>
    </div>
  </div>
</div>
