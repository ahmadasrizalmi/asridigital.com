---
import Icon from '../ui/Icon.astro';
---

<!-- FOMO Toast Container -->
<div id="fomo-container" class="fixed bottom-4 left-4 z-50 space-y-3 max-w-sm">
</div>

<script>
  interface RecentSale {
    firstName: string;
    productName: string;
    timeAgo: string;
  }

  const container = document.getElementById('fomo-container');

  function createToast(sale: RecentSale): HTMLElement {
    const toast = document.createElement('div');
    toast.className = 'bg-white border border-gray-200 rounded-xl shadow-float p-4 flex items-start gap-3 transform transition-all duration-500 translate-x-[-100%] opacity-0';
    toast.innerHTML = `
      <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center text-sm font-bold text-green-700 shrink-0">
        ${sale.firstName.charAt(0)}
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm text-gray-900">
          <span class="font-semibold">${sale.firstName}</span> baru saja membeli
        </p>
        <a href="/#produk" class="text-sm text-green-700 font-medium truncate hover:underline block">${sale.productName}</a>
        <p class="text-xs text-gray-500 mt-1">${sale.timeAgo} yang lalu</p>
      </div>
      <button onclick="this.parentElement.remove()" class="text-gray-400 hover:text-gray-600">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
      <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-gray-100 rounded-b-xl overflow-hidden">
        <div class="h-full bg-green-500 toast-progress" style="animation: shrink 4s linear forwards"></div>
      </div>
    `;
    return toast;
  }

  function showToast(sale: RecentSale, delay: number) {
    setTimeout(() => {
      const toast = createToast(sale);
      container?.appendChild(toast);
      
      requestAnimationFrame(() => {
        toast.classList.remove('translate-x-[-100%]', 'opacity-0');
        toast.classList.add('translate-x-0', 'opacity-100');
      });

      setTimeout(() => {
        toast.classList.remove('translate-x-0', 'opacity-100');
        toast.classList.add('translate-x-[-100%]', 'opacity-0');
        setTimeout(() => toast.remove(), 500);
      }, 4000);
    }, delay);
  }

  async function fetchRecentSales(): Promise<RecentSale[]> {
    try {
      const response = await fetch('/api/recent-sales');
      const data = await response.json() as any;
      return data.sales || [];
    } catch {
      return [];
    }
  }

  async function startSequence() {
    if (!container) return;

    // Check if FOMO is enabled in admin settings
    try {
      const settingsRes = await fetch('/api/site-settings');
      const settings = await settingsRes.json();
      if (settings.fomo_enabled === 'false' || settings.fomo_enabled === false) {
        container.style.display = 'none';
        return;
      }
    } catch {
      // If settings fetch fails, default to showing FOMO
    }

    // Fetch real sales data
    const sales = await fetchRecentSales();
    
    if (sales.length > 0) {
      // Show real sales
      sales.forEach((sale, index) => {
        showToast(sale, 3000 + (index * 5000));
      });

      // Repeat every 30 seconds
      setInterval(async () => {
        const newSales = await fetchRecentSales();
        newSales.forEach((sale, index) => {
          showToast(sale, index * 5000);
        });
      }, 30000);
    } else {
      // Fallback to mock data
      const mockSales: RecentSale[] = [
        { firstName: 'S***', productName: 'Animasi Muslim Kids Studio', timeAgo: '5 menit' },
        { firstName: 'B***', productName: 'Lifetime All-Access Pass', timeAgo: '12 menit' },
        { firstName: 'A***', productName: 'Sahabat Guru PAUD Islami', timeAgo: '1 jam' },
      ];

      mockSales.forEach((sale, index) => {
        showToast(sale, 3000 + (index * 5000));
      });

      setInterval(() => {
        mockSales.forEach((sale, index) => {
          showToast(sale, index * 5000);
        });
      }, 30000);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', startSequence);
  } else {
    startSequence();
  }
</script>

<style>
  @keyframes shrink {
    from { width: 100%; }
    to { width: 0%; }
  }
</style>
