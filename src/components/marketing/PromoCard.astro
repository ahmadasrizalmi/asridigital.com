---
// PromoCard.astro — Lifetime All-Access Pass promo section
// Displayed between hero and social proof on homepage
---

<section id="all-access" class="py-12 sm:py-16 lg:py-20 bg-gradient-to-br from-amber-50 via-orange-50 to-amber-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative bg-white rounded-3xl shadow-xl overflow-hidden border border-amber-100">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
        <!-- Content side -->
        <div class="p-6 sm:p-8 lg:p-10 flex flex-col justify-center">
          <!-- Badge -->
          <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-400 text-amber-900 rounded-full text-xs sm:text-sm font-bold shadow-sm w-fit mb-4">
            ⭐ Best Value
          </div>

          <h2 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-text-primary leading-tight mb-3">
            Lifetime<br/>All-Access Pass
          </h2>
          <p class="text-sm sm:text-base text-text-muted mb-6 max-w-md">
            Akses SEMUA Custom GPT yang tersedia — termasuk produk baru yang akan datang. Bayar sekali, seumur hidup.
          </p>

          <!-- Price -->
          <div class="mb-6">
            <div class="flex items-baseline gap-3">
              <span class="text-3xl sm:text-4xl font-extrabold text-primary">Rp 299.000</span>
              <span class="text-lg sm:text-xl text-text-muted line-through">Rp599.000</span>
            </div>
            <span class="inline-flex items-center gap-1 mt-2 px-2.5 py-1 bg-green-100 text-green-700 rounded-md text-xs font-bold">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              HEMAT 50%
            </span>
          </div>

          <!-- Features -->
          <ul class="space-y-2.5 mb-8">
            <li class="flex items-start gap-2.5">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-sm sm:text-base text-text-secondary">Akses SEMUA Custom GPT yang ada</span>
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-sm sm:text-base text-text-secondary">Termasuk produk baru yang akan datang</span>
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-sm sm:text-base text-text-secondary">Bayar sekali, akses seumur hidup</span>
            </li>
          </ul>

          <!-- CTA -->
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/checkout?product=lifetime-all-access-pass" class="inline-flex items-center justify-center gap-2 bg-primary text-white font-bold px-6 py-3.5 rounded-xl hover:bg-primary/90 transition-all shadow-btn-primary text-sm sm:text-base">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              Beli Sekarang
            </a>
            <a href="/#produk" class="inline-flex items-center justify-center gap-2 bg-white text-text-primary font-bold px-6 py-3.5 rounded-xl border border-border hover:bg-background transition-all text-sm sm:text-base">
              Lihat Semua Produk
            </a>
          </div>
        </div>

        <!-- Image side -->
        <div class="hidden lg:flex items-center justify-center bg-gradient-to-br from-primary/5 to-primary/10 p-8">
          <img
            src="https://res.cloudinary.com/daj8fzinf/image/upload/q_auto,f_auto/v1779956124/promo_all_access_pass_jgs9d1.png"
            alt="Lifetime All-Access Pass"
            class="w-full max-w-md rounded-2xl shadow-xl object-contain"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Mobile image (below content) -->
      <div class="lg:hidden px-6 pb-6">
        <img
          src="https://res.cloudinary.com/daj8fzinf/image/upload/q_auto,f_auto/v1779956124/promo_all_access_pass_jgs9d1.png"
          alt="Lifetime All-Access Pass"
          class="w-full rounded-2xl shadow-lg object-contain"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
