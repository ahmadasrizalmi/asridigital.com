---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatIDR } from '../lib/utils';
import { getDB } from '../db';
import { orders, products } from '../db/schema';
import { eq } from 'drizzle-orm';

const orderId = Astro.url.searchParams.get('order');
const env = Astro.locals?.runtime?.env || {};

let order: any = null;
let product: any = null;

if (orderId) {
  try {
    const db = getDB(env);
    const result = await db.select().from(orders).where(eq(orders.id, orderId)).limit(1);
    order = result[0] || null;
    
    if (order) {
      const prodResult = await db.select().from(products).where(eq(products.id, order.productId)).limit(1);
      product = prodResult[0] || null;
    }
  } catch (e) {
    console.error('Success page DB error:', e);
  }
}
---

<BaseLayout title="Pembayaran Berhasil - Asri Digital" noFOMO>
  <div class="max-w-2xl mx-auto px-4 py-20 text-center">
    <div class="animate-fade-in">
      {/* Success Icon */}
      <div class="w-24 h-24 mx-auto mb-8 rounded-full bg-success/20 flex items-center justify-center">
        <svg class="w-12 h-12 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold mb-4">🎉 Pembayaran Berhasil!</h1>
      
      {order ? (
        <div class="space-y-4">
          <p class="text-lg text-text-secondary">
            Terima kasih atas pembelian Anda.
          </p>
          
          <div class="bg-surface border border-border rounded-xl p-6 text-left max-w-md mx-auto">
            <div class="space-y-4">
              <div>
                <p class="text-sm text-text-muted">Order ID</p>
                <p class="font-mono font-medium">{order.dompetxRefId}</p>
              </div>
              {product && (
                <div>
                  <p class="text-sm text-text-muted">Produk</p>
                  <p class="font-medium">{product.title}</p>
                </div>
              )}
              <div>
                <p class="text-sm text-text-muted">Total</p>
                <p class="text-xl font-bold text-success">{formatIDR(order.amount)}</p>
              </div>
              <div>
                <p class="text-sm text-text-muted">Status</p>
                <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-success/20 text-success rounded-full text-sm">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  PAID
                </span>
              </div>
            </div>
          </div>

          <p class="text-text-muted">
            Akses produk Anda sudah tersedia di dashboard. Link GPT juga sudah dikirim ke email.
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8">
            <a href="/dashboard" class="w-full sm:w-auto px-8 py-3 bg-primary hover:bg-primary-hover text-white rounded-lg font-medium transition-colors flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
              </svg>
              Buka Dashboard
            </a>
            {product?.gptUrl && (
              <a href={product.gptUrl} target="_blank" rel="noopener noreferrer"
                class="w-full sm:w-auto px-8 py-3 bg-success hover:bg-success/90 text-white rounded-lg font-medium transition-colors flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Buka GPT
              </a>
            )}
          </div>
        </div>
      ) : (
        <div class="space-y-4">
          <p class="text-lg text-text-secondary">
            Pembayaran Anda telah berhasil diproses.
          </p>
          <p class="text-text-muted">
            Silakan cek email Anda untuk detail pesanan.
          </p>
          <a href="/" class="inline-flex items-center gap-2 px-8 py-3 bg-primary hover:bg-primary-hover text-white rounded-lg font-medium transition-colors mt-4">
            Kembali ke Beranda
          </a>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
