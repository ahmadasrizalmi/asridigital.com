---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Icon from '../components/ui/Icon.astro';
import { formatIDR } from '../lib/utils';
---

<BaseLayout title="Dashboard - Asri Digital" description="Dashboard member Asri Digital — akses semua produk digital yang sudah dibeli.">
  <Header />
  
  <main class="flex-1 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Welcome Banner -->
      <div id="welcome-banner" class="card p-6 mb-8 bg-gradient-to-r from-primary/5 to-primary/10">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
          <div>
            <h1 class="text-2xl font-bold text-text-primary mb-2">
              Selamat datang, <span id="user-name">Guest</span>! <Icon name="user" size={20} class="inline text-primary" />
            </h1>
            <p class="text-text-secondary" id="user-status">Silakan login untuk mengakses dashboard Anda.</p>
          </div>
          <div id="all-access-badge" class="hidden">
            <div class="flex items-center gap-2 px-4 py-2 bg-amber-100 text-amber-700 rounded-full">
              <Icon name="crown" size={20} />
              <span class="font-semibold text-sm sm:text-base">ALL-ACCESS MEMBER</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Auth Section (shown when not logged in) -->
      <div id="auth-section" class="max-w-md mx-auto">
        <div class="card p-8">
          <h2 class="text-xl font-bold text-text-primary mb-6 text-center">Login ke Dashboard</h2>
          
          <!-- Login Form -->
          <form id="login-form" class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Email</label>
              <input type="email" id="login-email" name="email" class="input" placeholder="email@contoh.com" required />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Password</label>
              <div class="relative">
                <input type="password" id="login-password" name="password" class="input pr-10" placeholder="Masukkan password" required />
                <button type="button" class="toggle-password absolute right-3 top-1/2 -translate-y-1/2 text-text-muted hover:text-text-primary" data-target="login-password">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-icon"><path d="M1 12C1 12 5 4 12 4C19 4 23 12 23 12C23 12 19 20 12 20C5 20 1 12 1 12Z"/><path d="M12 15C13.6569 15 15 13.6569 15 12C15 10.3431 13.6569 9 12 9C10.3431 9 9 10.3431 9 12C9 13.6569 10.3431 15 12 15Z"/></svg>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-off-icon hidden"><path d="M1 1L23 23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55A10.94 10.94 0 0 1 7.28 11.06"/><path d="M10.71 5.05A16 16 0 0 1 22.56 9"/><path d="M1.42 9A15.91 15.91 0 0 1 4.63 6.64"/><path d="M8.53 16.11A6 6 0 0 1 15.47 16.11"/><path d="M12 20H12.01"/></svg>
                </button>
              </div>
            </div>
            <button type="submit" class="btn-primary w-full">
              <Icon name="log-in" size={18} />
              Login
            </button>
          </form>

          <div class="mt-3 text-center">
            <button id="show-forgot" class="text-sm text-primary hover:underline">Lupa Password?</button>
          </div>

          <!-- Forgot Password Form (hidden by default) -->
          <form id="forgot-form" class="space-y-4 hidden">
            <p class="text-sm text-text-secondary text-center">Masukkan email Anda, kami akan mengirim link reset password.</p>
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Email</label>
              <input type="email" id="forgot-email" name="email" class="input" placeholder="email@contoh.com" required />
            </div>
            <button type="submit" class="btn-primary w-full">
              <Icon name="send" size={18} />
              Kirim Link Reset
            </button>
            <div class="text-center">
              <button id="back-to-login" class="text-sm text-text-muted hover:text-primary hover:underline">← Kembali ke Login</button>
            </div>
          </form>

          <div id="forgot-success" class="mt-4 text-sm text-green-600 text-center hidden"></div>

          <div class="mt-4 text-center">
            <p class="text-sm text-text-muted">
              Belum punya akun? 
              <button id="show-register" class="text-primary hover:underline font-medium">Daftar</button>
            </p>
          </div>

          <!-- Register Form (hidden by default) -->
          <form id="register-form" class="space-y-4 hidden">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Nama Lengkap</label>
              <input type="text" id="register-name" name="name" class="input" placeholder="Nama Anda" required />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Email</label>
              <input type="email" id="register-email" name="email" class="input" placeholder="email@contoh.com" required />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Password</label>
              <div class="relative">
                <input type="password" id="register-password" name="password" class="input pr-10" placeholder="Minimal 6 karakter" required minlength="6" />
                <button type="button" class="toggle-password absolute right-3 top-1/2 -translate-y-1/2 text-text-muted hover:text-text-primary" data-target="register-password">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-icon"><path d="M1 12C1 12 5 4 12 4C19 4 23 12 23 12C23 12 19 20 12 20C5 20 1 12 1 12Z"/><path d="M12 15C13.6569 15 15 13.6569 15 12C15 10.3431 13.6569 9 12 9C10.3431 9 9 10.3431 9 12C9 13.6569 10.3431 15 12 15Z"/></svg>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="eye-off-icon hidden"><path d="M1 1L23 23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55A10.94 10.94 0 0 1 7.28 11.06"/><path d="M10.71 5.05A16 16 0 0 1 22.56 9"/><path d="M1.42 9A15.91 15.91 0 0 1 4.63 6.64"/><path d="M8.53 16.11A6 6 0 0 1 15.47 16.11"/><path d="M12 20H12.01"/></svg>
                </button>
              </div>
            </div>
            <button type="submit" class="btn-primary w-full">
              <Icon name="user-plus" size={18} />
              Daftar
            </button>
          </form>

          <div id="auth-error" class="mt-4 text-sm text-red-600 text-center hidden"></div>
        </div>
      </div>

      <!-- Dashboard Content (hidden when not logged in) -->
      <div id="dashboard-content" class="hidden">
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
          <div class="card p-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
                <Icon name="package" size={20} class="text-primary" />
              </div>
              <div>
                <p class="text-sm text-text-muted">Produk Saya</p>
                <p id="product-count" class="text-xl font-bold text-text-primary">0</p>
              </div>
            </div>
          </div>
          <div class="card p-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                <Icon name="check-circle" size={20} class="text-green-600" />
              </div>
              <div>
                <p class="text-sm text-text-muted">Pesanan Berhasil</p>
                <p id="order-count" class="text-xl font-bold text-text-primary">0</p>
              </div>
            </div>
          </div>
          <div class="card p-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center">
                <Icon name="crown" size={20} class="text-amber-600" />
              </div>
              <div>
                <p class="text-sm text-text-muted">Status</p>
                <p id="member-status" class="text-xl font-bold text-text-primary">Regular</p>
              </div>
            </div>
          </div>
        </div>

        <!-- My Products -->
        <div class="mb-8">
          <h2 class="text-xl font-bold text-text-primary mb-4 flex items-center gap-2">
            <Icon name="sparkles" size={20} class="text-primary" />
            Produk Saya
          </h2>
          
          <div id="products-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <!-- Products will be loaded here -->
          </div>

          <div id="no-products" class="card p-8 text-center hidden">
            <Icon name="package" size={48} class="text-text-muted mx-auto mb-4" />
            <h3 class="font-semibold text-text-primary mb-2">Belum Ada Produk</h3>
            <p class="text-text-secondary mb-4">Anda belum memiliki produk. Mulai belanja sekarang!</p>
            <a href="/#produk" class="btn-primary">
              <Icon name="shopping-cart" size={18} />
              Lihat Produk
            </a>
          </div>
        </div>

        <!-- Order History -->
        <div class="mb-8">
          <h2 class="text-xl font-bold text-text-primary mb-4 flex items-center gap-2">
            <Icon name="clock" size={20} class="text-primary" />
            Riwayat Pesanan
          </h2>
          
          <div class="card overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full">
                <thead>
                  <tr class="border-b border-border bg-background">
                    <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Order ID</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Produk</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Jumlah</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Status</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Tanggal</th>
                  </tr>
                </thead>
                <tbody id="orders-table" class="divide-y divide-border">
                  <!-- Orders will be loaded here -->
                </tbody>
              </table>
            </div>
            
            <div id="no-orders" class="p-8 text-center hidden">
              <Icon name="shopping-bag" size={48} class="text-text-muted mx-auto mb-4" />
              <h3 class="font-semibold text-text-primary mb-2">Belum Ada Pesanan</h3>
              <p class="text-text-secondary">Riwayat pesanan Anda akan muncul di sini.</p>
            </div>
          </div>
        </div>

        <!-- Affiliate Section -->
        <div id="affiliate-section" class="mt-8">
          <h2 class="text-xl font-bold text-text-primary mb-4 flex items-center gap-2">
            <Icon name="link" size={20} />
            Affiliate
          </h2>
          <div class="card p-6">
            <p class="text-sm text-text-secondary mb-3">Bagikan link referral Anda dan dapatkan komisi!</p>
            <div class="flex flex-col sm:flex-row gap-2 mb-4">
              <input type="text" id="referral-link" class="input flex-1" readonly value="Loading..." />
              <button onclick="copyReferralLink()" class="btn-secondary px-4">
                <Icon name="copy" size={16} />
                Copy
              </button>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-center">
              <div class="p-3 bg-background rounded-lg">
                <p class="text-xl font-bold text-primary" id="affiliate-conversions">0</p>
                <p class="text-xs text-text-muted">Konversi</p>
              </div>
              <div class="p-3 bg-background rounded-lg">
                <p class="text-xl font-bold text-primary" id="affiliate-commission">Rp 0</p>
                <p class="text-xs text-text-muted">Total Komisi</p>
              </div>
              <div class="p-3 bg-background rounded-lg">
                <p class="text-xl font-bold text-primary" id="affiliate-available">Rp 0</p>
                <p class="text-xs text-text-muted">Tersedia</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // API helper
  const API_BASE = '/api';

  // Read token from URL fragment (magic login redirect)
  (function() {
    const hash = window.location.hash;
    if (hash && hash.includes('token=')) {
      const token = hash.split('token=')[1];
      if (token) {
        localStorage.setItem('auth_token', token);
        // Clean URL
        window.history.replaceState({}, '', '/dashboard');
        // Fetch user info with the token
        fetch('/api/auth/me', { headers: { 'Authorization': 'Bearer ' + token } })
          .then(r => r.json())
          .then(data => {
            if (data.user) {
              localStorage.setItem('user', JSON.stringify(data.user));
              location.reload();
            }
          })
          .catch(() => {});
      }
    }
  })();

  function getToken(): string | null {
    return localStorage.getItem('auth_token');
  }

  function getUser(): any {
    const user = localStorage.getItem('user');
    return user ? JSON.parse(user) : null;
  }

  function setAuth(token: string, user: any) {
    localStorage.setItem('auth_token', token);
    localStorage.setItem('user', JSON.stringify(user));
  }

  function clearAuth() {
    localStorage.removeItem('auth_token');
    localStorage.removeItem('user');
  }

  async function apiRequest(endpoint: string, options: RequestInit = {}) {
    const token = getToken();
    const headers: any = {
      'Content-Type': 'application/json',
      ...options.headers
    };

    if (token) {
      headers['Authorization'] = `Bearer ${token}`;
    }

    const response = await fetch(`${API_BASE}${endpoint}`, {
      ...options,
      headers
    });

    return response.json();
  }

  // Format IDR
  function formatIDR(amount: number): string {
    return new Intl.NumberFormat('id-ID', {
      style: 'currency',
      currency: 'IDR',
      minimumFractionDigits: 0
    }).format(amount);
  }

  // DOM Elements
  const authSection = document.getElementById('auth-section');
  const dashboardContent = document.getElementById('dashboard-content');
  const loginForm = document.getElementById('login-form') as HTMLFormElement;
  const registerForm = document.getElementById('register-form') as HTMLFormElement;
  const showRegisterBtn = document.getElementById('show-register');
  const authError = document.getElementById('auth-error');
  const logoutBtn = null; // Logout now in header

  // Password toggle (eye icon)
  document.querySelectorAll('.toggle-password').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const input = document.getElementById(targetId) as HTMLInputElement;
      if (!input) return;

      const eyeIcon = btn.querySelector('.eye-icon');
      const eyeOffIcon = btn.querySelector('.eye-off-icon');

      if (input.type === 'password') {
        input.type = 'text';
        eyeIcon?.classList.add('hidden');
        eyeOffIcon?.classList.remove('hidden');
      } else {
        input.type = 'password';
        eyeIcon?.classList.remove('hidden');
        eyeOffIcon?.classList.add('hidden');
      }
    });
  });

  // Show/hide auth forms
  showRegisterBtn?.addEventListener('click', () => {
    loginForm?.classList.add('hidden');
    registerForm?.classList.remove('hidden');
    authError?.classList.add('hidden');
  });

  // Login handler
  loginForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    authError?.classList.add('hidden');

    const email = (document.getElementById('login-email') as HTMLInputElement).value;
    const password = (document.getElementById('login-password') as HTMLInputElement).value;

    try {
      const data = await apiRequest('/auth/login', {
        method: 'POST',
        body: JSON.stringify({ email, password })
      });

      if (data.error) {
        throw new Error(data.error);
      }

      setAuth(data.token, data.user);
      window.dispatchEvent(new Event('auth-changed'));
      showDashboard();
    } catch (error: any) {
      if (authError) {
        authError.textContent = error.message || 'Login gagal';
        authError.classList.remove('hidden');
      }
    }
  });

  // Register handler
  registerForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    authError?.classList.add('hidden');

    const name = (document.getElementById('register-name') as HTMLInputElement).value;
    const email = (document.getElementById('register-email') as HTMLInputElement).value;
    const password = (document.getElementById('register-password') as HTMLInputElement).value;

    try {
      const data = await apiRequest('/auth/register', {
        method: 'POST',
        body: JSON.stringify({ email, password, name })
      });

      if (data.error) {
        throw new Error(data.error);
      }

      setAuth(data.token, data.user);
      window.dispatchEvent(new Event('auth-changed'));

      // Tracking: Lead (registration)
      if (typeof window.trackEvent === 'function') {
        window.trackEvent('lead', {
          content_name: 'registration',
          content_type: 'user',
          email: data.user?.email
        });
      }

      showDashboard();
    } catch (error: any) {
      if (authError) {
        authError.textContent = error.message || 'Registrasi gagal';
        authError.classList.remove('hidden');
      }
    }
  });

  // Forgot password handler
  const showForgotBtn = document.getElementById('show-forgot');
  const forgotForm = document.getElementById('forgot-form') as HTMLFormElement;
  const forgotSuccess = document.getElementById('forgot-success');
  const backToLoginBtn = document.getElementById('back-to-login');

  showForgotBtn?.addEventListener('click', () => {
    loginForm?.classList.add('hidden');
    showForgotBtn.classList.add('hidden');
    forgotForm?.classList.remove('hidden');
    authError?.classList.add('hidden');
    forgotSuccess?.classList.add('hidden');
  });

  backToLoginBtn?.addEventListener('click', () => {
    forgotForm?.classList.add('hidden');
    loginForm?.classList.remove('hidden');
    showForgotBtn?.classList.remove('hidden');
    forgotSuccess?.classList.add('hidden');
  });

  forgotForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    authError?.classList.add('hidden');
    forgotSuccess?.classList.add('hidden');

    const email = (document.getElementById('forgot-email') as HTMLInputElement).value;

    try {
      const data = await apiRequest('/auth/forgot-password', {
        method: 'POST',
        body: JSON.stringify({ email })
      });

      if (data.error) throw new Error(data.error);

      if (forgotSuccess) {
        forgotSuccess.textContent = 'Link reset password sudah dikirim ke email Anda. Cek inbox/spam.';
        forgotSuccess.classList.remove('hidden');
      }
      forgotForm.reset();
    } catch (error: any) {
      if (authError) {
        authError.textContent = error.message || 'Gagal mengirim link reset';
        authError.classList.remove('hidden');
      }
    }
  });

  // Logout handler
  logoutBtn?.addEventListener('click', () => {
    clearAuth();
    window.location.reload();
  });

  // Show dashboard
  async function showDashboard() {
    const user = getUser();
    if (!user) return;

    // Hide auth, show dashboard
    authSection?.classList.add('hidden');
    dashboardContent?.classList.remove('hidden');

    // Update UI
    const userName = document.getElementById('user-name');
    const userStatus = document.getElementById('user-status');
    const allAccessBadge = document.getElementById('all-access-badge');
    const memberStatus = document.getElementById('member-status');

    if (userName) userName.textContent = user.name || 'User';
    if (userStatus) userStatus.textContent = user.email;
    
    if (user.is_all_access) {
      allAccessBadge?.classList.remove('hidden');
      if (memberStatus) memberStatus.textContent = 'VIP';
    }

    // Fetch user products
    try {
      const productsData = await apiRequest('/user/products');
      const productsGrid = document.getElementById('products-grid');
      const noProducts = document.getElementById('no-products');
      const productCount = document.getElementById('product-count');

      if (productsData.products && productsData.products.length > 0) {
        if (productCount) productCount.textContent = productsData.products.length.toString();
        
        if (productsGrid) {
          productsGrid.innerHTML = productsData.products.map((product: any) => `
            <div class="card-hover p-4">
              <div class="flex items-start gap-3">
                <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"></path>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="font-semibold text-text-primary">${product.title}</h3>
                  <p class="text-sm text-text-muted mt-1">${product.short_description || ''}</p>
                </div>
              </div>
              <div class="mt-4 flex gap-2">
                ${product.gpt_url ? `
                  <a href="${product.gpt_url}" target="_blank" rel="noopener noreferrer" class="btn-primary flex-1 justify-center text-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M18 13V19C18 19.5304 17.7893 20.0391 17.4142 20.4142C17.0391 20.7893 16.5304 21 16 21H5C4.46957 21 3.96086 20.7893 3.58579 20.4142C3.21071 20.0391 3 19.5304 3 19V8C3 7.46957 3.21071 6.96086 3.58579 6.58579C3.96086 6.21071 4.46957 6 5 6H11 M15 3H21V9 M10 14L21 3"></path>
                    </svg>
                    Buka GPT
                  </a>
                ` : ''}
              </div>
            </div>
          `).join('');
        }
      } else {
        noProducts?.classList.remove('hidden');
      }
    } catch (error) {
      console.error('Error fetching products:', error);
    }

    // Fetch orders
    try {
      const ordersData = await apiRequest('/orders');
      const ordersTable = document.getElementById('orders-table');
      const noOrders = document.getElementById('no-orders');
      const orderCount = document.getElementById('order-count');

      if (ordersData.orders && ordersData.orders.length > 0) {
        if (orderCount) {
          const paidOrders = ordersData.orders.filter((o: any) => o.status === 'PAID');
          orderCount.textContent = paidOrders.length.toString();
        }

        if (ordersTable) {
          ordersTable.innerHTML = ordersData.orders.map((order: any) => `
            <tr>
              <td class="px-4 py-4">
                <span class="font-mono text-sm text-text-primary">${order.id.substring(0, 8)}...</span>
              </td>
              <td class="px-4 py-4 text-text-main">${order.product_title}</td>
              <td class="px-4 py-4 font-medium text-text-primary">${formatIDR(order.amount)}</td>
              <td class="px-4 py-4">
                <span class="${order.status === 'PAID' ? 'badge-success' : order.status === 'PENDING' ? 'badge-warning' : 'badge-danger'}">
                  ${order.status === 'PAID' ? 'Lunas' : order.status === 'PENDING' ? 'Pending' : 'Gagal'}
                </span>
              </td>
              <td class="px-4 py-4 text-sm text-text-muted">${new Date(order.created_at).toLocaleDateString('id-ID')}</td>
            </tr>
          `).join('');
        }
      } else {
        noOrders?.classList.remove('hidden');
      }
    } catch (error) {
      console.error('Error fetching orders:', error);
    }

    // Fetch affiliate stats
    try {
      const affiliateData = await apiRequest('/affiliate/stats');
      
      if (affiliateData) {
        const referralLink = document.getElementById('referral-link') as HTMLInputElement;
        const conversions = document.getElementById('affiliate-conversions');
        const commission = document.getElementById('affiliate-commission');
        const available = document.getElementById('affiliate-available');
        
        if (referralLink) referralLink.value = affiliateData.referralLink || '';
        if (conversions) conversions.textContent = affiliateData.totalConversions || '0';
        if (commission) commission.textContent = formatIDR(affiliateData.totalCommission || 0);
        if (available) available.textContent = formatIDR(affiliateData.availableCommission || 0);
      }
    } catch (error) {
      console.error('Error fetching affiliate stats:', error);
    }
  }

  function copyReferralLink() {
    const input = document.getElementById('referral-link') as HTMLInputElement;
    if (input) {
      input.select();
      document.execCommand('copy');
      alert('Link referral berhasil disalin!');
    }
  }

  // Check if already logged in
  const user = getUser();
  if (user && getToken()) {
    showDashboard();
  }
</script>
