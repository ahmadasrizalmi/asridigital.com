---
import '../styles/global.css';
import { getDB } from '../db';
import { orders, products, users, affiliates } from '../db/schema';
import { eq, and, desc, sql } from 'drizzle-orm';
import { getCurrentUser } from '../lib/auth';
import { formatIDR, timeAgo, generateReferralLink, parseTags } from '../lib/utils';

const env = Astro.locals?.runtime?.env || {};
const jwtSecret = env.JWT_SECRET || 'default-secret';
const currentUser = await getCurrentUser(Astro.cookies, jwtSecret);

if (!currentUser) {
  return Astro.redirect('/api/auth/login');
}

const db = getDB(env);

// Get user data
const user = await db.select().from(users).where(eq(users.id, currentUser.sub)).limit(1);
const userData = user[0];

// Get user's orders with product info
const userOrders = await db
  .select({
    orderId: orders.id,
    orderRef: orders.dompetxRefId,
    amount: orders.amount,
    status: orders.status,
    paidAt: orders.paidAt,
    createdAt: orders.createdAt,
    productId: orders.productId,
    productTitle: products.title,
    productSlug: products.slug,
    productGptUrl: products.gptUrl,
    productCategory: products.category,
  })
  .from(orders)
  .innerJoin(products, eq(orders.productId, products.id))
  .where(and(
    eq(orders.userId, currentUser.sub),
    eq(orders.status, 'PAID')
  ))
  .orderBy(desc(orders.createdAt));

// Get all products for All-Access users
let allProducts: any[] = [];
if (userData?.isAllAccess) {
  allProducts = await db.select().from(products).where(eq(products.isActive, true));
}

// Get affiliate stats
const affiliateStats = await db
  .select({
    totalCommission: sql<number>`sum(${affiliates.commissionAmount})`,
    totalConversions: sql<number>`count(*)`,
  })
  .from(affiliates)
  .where(eq(affiliates.referredByUserId, currentUser.sub));

const totalCommission = affiliateStats[0]?.totalCommission || 0;
const totalConversions = affiliateStats[0]?.totalConversions || 0;
const referralLink = generateReferralLink(currentUser.sub, env.APP_URL || 'https://asridigital.com');

// Dashboard menu items
const menuItems = [
  { id: 'products', label: 'Produk Saya', icon: '📦' },
  { id: 'orders', label: 'Riwayat Pesanan', icon: '🛒' },
  { id: 'affiliate', label: 'Affiliate', icon: '🤝' },
];

const activeTab = Astro.url.searchParams.get('tab') || 'products';
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard - Asri Digital</title>
</head>
<body class="h-screen overflow-hidden bg-background text-text-primary">
  <div class="flex h-full">
    {/* SIDEBAR */}
    <aside id="dashboard-sidebar" class="fixed lg:static inset-y-0 left-0 z-40 w-64 bg-surface border-r border-border flex flex-col transition-transform duration-300 lg:translate-x-0 -translate-x-full">
      {/* Logo */}
      <div class="flex items-center justify-between h-16 px-4 border-b border-border shrink-0">
        <a href="/" class="flex items-center gap-2">
          <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
          </svg>
          <span class="font-bold">Asri Digital</span>
        </a>
        <button id="sidebar-close" class="lg:hidden p-1.5 rounded-lg hover:bg-background text-text-muted">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      {/* User Info */}
      <div class="p-4 border-b border-border">
        <div class="flex items-center gap-3">
          <div class:list={[
            "w-10 h-10 rounded-full flex items-center justify-center font-bold",
            userData?.isAllAccess ? "bg-accent/20 text-accent" : "bg-primary/20 text-primary"
          ]}>
            {userData?.name?.charAt(0) || 'U'}
          </div>
          <div>
            <p class="font-medium text-sm">{userData?.name || 'User'}</p>
            {userData?.isAllAccess && (
              <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-accent/20 text-accent rounded-full text-xs">
                👑 All-Access
              </span>
            )}
          </div>
        </div>
      </div>

      {/* Navigation */}
      <nav class="flex-1 overflow-y-auto p-4 space-y-1">
        {menuItems.map(item => (
          <a 
            href={`/dashboard?tab=${item.id}`}
            class:list={[
              "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all",
              activeTab === item.id 
                ? "bg-primary/20 text-primary" 
                : "text-text-secondary hover:bg-background hover:text-text-primary"
            ]}
          >
            <span>{item.icon}</span>
            <span>{item.label}</span>
          </a>
        ))}
      </nav>

      {/* Footer */}
      <div class="p-4 border-t border-border space-y-2 shrink-0">
        <a href="/" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-background transition-colors text-sm text-text-muted">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Kembali ke Store
        </a>
        <a href="/api/auth/logout" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-background transition-colors text-sm text-danger">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
          Logout
        </a>
      </div>
    </aside>

    {/* Mobile Overlay */}
    <div id="sidebar-overlay" class="hidden fixed inset-0 bg-black/50 z-30 lg:hidden"></div>

    {/* MAIN CONTENT */}
    <div class="flex flex-1 flex-col overflow-hidden">
      {/* Top Header */}
      <header class="h-16 bg-surface border-b border-border flex items-center justify-between px-6 shrink-0">
        <div class="flex items-center gap-4">
          <button id="sidebar-toggle" class="lg:hidden p-2 rounded-lg hover:bg-background text-text-muted">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          <h2 class="text-lg font-semibold">Dashboard</h2>
        </div>
        <a href="/" class="text-sm text-text-muted hover:text-primary transition-colors">
          asridigital.com
        </a>
      </header>

      {/* Page Content */}
      <main class="flex-1 overflow-y-auto p-6">
        {/* Welcome Banner */}
        {userData?.isAllAccess && (
          <div class="mb-8 p-6 rounded-xl bg-gradient-to-r from-accent/20 to-yellow-600/20 border border-accent/30">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 rounded-full bg-accent/20 flex items-center justify-center text-2xl">
                👑
              </div>
              <div>
                <h3 class="font-bold text-lg">Selamat datang, {userData.name}!</h3>
                <p class="text-text-secondary">Anda adalah <span class="text-accent font-semibold">All-Access Member</span>. Akses seluruh produk kami seumur hidup.</p>
              </div>
            </div>
          </div>
        )}

        {/* Products Tab */}
        {activeTab === 'products' && (
          <div>
            <h3 class="text-xl font-bold mb-6">
              {userData?.isAllAccess ? '📦 Semua Produk' : '📦 Produk Saya'}
            </h3>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {(userData?.isAllAccess ? allProducts : userOrders.map(o => ({
                id: o.productId,
                title: o.productTitle,
                slug: o.productSlug,
                gptUrl: o.productGptUrl,
                category: o.productCategory,
              }))).map((item: any) => (
                <div class="bg-surface border border-border rounded-xl p-5 hover:border-primary/30 transition-colors">
                  <div class="flex items-start justify-between mb-4">
                    <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center">
                      <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                      </svg>
                    </div>
                    <span class="px-2 py-1 bg-primary/10 text-primary text-xs rounded-full">{item.category || 'general'}</span>
                  </div>
                  <h4 class="font-semibold mb-4">{item.title}</h4>
                  <div class="flex gap-2">
                    {item.gptUrl ? (
                      <a href={item.gptUrl} target="_blank" rel="noopener noreferrer"
                        class="flex-1 flex items-center justify-center gap-2 px-4 py-2 bg-primary hover:bg-primary-hover text-white rounded-lg text-sm font-medium transition-colors">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                        Buka GPT
                      </a>
                    ) : (
                      <span class="flex-1 text-center text-sm text-text-muted py-2">Link segera tersedia</span>
                    )}
                  </div>
                </div>
              ))}
            </div>

            {userOrders.length === 0 && !userData?.isAllAccess && (
              <div class="text-center py-16 border border-dashed border-border rounded-xl">
                <p class="text-text-muted mb-4">Anda belum memiliki produk</p>
                <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-lg">
                  Jelajahi Produk
                </a>
              </div>
            )}
          </div>
        )}

        {/* Orders Tab */}
        {activeTab === 'orders' && (
          <div>
            <h3 class="text-xl font-bold mb-6">🛒 Riwayat Pesanan</h3>
            
            <div class="bg-surface border border-border rounded-xl overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full">
                  <thead>
                    <tr class="border-b border-border">
                      <th class="text-left px-6 py-4 text-sm font-medium text-text-muted">Order ID</th>
                      <th class="text-left px-6 py-4 text-sm font-medium text-text-muted">Produk</th>
                      <th class="text-left px-6 py-4 text-sm font-medium text-text-muted">Total</th>
                      <th class="text-left px-6 py-4 text-sm font-medium text-text-muted">Status</th>
                      <th class="text-left px-6 py-4 text-sm font-medium text-text-muted">Tanggal</th>
                    </tr>
                  </thead>
                  <tbody>
                    {userOrders.map(order => (
                      <tr class="border-b border-border hover:bg-background/50 transition-colors">
                        <td class="px-6 py-4 text-sm font-mono">{order.orderRef.slice(0, 15)}...</td>
                        <td class="px-6 py-4 text-sm">{order.productTitle}</td>
                        <td class="px-6 py-4 text-sm font-medium">{formatIDR(order.amount)}</td>
                        <td class="px-6 py-4">
                          <span class:list={[
                            "inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium",
                            order.status === 'PAID' ? "bg-success/20 text-success" : 
                            order.status === 'PENDING' ? "bg-warning/20 text-warning" : 
                            "bg-danger/20 text-danger"
                          ]}>
                            {order.status === 'PAID' && '✅ '}
                            {order.status === 'PENDING' && '⏳ '}
                            {order.status === 'FAILED' && '❌ '}
                            {order.status}
                          </span>
                        </td>
                        <td class="px-6 py-4 text-sm text-text-muted">{timeAgo(order.createdAt || new Date())}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              
              {userOrders.length === 0 && (
                <div class="text-center py-12 text-text-muted">
                  Belum ada pesanan
                </div>
              )}
            </div>
          </div>
        )}

        {/* Affiliate Tab */}
        {activeTab === 'affiliate' && (
          <div>
            <h3 class="text-xl font-bold mb-6">🤝 Program Affiliate</h3>
            
            {/* Stats */}
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
              <div class="bg-surface border border-border rounded-xl p-5">
                <p class="text-sm text-text-muted mb-1">Total Konversi</p>
                <p class="text-2xl font-bold">{totalConversions}</p>
              </div>
              <div class="bg-surface border border-border rounded-xl p-5">
                <p class="text-sm text-text-muted mb-1">Total Komisi</p>
                <p class="text-2xl font-bold text-success">{formatIDR(totalCommission)}</p>
              </div>
              <div class="bg-surface border border-border rounded-xl p-5">
                <p class="text-sm text-text-muted mb-1">Komisi per Referral</p>
                <p class="text-2xl font-bold text-primary">10%</p>
              </div>
            </div>

            {/* Referral Link */}
            <div class="bg-surface border border-border rounded-xl p-6 mb-8">
              <h4 class="font-semibold mb-4">Link Affiliate Anda</h4>
              <div class="flex gap-2">
                <input type="text" value={referralLink} readonly
                  class="flex-1 px-4 py-3 bg-background border border-border rounded-lg font-mono text-sm" />
                <button onclick={`navigator.clip.writeText('${referralLink}');this.textContent='Copied!';setTimeout(()=>this.textContent='Copy',2000)`}
                  class="px-6 py-3 bg-primary hover:bg-primary-hover text-white rounded-lg font-medium transition-colors">
                  Copy
                </button>
              </div>
              <p class="text-sm text-text-muted mt-3">Bagikan link ini dan dapatkan komisi 10% dari setiap pembelian!</p>
            </div>
          </div>
        )}
      </main>
    </div>
  </div>

  {/* Sidebar toggle script */}
  <script>
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('dashboard-sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    const close = document.getElementById('sidebar-close');

    function closeSidebar() {
      sidebar?.classList.add('-translate-x-full');
      overlay?.classList.add('hidden');
    }

    toggle?.addEventListener('click', () => {
      sidebar?.classList.remove('-translate-x-full');
      overlay?.classList.remove('hidden');
    });

    overlay?.addEventListener('click', closeSidebar);
    close?.addEventListener('click', closeSidebar);
  </script>
</body>
</html>
