---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';

const coupons = [
  { id: 'coupon-launch50', code: 'LAUNCH50', type: 'PERCENTAGE', value: 50, minPurchase: 50000, maxUses: 100, currentUses: 12, isActive: true, expiresAt: '2026-12-31' },
  { id: 'coupon-diskon20k', code: 'DISKON20K', type: 'FIXED', value: 20000, minPurchase: 50000, maxUses: 50, currentUses: 8, isActive: true, expiresAt: '2026-12-31' },
  { id: 'coupon-welcome10', code: 'WELCOME10', type: 'PERCENTAGE', value: 10, minPurchase: null, maxUses: 1000, currentUses: 45, isActive: true, expiresAt: null },
];

const sidebarLinks = [
  { icon: 'bar-chart', label: 'Dashboard', href: '/admin', active: false },
  { icon: 'sparkles', label: 'Produk', href: '/admin/products', active: false },
  { icon: 'shopping-cart', label: 'Pesanan', href: '/admin/orders', active: false },
  { icon: 'users', label: 'Pengguna', href: '/admin/users', active: false },
  { icon: 'tag', label: 'Kupon', href: '/admin/coupons', active: true },
  { icon: 'link', label: 'Affiliate', href: '/admin/affiliates', active: false },
  { icon: 'file-text', label: 'Blog', href: '/admin/blog', active: false },
  { icon: 'settings', label: 'Pengaturan', href: '/admin/settings', active: false },
];
---

<BaseLayout title="Kupon - Admin">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-surface border-r border-border shrink-0 hidden lg:block">
      <div class="sticky top-0 h-screen overflow-y-auto p-4">
        <a href="/admin" class="flex items-center gap-2.5 mb-8 px-2">
          <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
            <Icon name="sparkles" size={18} class="text-white" />
          </div>
          <div>
            <span class="font-bold text-text-primary block">Asri Digital</span>
            <span class="text-xs text-text-muted">Admin Panel</span>
          </div>
        </a>
        
        <nav class="space-y-1">
          {sidebarLinks.map((link) => (
            <a href={link.href} class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${link.active ? 'bg-primary/10 text-primary' : 'text-text-secondary hover:text-text-primary hover:bg-background'}`}>
              <Icon name={link.icon} size={18} />
              {link.label}
            </a>
          ))}
        </nav>
        
        <div class="mt-8 pt-4 border-t border-border">
          <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-background transition-colors">
            <Icon name="external-link" size={18} />
            Lihat Website
          </a>
        </div>
      </div>
    </aside>
    
    <!-- Main Content -->
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button class="lg:hidden p-2 hover:bg-background rounded-lg">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Kelola Kupon</h1>
          </div>
          <button class="btn-primary text-sm">
            <Icon name="plus" size={16} />
            Buat Kupon
          </button>
        </div>
      </header>
      
      <div class="p-6">
        <!-- Coupons Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {coupons.map((coupon) => (
            <div class="card p-5">
              <div class="flex items-start justify-between mb-4">
                <div>
                  <div class="text-2xl font-bold text-primary mb-1">{coupon.code}</div>
                  <div class="text-sm text-text-muted">
                    {coupon.type === 'PERCENTAGE' ? `Diskon ${coupon.value}%` : `Diskon ${new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(coupon.value)}`}
                  </div>
                </div>
                <span class={coupon.isActive ? 'badge-success' : 'badge-danger'}>
                  {coupon.isActive ? 'Aktif' : 'Nonaktif'}
                </span>
              </div>
              
              <div class="space-y-2 text-sm">
                {coupon.minPurchase && (
                  <div class="flex justify-between">
                    <span class="text-text-muted">Min. Pembelian</span>
                    <span class="text-text-main">{new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(coupon.minPurchase)}</span>
                  </div>
                )}
                <div class="flex justify-between">
                  <span class="text-text-muted">Penggunaan</span>
                  <span class="text-text-main">{coupon.currentUses} / {coupon.maxUses}</span>
                </div>
                {coupon.expiresAt && (
                  <div class="flex justify-between">
                    <span class="text-text-muted">Berlaku Hingga</span>
                    <span class="text-text-main">{coupon.expiresAt}</span>
                  </div>
                )}
              </div>
              
              <!-- Usage Bar -->
              <div class="mt-4">
                <div class="w-full bg-background rounded-full h-2">
                  <div 
                    class="bg-primary rounded-full h-2 transition-all" 
                    style={`width: ${(coupon.currentUses / coupon.maxUses) * 100}%`}
                  ></div>
                </div>
              </div>
              
              <div class="flex items-center gap-2 mt-4 pt-4 border-t border-border">
                <button class="btn-ghost text-sm flex-1">
                  <Icon name="edit" size={14} />
                  Edit
                </button>
                <button class="btn-ghost text-sm text-red-600 hover:text-red-700 hover:bg-red-50">
                  <Icon name="trash" size={14} />
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </main>
  </div>
</BaseLayout>
