---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
---

<BaseLayout title="Kelola Kupon - Admin Asri Digital">
  <div class="flex min-h-screen">
    <aside id="admin-sidebar" class="w-64 bg-surface border-r border-border shrink-0 fixed inset-y-0 left-0 z-40 -translate-x-full transition-transform duration-300 lg:static lg:translate-x-0">
      <div class="sticky top-0 h-screen overflow-y-auto p-4">
        <a href="/admin" class="flex items-center gap-2.5 mb-8 px-2">
          <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
            <Icon name="sparkles" size={18} class="text-white" />
          </div>
          <div>
            <span class="font-bold text-text-primary block">Asri Digital</span>
            <span class="text-xs text-text-muted">Admin Panel</span>
          </div>
        </a>
        
        <nav class="space-y-1">
          {[
            { icon: 'bar-chart', label: 'Dashboard', href: '/admin' },
            { icon: 'sparkles', label: 'Produk', href: '/admin/products' },
            { icon: 'shopping-cart', label: 'Pesanan', href: '/admin/orders' },
            { icon: 'tag', label: 'Kupon', href: '/admin/coupons', active: true },
            { icon: 'link', label: 'Affiliate', href: '/admin/affiliates' },
            { icon: 'file-text', label: 'Blog', href: '/admin/blog' },
            { icon: 'folder', label: 'Kategori', href: '/admin/categories' },
            { icon: 'settings', label: 'Pengaturan', href: '/admin/settings' },
          ].map((link) => (
            <a
              href={link.href}
              class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${
                link.active
                  ? 'bg-primary/10 text-primary'
                  : 'text-text-secondary hover:text-text-primary hover:bg-background'
              }`}
            >
              <Icon name={link.icon} size={18} />
              {link.label}
            </a>
          ))}
        </nav>
        
        <div class="mt-8 pt-4 border-t border-border">
          <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-background transition-colors">
            <Icon name="external-link" size={18} />
            Lihat Website
          </a>
        </div>
      </div>
    </aside>
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-30 hidden lg:hidden" onclick="document.getElementById('admin-sidebar').classList.add('-translate-x-full');this.classList.add('hidden')"></div>
    
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-4 sm:px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2 hover:bg-background rounded-lg">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Kelola Kupon</h1>
          </div>
          
          <button onclick="openModal()" class="btn-primary">
            <Icon name="plus" size={18} />
            Tambah Kupon
          </button>
        </div>
      </header>
      
      <div class="p-4 sm:p-6">
        <div class="card">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border bg-background">
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Kode</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Tipe</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Nilai</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Penggunaan</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Min. Belanja</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Berlaku Hingga</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Aksi</th>
                </tr>
              </thead>
              <tbody id="coupons-table" class="divide-y divide-border">
                <tr>
                  <td colspan="8" class="px-6 py-12 text-center text-text-muted">
                    Loading...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Add/Edit Coupon Modal -->
  <div id="coupon-modal" class="fixed inset-0 bg-black/50 z-50 hidden">
    <div class="flex items-center justify-center min-h-screen p-4">
      <div class="bg-surface rounded-xl max-w-lg w-full">
        <div class="p-6 border-b border-border">
          <div class="flex items-center justify-between">
            <h2 class="text-xl font-bold text-text-primary" id="modal-title">Tambah Kupon</h2>
            <button onclick="closeModal()" class="p-2 hover:bg-background rounded-lg">
              <Icon name="x" size={20} class="text-text-secondary" />
            </button>
          </div>
        </div>
        
        <form id="coupon-form" class="p-6 space-y-4">
          <input type="hidden" id="coupon-id" />
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Kode Kupon *</label>
              <input type="text" id="coupon-code" class="input uppercase" required placeholder="CONTOH: DISKON50" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Deskripsi</label>
              <input type="text" id="coupon-description" class="input" />
            </div>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Tipe Diskon *</label>
              <select id="coupon-type" class="input" required>
                <option value="PERCENTAGE">Persentase (%)</option>
                <option value="FIXED">Nominal (Rp)</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Nilai Diskon *</label>
              <input type="number" id="coupon-value" class="input" required />
            </div>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Maks. Penggunaan</label>
              <input type="number" id="coupon-max-uses" class="input" value="100" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Min. Belanja (Rp)</label>
              <input type="number" id="coupon-min-purchase" class="input" />
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-text-main mb-2">Berlaku Hingga</label>
            <input type="datetime-local" id="coupon-expires" class="input" />
          </div>
          
          <div class="flex items-center gap-2">
            <input type="checkbox" id="coupon-active" class="rounded" checked />
            <label for="coupon-active" class="text-sm text-text-main">Kupon aktif</label>
          </div>
          
          <div class="flex justify-end gap-3 pt-4 border-t border-border">
            <button type="button" onclick="closeModal()" class="btn-tertiary">Batal</button>
            <button type="submit" class="btn-primary">Simpan Kupon</button>
          </div>
        </form>
      </div>
    </div>
  </div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('mobile-menu-btn');
    const sidebar = document.getElementById('admin-sidebar');
    if (toggle && sidebar) {
      toggle.addEventListener('click', () => {
        sidebar.classList.toggle('-translate-x-full');
        const overlay = document.getElementById('sidebar-overlay');
        if (overlay) overlay.classList.toggle('hidden');
      });
    }
  });
</script>

</BaseLayout>

<script>
  function getAdminToken(): string | null {
    return localStorage.getItem('admin_token');
  }

  function formatIDR(amount: number): string {
    return new Intl.NumberFormat('id-ID', {
      style: 'currency',
      currency: 'IDR',
      minimumFractionDigits: 0
    }).format(amount);
  }

  async function loadCoupons() {
    const table = document.getElementById('coupons-table')!;
    const token = getAdminToken();
    if (!token) {
      window.location.href = '/admin/login';
      return;
    }
    try {
      const res = await fetch('/api/admin/coupons', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.status === 401 || res.status === 403) {
        localStorage.removeItem('admin_token');
        window.location.href = '/admin/login';
        return;
      }
      if (!res.ok) throw new Error('Failed to fetch coupons');
      const data = await res.json();
      const coupons = data.coupons || [];

      if (coupons.length === 0) {
        table.innerHTML = `<tr><td colspan="8" class="px-6 py-12 text-center text-text-muted">Belum ada kupon.</td></tr>`;
        return;
      }

      table.innerHTML = coupons.map((c: any) => {
        const typeLabel = c.type === 'PERCENTAGE' ? 'Persentase' : 'Nominal';
        const valueDisplay = c.type === 'PERCENTAGE' ? `${c.value}%` : formatIDR(c.value);
        const minPurchase = c.min_purchase ? formatIDR(c.min_purchase) : '-';
        const expiresDisplay = c.expires_at
          ? new Date(c.expires_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })
          : '-';
        const statusBadge = c.is_active
          ? '<span class="badge-success">Aktif</span>'
          : '<span class="badge-error">Nonaktif</span>';

        return `
        <tr class="hover:bg-background/50">
          <td class="px-6 py-4">
            <span class="font-mono text-sm font-medium text-primary bg-primary/10 px-2 py-1 rounded">${c.code}</span>
          </td>
          <td class="px-6 py-4 text-text-main">${typeLabel}</td>
          <td class="px-6 py-4 font-medium text-text-primary">${valueDisplay}</td>
          <td class="px-6 py-4">
            <span class="text-text-muted">${c.current_uses ?? 0} / ${c.max_uses ?? '∞'}</span>
          </td>
          <td class="px-6 py-4 text-text-main">${minPurchase}</td>
          <td class="px-6 py-4 text-text-muted">${expiresDisplay}</td>
          <td class="px-6 py-4">${statusBadge}</td>
          <td class="px-6 py-4">
            <div class="flex items-center gap-2">
              <button onclick='editCoupon(${JSON.stringify(c).replace(/'/g, "&#39;")})' class="p-2.5 hover:bg-background rounded-lg text-text-secondary hover:text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              <button onclick="deleteCoupon('${c.id}')" class="p-2.5 hover:bg-red-50 rounded-lg text-text-secondary hover:text-red-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
              </button>
            </div>
          </td>
        </tr>`;
      }).join('');
    } catch (error) {
      console.error('Error loading coupons:', error);
      table.innerHTML = `<tr><td colspan="8" class="px-6 py-12 text-center text-red-500">Gagal memuat data kupon.</td></tr>`;
    }
  }

  function openModal() {
    document.getElementById('coupon-modal')!.classList.remove('hidden');
    (document.getElementById('coupon-form') as HTMLFormElement).reset();
    (document.getElementById('coupon-id') as HTMLInputElement).value = '';
    (document.getElementById('coupon-active') as HTMLInputElement).checked = true;
    document.getElementById('modal-title')!.textContent = 'Tambah Kupon';
  }

  function editCoupon(coupon: any) {
    document.getElementById('modal-title')!.textContent = 'Edit Kupon';
    document.getElementById('coupon-modal')!.classList.remove('hidden');
    (document.getElementById('coupon-id') as HTMLInputElement).value = coupon.id;
    (document.getElementById('coupon-code') as HTMLInputElement).value = coupon.code;
    (document.getElementById('coupon-type') as HTMLSelectElement).value = coupon.type;
    (document.getElementById('coupon-value') as HTMLInputElement).value = coupon.value;
    (document.getElementById('coupon-description') as HTMLInputElement).value = coupon.description || '';
    (document.getElementById('coupon-max-uses') as HTMLInputElement).value = coupon.max_uses || '';
    (document.getElementById('coupon-min-purchase') as HTMLInputElement).value = coupon.min_purchase || '';
    (document.getElementById('coupon-expires') as HTMLInputElement).value = coupon.expires_at ? coupon.expires_at.slice(0, 16) : '';
    (document.getElementById('coupon-active') as HTMLInputElement).checked = !!coupon.is_active;
  }

  async function deleteCoupon(id: number) {
    if (!confirm('Yakin ingin menghapus kupon ini?')) return;
    const token = getAdminToken();
    if (!token) { window.location.href = '/admin/login'; return; }
    try {
      const res = await fetch(`/api/admin/coupons/${id}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (!res.ok) throw new Error('Failed to delete coupon');
      loadCoupons();
    } catch (error) {
      console.error('Error deleting coupon:', error);
      alert('Gagal menghapus kupon.');
    }
  }

  function closeModal() {
    document.getElementById('coupon-modal')!.classList.add('hidden');
  }

  document.getElementById('coupon-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const token = getAdminToken();
    if (!token) { window.location.href = '/admin/login'; return; }

    const id = (document.getElementById('coupon-id') as HTMLInputElement).value;
    const couponData = {
      code: (document.getElementById('coupon-code') as HTMLInputElement).value.toUpperCase(),
      type: (document.getElementById('coupon-type') as HTMLSelectElement).value,
      value: parseInt((document.getElementById('coupon-value') as HTMLInputElement).value),
      description: (document.getElementById('coupon-description') as HTMLInputElement).value,
      max_uses: parseInt((document.getElementById('coupon-max-uses') as HTMLInputElement).value) || null,
      min_purchase: (document.getElementById('coupon-min-purchase') as HTMLInputElement).value ?
        parseInt((document.getElementById('coupon-min-purchase') as HTMLInputElement).value) : null,
      expires_at: (document.getElementById('coupon-expires') as HTMLInputElement).value || null,
      is_active: (document.getElementById('coupon-active') as HTMLInputElement).checked,
    };

    try {
      const isEdit = !!id;
      const url = isEdit ? `/api/admin/coupons/${id}` : '/api/admin/coupons';
      const method = isEdit ? 'PUT' : 'POST';
      const res = await fetch(url, {
        method,
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify(couponData)
      });
      if (!res.ok) throw new Error('Failed to save coupon');
      closeModal();
      loadCoupons();
    } catch (error) {
      console.error('Error saving coupon:', error);
      alert('Gagal menyimpan kupon.');
    }
  });

  // Expose to global scope for onclick handlers
  (window as any).openModal = openModal;
  (window as any).closeModal = closeModal;
  (window as any).editCoupon = editCoupon;
  (window as any).deleteCoupon = deleteCoupon;

  loadCoupons();
</script>
