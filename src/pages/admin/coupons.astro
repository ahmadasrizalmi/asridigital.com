---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDB } from '../../db';
import { coupons } from '../../db/schema';
import { desc } from 'drizzle-orm';

const env = Astro.locals?.runtime?.env || {};
const db = getDB(env);

const allCoupons = await db.select().from(coupons).orderBy(desc(coupons.createdAt));
---

<AdminLayout title="Kelola Kupon - Admin" activePage="coupons">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold">Kelola Kupon</h1>
    <button class="px-4 py-2 bg-primary hover:bg-primary-hover text-white rounded-lg font-medium transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Tambah Kupon
    </button>
  </div>

  <div class="bg-surface border border-border rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Kode</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Deskripsi</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Diskon</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Penggunaan</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Berlaku Hingga</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Status</th>
          </tr>
        </thead>
        <tbody>
          {allCoupons.map(coupon => (
            <tr class="border-b border-border hover:bg-background/50 transition-colors">
              <td class="px-6 py-4">
                <code class="px-2 py-1 bg-background rounded text-sm font-mono font-bold text-primary">{coupon.code}</code>
              </td>
              <td class="px-6 py-4 text-sm text-text-secondary">{coupon.description || '-'}</td>
              <td class="px-6 py-4 text-sm font-medium">{coupon.discountPercent}%</td>
              <td class="px-6 py-4 text-sm">{coupon.usedCount} / {coupon.maxUses}</td>
              <td class="px-6 py-4 text-sm text-text-muted">
                {coupon.validUntil ? new Date(coupon.validUntil).toLocaleDateString('id-ID') : '∞'}
              </td>
              <td class="px-6 py-4">
                <span class:list={[
                  "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium",
                  coupon.isActive ? "bg-success/20 text-success" : "bg-text-muted/20 text-text-muted"
                ]}>
                  {coupon.isActive ? 'Aktif' : 'Nonaktif'}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    
    {allCoupons.length === 0 && (
      <div class="text-center py-12 text-text-muted">
        Belum ada kupon
      </div>
    )}
  </div>
</AdminLayout>
