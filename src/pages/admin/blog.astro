---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDB } from '../../db';
import { blogPosts } from '../../db/schema';
import { desc } from 'drizzle-orm';
import { timeAgo, parseTags } from '../../lib/utils';

const env = Astro.locals?.runtime?.env || {};
const db = getDB(env);

const posts = await db.select().from(blogPosts).orderBy(desc(blogPosts.createdAt));
---

<AdminLayout title="Kelola Blog - Admin" activePage="blog">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold">Kelola Blog</h1>
    <a href="/admin/blog/new" class="px-4 py-2 bg-primary hover:bg-primary-hover text-white rounded-lg font-medium transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Tulis Artikel
    </a>
  </div>

  <div class="bg-surface border border-border rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Judul</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Kategori</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Views</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Status</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Tanggal</th>
          </tr>
        </thead>
        <tbody>
          {posts.map(post => (
            <tr class="border-b border-border hover:bg-background/50 transition-colors">
              <td class="px-6 py-4">
                <a href={`/admin/blog/${post.id}`} class="font-medium hover:text-primary transition-colors">
                  {post.title}
                </a>
              </td>
              <td class="px-6 py-4">
                <span class="px-2 py-1 bg-background text-text-secondary text-xs rounded-full">
                  {post.category || '-'}
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-text-muted">{post.viewCount || 0}</td>
              <td class="px-6 py-4">
                <span class:list={[
                  "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium",
                  post.isPublished ? "bg-success/20 text-success" : "bg-warning/20 text-warning"
                ]}>
                  {post.isPublished ? 'Published' : 'Draft'}
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-text-muted">{timeAgo(post.createdAt || new Date())}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    
    {posts.length === 0 && (
      <div class="text-center py-12 text-text-muted">
        Belum ada artikel. Mulai tulis artikel pertama Anda!
      </div>
    )}
  </div>
</AdminLayout>
