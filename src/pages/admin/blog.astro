---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
---

<BaseLayout title="Kelola Blog - Admin Asri Digital">
  <div class="flex min-h-screen">
    <aside id="admin-sidebar" class="w-64 bg-surface border-r border-border shrink-0 fixed inset-y-0 left-0 z-40 -translate-x-full transition-transform duration-300 lg:static lg:translate-x-0">
      <div class="sticky top-0 h-screen overflow-y-auto p-4">
        <a href="/admin" class="flex items-center gap-2.5 mb-8 px-2">
          <img src="https://res.cloudinary.com/daj8fzinf/image/upload/q_auto/f_auto/v1779951905/logo_asri_digital_resize_mgkdqj.png" alt="Asri Digital" class="h-8 w-auto" />
          <span class="text-xs text-text-muted font-medium">Admin</span>
        </a>
        
        <nav class="space-y-1">
          {[
            { icon: 'bar-chart', label: 'Dashboard', href: '/admin' },
            { icon: 'sparkles', label: 'Produk', href: '/admin/products' },
            { icon: 'shopping-cart', label: 'Pesanan', href: '/admin/orders' },
            { icon: 'tag', label: 'Kupon', href: '/admin/coupons' },
            { icon: 'link', label: 'Affiliate', href: '/admin/affiliates' },
            { icon: 'file-text', label: 'Blog', href: '/admin/blog', active: true },
            { icon: 'image', label: 'Hero Slides', href: '/admin/hero-slides' },
            { icon: 'folder', label: 'Kategori', href: '/admin/categories' },
            { icon: 'settings', label: 'Pengaturan', href: '/admin/settings' },
          ].map((link) => (
            <a
              href={link.href}
              class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${
                link.active
                  ? 'bg-primary/10 text-primary'
                  : 'text-text-secondary hover:text-text-primary hover:bg-background'
              }`}
            >
              <Icon name={link.icon} size={18} />
              {link.label}
            </a>
          ))}
        </nav>
        
        <div class="mt-8 pt-4 border-t border-border">
          <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-background transition-colors">
            <Icon name="external-link" size={18} />
            Lihat Website
          </a>
        </div>
      </div>
    </aside>
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-30 hidden lg:hidden" onclick="document.getElementById('admin-sidebar').classList.add('-translate-x-full');this.classList.add('hidden')"></div>
    
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-4 sm:px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2 hover:bg-background rounded-lg">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Kelola Blog</h1>
          </div>
          
          <button onclick="openModal()" class="btn-primary">
            <Icon name="plus" size={18} />
            Tulis Artikel
          </button>
        </div>
      </header>
      
      <div class="p-4 sm:p-6">
        <div class="card">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border bg-background">
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Judul</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Kategori</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Penulis</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Tanggal</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Aksi</th>
                </tr>
              </thead>
              <tbody id="blog-table" class="divide-y divide-border">
                <tr><td colspan="6" class="px-6 py-12 text-center text-text-muted">Loading...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Add Blog Post Modal -->
  <div id="blog-modal" class="fixed inset-0 bg-black/50 z-50 hidden">
    <div class="flex items-center justify-center min-h-screen p-4">
      <div class="bg-surface rounded-xl max-w-4xl w-full max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-border">
          <div class="flex items-center justify-between">
            <h2 class="text-xl font-bold text-text-primary">Tulis Artikel Baru</h2>
            <button onclick="closeModal()" class="p-2 hover:bg-background rounded-lg">
              <Icon name="x" size={20} class="text-text-secondary" />
            </button>
          </div>
        </div>
        
        <form id="blog-form" class="p-6 space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
            <div class="sm:col-span-2">
              <label class="block text-sm font-medium text-text-main mb-2">Judul Artikel *</label>
              <input type="text" class="input text-lg" id="blog-title" required placeholder="Judul artikel Anda..." />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Slug URL</label>
              <input type="text" class="input" id="blog-slug" placeholder="judul-artikel" />
            </div>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Kategori</label>
              <select class="input" id="blog-category">
                <option value="tips">Tips & Trik</option>
                <option value="tutorial">Tutorial</option>
                <option value="studi-kasus">Studi Kasus</option>
                <option value="berita">Berita</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Tags</label>
              <input type="text" class="input" id="blog-tags" placeholder="ai, gpt, tips" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Status</label>
              <select class="input" id="blog-status">
                <option value="draft">Draft</option>
                <option value="published">Published</option>
              </select>
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-text-main mb-2">Excerpt</label>
            <textarea class="input" id="blog-excerpt" rows="2" placeholder="Ringkasan singkat artikel..."></textarea>
          </div>
        
          <div>
            <label class="block text-sm font-medium text-text-main mb-2">URL Gambar</label>
            <input type="url" class="input" id="blog-image-url" placeholder="https://res.cloudinary.com/xxx/image.jpg" />
          </div>

          <div>
            <label class="block text-sm font-medium text-text-main mb-2">Konten *</label>
            <textarea class="input font-mono" id="blog-content" rows="12" required placeholder="Tulis konten artikel dalam format Markdown..."></textarea>
          </div>
          
          <div class="flex justify-end gap-3 pt-4 border-t border-border">
            <button type="button" onclick="closeModal()" class="btn-tertiary">Batal</button>
            <button type="button" onclick="window.saveDraft()" class="btn-tertiary">Simpan Draft</button>
            <button type="submit" class="btn-primary">Publish</button>
          </div>
        </form>
      </div>
    </div>
  </div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('mobile-menu-btn');
    const sidebar = document.getElementById('admin-sidebar');
    if (toggle && sidebar) {
      toggle.addEventListener('click', () => {
        sidebar.classList.toggle('-translate-x-full');
        const overlay = document.getElementById('sidebar-overlay');
        if (overlay) overlay.classList.toggle('hidden');
      });
    }
  });
</script>

</BaseLayout>

<script>
  let currentEditId: number | null = null;

  function getAdminToken(): string | null {
    return localStorage.getItem('admin_token');
  }

  function openModal() {
    document.getElementById('blog-modal')!.classList.remove('hidden');
  }

  function closeModal() {
    document.getElementById('blog-modal')!.classList.add('hidden');
    currentEditId = null;
    (document.getElementById('blog-form') as HTMLFormElement).reset();
    document.querySelector('#blog-modal h2')!.textContent = 'Tulis Artikel Baru';
  }

  function generateSlug(title: string): string {
    return title.toLowerCase()
      .replace(/[^a-z0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-');
  }

  // Auto-generate slug from title
  document.getElementById('blog-title')?.addEventListener('input', (e) => {
    const title = (e.target as HTMLInputElement).value;
    (document.getElementById('blog-slug') as HTMLInputElement).value = generateSlug(title);
  });

  async function loadPosts() {
    const token = getAdminToken();
    if (!token) {
      window.location.href = '/admin/login';
      return;
    }

    const tbody = document.getElementById('blog-table')!;
    tbody.innerHTML = '<tr><td colspan="6" class="px-6 py-12 text-center text-text-muted">Loading...</td></tr>';

    try {
      const res = await fetch('/api/admin/blog', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.status === 401 || res.status === 403) {
        window.location.href = '/admin/login';
        return;
      }
      const data = await res.json();
      const posts = data.posts || [];

      if (posts.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="px-6 py-12 text-center text-text-muted">Belum ada artikel</td></tr>';
        return;
      }

      const categoryColors: Record<string, string> = {
        'tips': 'bg-primary/10 text-primary',
        'tutorial': 'bg-blue-100 text-blue-600',
        'studi-kasus': 'bg-purple-100 text-purple-600',
        'berita': 'bg-green-100 text-green-600',
        'news': 'bg-green-100 text-green-600',
      };

      const categoryLabels: Record<string, string> = {
        'tips': 'Tips & Trik',
        'tutorial': 'Tutorial',
        'studi-kasus': 'Studi Kasus',
        'berita': 'Berita',
        'news': 'News',
      };

      tbody.innerHTML = posts.map((post: any) => {
        const catColor = categoryColors[post.category] || 'bg-gray-100 text-gray-600';
        const catLabel = categoryLabels[post.category] || post.category;
        const statusBadge = post.is_published
          ? '<span class="badge-success">Published</span>'
          : '<span class="badge-warning">Draft</span>';
        const dateStr = post.published_at || post.created_at;
        const formattedDate = dateStr ? new Date(dateStr).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) : '-';

        return `
          <tr class="hover:bg-background/50">
            <td class="px-6 py-4">
              <div>
                <p class="font-medium text-text-primary">${escapeHtml(post.title)}</p>
                <p class="text-xs text-text-muted">${escapeHtml(post.slug)}</p>
              </div>
            </td>
            <td class="px-6 py-4">
              <span class="px-2 py-1 ${catColor} text-xs rounded-full">${escapeHtml(catLabel)}</span>
            </td>
            <td class="px-6 py-4 text-text-main">${escapeHtml(post.author_name || 'Admin')}</td>
            <td class="px-6 py-4">${statusBadge}</td>
            <td class="px-6 py-4 text-sm text-text-muted">${formattedDate}</td>
            <td class="px-6 py-4">
              <div class="flex items-center gap-2">
                <button onclick='editPost(${JSON.stringify(post).replace(/'/g, "&#39;")})' class="p-2.5 hover:bg-background rounded-lg text-text-secondary hover:text-primary" title="Edit">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <button onclick="deletePost('${post.id}')" class="p-2.5 hover:bg-red-50 rounded-lg text-text-secondary hover:text-red-600" title="Hapus">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                </button>
              </div>
            </td>
          </tr>
        `;
      }).join('');
    } catch (err) {
      tbody.innerHTML = '<tr><td colspan="6" class="px-6 py-12 text-center text-red-500">Gagal memuat data</td></tr>';
      console.error('Failed to load posts:', err);
    }
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function editPost(post: any) {
    currentEditId = post.id;
    document.querySelector('#blog-modal h2')!.textContent = 'Edit Artikel';
    (document.getElementById('blog-title') as HTMLInputElement).value = post.title || '';
    (document.getElementById('blog-slug') as HTMLInputElement).value = post.slug || '';
    (document.getElementById('blog-category') as HTMLSelectElement).value = post.category || 'tips';
    (document.getElementById('blog-tags') as HTMLInputElement).value = post.tags || '';
    (document.getElementById('blog-image-url') as HTMLInputElement).value = post.image_url || '';
    (document.getElementById('blog-excerpt') as HTMLTextAreaElement).value = post.excerpt || '';
    (document.getElementById('blog-content') as HTMLTextAreaElement).value = post.content || '';
    const statusSelect = document.getElementById('blog-status') as HTMLSelectElement;
    statusSelect.value = post.is_published ? 'published' : 'draft';
    openModal();
  }

  async function deletePost(id: number) {
    if (!confirm('Yakin ingin menghapus artikel ini?')) return;
    const token = getAdminToken();
    if (!token) {
      window.location.href = '/admin/login';
      return;
    }

    try {
      const res = await fetch(`/api/admin/blog/${id}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        loadPosts();
      } else {
        alert('Gagal menghapus artikel');
      }
    } catch (err) {
      alert('Gagal menghapus artikel');
      console.error('Delete failed:', err);
    }
  }

  document.getElementById('blog-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const token = getAdminToken();
    if (!token) {
      window.location.href = '/admin/login';
      return;
    }

    const title = (document.getElementById('blog-title') as HTMLInputElement).value;
    const slug = (document.getElementById('blog-slug') as HTMLInputElement).value;
    const category = (document.getElementById('blog-category') as HTMLSelectElement).value;
    const tags = (document.getElementById('blog-tags') as HTMLInputElement).value;
    const excerpt = (document.getElementById('blog-excerpt') as HTMLTextAreaElement).value;
    const content = (document.getElementById('blog-content') as HTMLTextAreaElement).value;
    const is_published = (document.getElementById('blog-status') as HTMLSelectElement).value === 'published';

    const image_url = (document.getElementById('blog-image-url') as HTMLInputElement).value;
    const body = { title, slug, content, excerpt, image_url, category, tags, author_name: 'Admin', is_published };

    try {
      const url = currentEditId ? `/api/admin/blog/${currentEditId}` : '/api/admin/blog';
      const method = currentEditId ? 'PUT' : 'POST';

      const res = await fetch(url, {
        method,
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify(body)
      });

      if (res.ok) {
        closeModal();
        loadPosts();
      } else {
        const err = await res.json().catch(() => ({}));
        alert(err.message || 'Gagal menyimpan artikel');
      }
    } catch (err) {
      alert('Gagal menyimpan artikel');
      console.error('Save failed:', err);
    }
  });

  // Expose to global scope for onclick handlers
  (window as any).openModal = openModal;
  (window as any).closeModal = closeModal;
  (window as any).editPost = editPost;
  (window as any).deletePost = deletePost;

  async function saveDraft() {
    const token = getAdminToken();
    if (!token) { window.location.href = '/admin/login'; return; }

    const title = (document.getElementById('blog-title') as HTMLInputElement).value;
    const slug = (document.getElementById('blog-slug') as HTMLInputElement).value;
    const category = (document.getElementById('blog-category') as HTMLSelectElement).value;
    const tags = (document.getElementById('blog-tags') as HTMLInputElement).value;
    const excerpt = (document.getElementById('blog-excerpt') as HTMLTextAreaElement).value;
    const content = (document.getElementById('blog-content') as HTMLTextAreaElement).value;
    const image_url = (document.getElementById('blog-image-url') as HTMLInputElement).value;

    const body = { title, slug, content, excerpt, image_url, category, tags, author_name: 'Admin', is_published: false };

    try {
      const url = currentEditId ? `/api/admin/blog/${currentEditId}` : '/api/admin/blog';
      const method = currentEditId ? 'PUT' : 'POST';

      const res = await fetch(url, {
        method,
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify(body)
      });

      if (res.ok) {
        closeModal();
        loadPosts();
      } else {
        const err = await res.json().catch(() => ({}));
        alert(err.message || 'Gagal menyimpan draft');
      }
    } catch (err) {
      alert('Gagal menyimpan draft');
      console.error('Save draft failed:', err);
    }
  }
  (window as any).saveDraft = saveDraft;


  // Load posts on page load
  loadPosts();
</script>
