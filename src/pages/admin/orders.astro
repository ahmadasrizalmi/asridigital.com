---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
---

<BaseLayout title="Kelola Pesanan - Admin Asri Digital">
  <div class="flex min-h-screen">
    <aside class="w-64 bg-surface border-r border-border shrink-0 hidden lg:block">
      <div class="sticky top-0 h-screen overflow-y-auto p-4">
        <a href="/admin" class="flex items-center gap-2.5 mb-8 px-2">
          <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
            <Icon name="sparkles" size={18} class="text-white" />
          </div>
          <div>
            <span class="font-bold text-text-primary block">Asri Digital</span>
            <span class="text-xs text-text-muted">Admin Panel</span>
          </div>
        </a>
        
        <nav class="space-y-1">
          {[
            { icon: 'bar-chart', label: 'Dashboard', href: '/admin' },
            { icon: 'sparkles', label: 'Produk', href: '/admin/products' },
            { icon: 'shopping-cart', label: 'Pesanan', href: '/admin/orders', active: true },
            { icon: 'tag', label: 'Kupon', href: '/admin/coupons' },
            { icon: 'link', label: 'Affiliate', href: '/admin/affiliates' },
            { icon: 'file-text', label: 'Blog', href: '/admin/blog' },
            { icon: 'settings', label: 'Pengaturan', href: '/admin/settings' },
          ].map((link) => (
            <a
              href={link.href}
              class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${
                link.active
                  ? 'bg-primary/10 text-primary'
                  : 'text-text-secondary hover:text-text-primary hover:bg-background'
              }`}
            >
              <Icon name={link.icon} size={18} />
              {link.label}
            </a>
          ))}
        </nav>
        
        <div class="mt-8 pt-4 border-t border-border">
          <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-background transition-colors">
            <Icon name="external-link" size={18} />
            Lihat Website
          </a>
        </div>
      </div>
    </aside>
    
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2 hover:bg-background rounded-lg">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Kelola Pesanan</h1>
          </div>
          
          <div class="flex items-center gap-3">
            <select id="status-filter" class="input py-2 text-sm">
              <option value="all">Semua Status</option>
              <option value="PAID">Lunas</option>
              <option value="PENDING">Pending</option>
              <option value="FAILED">Gagal</option>
            </select>
            <button onclick="exportOrders()" class="btn-tertiary py-2">
              <Icon name="download" size={16} />
              Export
            </button>
          </div>
        </div>
      </header>
      
      <div class="p-6">
        <div class="card">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border bg-background">
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Order ID</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Pelanggan</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Produk</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Jumlah</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Metode</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Tanggal</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Aksi</th>
                </tr>
              </thead>
              <tbody id="orders-table" class="divide-y divide-border">
                <tr>
                  <td colspan="8" class="px-6 py-12 text-center text-text-muted">
                    Loading...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          
          <div id="empty-state" class="hidden p-12 text-center">
            <Icon name="shopping-bag" size={48} class="text-text-muted mx-auto mb-4" />
            <h3 class="text-lg font-semibold text-text-primary mb-2">Belum Ada Pesanan</h3>
            <p class="text-text-secondary">Pesanan akan muncul di sini ketika pelanggan melakukan checkout.</p>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<script>
  const API_BASE = '/api';
  let allOrders: any[] = [];

  function formatIDR(amount: number): string {
    return new Intl.NumberFormat('id-ID', {
      style: 'currency',
      currency: 'IDR',
      minimumFractionDigits: 0
    }).format(amount);
  }

  function getStatusBadge(status: string) {
    const statusMap: Record<string, { class: string; label: string }> = {
      'PAID': { class: 'badge-success', label: 'Lunas' },
      'PENDING': { class: 'badge-warning', label: 'Pending' },
      'FAILED': { class: 'badge-danger', label: 'Gagal' },
    };
    const s = statusMap[status] || { class: 'bg-gray-100 text-gray-600', label: status };
    return `<span class="${s.class}">${s.label}</span>`;
  }

  function renderOrders(orders: any[]) {
    const table = document.getElementById('orders-table')!;
    const emptyState = document.getElementById('empty-state')!;
    
    if (orders.length === 0) {
      table.innerHTML = '';
      emptyState.classList.remove('hidden');
      return;
    }
    
    emptyState.classList.add('hidden');
    table.innerHTML = orders.map(order => `
      <tr class="hover:bg-background/50">
        <td class="px-6 py-4">
          <span class="font-mono text-sm text-text-primary">${order.id.substring(0, 12)}...</span>
        </td>
        <td class="px-6 py-4">
          <div>
            <p class="text-text-main font-medium">${order.user_name || '-'}</p>
            <p class="text-xs text-text-muted">${order.user_email}</p>
          </div>
        </td>
        <td class="px-6 py-4 text-text-main">${order.product_title}</td>
        <td class="px-6 py-4 font-medium text-text-primary">${formatIDR(order.amount)}</td>
        <td class="px-6 py-4">
          <span class="px-2 py-1 bg-background rounded text-xs font-medium text-text-secondary">
            ${(order.payment_method || 'qris').toUpperCase()}
          </span>
        </td>
        <td class="px-6 py-4">${getStatusBadge(order.status)}</td>
        <td class="px-6 py-4 text-sm text-text-muted">
          ${new Date(order.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}
        </td>
        <td class="px-6 py-4">
          <div class="flex items-center gap-2">
            <button onclick="viewOrder('${order.id}')" class="p-1.5 hover:bg-background rounded-lg text-text-secondary hover:text-primary" title="Lihat Detail">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            ${order.status === 'PENDING' ? `
              <button onclick="markAsPaid('${order.id}')" class="p-1.5 hover:bg-green-50 rounded-lg text-text-secondary hover:text-green-600" title="Tandai Lunas">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            ` : ''}
          </div>
        </td>
      </tr>
    `).join('');
  }

  async function loadOrders() {
    try {
      const response = await fetch(`${API_BASE}/orders`);
      const data = await response.json() as any;
      allOrders = data.orders || [];
      renderOrders(allOrders);
    } catch (error) {
      console.error('Error loading orders:', error);
    }
  }

  function filterOrders() {
    const status = (document.getElementById('status-filter') as HTMLSelectElement).value;
    if (status === 'all') {
      renderOrders(allOrders);
    } else {
      renderOrders(allOrders.filter(o => o.status === status));
    }
  }

  async function viewOrder(orderId: string) {
    try {
      const response = await fetch(`${API_BASE}/orders/${orderId}`);
      const data = await response.json() as any;
      const order = data.order;
      
      alert(`Order Details:\n\nID: ${order.id}\nCustomer: ${order.user_name} (${order.user_email})\nProduct: ${order.product_title}\nAmount: ${formatIDR(order.amount)}\nStatus: ${order.status}\nDate: ${new Date(order.created_at).toLocaleString('id-ID')}`);
    } catch (error) {
      console.error('Error viewing order:', error);
    }
  }

  async function markAsPaid(orderId: string) {
    if (!confirm('Tandai pesanan ini sebagai LUNAS?')) return;
    const token = localStorage.getItem('admin_token');
    if (!token) { alert('Session expired. Silakan login kembali.'); return; }
    try {
      const response = await fetch(`${API_BASE}/admin/orders/${orderId}/status`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({ status: 'PAID' })
      });
      const result = await response.json() as any;
      if (response.ok) {
        alert('Pesanan berhasil ditandai LUNAS!');
        loadOrders();
      } else {
        alert(result.error || 'Gagal update status');
      }
    } catch (error) {
      console.error('Error updating order:', error);
      alert('Terjadi kesalahan.');
    }
  }

  function exportOrders() {
    const csv = [
      ['Order ID', 'Nama', 'Email', 'Produk', 'Jumlah', 'Status', 'Tanggal'].join(','),
      ...allOrders.map(o => [
        o.id,
        `"${o.user_name || ''}"`,
        o.user_email,
        `"${o.product_title}"`,
        o.amount,
        o.status,
        new Date(o.created_at).toLocaleDateString('id-ID')
      ].join(','))
    ].join('\n');
    
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `orders-${new Date().toISOString().split('T')[0]}.csv`;
    a.click();
    URL.revokeObjectURL(url);
  }

  // Event listeners
  document.getElementById('status-filter')?.addEventListener('change', filterOrders);

  // Expose to global scope for onclick handlers
  (window as any).exportOrders = exportOrders;
  (window as any).viewOrder = viewOrder;
  (window as any).markAsPaid = markAsPaid;

  // Load on page load
  loadOrders();
</script>
