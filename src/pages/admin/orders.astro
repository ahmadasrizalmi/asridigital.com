---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdminSidebar from '../../components/layout/AdminSidebar.astro';
import Icon from '../../components/ui/Icon.astro';
---

<BaseLayout title="Kelola Pesanan - Admin Asri Digital">
  <div class="flex min-h-screen">
    <AdminSidebar activePage="orders" />
    
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-4 md:px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2 hover:bg-background rounded-lg mr-2" onclick="window.__openSidebar?.()">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Kelola Pesanan</h1>
          </div>
          
          <div class="flex items-center gap-3">
            <select id="status-filter" class="input py-2 text-sm">
              <option value="all">Semua Status</option>
              <option value="PAID">Lunas</option>
              <option value="PENDING">Pending</option>
              <option value="FAILED">Gagal</option>
              <option value="CANCELLED">Dibatalkan</option>
            </select>
          <button onclick="exportOrders()" class="btn-tertiary">
            <Icon name="download" size={18} />
            <span class="hidden md:inline">Export</span>
          </button>
          </div>
        </div>
      </header>
      
      <div class="p-4 md:p-6">
        <div class="mb-4 flex flex-col md:flex-row items-start md:items-center gap-3">
          <div class="relative flex-1 max-w-md w-full">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="order-search" class="input pl-10 w-full" placeholder="Cari pesanan..." />
          </div>
          <span id="order-count" class="text-sm text-text-muted"></span>
        </div>
        <div class="card">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border bg-background">
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase hidden md:table-cell">Order ID</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase hidden md:table-cell">Pelanggan</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Produk</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Jumlah</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase hidden md:table-cell">Metode</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase hidden md:table-cell">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase hidden md:table-cell">Tanggal</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Aksi</th>
                </tr>
              </thead>
              <tbody id="orders-table" class="divide-y divide-border">
                <tr>
                  <td colspan="8" class="px-6 py-12 text-center text-text-muted">
                    Loading...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          
          <div id="empty-state" class="hidden p-12 text-center">
            <Icon name="shopping-bag" size={48} class="text-text-muted mx-auto mb-4" />
            <h3 class="text-lg font-semibold text-text-primary mb-2">Belum Ada Pesanan</h3>
            <p class="text-text-secondary">Pesanan akan muncul di sini ketika pelanggan melakukan checkout.</p>
          </div>
        </div>
        <div id="order-pagination" class="mt-4 flex flex-wrap items-center justify-center gap-2 sm:gap-3"></div>
      </div>
    </main>
  </div>

  <!-- Order Detail Modal -->
  <div id="detail-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50" onclick="window.closeDetailModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg bg-surface rounded-xl shadow-2xl p-4 md:p-6 max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-text-primary">Detail Pesanan</h2>
        <button onclick="window.closeDetailModal()" class="p-2 hover:bg-background rounded-lg text-text-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div id="detail-content" class="space-y-3"></div>
      <div class="mt-6 flex justify-end">
        <button onclick="window.closeDetailModal()" class="btn-tertiary py-2 px-4">Tutup</button>
      </div>
    </div>
  </div>

  <!-- Edit Order Modal -->
  <div id="edit-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50" onclick="window.closeEditModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg bg-surface rounded-xl shadow-2xl p-4 md:p-6 max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-text-primary">Edit Pesanan</h2>
        <button onclick="window.closeEditModal()" class="p-2 hover:bg-background rounded-lg text-text-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <form id="edit-form" onsubmit="window.submitEditOrder(event)" class="space-y-4">
        <input type="hidden" id="edit-order-id" />
        <div>
          <label class="block text-sm font-medium text-text-primary mb-1">Nama Pelanggan</label>
          <input type="text" id="edit-user-name" class="input w-full" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-primary mb-1">Email</label>
          <input type="email" id="edit-user-email" class="input w-full" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-primary mb-1">No. Telepon</label>
          <input type="text" id="edit-user-phone" class="input w-full" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-primary mb-1">Jumlah (IDR)</label>
          <input type="number" id="edit-amount" class="input w-full" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-primary mb-1">Metode Pembayaran</label>
          <select id="edit-payment-method" class="input w-full">
            <option value="qris">QRIS</option>
            <option value="bank_transfer">Bank Transfer</option>
            <option value="ewallet">E-Wallet</option>
            <option value="credit_card">Kartu Kredit</option>
          </select>
        </div>
        <div class="flex justify-end gap-3 pt-2">
          <button type="button" onclick="window.closeEditModal()" class="btn-tertiary py-2 px-4">Batal</button>
          <button type="submit" class="btn-primary py-2 px-4">Simpan Perubahan</button>
        </div>
      </form>
    </div>
  </div>


</BaseLayout>

<script is:inline src="/js/admin-utils.js?v=2"></script>
<script>
  const API_BASE = '/api';
  let allOrders: any[] = [];
  let orderSearchQuery = '';
  let orderCurrentPage = 1;
  const ORDERS_PER_PAGE = 20;

  function getStatusBadge(status: string) {
    const statusMap: Record<string, { class: string; label: string }> = {
      'PAID': { class: 'badge-success', label: 'Lunas' },
      'PENDING': { class: 'badge-warning', label: 'Pending' },
      'FAILED': { class: 'badge-danger', label: 'Gagal' },
      'CANCELLED': { class: 'bg-gray-100 text-gray-600 px-2 py-1 rounded-full text-xs font-medium', label: 'Dibatalkan' },
    };
    const s = statusMap[status] || { class: 'bg-gray-100 text-gray-600', label: status };
    return '<span class="' + s.class + '">' + s.label + '</span>';
  }

  function getDetailRow(label: string, value: string) {
    return '<div class="flex justify-between py-2 border-b border-border last:border-0">' +
      '<span class="text-sm text-text-secondary">' + label + '</span>' +
      '<span class="text-sm text-text-primary font-medium text-right">' + value + '</span>' +
      '</div>';
  }

  function renderOrders(orders: any[]) {
    const table = document.getElementById('orders-table');
    const emptyState = document.getElementById('empty-state');
    
    if (!table || !emptyState) return;

    if (orders.length === 0) {
      table.innerHTML = '';
      emptyState.classList.remove('hidden');
      return;
    }
    
    emptyState.classList.add('hidden');
    table.innerHTML = orders.map(function(order) {
      return '<tr class="hover:bg-background/50">' +
        '<td class="px-6 py-4 hidden md:table-cell">' +
          '<span class="font-mono text-sm text-text-primary">' + order.id.substring(0, 12) + '...</span>' +
        '</td>' +
        '<td class="px-6 py-4 hidden md:table-cell">' +
          '<div>' +
            '<p class="text-text-main font-medium">' + (order.user_name || '-') + '</p>' +
            '<p class="text-xs text-text-muted">' + order.user_email + '</p>' +
          '</div>' +
        '</td>' +
        '<td class="px-6 py-4 text-text-main">' + order.product_title + '</td>' +
        '<td class="px-6 py-4 font-medium text-text-primary">' + formatIDR(order.amount) + '</td>' +
        '<td class="px-6 py-4 hidden md:table-cell">' +
          '<span class="px-2 py-1 bg-background rounded text-xs font-medium text-text-secondary">' +
            (order.payment_method || 'qris').toUpperCase() +
          '</span>' +
        '</td>' +
        '<td class="px-6 py-4 hidden md:table-cell">' +
          '<select onchange="window.changeStatus(\'' + order.id + '\', this.value)" class="input py-1 text-xs">' +
            '<option value="PENDING"' + (order.status === 'PENDING' ? ' selected' : '') + '>Pending</option>' +
            '<option value="PAID"' + (order.status === 'PAID' ? ' selected' : '') + '>Lunas</option>' +
            '<option value="FAILED"' + (order.status === 'FAILED' ? ' selected' : '') + '>Gagal</option>' +
            '<option value="CANCELLED"' + (order.status === 'CANCELLED' ? ' selected' : '') + '>Dibatalkan</option>' +
          '</select>' +
        '</td>' +
        '<td class="px-6 py-4 text-sm text-text-muted hidden md:table-cell">' +
          new Date(order.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) +
        '</td>' +
        '<td class="px-6 py-4">' +
          '<div class="flex items-center gap-1">' +
            '<button onclick="window.viewOrder(\'' + order.id + '\')" class="p-2 hover:bg-background rounded-lg text-text-secondary hover:text-primary" title="Lihat Detail">' +
              '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>' +
            '</button>' +
            '<button onclick="window.editOrder(\'' + order.id + '\')" class="p-2 hover:bg-blue-50 rounded-lg text-text-secondary hover:text-blue-600" title="Edit">' +
              '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>' +
            '</button>' +
            '<button onclick="window.deleteOrder(\'' + order.id + '\')" class="p-2 hover:bg-red-50 rounded-lg text-text-secondary hover:text-red-600" title="Hapus">' +
              '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>' +
            '</button>' +
          '</div>' +
        '</td>' +
      '</tr>';
    }).join('');
  }

  async function loadOrders() {
    try {
      const response = await adminFetch(API_BASE + '/orders');
      if (response.status === 401 || response.status === 403) return;
      const data = await response.json();
      allOrders = data.orders || [];
      orderCurrentPage = 1;
      orderSearchQuery = '';
      const searchInput = document.getElementById('order-search') as HTMLInputElement;
      if (searchInput) searchInput.value = '';
      applyOrderFilters();
    } catch (error) {
    }
  }

  function applyOrderFilters() {
    const el = document.getElementById('status-filter') as HTMLSelectElement;
    const status = el.value;
    const query = orderSearchQuery.toLowerCase();

    let filtered = allOrders;
    if (status !== 'all') {
      filtered = filtered.filter(function(o) { return o.status === status; });
    }
    if (query) {
      filtered = filtered.filter(function(o) {
        return (o.user_name || '').toLowerCase().includes(query) ||
               o.user_email.toLowerCase().includes(query) ||
               o.product_title.toLowerCase().includes(query);
      });
    }

    const countEl = document.getElementById('order-count');
    if (countEl) {
      const showing = Math.min(filtered.length, ORDERS_PER_PAGE);
      countEl.textContent = 'Menampilkan ' + showing + ' dari ' + filtered.length + ' data';
    }

    const totalPages = Math.max(1, Math.ceil(filtered.length / ORDERS_PER_PAGE));
    if (orderCurrentPage > totalPages) orderCurrentPage = totalPages;
    const start = (orderCurrentPage - 1) * ORDERS_PER_PAGE;
    const pageItems = filtered.slice(start, start + ORDERS_PER_PAGE);

    renderOrders(pageItems);
    renderOrderPagination(totalPages);
  }

  function viewOrder(orderId: string) {
    try {
      const order = allOrders.find(function(o) { return o.id === orderId; });
      if (!order) { showToast('Pesanan tidak ditemukan.', 'error'); return; }

      const content = document.getElementById('detail-content');
      if (!content) return;

      content.innerHTML =
        getDetailRow('Order ID', '<span class="font-mono text-xs">' + order.id + '</span>') +
        getDetailRow('Nama', order.user_name || '-') +
        getDetailRow('Email', order.user_email || '-') +
        getDetailRow('Telepon', order.user_phone || '-') +
        getDetailRow('Produk', order.product_title || '-') +
        getDetailRow('Jumlah', formatIDR(order.amount)) +
        getDetailRow('Metode Pembayaran', (order.payment_method || 'qris').toUpperCase()) +
        getDetailRow('Status', getStatusBadge(order.status)) +
        getDetailRow('Tanggal', new Date(order.created_at).toLocaleString('id-ID')) +
        (order.paid_at ? getDetailRow('Dibayar', new Date(order.paid_at).toLocaleString('id-ID')) : '') +
        (order.payment_reference ? getDetailRow('Ref. Pembayaran', order.payment_reference) : '');

      document.getElementById('detail-modal')?.classList.remove('hidden');
    } catch (error) {
      showToast('Gagal memuat detail pesanan.', 'error');
    }
  }

  function closeDetailModal() {
    document.getElementById('detail-modal')?.classList.add('hidden');
  }

  function editOrder(orderId: string) {
    try {
      const order = allOrders.find(function(o) { return o.id === orderId; });
      if (!order) { showToast('Pesanan tidak ditemukan.', 'error'); return; }

      (document.getElementById('edit-order-id') as HTMLInputElement).value = order.id;
      (document.getElementById('edit-user-name') as HTMLInputElement).value = order.user_name || '';
      (document.getElementById('edit-user-email') as HTMLInputElement).value = order.user_email || '';
      (document.getElementById('edit-user-phone') as HTMLInputElement).value = order.user_phone || '';
      (document.getElementById('edit-amount') as HTMLInputElement).value = order.amount || '';
      (document.getElementById('edit-payment-method') as HTMLSelectElement).value = order.payment_method || 'qris';

      document.getElementById('edit-modal')?.classList.remove('hidden');
    } catch (error) {
      showToast('Gagal memuat data pesanan.', 'error');
    }
  }

  function closeEditModal() {
    document.getElementById('edit-modal')?.classList.add('hidden');
  }

  async function submitEditOrder(e: Event) {
    e.preventDefault();
    const orderId = (document.getElementById('edit-order-id') as HTMLInputElement).value;

    const body = {
      user_name: (document.getElementById('edit-user-name') as HTMLInputElement).value,
      user_email: (document.getElementById('edit-user-email') as HTMLInputElement).value,
      user_phone: (document.getElementById('edit-user-phone') as HTMLInputElement).value,
      amount: Number((document.getElementById('edit-amount') as HTMLInputElement).value),
      payment_method: (document.getElementById('edit-payment-method') as HTMLSelectElement).value,
    };

    try {
      const response = await adminFetch(API_BASE + '/admin/orders/' + orderId, {
        method: 'PUT',
        body: JSON.stringify(body),
      });
      const result = await response.json();
      if (response.ok) {
        showToast('Pesanan berhasil diperbarui!');
        closeEditModal();
        loadOrders();
      } else {
        showToast(result.error || 'Gagal memperbarui pesanan', 'error');
      }
    } catch (error) {
      if (error.message !== 'Auth expired') showToast('Terjadi kesalahan.', 'error');
    }
  }

  async function deleteOrder(orderId: string) {
    if (!confirm('Apakah Anda yakin ingin menghapus pesanan ini? Tindakan ini tidak dapat dibatalkan.')) return;

    try {
      const response = await adminFetch(API_BASE + '/admin/orders/' + orderId, {
        method: 'DELETE',
      });
      const result = await response.json();
      if (response.ok) {
        showToast('Pesanan berhasil dihapus!');
        loadOrders();
      } else {
        showToast(result.error || 'Gagal menghapus pesanan', 'error');
      }
    } catch (error) {
      if (error.message !== 'Auth expired') showToast('Terjadi kesalahan.', 'error');
    }
  }

  async function changeStatus(orderId: string, newStatus: string) {
    try {
      const response = await adminFetch(API_BASE + '/admin/orders/' + orderId + '/status', {
        method: 'PUT',
        body: JSON.stringify({ status: newStatus }),
      });
      const result = await response.json();
      if (response.ok) {
        loadOrders();
      } else {
        showToast(result.error || 'Gagal mengubah status', 'error');
        loadOrders();
      }
    } catch (error) {
      if (error.message !== 'Auth expired') showToast('Terjadi kesalahan.', 'error');
      loadOrders();
    }
  }


  function exportOrders() {
    const csv = [
      ['Order ID', 'Nama', 'Email', 'Produk', 'Jumlah', 'Status', 'Tanggal'].join(','),
      ...allOrders.map(function(o) {
        return [
          o.id,
          '"' + (o.user_name || '') + '"',
          o.user_email,
          '"' + o.product_title + '"',
          o.amount,
          o.status,
          new Date(o.created_at).toLocaleDateString('id-ID')
        ].join(',');
      })
    ].join('\n');
    
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'orders-' + new Date().toISOString().split('T')[0] + '.csv';
    a.click();
    URL.revokeObjectURL(url);
  }

  function renderOrderPagination(totalPages: number) {
    const container = document.getElementById('order-pagination');
    if (!container) return;
    if (totalPages <= 1) { container.innerHTML = ''; return; }
    container.innerHTML =
      '<button onclick="orderPrevPage()" ' + (orderCurrentPage <= 1 ? 'disabled' : '') + ' class="btn-tertiary py-2 px-4 disabled:opacity-50 disabled:cursor-not-allowed">Sebelumnya</button>' +
      '<span class="text-sm text-text-muted">Halaman ' + orderCurrentPage + ' dari ' + totalPages + '</span>' +
      '<button onclick="orderNextPage()" ' + (orderCurrentPage >= totalPages ? 'disabled' : '') + ' class="btn-tertiary py-2 px-4 disabled:opacity-50 disabled:cursor-not-allowed">Berikutnya</button>';
  }

  function orderPrevPage() {
    if (orderCurrentPage > 1) { orderCurrentPage--; applyOrderFilters(); }
  }

  function orderNextPage() {
    orderCurrentPage++; applyOrderFilters();
  }

  // Event listeners
  document.getElementById('status-filter')?.addEventListener('change', function() {
    orderCurrentPage = 1;
    applyOrderFilters();
  });
  document.getElementById('order-search')?.addEventListener('input', function(e) {
    orderSearchQuery = (e.target as HTMLInputElement).value;
    orderCurrentPage = 1;
    applyOrderFilters();
  });

  // Auth guard
  if (!localStorage.getItem('admin_token')) {
    window.location.href = '/admin/login';
  }

  // Expose to global scope for onclick handlers
  (window as any).exportOrders = exportOrders;
  (window as any).viewOrder = viewOrder;
  (window as any).editOrder = editOrder;
  (window as any).deleteOrder = deleteOrder;
  (window as any).changeStatus = changeStatus;
  (window as any).closeDetailModal = closeDetailModal;
  (window as any).closeEditModal = closeEditModal;
  (window as any).submitEditOrder = submitEditOrder;
  (window as any).orderPrevPage = orderPrevPage;
  (window as any).orderNextPage = orderNextPage;

  // Load on page load
  loadOrders();
</script>
