---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDB } from '../../db';
import { orders, products } from '../../db/schema';
import { eq, desc } from 'drizzle-orm';
import { formatIDR, timeAgo } from '../../lib/utils';

const env = Astro.locals?.runtime?.env || {};
const db = getDB(env);

const allOrders = await db
  .select({
    id: orders.id,
    ref: orders.dompetxRefId,
    amount: orders.amount,
    originalAmount: orders.originalAmount,
    discountAmount: orders.discountAmount,
    couponCode: orders.couponCode,
    status: orders.status,
    paymentMethod: orders.paymentMethod,
    customerEmail: orders.customerEmail,
    customerName: orders.customerName,
    createdAt: orders.createdAt,
    paidAt: orders.paidAt,
    productTitle: products.title,
    productId: orders.productId,
  })
  .from(orders)
  .innerJoin(products, eq(orders.productId, products.id))
  .orderBy(desc(orders.createdAt))
  .limit(100);
---

<AdminLayout title="Kelola Orders - Admin" activePage="orders">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold">Kelola Orders</h1>
    <div class="flex items-center gap-3">
      <select class="px-4 py-2 bg-surface border border-border rounded-lg text-sm">
        <option value="">Semua Status</option>
        <option value="PAID">Paid</option>
        <option value="PENDING">Pending</option>
        <option value="FAILED">Failed</option>
      </select>
    </div>
  </div>

  <div class="bg-surface border border-border rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Order ID</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Customer</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Produk</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Total</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Payment</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Status</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Tanggal</th>
          </tr>
        </thead>
        <tbody>
          {allOrders.map(order => (
            <tr class="border-b border-border hover:bg-background/50 transition-colors cursor-pointer">
              <td class="px-6 py-4 text-sm font-mono">{order.ref.slice(0, 20)}...</td>
              <td class="px-6 py-4 text-sm">
                <div>
                  <p>{order.customerName || '-'}</p>
                  <p class="text-xs text-text-muted">{order.customerEmail}</p>
                </div>
              </td>
              <td class="px-6 py-4 text-sm">
                <span class:list={[
                  order.productId === 'ALL-ACCESS' ? "text-accent font-medium" : ""
                ]}>
                  {order.productTitle}
                </span>
              </td>
              <td class="px-6 py-4 text-sm">
                <div>
                  <p class="font-medium">{formatIDR(order.amount)}</p>
                  {order.discountAmount > 0 && (
                    <p class="text-xs text-success">-{formatIDR(order.discountAmount)} ({order.couponCode})</p>
                  )}
                </div>
              </td>
              <td class="px-6 py-4 text-sm text-text-muted">{order.paymentMethod || '-'}</td>
              <td class="px-6 py-4">
                <span class:list={[
                  "inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium",
                  order.status === 'PAID' ? "bg-success/20 text-success" : 
                  order.status === 'PENDING' ? "bg-warning/20 text-warning" : 
                  "bg-danger/20 text-danger"
                ]}>
                  {order.status === 'PAID' && '✅ '}
                  {order.status === 'PENDING' && '⏳ '}
                  {order.status === 'FAILED' && '❌ '}
                  {order.status}
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-text-muted">{timeAgo(order.createdAt || new Date())}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    
    {allOrders.length === 0 && (
      <div class="text-center py-12 text-text-muted">
        Belum ada order
      </div>
    )}
  </div>
</AdminLayout>
