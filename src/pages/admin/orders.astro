---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
import { formatIDR } from '../../lib/utils';

// Mock orders data
const orders = [
  { id: 'INV-20260517-001', customer: 'S***', email: 's***@gmail.com', product: 'All-Access Pass', amount: 299000, status: 'PAID', payment: 'QRIS', date: '2026-05-17 14:30' },
  { id: 'INV-20260517-002', customer: 'B***', email: 'b***@gmail.com', product: 'Animasi Muslim', amount: 99000, status: 'PAID', payment: 'BCA', date: '2026-05-17 12:15' },
  { id: 'INV-20260517-003', customer: 'A***', email: 'a***@yahoo.com', product: 'Sahabat Guru', amount: 79000, status: 'PENDING', payment: 'QRIS', date: '2026-05-17 10:45' },
  { id: 'INV-20260516-001', customer: 'R***', email: 'r***@gmail.com', product: 'All-Access Pass', amount: 149500, status: 'PAID', payment: 'GoPay', date: '2026-05-16 20:30', coupon: 'LAUNCH50' },
  { id: 'INV-20260516-002', customer: 'M***', email: 'm***@outlook.com', product: 'Content Creator', amount: 89000, status: 'PAID', payment: 'DANA', date: '2026-05-16 15:20' },
  { id: 'INV-20260515-001', customer: 'D***', email: 'd***@gmail.com', product: 'Copywriter AI', amount: 79000, status: 'FAILED', payment: 'BCA', date: '2026-05-15 09:10' },
];

const sidebarLinks = [
  { icon: 'bar-chart', label: 'Dashboard', href: '/admin', active: false },
  { icon: 'sparkles', label: 'Produk', href: '/admin/products', active: false },
  { icon: 'shopping-cart', label: 'Pesanan', href: '/admin/orders', active: true },
  { icon: 'users', label: 'Pengguna', href: '/admin/users', active: false },
  { icon: 'tag', label: 'Kupon', href: '/admin/coupons', active: false },
  { icon: 'link', label: 'Affiliate', href: '/admin/affiliates', active: false },
  { icon: 'file-text', label: 'Blog', href: '/admin/blog', active: false },
  { icon: 'settings', label: 'Pengaturan', href: '/admin/settings', active: false },
];
---

<BaseLayout title="Pesanan - Admin">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-surface border-r border-border shrink-0 hidden lg:block">
      <div class="sticky top-0 h-screen overflow-y-auto p-4">
        <a href="/admin" class="flex items-center gap-2.5 mb-8 px-2">
          <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
            <Icon name="sparkles" size={18} class="text-white" />
          </div>
          <div>
            <span class="font-bold text-text-primary block">Asri Digital</span>
            <span class="text-xs text-text-muted">Admin Panel</span>
          </div>
        </a>
        
        <nav class="space-y-1">
          {sidebarLinks.map((link) => (
            <a href={link.href} class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${link.active ? 'bg-primary/10 text-primary' : 'text-text-secondary hover:text-text-primary hover:bg-background'}`}>
              <Icon name={link.icon} size={18} />
              {link.label}
            </a>
          ))}
        </nav>
        
        <div class="mt-8 pt-4 border-t border-border">
          <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-background transition-colors">
            <Icon name="external-link" size={18} />
            Lihat Website
          </a>
        </div>
      </div>
    </aside>
    
    <!-- Main Content -->
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button class="lg:hidden p-2 hover:bg-background rounded-lg">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Pesanan</h1>
          </div>
          <div class="flex items-center gap-3">
            <button class="btn-tertiary text-sm">
              <Icon name="filter" size={16} />
              Filter
            </button>
            <button class="btn-tertiary text-sm">
              <Icon name="download" size={16} />
              Export
            </button>
          </div>
        </div>
      </header>
      
      <div class="p-6">
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-6">
          <div class="card p-4">
            <p class="text-sm text-text-muted mb-1">Total Pesanan</p>
            <p class="text-2xl font-bold text-text-primary">{orders.length}</p>
          </div>
          <div class="card p-4">
            <p class="text-sm text-text-muted mb-1">Lunas</p>
            <p class="text-2xl font-bold text-green-600">{orders.filter(o => o.status === 'PAID').length}</p>
          </div>
          <div class="card p-4">
            <p class="text-sm text-text-muted mb-1">Pending</p>
            <p class="text-2xl font-bold text-amber-600">{orders.filter(o => o.status === 'PENDING').length}</p>
          </div>
          <div class="card p-4">
            <p class="text-sm text-text-muted mb-1">Gagal</p>
            <p class="text-2xl font-bold text-red-600">{orders.filter(o => o.status === 'FAILED').length}</p>
          </div>
        </div>
        
        <!-- Orders Table -->
        <div class="card overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border bg-background">
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Invoice</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Pelanggan</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Produk</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Jumlah</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Status</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Pembayaran</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Tanggal</th>
                  <th class="px-4 py-3 text-right text-xs font-medium text-text-muted uppercase">Aksi</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-border">
                {orders.map((order) => (
                  <tr>
                    <td class="px-4 py-4">
                      <span class="font-mono text-sm text-text-primary">{order.id}</span>
                    </td>
                    <td class="px-4 py-4">
                      <div>
                        <div class="font-medium text-text-primary">{order.customer}</div>
                        <div class="text-xs text-text-muted">{order.email}</div>
                      </div>
                    </td>
                    <td class="px-4 py-4 text-text-main">{order.product}</td>
                    <td class="px-4 py-4">
                      <div class="font-medium text-text-primary">{formatIDR(order.amount)}</div>
                      {order.coupon && <div class="text-xs text-green-600">Kupon: {order.coupon}</div>}
                    </td>
                    <td class="px-4 py-4">
                      <span class={order.status === 'PAID' ? 'badge-success' : order.status === 'PENDING' ? 'badge-warning' : 'badge-danger'}>
                        {order.status === 'PAID' ? 'Lunas' : order.status === 'PENDING' ? 'Pending' : 'Gagal'}
                      </span>
                    </td>
                    <td class="px-4 py-4 text-sm text-text-main">{order.payment}</td>
                    <td class="px-4 py-4 text-sm text-text-muted">{order.date}</td>
                    <td class="px-4 py-4 text-right">
                      <button class="p-2 hover:bg-background rounded-lg text-text-secondary hover:text-text-primary">
                        <Icon name="eye" size={16} />
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>
