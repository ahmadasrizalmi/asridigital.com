---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
---

<BaseLayout title="Pengaturan - Admin Asri Digital">
  <div class="flex min-h-screen">
    <aside id="admin-sidebar" class="w-64 bg-surface border-r border-border shrink-0 fixed inset-y-0 left-0 z-40 -translate-x-full transition-transform duration-300 lg:static lg:translate-x-0">
      <div class="sticky top-0 h-screen overflow-y-auto p-4">
        <a href="/admin" class="flex items-center gap-2.5 mb-8 px-2">
          <img src="https://res.cloudinary.com/daj8fzinf/image/upload/q_auto/f_auto/v1779951905/fav_icon_asri_digital_rktguz.png" alt="Asri Digital" class="h-8 w-auto rounded-lg" />
          <span class="text-xs text-text-muted font-medium">Admin</span>
        </a>
        
        <nav class="space-y-1">
          {[
            { icon: 'bar-chart', label: 'Dashboard', href: '/admin' },
            { icon: 'sparkles', label: 'Produk', href: '/admin/products' },
            { icon: 'shopping-cart', label: 'Pesanan', href: '/admin/orders' },
            { icon: 'tag', label: 'Kupon', href: '/admin/coupons' },
            { icon: 'link', label: 'Affiliate', href: '/admin/affiliates' },
            { icon: 'file-text', label: 'Blog', href: '/admin/blog' },
            { icon: 'image', label: 'Hero Slides', href: '/admin/hero-slides' },
            { icon: 'folder', label: 'Kategori', href: '/admin/categories' },
            { icon: 'settings', label: 'Pengaturan', href: '/admin/settings', active: true },
          ].map((link) => (
            <a
              href={link.href}
              class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${
                link.active
                  ? 'bg-primary/10 text-primary'
                  : 'text-text-secondary hover:text-text-primary hover:bg-background'
              }`}
            >
              <Icon name={link.icon} size={18} />
              {link.label}
            </a>
          ))}
        </nav>
        
        <div class="mt-8 pt-4 border-t border-border">
          <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-background transition-colors">
            <Icon name="external-link" size={18} />
            Lihat Website
          </a>
          <button onclick="logout()" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-red-500 hover:bg-red-50 transition-colors">
            <Icon name="log-out" size={18} />
            Logout
          </button>
        </div>
      </div>
    </aside>
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-30 hidden lg:hidden" onclick="document.getElementById('admin-sidebar').classList.add('-translate-x-full');this.classList.add('hidden')"></div>
    
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-4 sm:px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2 hover:bg-background rounded-lg">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Pengaturan</h1>
          </div>
          
          <button onclick="saveSettings()" class="btn-primary">
            <Icon name="save" size={18} />
            Simpan Semua
          </button>
        </div>
      </header>
      
      <div class="p-4 sm:p-6 max-w-4xl">
        <!-- General Settings -->
        <div class="card p-6 mb-6">
          <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
            <Icon name="globe" size={20} class="text-primary" />
            Pengaturan Umum
          </h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Nama Situs</label>
              <input type="text" id="setting-site-name" class="input" value="Asri Digital" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Deskripsi Situs</label>
              <textarea id="setting-site-description" class="input" rows="2">Custom GPT Marketplace untuk Profesional Indonesia</textarea>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">URL Situs</label>
              <input type="url" id="setting-site-url" class="input" value="https://asridigital.com" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Logo URL</label>
              <input type="text" id="setting-logo-url" class="input" placeholder="/images/logo.svg" />
            </div>
          </div>
        </div>
        
        <!-- Contact Settings -->
        <div class="card p-6 mb-6">
          <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
            <Icon name="phone" size={20} class="text-primary" />
            Kontak
          </h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Email Support</label>
              <input type="email" id="setting-email" class="input" value="support@asridigital.com" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">WhatsApp Number</label>
              <input type="tel" id="setting-whatsapp" class="input" placeholder="628123456789" />
            </div>
          </div>
        </div>
        
        <!-- Payment Settings -->
        <div class="card p-6 mb-6">
          <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
            <Icon name="credit-card" size={20} class="text-primary" />
            Pembayaran
          </h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">DompetX API Key</label>
              <input type="password" id="setting-dompetx-key" class="input" placeholder="Masukkan API Key" />
              <p class="text-xs text-text-muted mt-1">Dapatkan dari dashboard DompetX</p>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">DompetX Webhook Secret</label>
              <input type="password" id="setting-dompetx-webhook" class="input" placeholder="Masukkan Webhook Secret" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Komisi Affiliate (%)</label>
              <input type="number" id="setting-commission" class="input" value="15" min="5" max="50" />
            </div>
          </div>
        </div>
        
        <!-- Email Settings -->
        <div class="card p-6 mb-6">
          <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
            <Icon name="mail" size={20} class="text-primary" />
            Email
          </h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Resend API Key</label>
              <input type="password" id="setting-resend-key" class="input" placeholder="re_xxxxxxxxxxxx" />
              <p class="text-xs text-text-muted mt-1">Dapatkan dari resend.com</p>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Email Pengirim</label>
              <input type="email" id="setting-from-email" class="input" value="noreply@asridigital.com" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Nama Pengirim</label>
              <input type="text" id="setting-from-name" class="input" value="Asri Digital" />
            </div>
          </div>
        </div>
        
        <!-- FOMO Settings -->
        <div class="card p-6 mb-6">
          <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
            <Icon name="bell" size={20} class="text-primary" />
            FOMO & Notifikasi
          </h2>
          
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="font-medium text-text-primary">FOMO Popup</p>
                <p class="text-sm text-text-muted">Tampilkan notifikasi penjualan terbaru</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="setting-fomo-enabled" class="sr-only peer" checked />
                <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
              </label>
            </div>
            
            <div class="flex items-center justify-between">
              <div>
                <p class="font-medium text-text-primary">Auto Email Konfirmasi</p>
                <p class="text-sm text-text-muted">Kirim email otomatis setelah pembayaran</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="setting-auto-email" class="sr-only peer" checked />
                <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
              </label>
            </div>
          </div>
        </div>
        
        <!-- Social Media -->
        <div class="card p-6 mb-6">
          <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
            <Icon name="share-2" size={20} class="text-primary" />
            Social Media
          </h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Instagram</label>
              <input type="url" id="setting-instagram" class="input" placeholder="https://instagram.com/asridigital" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">TikTok</label>
              <input type="url" id="setting-tiktok" class="input" placeholder="https://tiktok.com/@asridigital" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">YouTube</label>
              <input type="url" id="setting-youtube" class="input" placeholder="https://youtube.com/@asridigital" />
            </div>
          </div>
        </div>
        
        <!-- Tracking & Analytics -->
        <div class="card p-6 mb-6">
          <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
            <Icon name="target" size={20} class="text-primary" />
            Tracking & Analytics
          </h2>
          <p class="text-sm text-text-muted mb-4">Isi ID tracking untuk mengaktifkan Google Tag Manager, Meta Pixel, dan Google Ads conversion tracking. Kosongkan jika belum punya.</p>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Google Tag Manager ID</label>
              <input type="text" id="setting-gtm-id" class="input" placeholder="GTM-XXXXXXX" />
              <p class="text-xs text-text-muted mt-1">Format: GTM-XXXXXXX — dari tagmanager.google.com</p>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Meta Pixel ID</label>
              <input type="text" id="setting-meta-pixel-id" class="input" placeholder="1234567890123456" />
              <p class="text-xs text-text-muted mt-1">Angka saja — dari Meta Events Manager</p>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-text-main mb-2">Google Ads Conversion ID</label>
                <input type="text" id="setting-google-ads-id" class="input" placeholder="AW-XXXXXXXXX" />
                <p class="text-xs text-text-muted mt-1">Format: AW-XXXXXXXXX</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-text-main mb-2">Google Ads Conversion Label</label>
                <input type="text" id="setting-google-ads-label" class="input" placeholder="AbCdEfGhIjK" />
                <p class="text-xs text-text-muted mt-1">Dari Google Ads > Conversion goals</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Save Button -->
        <div class="flex justify-end gap-3">
          <button onclick="resetSettings()" class="btn-tertiary">
            <Icon name="refresh-cw" size={18} />
            Reset
          </button>
          <button onclick="saveSettings()" class="btn-primary">
            <Icon name="save" size={18} />
            Simpan Semua Pengaturan
          </button>
        </div>
      </div>
    </main>
  </div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('mobile-menu-btn');
    const sidebar = document.getElementById('admin-sidebar');
    if (toggle && sidebar) {
      toggle.addEventListener('click', () => {
        sidebar.classList.toggle('-translate-x-full');
        const overlay = document.getElementById('sidebar-overlay');
        if (overlay) overlay.classList.toggle('hidden');
      });
    }
  });
</script>

</BaseLayout>

<script is:inline src="/js/admin-utils.js"></script>
<script>
  // Load settings
  async function loadSettings() {
    try {
      const response = await adminFetch('/api/admin/settings');
      if (response.status === 401 || response.status === 403) return;
      const data = await response.json();
      
      if (data.settings) {
        const s = data.settings;
        const setVal = (id, val) => { const el = document.getElementById(id); if (el && val) el.value = val; };
        const setCheck = (id, val) => { const el = document.getElementById(id); if (el) el.checked = val === 'true'; };
        
        setVal('setting-site-name', s.site_name);
        setVal('setting-site-description', s.site_description);
        setVal('setting-site-url', s.site_url);
        setVal('setting-logo-url', s.logo_url);
        setVal('setting-whatsapp', s.whatsapp_number);
        setVal('setting-email', s.email);
        setVal('setting-dompetx-key', s.dompetx_api_key);
        setVal('setting-dompetx-webhook', s.dompetx_webhook_secret);
        setVal('setting-commission', s.commission_percent);
        setVal('setting-resend-key', s.resend_api_key);
        setVal('setting-from-email', s.from_email);
        setVal('setting-from-name', s.from_name);
        setCheck('setting-fomo-enabled', s.fomo_enabled);
        setCheck('setting-auto-email', s.auto_email);
        setVal('setting-instagram', s.instagram);
        setVal('setting-tiktok', s.tiktok);
        setVal('setting-youtube', s.youtube);
        setVal('setting-gtm-id', s.gtm_id);
        setVal('setting-meta-pixel-id', s.meta_pixel_id);
        setVal('setting-google-ads-id', s.google_ads_id);
        setVal('setting-google-ads-label', s.google_ads_label);
      }
    } catch (error) {
      if (error.message !== 'Auth expired') {
        showToast('Gagal memuat pengaturan', 'error');
      }
    }
  }
  
  async function saveSettings() {
    const btn = event?.target?.closest('button');
    if (btn) { btn.disabled = true; btn.textContent = 'Menyimpan...'; }

    const settings = {
      site_name: document.getElementById('setting-site-name').value,
      site_description: document.getElementById('setting-site-description').value,
      site_url: document.getElementById('setting-site-url').value,
      logo_url: document.getElementById('setting-logo-url').value,
      whatsapp_number: document.getElementById('setting-whatsapp').value,
      email: document.getElementById('setting-email').value,
      dompetx_api_key: document.getElementById('setting-dompetx-key').value,
      dompetx_webhook_secret: document.getElementById('setting-dompetx-webhook').value,
      commission_percent: document.getElementById('setting-commission').value,
      resend_api_key: document.getElementById('setting-resend-key').value,
      from_email: document.getElementById('setting-from-email').value,
      from_name: document.getElementById('setting-from-name').value,
      fomo_enabled: document.getElementById('setting-fomo-enabled').checked.toString(),
      auto_email: document.getElementById('setting-auto-email').checked.toString(),
      instagram: document.getElementById('setting-instagram').value,
      tiktok: document.getElementById('setting-tiktok').value,
      youtube: document.getElementById('setting-youtube').value,
      gtm_id: document.getElementById('setting-gtm-id').value,
      meta_pixel_id: document.getElementById('setting-meta-pixel-id').value,
      google_ads_id: document.getElementById('setting-google-ads-id').value,
      google_ads_label: document.getElementById('setting-google-ads-label').value,
    };
    
    try {
      const response = await adminFetch('/api/admin/settings', {
        method: 'PUT',
        body: JSON.stringify(settings)
      });
      
      if (response.status === 401 || response.status === 403) return;
      const data = await response.json();
      
      if (data.success) {
        showToast('Pengaturan berhasil disimpan!');
      } else {
        showToast(data.error || 'Gagal menyimpan pengaturan', 'error');
      }
    } catch (error) {
      if (error.message !== 'Auth expired') {
        showToast('Terjadi kesalahan saat menyimpan', 'error');
      }
    } finally {
      if (btn) { btn.disabled = false; btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Simpan Semua'; }
    }
  }
  
  function resetSettings() {
    if (confirm('Reset semua pengaturan ke default?')) {
      loadSettings();
    }
  }
  
  (window as any).saveSettings = saveSettings;
  (window as any).resetSettings = resetSettings;

  loadSettings();
  
  function logout() {
    localStorage.removeItem('admin_token');
    window.location.href = '/admin/login';
  }
</script>
