---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDB } from '../../db';
import { siteSettings } from '../../db/schema';

const env = Astro.locals?.runtime?.env || {};
const db = getDB(env);

const settings = await db.select().from(siteSettings).limit(1);
const currentSettings = settings[0] || {
  siteName: 'Asri Digital',
  siteTagline: 'Custom GPT untuk Profesional Indonesia',
  commissionPercent: 10,
  allAccessProductId: 'ALL-ACCESS',
  maintenanceMode: false,
};
---

<AdminLayout title="Settings - Admin" activePage="settings">
  <h1 class="text-2xl font-bold mb-8">Settings</h1>

  <div class="max-w-2xl space-y-6">
    {/* General Settings */}
    <div class="bg-surface border border-border rounded-xl p-6">
      <h2 class="text-lg font-semibold mb-6">Pengaturan Umum</h2>
      <form id="settings-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-2">Nama Situs</label>
          <input type="text" name="siteName" value={currentSettings.siteName}
            class="w-full px-4 py-3 bg-background border border-border rounded-lg focus:border-primary outline-none" />
        </div>
        
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-2">Tagline</label>
          <input type="text" name="siteTagline" value={currentSettings.siteTagline || ''}
            class="w-full px-4 py-3 bg-background border border-border rounded-lg focus:border-primary outline-none" />
        </div>

        <div>
          <label class="block text-sm font-medium text-text-secondary mb-2">Komisi Affiliate (%)</label>
          <input type="number" name="commissionPercent" value={currentSettings.commissionPercent} min="0" max="100"
            class="w-full px-4 py-3 bg-background border border-border rounded-lg focus:border-primary outline-none" />
        </div>

        <div class="flex items-center justify-between p-4 bg-background rounded-lg">
          <div>
            <p class="font-medium">Maintenance Mode</p>
            <p class="text-sm text-text-muted">Aktifkan untuk menampilkan halaman maintenance</p>
          </div>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" name="maintenanceMode" class="sr-only peer" checked={currentSettings.maintenanceMode} />
            <div class="w-11 h-6 bg-border peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
          </label>
        </div>

        <button type="submit" class="w-full py-3 bg-primary hover:bg-primary-hover text-white rounded-lg font-medium transition-colors">
          Simpan Settings
        </button>
      </form>
    </div>

    {/* API Info */}
    <div class="bg-surface border border-border rounded-xl p-6">
      <h2 class="text-lg font-semibold mb-6">Informasi API</h2>
      <div class="space-y-4">
        <div>
          <p class="text-sm text-text-muted mb-1">DompetX Status</p>
          <span class="inline-flex items-center gap-1 px-2 py-1 bg-success/20 text-success rounded-full text-xs">
            <span class="w-2 h-2 bg-success rounded-full"></span>
            Connected
          </span>
        </div>
        <div>
          <p class="text-sm text-text-muted mb-1">Resend Email Status</p>
          <span class="inline-flex items-center gap-1 px-2 py-1 bg-success/20 text-success rounded-full text-xs">
            <span class="w-2 h-2 bg-success rounded-full"></span>
            Connected
          </span>
        </div>
        <div>
          <p class="text-sm text-text-muted mb-1">Webhook URL</p>
          <code class="text-sm text-primary">{env.APP_URL || 'https://asridigital.com'}/api/webhook/dompetx</code>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('settings-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const formData = new FormData(form);
      
      try {
        const response = await fetch('/api/admin/settings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            siteName: formData.get('siteName'),
            siteTagline: formData.get('siteTagline'),
            commissionPercent: parseInt(formData.get('commissionPercent') as string),
            maintenanceMode: (form.querySelector('[name="maintenanceMode"]') as HTMLInputElement)?.checked || false,
          }),
        });

        if (response.ok) {
          alert('Settings berhasil disimpan!');
        } else {
          alert('Gagal menyimpan settings');
        }
      } catch {
        alert('Terjadi kesalahan');
      }
    });
  </script>
</AdminLayout>
