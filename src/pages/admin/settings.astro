---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';

const sidebarLinks = [
  { icon: 'bar-chart', label: 'Dashboard', href: '/admin', active: false },
  { icon: 'sparkles', label: 'Produk', href: '/admin/products', active: false },
  { icon: 'shopping-cart', label: 'Pesanan', href: '/admin/orders', active: false },
  { icon: 'users', label: 'Pengguna', href: '/admin/users', active: false },
  { icon: 'tag', label: 'Kupon', href: '/admin/coupons', active: false },
  { icon: 'link', label: 'Affiliate', href: '/admin/affiliates', active: false },
  { icon: 'file-text', label: 'Blog', href: '/admin/blog', active: false },
  { icon: 'settings', label: 'Pengaturan', href: '/admin/settings', active: true },
];
---

<BaseLayout title="Pengaturan - Admin">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-surface border-r border-border shrink-0 hidden lg:block">
      <div class="sticky top-0 h-screen overflow-y-auto p-4">
        <a href="/admin" class="flex items-center gap-2.5 mb-8 px-2">
          <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
            <Icon name="sparkles" size={18} class="text-white" />
          </div>
          <div>
            <span class="font-bold text-text-primary block">Asri Digital</span>
            <span class="text-xs text-text-muted">Admin Panel</span>
          </div>
        </a>
        
        <nav class="space-y-1">
          {sidebarLinks.map((link) => (
            <a href={link.href} class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${link.active ? 'bg-primary/10 text-primary' : 'text-text-secondary hover:text-text-primary hover:bg-background'}`}>
              <Icon name={link.icon} size={18} />
              {link.label}
            </a>
          ))}
        </nav>
        
        <div class="mt-8 pt-4 border-t border-border">
          <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-background transition-colors">
            <Icon name="external-link" size={18} />
            Lihat Website
          </a>
        </div>
      </div>
    </aside>
    
    <!-- Main Content -->
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center gap-4">
          <button class="lg:hidden p-2 hover:bg-background rounded-lg">
            <Icon name="menu" size={24} class="text-text-secondary" />
          </button>
          <h1 class="text-xl font-bold text-text-primary">Pengaturan</h1>
        </div>
      </header>
      
      <div class="p-6 max-w-4xl">
        <!-- General Settings -->
        <div class="card p-6 mb-6">
          <h2 class="text-lg font-semibold text-text-primary mb-6 flex items-center gap-2">
            <Icon name="settings" size={20} class="text-text-muted" />
            Pengaturan Umum
          </h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Nama Website</label>
              <input type="text" value="Asri Digital" class="input" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Deskripsi</label>
              <textarea class="input" rows="3">Custom GPT untuk Profesional Indonesia</textarea>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">URL Website</label>
              <input type="url" value="https://asridigital-com.pages.dev" class="input" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Email Kontak</label>
              <input type="email" value="support@asridigital.com" class="input" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">WhatsApp</label>
              <input type="tel" value="628123456789" class="input" />
            </div>
          </div>
        </div>
        
        <!-- Payment Settings -->
        <div class="card p-6 mb-6">
          <h2 class="text-lg font-semibold text-text-primary mb-6 flex items-center gap-2">
            <Icon name="credit-card" size={20} class="text-text-muted" />
            Pengaturan Pembayaran
          </h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">DompetX API Key</label>
              <input type="password" value="••••••••" class="input" />
              <p class="text-xs text-text-muted mt-1">Digunakan untuk integrasi pembayaran</p>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">DompetX Webhook Secret</label>
              <input type="password" value="••••••••" class="input" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Mata Uang</label>
              <select class="input">
                <option value="IDR" selected>IDR - Rupiah Indonesia</option>
                <option value="USD">USD - US Dollar</option>
              </select>
            </div>
          </div>
        </div>
        
        <!-- Email Settings -->
        <div class="card p-6 mb-6">
          <h2 class="text-lg font-semibold text-text-primary mb-6 flex items-center gap-2">
            <Icon name="mail" size={20} class="text-text-muted" />
            Pengaturan Email
          </h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Resend API Key</label>
              <input type="password" value="••••••••" class="input" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Email Pengirim</label>
              <input type="email" value="noreply@asridigital.com" class="input" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Nama Pengirim</label>
              <input type="text" value="Asri Digital" class="input" />
            </div>
          </div>
        </div>
        
        <!-- Affiliate Settings -->
        <div class="card p-6 mb-6">
          <h2 class="text-lg font-semibold text-text-primary mb-6 flex items-center gap-2">
            <Icon name="link" size={20} class="text-text-muted" />
            Pengaturan Affiliate
          </h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Komisi Default (%)</label>
              <input type="number" value="10" min="1" max="50" class="input" />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Minimal Withdrawal (IDR)</label>
              <input type="number" value="50000" class="input" />
            </div>
            
            <div class="flex items-center gap-3">
              <input type="checkbox" id="affiliate-enabled" checked class="w-4 h-4 text-primary focus:ring-primary border-border rounded" />
              <label for="affiliate-enabled" class="text-sm text-text-main">Aktifkan sistem affiliate</label>
            </div>
          </div>
        </div>
        
        <!-- FOMO Settings -->
        <div class="card p-6 mb-6">
          <h2 class="text-lg font-semibold text-text-primary mb-6 flex items-center gap-2">
            <Icon name="bell" size={20} class="text-text-muted" />
            FOMO Popup Settings
          </h2>
          
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <input type="checkbox" id="fomo-enabled" checked class="w-4 h-4 text-primary focus:ring-primary border-border rounded" />
              <label for="fomo-enabled" class="text-sm text-text-main">Aktifkan FOMO popup</label>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Interval (detik)</label>
              <input type="number" value="30" min="10" max="120" class="input" />
            </div>
          </div>
        </div>
        
        <!-- Save Button -->
        <div class="flex justify-end">
          <button class="btn-primary">
            <Icon name="check" size={16} />
            Simpan Pengaturan
          </button>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>
