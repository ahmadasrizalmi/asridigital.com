---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdminSidebar from '../../components/layout/AdminSidebar.astro';
import Icon from '../../components/ui/Icon.astro';
import { formatIDR } from '../../lib/utils';
---

<BaseLayout title="Admin Dashboard - Asri Digital">
  <div class="flex min-h-screen">
    <!-- Admin Sidebar -->
    <AdminSidebar activePage="dashboard" />
    
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-4 md:px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2 hover:bg-background rounded-lg mr-2" onclick="window.__openSidebar?.()">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Dashboard</h1>
          </div>
          
          <div class="flex items-center gap-4">
            <button class="p-2 hover:bg-background rounded-lg" aria-label="Notifikasi">
              <Icon name="bell" size={20} class="text-text-secondary" />
            </button>
            
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center">
                <span class="text-sm font-bold text-primary">A</span>
              </div>
              <span class="text-sm font-medium text-text-primary hidden md:block">Admin</span>
            </div>
          </div>
        </div>
      </header>
      
      <div class="p-4 md:p-6">
        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
          <div class="card p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-text-muted">Total Revenue</p>
                <p id="stat-revenue" class="text-2xl font-bold text-text-primary mt-1">-</p>
              </div>
              <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
                <Icon name="dollar-sign" size={24} class="text-green-600" />
              </div>
            </div>
            <div class="mt-4 flex items-center gap-2 text-sm">
              <span class="text-text-muted">bulan ini</span>
            </div>
          </div>
          
          <div class="card p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-text-muted">Total Pesanan</p>
                <p id="stat-orders" class="text-2xl font-bold text-text-primary mt-1">-</p>
              </div>
              <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
                <Icon name="shopping-cart" size={24} class="text-blue-600" />
              </div>
            </div>
            <div class="mt-4 flex items-center gap-2 text-sm">
              <span id="stat-paid-orders" class="text-green-600 font-medium">-</span>
              <span class="text-text-muted">berhasil</span>
            </div>
          </div>
          
          <div class="card p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-text-muted">Total User</p>
                <p id="stat-users" class="text-2xl font-bold text-text-primary mt-1">-</p>
              </div>
              <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center">
                <Icon name="users" size={24} class="text-purple-600" />
              </div>
            </div>
            <div class="mt-4 flex items-center gap-2 text-sm">
              <span class="text-text-muted">terdaftar</span>
            </div>
          </div>
          
          <div class="card p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-text-muted">Pending</p>
                <p id="stat-pending" class="text-2xl font-bold text-text-primary mt-1">-</p>
              </div>
              <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center">
                <Icon name="clock" size={24} class="text-amber-600" />
              </div>
            </div>
            <div class="mt-4 flex items-center gap-2 text-sm">
              <span class="text-amber-600 font-medium">Perlu ditindak</span>
            </div>
          </div>
        </div>
        
        <!-- Recent Orders -->
        <div class="card">
          <div class="p-6 border-b border-border">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-semibold text-text-primary">Pesanan Terbaru</h2>
              <a href="/admin/orders" class="text-sm text-primary hover:underline font-medium">
                Lihat Semua →
              </a>
            </div>
          </div>
          
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border bg-background">
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase hidden md:table-cell">Order ID</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase hidden md:table-cell">Pelanggan</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Produk</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Jumlah</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase hidden md:table-cell">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase hidden md:table-cell">Tanggal</th>
                </tr>
              </thead>
              <tbody id="orders-table" class="divide-y divide-border">
                <tr>
                  <td colspan="6" class="px-6 py-12 text-center text-text-muted">
                    Loading...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>


</BaseLayout>

<script is:inline src="/js/admin-utils.js?v=3"></script>
<script>
  const API_BASE = '/api';

  async function loadAdminStats() {
    try {
      const response = await adminFetch(`${API_BASE}/admin/stats`);
      if (response.status === 401 || response.status === 403) return;
      const data = await response.json() as any;
      
      if (data.stats) {
        document.getElementById('stat-revenue')!.textContent = formatIDR(data.stats.revenue || 0);
        document.getElementById('stat-orders')!.textContent = (data.stats.totalOrders || 0).toString();
        document.getElementById('stat-paid-orders')!.textContent = `${data.stats.paidOrders || 0} lunas`;
        document.getElementById('stat-users')!.textContent = (data.stats.totalUsers || 0).toString();
        document.getElementById('stat-pending')!.textContent = (data.stats.pendingOrders || 0).toString();
      }
      
      if (data.recentOrders && data.recentOrders.length > 0) {
        const ordersTable = document.getElementById('orders-table')!;
        ordersTable.innerHTML = data.recentOrders.map((order: any) => `
          <tr class="hover:bg-background/50">
            <td class="px-6 py-4 hidden md:table-cell">
              <span class="font-mono text-sm text-text-primary">${order.id.substring(0, 8)}...</span>
            </td>
            <td class="px-6 py-4 hidden md:table-cell">
              <span class="text-text-main">${order.user_name || order.user_email}</span>
            </td>
            <td class="px-6 py-4 text-text-main">${order.product_title}</td>
            <td class="px-6 py-4 font-medium text-text-primary">${formatIDR(order.amount)}</td>
            <td class="px-6 py-4 hidden md:table-cell">
              <span class="${order.status === 'PAID' ? 'badge-success' : order.status === 'PENDING' ? 'badge-warning' : 'badge-danger'}">
                ${order.status === 'PAID' ? 'Lunas' : order.status === 'PENDING' ? 'Pending' : 'Gagal'}
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-text-muted hidden md:table-cell">
              ${new Date(order.created_at).toLocaleDateString('id-ID')}
            </td>
          </tr>
        `).join('');
      }
    } catch (error) {
    }
  }

  // Auth handled by admin-utils.js checkAuth()
  loadAdminStats();

  // Refresh every 30 seconds
  setInterval(loadAdminStats, 30000);
</script>
