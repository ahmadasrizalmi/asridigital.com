---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
import { formatIDR } from '../../lib/utils';
---

<BaseLayout title="Admin Dashboard - Asri Digital">
  <!-- Login Overlay -->
  <div id="login-overlay" class="fixed inset-0 bg-background z-50 flex items-center justify-center">
    <div class="card p-8 max-w-md w-full mx-4">
      <div class="text-center mb-8">
        <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <Icon name="shield" size={32} class="text-primary" />
        </div>
        <h1 class="text-2xl font-bold text-text-primary">Admin Login</h1>
        <p class="text-text-secondary mt-2">Masuk untuk mengakses admin panel</p>
      </div>
      
      <form id="admin-login-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text-primary mb-1">Email</label>
          <input type="email" name="email" required class="input" placeholder="admin@asridigital.com" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-primary mb-1">Password</label>
          <input type="password" name="password" required class="input" placeholder="••••••••" />
        </div>
        <div id="login-error" class="hidden text-red-500 text-sm"></div>
        <button type="submit" class="btn-primary w-full">
          <Icon name="log-in" size={18} />
          Masuk
        </button>
      </form>
    </div>
  </div>

  <!-- Admin Content (hidden until login) -->
  <div id="admin-content" class="hidden">
  <div class="flex min-h-screen">
    <!-- Admin Sidebar -->
    <aside class="w-64 bg-surface border-r border-border shrink-0 hidden lg:block">
      <div class="sticky top-0 h-screen overflow-y-auto p-4">
        <a href="/admin" class="flex items-center gap-2.5 mb-8 px-2">
          <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
            <Icon name="sparkles" size={18} class="text-white" />
          </div>
          <div>
            <span class="font-bold text-text-primary block">Asri Digital</span>
            <span class="text-xs text-text-muted">Admin Panel</span>
          </div>
        </a>
        
        <nav class="space-y-1">
          {[
            { icon: 'bar-chart', label: 'Dashboard', href: '/admin', active: true },
            { icon: 'sparkles', label: 'Produk', href: '/admin/products' },
            { icon: 'shopping-cart', label: 'Pesanan', href: '/admin/orders' },
            { icon: 'tag', label: 'Kupon', href: '/admin/coupons' },
            { icon: 'link', label: 'Affiliate', href: '/admin/affiliates' },
            { icon: 'file-text', label: 'Blog', href: '/admin/blog' },
            { icon: 'settings', label: 'Pengaturan', href: '/admin/settings' },
          ].map((link) => (
            <a
              href={link.href}
              class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${
                link.active
                  ? 'bg-primary/10 text-primary'
                  : 'text-text-secondary hover:text-text-primary hover:bg-background'
              }`}
            >
              <Icon name={link.icon} size={18} />
              {link.label}
            </a>
          ))}
        </nav>
        
        <div class="mt-8 pt-4 border-t border-border">
          <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-background transition-colors">
            <Icon name="external-link" size={18} />
            Lihat Website
          </a>
          <button onclick="adminLogout()" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50 transition-colors w-full mt-2">
            <Icon name="log-out" size={18} />
            Logout
          </button>
        </div>
      </div>
    </aside>
    
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2 hover:bg-background rounded-lg">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Dashboard</h1>
          </div>
          
          <div class="flex items-center gap-4">
            <button class="p-2 hover:bg-background rounded-lg relative">
              <Icon name="bell" size={20} class="text-text-secondary" />
              <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span>
            </button>
            
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center">
                <span class="text-sm font-bold text-primary">A</span>
              </div>
              <span class="text-sm font-medium text-text-primary hidden sm:block">Admin</span>
            </div>
          </div>
        </div>
      </header>
      
      <div class="p-6">
        <!-- Stats Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
          <div class="card p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-text-muted">Total Revenue</p>
                <p id="stat-revenue" class="text-2xl font-bold text-text-primary mt-1">-</p>
              </div>
              <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
                <Icon name="dollar-sign" size={24} class="text-green-600" />
              </div>
            </div>
            <div class="mt-4 flex items-center gap-2 text-sm">
              <span class="text-green-600 font-medium">↑ 12%</span>
              <span class="text-text-muted">vs bulan lalu</span>
            </div>
          </div>
          
          <div class="card p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-text-muted">Total Pesanan</p>
                <p id="stat-orders" class="text-2xl font-bold text-text-primary mt-1">-</p>
              </div>
              <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
                <Icon name="shopping-cart" size={24} class="text-blue-600" />
              </div>
            </div>
            <div class="mt-4 flex items-center gap-2 text-sm">
              <span id="stat-paid-orders" class="text-green-600 font-medium">-</span>
              <span class="text-text-muted">berhasil</span>
            </div>
          </div>
          
          <div class="card p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-text-muted">Total User</p>
                <p id="stat-users" class="text-2xl font-bold text-text-primary mt-1">-</p>
              </div>
              <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center">
                <Icon name="users" size={24} class="text-purple-600" />
              </div>
            </div>
            <div class="mt-4 flex items-center gap-2 text-sm">
              <span class="text-purple-600 font-medium">5</span>
              <span class="text-text-muted">baru hari ini</span>
            </div>
          </div>
          
          <div class="card p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-text-muted">Pending</p>
                <p id="stat-pending" class="text-2xl font-bold text-text-primary mt-1">-</p>
              </div>
              <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center">
                <Icon name="clock" size={24} class="text-amber-600" />
              </div>
            </div>
            <div class="mt-4 flex items-center gap-2 text-sm">
              <span class="text-amber-600 font-medium">Perlu ditindak</span>
            </div>
          </div>
        </div>
        
        <!-- Recent Orders -->
        <div class="card">
          <div class="p-6 border-b border-border">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-semibold text-text-primary">Pesanan Terbaru</h2>
              <a href="/admin/orders" class="text-sm text-primary hover:underline font-medium">
                Lihat Semua →
              </a>
            </div>
          </div>
          
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border bg-background">
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Order ID</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Pelanggan</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Produk</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Jumlah</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Tanggal</th>
                </tr>
              </thead>
              <tbody id="orders-table" class="divide-y divide-border">
                <tr>
                  <td colspan="6" class="px-6 py-12 text-center text-text-muted">
                    Loading...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>
  </div><!-- end admin-content -->
</BaseLayout>

<script>
  const API_BASE = '/api';

  // Check admin auth
  function getAdminToken() {
    return localStorage.getItem('admin_token');
  }

  function setAdminToken(token) {
    localStorage.setItem('admin_token', token);
  }

  function clearAdminToken() {
    localStorage.removeItem('admin_token');
  }

  // Show admin content
  function showAdminContent() {
    document.getElementById('login-overlay')!.classList.add('hidden');
    document.getElementById('admin-content')!.classList.remove('hidden');
    loadAdminStats();
  }

  // Show login
  function showLogin() {
    document.getElementById('login-overlay')!.classList.remove('hidden');
    document.getElementById('admin-content')!.classList.add('hidden');
  }

  // Admin login form
  document.getElementById('admin-login-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    const errorDiv = document.getElementById('login-error')!;
    
    try {
      const response = await fetch(`${API_BASE}/auth/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: formData.get('email'),
          password: formData.get('password')
        })
      });
      
      const data = await response.json() as any;
      
      if (data.success && data.token) {
        // Verify admin role
        const meResponse = await fetch(`${API_BASE}/auth/me`, {
          headers: { 'Authorization': `Bearer ${data.token}` }
        });
        const meData = await meResponse.json() as any;
        
        if (meData.user?.role === 'admin') {
          setAdminToken(data.token);
          showAdminContent();
        } else {
          errorDiv.textContent = 'Akses ditolak. Hanya admin yang bisa masuk.';
          errorDiv.classList.remove('hidden');
        }
      } else {
        errorDiv.textContent = data.error || 'Login gagal';
        errorDiv.classList.remove('hidden');
      }
    } catch (error) {
      errorDiv.textContent = 'Terjadi kesalahan';
      errorDiv.classList.remove('hidden');
    }
  });

  // Logout
  function adminLogout() {
    clearAdminToken();
    showLogin();
  }

  // Make adminLogout available globally
  (window as any).adminLogout = adminLogout;

  function formatIDR(amount: number): string {
    return new Intl.NumberFormat('id-ID', {
      style: 'currency',
      currency: 'IDR',
      minimumFractionDigits: 0
    }).format(amount);
  }

  async function loadAdminStats() {
    const token = getAdminToken();
    if (!token) return;
    
    try {
      const response = await fetch(`${API_BASE}/admin/stats`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json() as any;
      
      if (data.stats) {
        document.getElementById('stat-revenue')!.textContent = formatIDR(data.stats.revenue || 0);
        document.getElementById('stat-orders')!.textContent = (data.stats.totalOrders || 0).toString();
        document.getElementById('stat-paid-orders')!.textContent = `${data.stats.paidOrders || 0} lunas`;
        document.getElementById('stat-users')!.textContent = (data.stats.totalUsers || 0).toString();
        document.getElementById('stat-pending')!.textContent = (data.stats.pendingOrders || 0).toString();
      }
      
      if (data.recentOrders && data.recentOrders.length > 0) {
        const ordersTable = document.getElementById('orders-table')!;
        ordersTable.innerHTML = data.recentOrders.map((order: any) => `
          <tr class="hover:bg-background/50">
            <td class="px-6 py-4">
              <span class="font-mono text-sm text-text-primary">${order.id.substring(0, 8)}...</span>
            </td>
            <td class="px-6 py-4">
              <span class="text-text-main">${order.user_name || order.user_email}</span>
            </td>
            <td class="px-6 py-4 text-text-main">${order.product_title}</td>
            <td class="px-6 py-4 font-medium text-text-primary">${formatIDR(order.amount)}</td>
            <td class="px-6 py-4">
              <span class="${order.status === 'PAID' ? 'badge-success' : order.status === 'PENDING' ? 'badge-warning' : 'badge-danger'}">
                ${order.status === 'PAID' ? 'Lunas' : order.status === 'PENDING' ? 'Pending' : 'Gagal'}
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-text-muted">
              ${new Date(order.created_at).toLocaleDateString('id-ID')}
            </td>
          </tr>
        `).join('');
      }
    } catch (error) {
      console.error('Error loading admin stats:', error);
    }
  }

  // Load on page load - check if already logged in
  const existingToken = getAdminToken();
  if (existingToken) {
    // Verify token is still valid
    fetch(`${API_BASE}/auth/me`, {
      headers: { 'Authorization': `Bearer ${existingToken}` }
    })
    .then(r => r.json())
    .then((data: any) => {
      if (data.user?.role === 'admin') {
        showAdminContent();
      } else {
        clearAdminToken();
        showLogin();
      }
    })
    .catch(() => {
      clearAdminToken();
      showLogin();
    });
  } else {
    showLogin();
  }

  // Expose to global scope for onclick handlers
  (window as any).adminLogout = adminLogout;

  // Refresh every 30 seconds
  setInterval(loadAdminStats, 30000);
</script>
