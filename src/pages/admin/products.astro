---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
---

<BaseLayout title="Kelola Produk - Admin Asri Digital">
  <div class="flex min-h-screen">
    <aside id="admin-sidebar" class="w-64 bg-surface border-r border-border shrink-0 fixed inset-y-0 left-0 z-40 -translate-x-full transition-transform duration-300 lg:static lg:translate-x-0">
      <div class="sticky top-0 h-screen overflow-y-auto p-4">
        <a href="/admin" class="flex items-center gap-2.5 mb-8 px-2">
          <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
            <Icon name="sparkles" size={18} class="text-white" />
          </div>
          <div>
            <span class="font-bold text-text-primary block">Asri Digital</span>
            <span class="text-xs text-text-muted">Admin Panel</span>
          </div>
        </a>
        
        <nav class="space-y-1">
          {[
            { icon: 'bar-chart', label: 'Dashboard', href: '/admin' },
            { icon: 'sparkles', label: 'Produk', href: '/admin/products', active: true },
            { icon: 'shopping-cart', label: 'Pesanan', href: '/admin/orders' },
            { icon: 'tag', label: 'Kupon', href: '/admin/coupons' },
            { icon: 'link', label: 'Affiliate', href: '/admin/affiliates' },
            { icon: 'file-text', label: 'Blog', href: '/admin/blog' },
            { icon: 'image', label: 'Hero Slides', href: '/admin/hero-slides' },
            { icon: 'folder', label: 'Kategori', href: '/admin/categories' },
            { icon: 'settings', label: 'Pengaturan', href: '/admin/settings' },
          ].map((link) => (
            <a
              href={link.href}
              class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${
                link.active
                  ? 'bg-primary/10 text-primary'
                  : 'text-text-secondary hover:text-text-primary hover:bg-background'
              }`}
            >
              <Icon name={link.icon} size={18} />
              {link.label}
            </a>
          ))}
        </nav>
        
        <div class="mt-8 pt-4 border-t border-border">
          <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-background transition-colors">
            <Icon name="external-link" size={18} />
            Lihat Website
          </a>
        </div>
      </div>
    </aside>
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-30 hidden lg:hidden" onclick="document.getElementById('admin-sidebar').classList.add('-translate-x-full');this.classList.add('hidden')"></div>
    
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-4 sm:px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2 hover:bg-background rounded-lg">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Kelola Produk</h1>
          </div>
          
          <button onclick="openModal()" class="btn-primary">
            <Icon name="plus" size={18} />
            Tambah Produk
          </button>
        </div>
      </header>
      
      <div class="p-4 sm:p-6">
        <div class="card">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border bg-background">
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Produk</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Kategori</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Harga</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Featured</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Aksi</th>
                </tr>
              </thead>
              <tbody id="products-table" class="divide-y divide-border">
                <tr>
                  <td colspan="6" class="px-6 py-12 text-center text-text-muted">
                    Loading...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Add/Edit Product Modal -->
  <div id="product-modal" class="fixed inset-0 bg-black/50 z-50 hidden">
    <div class="flex items-center justify-center min-h-screen p-4">
      <div class="bg-surface rounded-xl max-w-3xl w-full max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-border">
          <div class="flex items-center justify-between">
            <h2 class="text-xl font-bold text-text-primary" id="modal-title">Tambah Produk</h2>
            <button onclick="closeModal()" class="p-2 hover:bg-background rounded-lg">
              <Icon name="x" size={20} class="text-text-secondary" />
            </button>
          </div>
        </div>
        
        <form id="product-form" class="p-6 space-y-4">
          <input type="hidden" id="product-id" />
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Nama Produk *</label>
              <input type="text" id="product-title" class="input" required />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Slug *</label>
              <input type="text" id="product-slug" class="input" required />
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-text-main mb-2">Deskripsi</label>
            <textarea id="product-description" class="input" rows="3"></textarea>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-text-main mb-2">Deskripsi Pendek</label>
            <input type="text" id="product-short-desc" class="input" />
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Harga *</label>
              <div class="flex items-center gap-3">
                <input type="number" id="product-price" class="input flex-1" required />
                <label class="flex items-center gap-2 whitespace-nowrap">
                  <input type="checkbox" id="product-is-free" class="rounded" onchange="toggleFreeProduct()" />
                  <span class="text-sm text-text-main">Gratis</span>
                </label>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Harga Coret</label>
              <input type="number" id="product-compare-price" class="input" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-main mb-2">Kategori</label>
              <select id="product-category" class="input">
                <option value="">Loading...</option>
              </select>
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-text-main mb-2">URL GPT</label>
            <input type="url" id="product-gpt-url" class="input" placeholder="https://chatgpt.com/g/..." />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-text-main mb-2">Tags</label>
            <input type="text" id="product-tags" class="input" placeholder="tag1, tag2, tag3" />
          </div>

          {/* ====== MEDIA GALLERY SECTION ====== */}
          <div class="border-t border-border pt-4 mt-4">
            <h3 class="text-base font-semibold text-text-primary mb-4 flex items-center gap-2">
              📸 Media Produk
            </h3>

            {/* Gallery Images */}
            <div class="mb-4">
              <label class="block text-sm font-medium text-text-main mb-2">
                Gambar Produk <span class="text-text-muted font-normal">(klik untuk jadikan cover)</span>
              </label>

              <div id="gallery-grid" class="grid grid-cols-3 sm:grid-cols-4 gap-3 mb-3">
                {/* Image thumbnails will be rendered here */}
              </div>

              <div class="flex gap-2">
                <input type="url" id="image-url-input" class="input flex-1" placeholder="https://res.cloudinary.com/xxx/image.jpg" />
                <button type="button" onclick="addImage()" class="btn-secondary whitespace-nowrap px-3">
                  + Tambah
                </button>
              </div>
              <p class="text-xs text-text-muted mt-1">Paste URL gambar dari Cloudinary, lalu klik gambar untuk pilih cover</p>
            </div>

            {/* Video */}
            <div class="mb-2">
              <label class="block text-sm font-medium text-text-main mb-2">
                Video <span class="text-text-muted font-normal">(opsional, YouTube/Vimeo)</span>
              </label>
              <div class="flex gap-2">
                <input type="url" id="video-url-input" class="input flex-1" placeholder="https://youtube.com/watch?v=xxx atau https://vimeo.com/xxx" />
                <button type="button" onclick="addVideo()" class="btn-secondary whitespace-nowrap px-3">
                  + Video
                </button>
              </div>
              <div id="video-preview" class="hidden mt-2">
                <div class="flex items-center gap-2 p-2 bg-background rounded-lg">
                  <span class="text-sm text-text-main flex-1 truncate" id="video-url-display"></span>
                  <button type="button" onclick="removeVideo()" class="text-red-500 hover:text-red-700 text-sm">✕ Hapus</button>
                </div>
              </div>
            </div>
          </div>
          {/* ====== END MEDIA SECTION ====== */}

          <div class="flex items-center gap-6">
            <label class="flex items-center gap-2">
              <input type="checkbox" id="product-active" class="rounded" checked />
              <span class="text-sm text-text-main">Aktif</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" id="product-featured" class="rounded" />
              <span class="text-sm text-text-main">Featured</span>
            </label>
          </div>
          
          <div class="flex justify-end gap-3 pt-4 border-t border-border">
            <button type="button" onclick="closeModal()" class="btn-tertiary">Batal</button>
            <button type="submit" class="btn-primary">Simpan Produk</button>
          </div>
        </form>
      </div>
    </div>
  </div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('mobile-menu-btn');
    const sidebar = document.getElementById('admin-sidebar');
    if (toggle && sidebar) {
      toggle.addEventListener('click', () => {
        sidebar.classList.toggle('-translate-x-full');
        const overlay = document.getElementById('sidebar-overlay');
        if (overlay) overlay.classList.toggle('hidden');
      });
    }
  });
</script>

</BaseLayout>

<script>
  // Auth guard
  if (!localStorage.getItem('admin_token')) {
    window.location.href = '/admin/login';
  }

  const API_BASE = '/api';

  function getAdminToken(): string | null {
    return localStorage.getItem('admin_token');
  }

  function formatIDR(amount: number): string {
    return new Intl.NumberFormat('id-ID', {
      style: 'currency',
      currency: 'IDR',
      minimumFractionDigits: 0
    }).format(amount);
  }

  // ====== GALLERY MANAGEMENT ======
  let galleryImages: string[] = [];
  let coverImage: string = '';
  let videoUrl: string = '';

  function renderGallery() {
    const grid = document.getElementById('gallery-grid')!;
    if (galleryImages.length === 0) {
      grid.innerHTML = '<p class="text-xs text-text-muted col-span-full py-4 text-center border-2 border-dashed border-border rounded-lg">Belum ada gambar. Paste URL gambar di bawah.</p>';
      return;
    }
    grid.innerHTML = galleryImages.map((url, i) => `
      <div class="relative group rounded-lg overflow-hidden border-2 ${url === coverImage ? 'border-primary ring-2 ring-primary/30' : 'border-border'} aspect-square cursor-pointer" onclick="setCover(${i})">
        <img src="${url}" alt="Gambar ${i + 1}" class="w-full h-full object-cover" onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect fill=%22%23f3f4f6%22 width=%22100%22 height=%22100%22/><text x=%2250%22 y=%2255%22 text-anchor=%22middle%22 fill=%22%239ca3af%22 font-size=%2212%22>Error</text></svg>'" />
        ${url === coverImage ? '<div class="absolute top-1 left-1 bg-primary text-white text-[10px] px-1.5 py-0.5 rounded-full font-bold">⭐ Cover</div>' : ''}
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors flex items-center justify-center gap-1 opacity-0 group-hover:opacity-100">
          ${i > 0 ? `<button type="button" onclick="event.stopPropagation(); moveImage(${i}, -1)" class="bg-white/90 rounded-full w-6 h-6 flex items-center justify-center text-xs hover:bg-white">◀</button>` : ''}
          ${i < galleryImages.length - 1 ? `<button type="button" onclick="event.stopPropagation(); moveImage(${i}, 1)" class="bg-white/90 rounded-full w-6 h-6 flex items-center justify-center text-xs hover:bg-white">▶</button>` : ''}
          <button type="button" onclick="event.stopPropagation(); removeImage(${i})" class="bg-red-500/90 rounded-full w-6 h-6 flex items-center justify-center text-white text-xs hover:bg-red-600">✕</button>
        </div>
      </div>
    `).join('');
  }

  function addImage() {
    const input = document.getElementById('image-url-input') as HTMLInputElement;
    const url = input.value.trim();
    if (!url) return;
    if (!url.startsWith('http')) { alert('URL harus dimulai dengan http:// atau https://'); return; }
    if (galleryImages.includes(url)) { alert('Gambar sudah ditambahkan'); return; }
    galleryImages.push(url);
    if (galleryImages.length === 1) coverImage = url; // First image = cover
    input.value = '';
    renderGallery();
  }

  function removeImage(index: number) {
    const removed = galleryImages.splice(index, 1)[0];
    if (removed === coverImage) coverImage = galleryImages[0] || '';
    renderGallery();
  }

  function setCover(index: number) {
    coverImage = galleryImages[index];
    renderGallery();
  }

  function moveImage(index: number, direction: number) {
    const newIndex = index + direction;
    if (newIndex < 0 || newIndex >= galleryImages.length) return;
    [galleryImages[index], galleryImages[newIndex]] = [galleryImages[newIndex], galleryImages[index]];
    renderGallery();
  }

  function addVideo() {
    const input = document.getElementById('video-url-input') as HTMLInputElement;
    const url = input.value.trim();
    if (!url) return;
    if (!url.includes('youtube.com') && !url.includes('youtu.be') && !url.includes('vimeo.com')) {
      alert('URL harus dari YouTube atau Vimeo');
      return;
    }
    videoUrl = url;
    input.value = '';
    const preview = document.getElementById('video-preview')!;
    const display = document.getElementById('video-url-display')!;
    preview.classList.remove('hidden');
    display.textContent = url;
  }

  function removeVideo() {
    videoUrl = '';
    document.getElementById('video-preview')!.classList.add('hidden');
  }

  function resetMedia() {
    galleryImages = [];
    coverImage = '';
    videoUrl = '';
    renderGallery();
    document.getElementById('video-preview')!.classList.add('hidden');
    (document.getElementById('image-url-input') as HTMLInputElement).value = '';
    (document.getElementById('video-url-input') as HTMLInputElement).value = '';
  }

  function parseJsonField(val: any): any[] {
    if (!val) return [];
    if (Array.isArray(val)) return val;
    try { return JSON.parse(val); } catch { return []; }
  }

  // Expose gallery functions to global scope
  (window as any).addImage = addImage;
  (window as any).removeImage = removeImage;
  (window as any).setCover = setCover;
  (window as any).moveImage = moveImage;
  (window as any).addVideo = addVideo;
  (window as any).removeVideo = removeVideo;

  // Toggle free product
  function toggleFreeProduct() {
    const priceInput = document.getElementById('product-price') as HTMLInputElement;
    const isFree = (document.getElementById('product-is-free') as HTMLInputElement).checked;
    if (isFree) {
      priceInput.value = '0';
      priceInput.disabled = true;
    } else {
      priceInput.disabled = false;
      priceInput.value = '';
    }
  }
  (window as any).toggleFreeProduct = toggleFreeProduct;

  // Load categories from API
  async function loadCategories() {
    try {
      const token = getAdminToken();
      const res = await fetch('/api/admin/categories', {
        headers: { ...(token ? { 'Authorization': 'Bearer ' + token } : {}) }
      });
      const data = await res.json();
      const categories = data.categories || [];
      const select = document.getElementById('product-category') as HTMLSelectElement;
      select.innerHTML = categories.map((c: any) =>
        '<option value="' + c.slug + '">' + c.name + '</option>'
      ).join('');
    } catch (e) {
      console.error('Error loading categories:', e);
    }
  }
  loadCategories();

  async function loadProducts() {
    try {
      const token = getAdminToken();
      const response = await fetch(`${API_BASE}/admin/products`, {
        headers: {
          ...(token ? { 'Authorization': `Bearer ${token}` } : {})
        }
      });
      const data = await response.json() as any;
      
      const table = document.getElementById('products-table')!;
      if (data.products && data.products.length > 0) {
        table.innerHTML = data.products.map((product: any) => `
          <tr class="hover:bg-background/50">
            <td class="px-6 py-4">
              <div>
                <p class="font-medium text-text-primary">${product.title}</p>
                <p class="text-xs text-text-muted">${product.slug}</p>
              </div>
            </td>
            <td class="px-6 py-4">
              <span class="px-2 py-1 bg-background rounded text-xs font-medium text-text-secondary">
                ${product.category || '-'}
              </span>
            </td>
            <td class="px-6 py-4">
              <div>
                ${product.price === 0 ? '<span class="badge-success">Gratis</span>' : `<p class="font-medium text-text-primary">${formatIDR(product.price)}</p>`}
                ${product.compare_at_price ? `<p class="text-xs text-text-muted line-through">${formatIDR(product.compare_at_price)}</p>` : ''}
              </div>
            </td>
            <td class="px-6 py-4">
              <span class="${product.is_active ? 'badge-success' : 'badge-danger'}">
                ${product.is_active ? 'Aktif' : 'Nonaktif'}
              </span>
            </td>
            <td class="px-6 py-4">
              ${product.is_featured ? '<span class="badge-warning">Featured</span>' : '<span class="text-text-muted">-</span>'}
            </td>
            <td class="px-6 py-4">
              <div class="flex items-center gap-2">
                <button onclick='editProduct(${JSON.stringify(product)})' class="p-2.5 hover:bg-background rounded-lg text-text-secondary hover:text-primary" title="Edit">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <button onclick="toggleProduct('${product.id}', ${product.is_active})" class="p-2.5 hover:bg-green-50 rounded-lg ${product.is_active ? 'text-green-600' : 'text-text-muted'} hover:text-green-700" title="${product.is_active ? 'Nonaktifkan' : 'Aktifkan'}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
                </button>
                <button onclick="deleteProduct('${product.id}')" class="p-2.5 hover:bg-red-50 rounded-lg text-text-secondary hover:text-red-600" title="Hapus">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                </button>
              </div>
            </td>
          </tr>
        `).join('');
      }
    } catch (error) {
      console.error('Error loading products:', error);
    }
  }

  function openModal(product?: any) {
    const modal = document.getElementById('product-modal')!;
    const title = document.getElementById('modal-title')!;
    
    if (product) {
      title.textContent = 'Edit Produk';
      (document.getElementById('product-id') as HTMLInputElement).value = product.id;
      (document.getElementById('product-title') as HTMLInputElement).value = product.title;
      (document.getElementById('product-slug') as HTMLInputElement).value = product.slug;
      (document.getElementById('product-description') as HTMLTextAreaElement).value = product.description || '';
      (document.getElementById('product-short-desc') as HTMLInputElement).value = product.short_description || '';
      (document.getElementById('product-price') as HTMLInputElement).value = product.price;
      (document.getElementById('product-compare-price') as HTMLInputElement).value = product.compare_at_price || '';
      (document.getElementById('product-category') as HTMLSelectElement).value = product.category || 'membership';
      (document.getElementById('product-gpt-url') as HTMLInputElement).value = product.gpt_url || '';
      (document.getElementById('product-tags') as HTMLInputElement).value = product.tags || '';
      (document.getElementById('product-active') as HTMLInputElement).checked = product.is_active;
      (document.getElementById('product-featured') as HTMLInputElement).checked = product.is_featured;

      // Handle free product checkbox
      const isFree = product.price === 0;
      (document.getElementById('product-is-free') as HTMLInputElement).checked = isFree;
      (document.getElementById('product-price') as HTMLInputElement).disabled = isFree;

      // Load media data
      galleryImages = parseJsonField(product.gallery_images);
      coverImage = product.image_icon || galleryImages[0] || '';
      const videos = parseJsonField(product.gallery_videos);
      videoUrl = product.video_embed_url || videos[0] || '';
      renderGallery();
      if (videoUrl) {
        document.getElementById('video-preview')!.classList.remove('hidden');
        document.getElementById('video-url-display')!.textContent = videoUrl;
      } else {
        document.getElementById('video-preview')!.classList.add('hidden');
      }
    } else {
      title.textContent = 'Tambah Produk';
      (document.getElementById('product-form') as HTMLFormElement).reset();
      (document.getElementById('product-id') as HTMLInputElement).value = '';
      (document.getElementById('product-active') as HTMLInputElement).checked = true;
      (document.getElementById('product-price') as HTMLInputElement).disabled = false;
      resetMedia();
    }
    
    modal.classList.remove('hidden');
  }

  function closeModal() {
    document.getElementById('product-modal')!.classList.add('hidden');
  }

  function editProduct(product: any) {
    openModal(product);
  }

  async function toggleProduct(id: string, isActive: boolean) {
    try {
      const token = getAdminToken();
      const response = await fetch(`${API_BASE}/admin/products/${id}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
          ...(token ? { 'Authorization': `Bearer ${token}` } : {})
        },
        body: JSON.stringify({ is_active: !isActive }),
      });

      const result = await response.json() as any;

      if (response.ok) {
        loadProducts();
      } else {
        alert(result.error || 'Terjadi kesalahan');
      }
    } catch (error) {
      console.error('Error toggling product:', error);
      alert('Terjadi kesalahan. Silakan coba lagi.');
    }
  }

  async function deleteProduct(id: string) {
    if (!confirm('Yakin ingin menghapus produk ini?')) return;
    
    try {
      const token = getAdminToken();
      const response = await fetch(`${API_BASE}/admin/products/${id}`, {
        method: 'DELETE',
        headers: {
          ...(token ? { 'Authorization': `Bearer ${token}` } : {})
        }
      });
      
      const result = await response.json() as any;
      
      if (response.ok) {
        alert('Produk berhasil dihapus');
        loadProducts();
      } else {
        alert(result.error || 'Terjadi kesalahan');
      }
    } catch (error) {
      console.error('Error deleting product:', error);
      alert('Terjadi kesalahan. Silakan coba lagi.');
    }
  }

  // Form submission
  document.getElementById('product-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const productId = (document.getElementById('product-id') as HTMLInputElement).value;
    const method = productId ? 'PUT' : 'POST';
    const url = productId ? `${API_BASE}/admin/products/${productId}` : `${API_BASE}/admin/products`;
    
    const productData = {
      id: productId || null,
      title: (document.getElementById('product-title') as HTMLInputElement).value,
      slug: (document.getElementById('product-slug') as HTMLInputElement).value,
      description: (document.getElementById('product-description') as HTMLTextAreaElement).value,
      short_description: (document.getElementById('product-short-desc') as HTMLInputElement).value,
      price: parseInt((document.getElementById('product-price') as HTMLInputElement).value),
      compare_at_price: (document.getElementById('product-compare-price') as HTMLInputElement).value ? 
        parseInt((document.getElementById('product-compare-price') as HTMLInputElement).value) : null,
      category: (document.getElementById('product-category') as HTMLSelectElement).value,
      gpt_url: (document.getElementById('product-gpt-url') as HTMLInputElement).value || null,
      tags: (document.getElementById('product-tags') as HTMLInputElement).value,
      is_active: (document.getElementById('product-active') as HTMLInputElement).checked,
      is_featured: (document.getElementById('product-featured') as HTMLInputElement).checked,
      // Media fields
      image_icon: coverImage || null,
      gallery_images: galleryImages.length > 0 ? JSON.stringify(galleryImages) : null,
      gallery_videos: videoUrl ? JSON.stringify([videoUrl]) : null,
      video_embed_url: videoUrl || null,
    };

    const submitBtn = e.target.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Menyimpan...';

    try {
      const response = await fetch(url, {
        method,
        headers: {
          'Content-Type': 'application/json',
          ...(getAdminToken() ? { 'Authorization': `Bearer ${getAdminToken()}` } : {})
        },
        body: JSON.stringify(productData),
      });
      
      const result = await response.json() as any;
      
      if (response.ok) {
        alert('Produk berhasil ' + (productId ? 'diupdate' : 'ditambahkan'));
        closeModal();
        loadProducts();
      } else {
        alert(result.error || 'Terjadi kesalahan');
      }
    } catch (error) {
      console.error('Error saving product:', error);
      alert('Terjadi kesalahan. Silakan coba lagi.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Simpan Produk';
    }
  });

  // Auto-generate slug from title
  document.getElementById('product-title')?.addEventListener('input', (e) => {
    const title = (e.target as HTMLInputElement).value;
    const slug = title.toLowerCase()
      .replace(/[^a-z0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-');
    (document.getElementById('product-slug') as HTMLInputElement).value = slug;
  });

  // Expose to global scope for onclick handlers
  (window as any).openModal = openModal;
  (window as any).closeModal = closeModal;
  (window as any).editProduct = editProduct;
  (window as any).toggleProduct = toggleProduct;
  (window as any).deleteProduct = deleteProduct;

  // Load on page load
  loadProducts();
</script>
