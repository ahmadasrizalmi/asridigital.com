---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
import { formatIDR } from '../../lib/utils';

// Mock products data
const products = [
  { id: 'ALL-ACCESS', title: 'Lifetime All-Access Pass', price: 299000, category: 'membership', isActive: true, isFeatured: true, orders: 25 },
  { id: 'gpt-animasi-muslim', title: 'Animasi Muslim Kids Studio', price: 99000, category: 'kreatif', isActive: true, isFeatured: true, orders: 18 },
  { id: 'gpt-sahabat-guru', title: 'Sahabat Guru PAUD Islami', price: 79000, category: 'pendidikan', isActive: true, isFeatured: false, orders: 12 },
  { id: 'gpt-content-creator', title: 'Content Creator Pro', price: 89000, category: 'marketing', isActive: true, isFeatured: false, orders: 8 },
  { id: 'gpt-copywriter', title: 'Copywriter AI', price: 79000, category: 'marketing', isActive: true, isFeatured: false, orders: 5 },
  { id: 'gpt-code-helper', title: 'Code Helper Pro', price: 99000, category: 'coding', isActive: true, isFeatured: false, orders: 3 },
];

const sidebarLinks = [
  { icon: 'bar-chart', label: 'Dashboard', href: '/admin', active: false },
  { icon: 'sparkles', label: 'Produk', href: '/admin/products', active: true },
  { icon: 'shopping-cart', label: 'Pesanan', href: '/admin/orders', active: false },
  { icon: 'users', label: 'Pengguna', href: '/admin/users', active: false },
  { icon: 'tag', label: 'Kupon', href: '/admin/coupons', active: false },
  { icon: 'link', label: 'Affiliate', href: '/admin/affiliates', active: false },
  { icon: 'file-text', label: 'Blog', href: '/admin/blog', active: false },
  { icon: 'settings', label: 'Pengaturan', href: '/admin/settings', active: false },
];
---

<BaseLayout title="Kelola Produk - Admin">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-surface border-r border-border shrink-0 hidden lg:block">
      <div class="sticky top-0 h-screen overflow-y-auto p-4">
        <a href="/admin" class="flex items-center gap-2.5 mb-8 px-2">
          <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
            <Icon name="sparkles" size={18} class="text-white" />
          </div>
          <div>
            <span class="font-bold text-text-primary block">Asri Digital</span>
            <span class="text-xs text-text-muted">Admin Panel</span>
          </div>
        </a>
        
        <nav class="space-y-1">
          {sidebarLinks.map((link) => (
            <a href={link.href} class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${link.active ? 'bg-primary/10 text-primary' : 'text-text-secondary hover:text-text-primary hover:bg-background'}`}>
              <Icon name={link.icon} size={18} />
              {link.label}
            </a>
          ))}
        </nav>
        
        <div class="mt-8 pt-4 border-t border-border">
          <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-background transition-colors">
            <Icon name="external-link" size={18} />
            Lihat Website
          </a>
        </div>
      </div>
    </aside>
    
    <!-- Main Content -->
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button class="lg:hidden p-2 hover:bg-background rounded-lg">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Kelola Produk</h1>
          </div>
          <button class="btn-primary text-sm">
            <Icon name="plus" size={16} />
            Tambah Produk
          </button>
        </div>
      </header>
      
      <div class="p-6">
        <!-- Products Table -->
        <div class="card overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border bg-background">
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Produk</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Kategori</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Harga</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Status</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Pesanan</th>
                  <th class="px-4 py-3 text-right text-xs font-medium text-text-muted uppercase">Aksi</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-border">
                {products.map((product) => (
                  <tr>
                    <td class="px-4 py-4">
                      <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
                          <Icon name="sparkles" size={16} class="text-primary" />
                        </div>
                        <div>
                          <div class="font-medium text-text-primary">{product.title}</div>
                          <div class="text-xs text-text-muted">ID: {product.id}</div>
                        </div>
                      </div>
                    </td>
                    <td class="px-4 py-4">
                      <span class="badge-muted">{product.category}</span>
                    </td>
                    <td class="px-4 py-4 font-medium text-text-primary">{formatIDR(product.price)}</td>
                    <td class="px-4 py-4">
                      <span class={product.isActive ? 'badge-success' : 'badge-danger'}>
                        {product.isActive ? 'Aktif' : 'Nonaktif'}
                      </span>
                    </td>
                    <td class="px-4 py-4 text-text-main">{product.orders}</td>
                    <td class="px-4 py-4 text-right">
                      <div class="flex items-center justify-end gap-2">
                        <button class="p-2 hover:bg-background rounded-lg text-text-secondary hover:text-text-primary">
                          <Icon name="edit" size={16} />
                        </button>
                        <button class="p-2 hover:bg-red-50 rounded-lg text-text-secondary hover:text-red-600">
                          <Icon name="trash" size={16} />
                        </button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>
