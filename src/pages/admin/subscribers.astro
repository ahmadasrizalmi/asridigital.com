---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdminSidebar from '../../components/layout/AdminSidebar.astro';
import Icon from '../../components/ui/Icon.astro';
---

<BaseLayout title="Subscribers - Admin Asri Digital">
  <div class="flex min-h-screen">
    <AdminSidebar activePage="subscribers" />
    
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-4 md:px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2 hover:bg-background rounded-lg mr-2" onclick="window.__openSidebar?.()">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Subscribers</h1>
          </div>
        </div>
      </header>

      <div class="p-4 md:p-6">
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6" id="stats-cards">
          <div class="bg-surface rounded-xl border border-border p-5">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
                <Icon name="users" size={20} class="text-primary" />
              </div>
              <div>
                <p class="text-xs text-text-muted uppercase tracking-wide">Total Active</p>
                <p class="text-2xl font-bold text-text-primary" id="stat-total">-</p>
              </div>
            </div>
          </div>
          <div class="bg-surface rounded-xl border border-border p-5">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 bg-emerald-500/10 rounded-lg flex items-center justify-center">
                <Icon name="trending-up" size={20} class="text-emerald-500" />
              </div>
              <div>
                <p class="text-xs text-text-muted uppercase tracking-wide">Baru Minggu Ini</p>
                <p class="text-2xl font-bold text-text-primary" id="stat-week">-</p>
              </div>
            </div>
          </div>
          <div class="bg-surface rounded-xl border border-border p-5">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 bg-amber-500/10 rounded-lg flex items-center justify-center">
                <Icon name="calendar" size={20} class="text-amber-500" />
              </div>
              <div>
                <p class="text-xs text-text-muted uppercase tracking-wide">Baru Bulan Ini</p>
                <p class="text-2xl font-bold text-text-primary" id="stat-month">-</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Filters -->
        <div class="bg-surface rounded-xl border border-border p-4 mb-6">
          <div class="flex flex-col md:flex-row gap-3">
            <div class="flex-1">
              <input
                type="text"
                id="search-input"
                placeholder="Cari email, nama, atau WhatsApp..."
                class="w-full px-4 py-2.5 bg-background border border-border rounded-lg text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary/50"
              />
            </div>
            <select
              id="status-filter"
              class="px-4 py-2.5 bg-background border border-border rounded-lg text-sm text-text-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
            >
              <option value="all">Semua Status</option>
              <option value="active">Active</option>
              <option value="unsubscribed">Unsubscribed</option>
            </select>
            <button
              id="export-btn"
              class="px-4 py-2.5 bg-surface border border-border rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-background transition-colors flex items-center gap-2"
            >
              <Icon name="download" size={16} />
              Export CSV
            </button>
          </div>
        </div>

        <!-- Table -->
        <div class="bg-surface rounded-xl border border-border overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border bg-background/50">
                  <th class="text-left px-4 py-3 text-xs font-semibold text-text-muted uppercase tracking-wide hidden md:table-cell">Nama</th>
                  <th class="text-left px-4 py-3 text-xs font-semibold text-text-muted uppercase tracking-wide">Email</th>
                  <th class="text-left px-4 py-3 text-xs font-semibold text-text-muted uppercase tracking-wide hidden md:table-cell">WhatsApp</th>
                  <th class="text-left px-4 py-3 text-xs font-semibold text-text-muted uppercase tracking-wide hidden md:table-cell">Source</th>
                  <th class="text-left px-4 py-3 text-xs font-semibold text-text-muted uppercase tracking-wide hidden md:table-cell">Status</th>
                  <th class="text-left px-4 py-3 text-xs font-semibold text-text-muted uppercase tracking-wide hidden md:table-cell">Tanggal</th>
                  <th class="text-left px-4 py-3 text-xs font-semibold text-text-muted uppercase tracking-wide">Aksi</th>
                </tr>
              </thead>
              <tbody id="subscribers-table">
                <tr>
                  <td colspan="7" class="text-center py-12 text-text-muted">
                    <div class="flex flex-col items-center gap-2">
                      <div class="w-8 h-8 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
                      <span class="text-sm">Memuat data...</span>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          
          <!-- Pagination -->
          <div class="border-t border-border px-4 py-3 flex flex-col sm:flex-row items-center justify-between gap-2" id="pagination">
            <p class="text-xs sm:text-sm text-text-muted text-center sm:text-left" id="pagination-info">-</p>
            <div class="flex gap-2" id="pagination-buttons"></div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script is:inline>
    const API_BASE = '/api';
    let currentPage = 1;
    let currentStatus = 'all';
    let currentSearch = '';

    function getToken() {
      return localStorage.getItem('admin_token') || '';
    }


    async function fetchStats() {
      try {
        const res = await fetch(`${API_BASE}/admin/subscribers/stats`, {
          headers: { 'Authorization': `Bearer ${getToken()}` }
        });
        if (!res.ok) return;
        const data = await res.json();
        document.getElementById('stat-total').textContent = data.totalActive || 0;
        document.getElementById('stat-week').textContent = data.newThisWeek || 0;
        document.getElementById('stat-month').textContent = data.newThisMonth || 0;
      } catch (e) {
        console.error('Stats error:', e);
      }
    }

    async function fetchSubscribers(page = 1) {
      currentPage = page;
      const params = new URLSearchParams({
        page: page.toString(),
        limit: '20',
        status: currentStatus,
        search: currentSearch
      });

      try {
        const res = await fetch(`${API_BASE}/admin/subscribers?${params}`, {
          headers: { 'Authorization': `Bearer ${getToken()}` }
        });
        if (!res.ok) throw new Error('Failed to fetch');
        const data = await res.json();
        renderTable(data.subscribers || []);
        renderPagination(data);
      } catch (e) {
        console.error('Fetch error:', e);
        document.getElementById('subscribers-table').innerHTML = `
          <tr><td colspan="7" class="text-center py-12 text-red-500">Gagal memuat data</td></tr>
        `;
      }
    }

    function renderTable(subscribers) {
      const tbody = document.getElementById('subscribers-table');
      if (!subscribers.length) {
        tbody.innerHTML = `
          <tr><td colspan="7" class="text-center py-12 text-text-muted">
            <div class="flex flex-col items-center gap-2">
              <span class="text-3xl">📭</span>
              <span>Belum ada subscriber</span>
            </div>
          </td></tr>
        `;
        return;
      }

      tbody.innerHTML = subscribers.map(s => `
        <tr class="border-b border-border hover:bg-background/50 transition-colors">
          <td class="px-4 py-3 text-sm font-medium text-text-primary hidden md:table-cell">${escapeHtml(s.name || '-')}</td>
          <td class="px-4 py-3 text-sm text-text-secondary">${escapeHtml(s.email)}</td>
          <td class="px-4 py-3 text-sm text-text-secondary hidden md:table-cell">${escapeHtml(s.whatsapp || '-')}</td>
          <td class="px-4 py-3 hidden md:table-cell">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary">
              ${escapeHtml(s.source || 'free_product')}
            </span>
          </td>
          <td class="px-4 py-3 hidden md:table-cell">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${
              s.is_active ? 'bg-emerald-500/10 text-emerald-500' : 'bg-red-500/10 text-red-500'
            }">
              ${s.is_active ? 'Active' : 'Unsubscribed'}
            </span>
          </td>
          <td class="px-4 py-3 text-sm text-text-muted hidden md:table-cell">${formatDate(s.created_at)}</td>
          <td class="px-4 py-3">
            <div class="hidden md:block">
              <button onclick="toggleStatus('${s.id}', ${s.is_active ? 0 : 1})" 
                class="text-xs px-2 py-1 rounded ${s.is_active ? 'text-red-500 hover:bg-red-500/10' : 'text-emerald-500 hover:bg-emerald-500/10'}">
                ${s.is_active ? 'Unsubscribe' : 'Reactivate'}
              </button>
            </div>
            <div class="action-menu md:hidden">
              <button class="action-menu-btn p-2 hover:bg-background rounded-lg text-text-secondary" onclick="toggleActionMenu(event)"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg></button>
              <div class="action-dropdown">
                <button class="action-dropdown-item ${s.is_active ? 'text-red-600' : ''}" onclick="toggleStatus('${s.id}', ${s.is_active ? 0 : 1})">${s.is_active ? 'Unsubscribe' : 'Reactivate'}</button>
              </div>
            </div>
          </td>
        </tr>
      `).join('');
    }

    function renderPagination(data) {
      const info = document.getElementById('pagination-info');
      const buttons = document.getElementById('pagination-buttons');
      info.textContent = `Menampilkan ${(data.page - 1) * data.limit + 1}-${Math.min(data.page * data.limit, data.total)} dari ${data.total}`;

      let html = '';
      if (data.page > 1) {
        html += `<button onclick="fetchSubscribers(${data.page - 1})" class="px-3 py-1.5 text-sm rounded-lg border border-border hover:bg-background">Prev</button>`;
      }
      if (data.page < data.totalPages) {
        html += `<button onclick="fetchSubscribers(${data.page + 1})" class="px-3 py-1.5 text-sm rounded-lg border border-border hover:bg-background">Next</button>`;
      }
      buttons.innerHTML = html;
    }

    async function toggleStatus(id, newStatus) {
      try {
        const res = await fetch(`${API_BASE}/admin/subscribers/${id}`, {
          method: 'PATCH',
          headers: {
            'Authorization': `Bearer ${getToken()}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ is_active: newStatus })
        });
        if (res.ok) {
          fetchSubscribers(currentPage);
          fetchStats();
        }
      } catch (e) {
        console.error('Toggle error:', e);
      }
    }

    function exportCSV() {
      const rows = [['Nama', 'Email', 'WhatsApp', 'Source', 'Status', 'Tanggal']];
      document.querySelectorAll('#subscribers-table tr').forEach(tr => {
        const cells = Array.from(tr.querySelectorAll('td')).map(td => td.textContent.trim());
        if (cells.length >= 6) rows.push(cells.slice(0, 6));
      });
      const csv = rows.map(r => r.map(c => `"${c}"`).join(',')).join('\n');
      const blob = new Blob([csv], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `subscribers-${new Date().toISOString().split('T')[0]}.csv`;
      a.click();
    }

    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function formatDate(dateStr) {
      if (!dateStr) return '-';
      const d = new Date(dateStr);
      return d.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' });
    }

    // Event listeners
    document.getElementById('search-input').addEventListener('input', (e) => {
      currentSearch = e.target.value;
      clearTimeout(window._searchTimeout);
      window._searchTimeout = setTimeout(() => fetchSubscribers(1), 300);
    });

    document.getElementById('status-filter').addEventListener('change', (e) => {
      currentStatus = e.target.value;
      fetchSubscribers(1);
    });

    document.getElementById('export-btn').addEventListener('click', exportCSV);

    // Init
    fetchStats();
    fetchSubscribers(1);
  </script>
</BaseLayout>
