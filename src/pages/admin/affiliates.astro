---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDB } from '../../db';
import { affiliates, users, orders, products } from '../../db/schema';
import { eq, desc, sql } from 'drizzle-orm';
import { formatIDR, timeAgo } from '../../lib/utils';

const env = Astro.locals?.runtime?.env || {};
const db = getDB(env);

const allAffiliates = await db
  .select({
    id: affiliates.id,
    commissionAmount: affiliates.commissionAmount,
    commissionPercent: affiliates.commissionPercent,
    status: affiliates.status,
    createdAt: affiliates.createdAt,
    referrerName: users.name,
    referrerEmail: users.email,
    orderRef: orders.dompetxRefId,
    productTitle: products.title,
  })
  .from(affiliates)
  .innerJoin(users, eq(affiliates.referredByUserId, users.id))
  .innerJoin(orders, eq(affiliates.orderId, orders.id))
  .innerJoin(products, eq(orders.productId, products.id))
  .orderBy(desc(affiliates.createdAt))
  .limit(100);

// Stats
const [stats] = await db
  .select({
    totalCommission: sql<number>`coalesce(sum(${affiliates.commissionAmount}), 0)`,
    pendingCount: sql<number>`sum(case when ${affiliates.status} = 'PENDING' then 1 else 0 end)`,
    availableCount: sql<number>`sum(case when ${affiliates.status} = 'AVAILABLE' then 1 else 0 end)`,
    paidCount: sql<number>`sum(case when ${affiliates.status} = 'PAID_OUT' then 1 else 0 end)`,
  })
  .from(affiliates);
---

<AdminLayout title="Kelola Affiliate - Admin" activePage="affiliates">
  <h1 class="text-2xl font-bold mb-8">Kelola Affiliate</h1>

  {/* Stats */}
  <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-8">
    <div class="bg-surface border border-border rounded-xl p-5">
      <p class="text-sm text-text-muted mb-1">Total Komisi</p>
      <p class="text-xl font-bold">{formatIDR(stats?.totalCommission || 0)}</p>
    </div>
    <div class="bg-surface border border-border rounded-xl p-5">
      <p class="text-sm text-text-muted mb-1">Pending</p>
      <p class="text-xl font-bold text-warning">{stats?.pendingCount || 0}</p>
    </div>
    <div class="bg-surface border border-border rounded-xl p-5">
      <p class="text-sm text-text-muted mb-1">Available</p>
      <p class="text-xl font-bold text-info">{stats?.availableCount || 0}</p>
    </div>
    <div class="bg-surface border border-border rounded-xl p-5">
      <p class="text-sm text-text-muted mb-1">Sudah Dibayar</p>
      <p class="text-xl font-bold text-success">{stats?.paidCount || 0}</p>
    </div>
  </div>

  <div class="bg-surface border border-border rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Affiliate</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Order</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Produk</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Komisi</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Status</th>
            <th class="text-left px-6 py-3 text-xs font-medium text-text-muted uppercase">Tanggal</th>
          </tr>
        </thead>
        <tbody>
          {allAffiliates.map(aff => (
            <tr class="border-b border-border hover:bg-background/50 transition-colors">
              <td class="px-6 py-4 text-sm">
                <p class="font-medium">{aff.referrerName}</p>
                <p class="text-xs text-text-muted">{aff.referrerEmail}</p>
              </td>
              <td class="px-6 py-4 text-sm font-mono">{aff.orderRef.slice(0, 15)}...</td>
              <td class="px-6 py-4 text-sm">{aff.productTitle}</td>
              <td class="px-6 py-4 text-sm font-medium text-success">{formatIDR(aff.commissionAmount)}</td>
              <td class="px-6 py-4">
                <span class:list={[
                  "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium",
                  aff.status === 'PAID_OUT' ? "bg-success/20 text-success" : 
                  aff.status === 'AVAILABLE' ? "bg-info/20 text-info" : 
                  aff.status === 'PENDING' ? "bg-warning/20 text-warning" :
                  "bg-danger/20 text-danger"
                ]}>
                  {aff.status}
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-text-muted">{timeAgo(aff.createdAt || new Date())}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    
    {allAffiliates.length === 0 && (
      <div class="text-center py-12 text-text-muted">
        Belum ada affiliate
      </div>
    )}
  </div>
</AdminLayout>
