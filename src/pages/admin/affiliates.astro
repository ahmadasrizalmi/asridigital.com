---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
---

<BaseLayout title="Kelola Affiliate - Admin Asri Digital">
  <div class="flex min-h-screen">
    <aside id="admin-sidebar" class="w-64 bg-surface border-r border-border shrink-0 fixed inset-y-0 left-0 z-40 -translate-x-full transition-transform duration-300 lg:static lg:translate-x-0">
      <div class="sticky top-0 h-screen overflow-y-auto p-4">
        <a href="/admin" class="flex items-center gap-2.5 mb-8 px-2">
          <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
            <Icon name="sparkles" size={18} class="text-white" />
          </div>
          <div>
            <span class="font-bold text-text-primary block">Asri Digital</span>
            <span class="text-xs text-text-muted">Admin Panel</span>
          </div>
        </a>
        
        <nav class="space-y-1">
          {[
            { icon: 'bar-chart', label: 'Dashboard', href: '/admin' },
            { icon: 'sparkles', label: 'Produk', href: '/admin/products' },
            { icon: 'shopping-cart', label: 'Pesanan', href: '/admin/orders' },
            { icon: 'tag', label: 'Kupon', href: '/admin/coupons' },
            { icon: 'link', label: 'Affiliate', href: '/admin/affiliates', active: true },
            { icon: 'file-text', label: 'Blog', href: '/admin/blog' },
            { icon: 'settings', label: 'Pengaturan', href: '/admin/settings' },
          ].map((link) => (
            <a
              href={link.href}
              class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${
                link.active
                  ? 'bg-primary/10 text-primary'
                  : 'text-text-secondary hover:text-text-primary hover:bg-background'
              }`}
            >
              <Icon name={link.icon} size={18} />
              {link.label}
            </a>
          ))}
        </nav>
        
        <div class="mt-8 pt-4 border-t border-border">
          <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-background transition-colors">
            <Icon name="external-link" size={18} />
            Lihat Website
          </a>
        </div>
      </div>
    </aside>
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-30 hidden lg:hidden" onclick="document.getElementById('admin-sidebar').classList.add('-translate-x-full');this.classList.add('hidden')"></div>
    
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-4 sm:px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2 hover:bg-background rounded-lg">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Kelola Affiliate</h1>
          </div>
          
          <button onclick="openModal()" class="btn-primary">
            <Icon name="plus" size={18} />
            Tambah Affiliate
          </button>
        </div>
      </header>
      
      <div class="p-4 sm:p-6">
        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
          <div class="card p-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                <Icon name="users" size={20} class="text-blue-600" />
              </div>
              <div>
                <p class="text-sm text-text-muted">Total Affiliate</p>
                <p id="stat-affiliates" class="text-xl font-bold text-text-primary">3</p>
              </div>
            </div>
          </div>
          <div class="card p-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                <Icon name="dollar-sign" size={20} class="text-green-600" />
              </div>
              <div>
                <p class="text-sm text-text-muted">Total Komisi</p>
                <p id="stat-commission" class="text-xl font-bold text-text-primary">Rp 0</p>
              </div>
            </div>
          </div>
          <div class="card p-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center">
                <Icon name="link" size={20} class="text-amber-600" />
              </div>
              <div>
                <p class="text-sm text-text-muted">Total Referral</p>
                <p id="stat-referrals" class="text-xl font-bold text-text-primary">12</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Affiliates Table -->
        <div class="card">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border bg-background">
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Affiliate</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Kode</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Komisi (%)</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Total Referral</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Total Komisi</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Aksi</th>
                </tr>
              </thead>
              <tbody id="affiliates-table" class="divide-y divide-border">
                <tr><td colspan="7" class="px-6 py-12 text-center text-text-muted">Memuat data affiliate...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Add Affiliate Modal -->
  <div id="affiliate-modal" class="fixed inset-0 bg-black/50 z-50 hidden">
    <div class="flex items-center justify-center min-h-screen p-4">
      <div class="bg-surface rounded-xl max-w-lg w-full">
        <div class="p-6 border-b border-border">
          <div class="flex items-center justify-between">
            <h2 class="text-xl font-bold text-text-primary">Tambah Affiliate</h2>
            <button onclick="closeModal()" class="p-2 hover:bg-background rounded-lg">
              <Icon name="x" size={20} class="text-text-secondary" />
            </button>
          </div>
        </div>
        
        <form id="affiliate-form" class="p-6 space-y-4">
          <div>
            <label class="block text-sm font-medium text-text-main mb-2">Pilih User</label>
            <select class="input" id="affiliate-user">
              <option value="">Pilih user...</option>
              <!-- Will be populated from API -->
            </select>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-text-main mb-2">Kode Affiliate</label>
            <input type="text" class="input" id="affiliate-code" placeholder="Contoh: AHMAD20" />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-text-main mb-2">Komisi (%)</label>
            <input type="number" class="input" id="affiliate-commission" value="15" min="5" max="50" />
          </div>
          
          <div class="flex justify-end gap-3 pt-4 border-t border-border">
            <button type="button" onclick="closeModal()" class="btn-tertiary">Batal</button>
            <button type="submit" class="btn-primary">Simpan</button>
          </div>
        </form>
      </div>
    </div>
  </div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('mobile-menu-btn');
    const sidebar = document.getElementById('admin-sidebar');
    if (toggle && sidebar) {
      toggle.addEventListener('click', () => {
        sidebar.classList.toggle('-translate-x-full');
        const overlay = document.getElementById('sidebar-overlay');
        if (overlay) overlay.classList.toggle('hidden');
      });
    }
  });
</script>

</BaseLayout>

<script>
  const API_BASE = '/api';

  function getAdminToken(): string | null {
    return localStorage.getItem('admin_token');
  }

  function formatIDR(amount: number): string {
    return new Intl.NumberFormat('id-ID', {
      style: 'currency',
      currency: 'IDR',
      minimumFractionDigits: 0
    }).format(amount);
  }

  function openModal() {
    document.getElementById('affiliate-modal')!.classList.remove('hidden');
  }
  (window as any).openModal = openModal;

  function closeModal() {
    document.getElementById('affiliate-modal')!.classList.add('hidden');
  }
  (window as any).closeModal = closeModal;

  async function copyReferralCode(code: string) {
    try {
      await navigator.clipboard.writeText(code);
      alert(`Kode referral "${code}" berhasil disalin!`);
    } catch {
      // Fallback for older browsers
      const textarea = document.createElement('textarea');
      textarea.value = code;
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
      alert(`Kode referral "${code}" berhasil disalin!`);
    }
  }
  (window as any).copyReferralCode = copyReferralCode;

  function viewAffiliateDetails(affiliate: any) {
    const details = [
      `Nama: ${affiliate.name || '-'}`,
      `Email: ${affiliate.email || '-'}`,
      `Kode Referral: ${affiliate.code || '-'}`,
      `Komisi: ${affiliate.commission || 0}%`,
      `Total Referral: ${affiliate.totalReferrals || 0}`,
      `Total Komisi: ${formatIDR(affiliate.totalCommission || 0)}`,
      `Status: ${affiliate.status || '-'}`,
    ].join('\n');
    alert(details);
  }
  (window as any).viewAffiliateDetails = viewAffiliateDetails;

  let allAffiliates: any[] = [];

  async function loadAffiliates() {
    const table = document.getElementById('affiliates-table')!;
    const token = getAdminToken();
    if (!token) {
      window.location.href = '/admin/login';
      return;
    }

    try {
      // Try fetching admin stats for any affiliate-related data
      const res = await fetch(`${API_BASE}/admin/stats`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });

      if (res.status === 401 || res.status === 403) {
        localStorage.removeItem('admin_token');
        window.location.href = '/admin/login';
        return;
      }

      if (!res.ok) throw new Error('Failed to fetch admin stats');
      const data = await res.json() as any;

      // Extract affiliate data from stats if available
      const affiliates = data.affiliates || data.stats?.affiliates || [];
      allAffiliates = Array.isArray(affiliates) ? affiliates : [];

      // Update summary stats
      const totalAffiliates = allAffiliates.length;
      const totalCommission = allAffiliates.reduce((sum: number, a: any) => sum + (a.totalCommission || a.total_commission || 0), 0);
      const totalReferrals = allAffiliates.reduce((sum: number, a: any) => sum + (a.totalReferrals || a.total_referrals || 0), 0);

      const statAffEl = document.getElementById('stat-affiliates');
      const statCommEl = document.getElementById('stat-commission');
      const statRefEl = document.getElementById('stat-referrals');

      if (statAffEl) statAffEl.textContent = totalAffiliates.toString();
      if (statCommEl) statCommEl.textContent = formatIDR(totalCommission);
      if (statRefEl) statRefEl.textContent = totalReferrals.toString();

      renderAffiliateTable();
    } catch (error) {
      console.error('Error loading affiliates:', error);
      table.innerHTML = `<tr><td colspan="7" class="px-6 py-12 text-center text-red-500">Gagal memuat data affiliate.</td></tr>`;
    }
  }

  function renderAffiliateTable() {
    const table = document.getElementById('affiliates-table')!;

    if (allAffiliates.length === 0) {
      table.innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center gap-2">
              <p class="text-text-muted text-sm">Belum ada affiliate terdaftar.</p>
              <p class="text-text-muted text-xs">Klik "Tambah Affiliate" untuk menambahkan affiliate baru.</p>
            </div>
          </td>
        </tr>`;
      return;
    }

    table.innerHTML = allAffiliates.map((a: any) => {
      const name = a.name || a.user_name || '-';
      const email = a.email || a.user_email || '-';
      const code = a.code || a.referral_code || '-';
      const commission = a.commission || a.commission_rate || 0;
      const referrals = a.totalReferrals || a.total_referrals || 0;
      const totalComm = a.totalCommission || a.total_commission || 0;
      const status = a.status || 'active';
      const isActive = status === 'active' || status === 'Aktif' || a.is_active;
      const badge = isActive
        ? '<span class="badge-success">Aktif</span>'
        : '<span class="badge-warning">Pending</span>';

      // Encode affiliate data for the view button
      const affJson = JSON.stringify(a).replace(/"/g, '&quot;').replace(/'/g, '&#39;');

      return `
        <tr class="hover:bg-background/50">
          <td class="px-6 py-4">
            <div>
              <p class="font-medium text-text-primary">${name}</p>
              <p class="text-xs text-text-muted">${email}</p>
            </div>
          </td>
          <td class="px-6 py-4">
            <span class="font-mono text-sm bg-primary/10 text-primary px-2 py-1 rounded">${code}</span>
          </td>
          <td class="px-6 py-4 font-medium text-text-primary">${commission}%</td>
          <td class="px-6 py-4 text-text-main">${referrals}</td>
          <td class="px-6 py-4 font-medium text-green-600">${formatIDR(totalComm)}</td>
          <td class="px-6 py-4">${badge}</td>
          <td class="px-6 py-4">
            <div class="flex items-center gap-2">
              <button onclick="copyReferralCode('${code}')" class="p-2.5 hover:bg-background rounded-lg text-text-secondary hover:text-primary" title="Salin kode">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
              </button>
              <button onclick='viewAffiliateDetails(${affJson})' class="p-2.5 hover:bg-background rounded-lg text-text-secondary hover:text-primary" title="Lihat detail">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </td>
        </tr>`;
    }).join('');
  }

  // Form submit handler
  document.getElementById('affiliate-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const userSelect = document.getElementById('affiliate-user') as HTMLSelectElement;
    const codeInput = document.getElementById('affiliate-code') as HTMLInputElement;
    const commissionInput = document.getElementById('affiliate-commission') as HTMLInputElement;

    const userId = userSelect?.value;
    const code = codeInput?.value?.trim();
    const commission = commissionInput?.value;

    if (!userId || !code) {
      alert('Harap isi semua field yang diperlukan.');
      return;
    }

    const token = getAdminToken();
    if (!token) {
      window.location.href = '/admin/login';
      return;
    }

    try {
      // Try to create affiliate via API
      const res = await fetch(`${API_BASE}/admin/affiliates`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ userId, code: code.toUpperCase(), commission: Number(commission) })
      });

      if (res.ok) {
        alert('Affiliate berhasil ditambahkan!');
        closeModal();
        loadAffiliates();
      } else if (res.status === 404) {
        alert('Endpoint belum tersedia. Fitur tambah affiliate akan segera hadir.');
        closeModal();
      } else {
        const data = await res.json() as any;
        alert(data.error || 'Gagal menambahkan affiliate.');
      }
    } catch (error) {
      alert('Fitur tambah affiliate belum tersedia. Silakan hubungi developer.');
      closeModal();
    }
  });

  // Load on page ready
  const existingToken = getAdminToken();
  if (existingToken) {
    // Expose to global scope for onclick handlers
    (window as any).openModal = openModal;
    (window as any).closeModal = closeModal;
    (window as any).copyReferralCode = copyReferralCode;
    (window as any).viewAffiliateDetails = viewAffiliateDetails;

    loadAffiliates();
  } else {
    window.location.href = '/admin/login';
  }
</script>
