---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/ui/Icon.astro';
import { formatIDR } from '../../lib/utils';

const affiliates = [
  { id: 'aff-1', name: 'Ahmad', email: 'ahmad@gmail.com', code: 'AHMAD10', clicks: 1250, conversions: 45, earnings: 1345000, status: 'active' },
  { id: 'aff-2', name: 'Budi', email: 'budi@yahoo.com', code: 'BUDI10', clicks: 890, conversions: 32, earnings: 958000, status: 'active' },
  { id: 'aff-3', name: 'Citra', email: 'citra@outlook.com', code: 'CITRA10', clicks: 560, conversions: 18, earnings: 538000, status: 'active' },
  { id: 'aff-4', name: 'Dewi', email: 'dewi@gmail.com', code: 'DEWI10', clicks: 230, conversions: 8, earnings: 239000, status: 'pending' },
];

const sidebarLinks = [
  { icon: 'bar-chart', label: 'Dashboard', href: '/admin', active: false },
  { icon: 'sparkles', label: 'Produk', href: '/admin/products', active: false },
  { icon: 'shopping-cart', label: 'Pesanan', href: '/admin/orders', active: false },
  { icon: 'users', label: 'Pengguna', href: '/admin/users', active: false },
  { icon: 'tag', label: 'Kupon', href: '/admin/coupons', active: false },
  { icon: 'link', label: 'Affiliate', href: '/admin/affiliates', active: true },
  { icon: 'file-text', label: 'Blog', href: '/admin/blog', active: false },
  { icon: 'settings', label: 'Pengaturan', href: '/admin/settings', active: false },
];
---

<BaseLayout title="Affiliate - Admin">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-surface border-r border-border shrink-0 hidden lg:block">
      <div class="sticky top-0 h-screen overflow-y-auto p-4">
        <a href="/admin" class="flex items-center gap-2.5 mb-8 px-2">
          <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
            <Icon name="sparkles" size={18} class="text-white" />
          </div>
          <div>
            <span class="font-bold text-text-primary block">Asri Digital</span>
            <span class="text-xs text-text-muted">Admin Panel</span>
          </div>
        </a>
        
        <nav class="space-y-1">
          {sidebarLinks.map((link) => (
            <a href={link.href} class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${link.active ? 'bg-primary/10 text-primary' : 'text-text-secondary hover:text-text-primary hover:bg-background'}`}>
              <Icon name={link.icon} size={18} />
              {link.label}
            </a>
          ))}
        </nav>
        
        <div class="mt-8 pt-4 border-t border-border">
          <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-background transition-colors">
            <Icon name="external-link" size={18} />
            Lihat Website
          </a>
        </div>
      </div>
    </aside>
    
    <!-- Main Content -->
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button class="lg:hidden p-2 hover:bg-background rounded-lg">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Affiliate</h1>
          </div>
          <button class="btn-primary text-sm">
            <Icon name="plus" size={16} />
            Tambah Affiliate
          </button>
        </div>
      </header>
      
      <div class="p-6">
        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-6">
          <div class="card p-4">
            <p class="text-sm text-text-muted mb-1">Total Affiliate</p>
            <p class="text-2xl font-bold text-text-primary">{affiliates.length}</p>
          </div>
          <div class="card p-4">
            <p class="text-sm text-text-muted mb-1">Total Klik</p>
            <p class="text-2xl font-bold text-text-primary">{affiliates.reduce((a, b) => a + b.clicks, 0).toLocaleString()}</p>
          </div>
          <div class="card p-4">
            <p class="text-sm text-text-muted mb-1">Total Konversi</p>
            <p class="text-2xl font-bold text-text-primary">{affiliates.reduce((a, b) => a + b.conversions, 0)}</p>
          </div>
          <div class="card p-4">
            <p class="text-sm text-text-muted mb-1">Total Komisi</p>
            <p class="text-2xl font-bold text-primary">{formatIDR(affiliates.reduce((a, b) => a + b.earnings, 0))}</p>
          </div>
        </div>
        
        <!-- Affiliates Table -->
        <div class="card overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border bg-background">
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Affiliate</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Kode</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Klik</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Konversi</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Komisi</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-text-muted uppercase">Status</th>
                  <th class="px-4 py-3 text-right text-xs font-medium text-text-muted uppercase">Aksi</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-border">
                {affiliates.map((aff) => (
                  <tr>
                    <td class="px-4 py-4">
                      <div>
                        <div class="font-medium text-text-primary">{aff.name}</div>
                        <div class="text-xs text-text-muted">{aff.email}</div>
                      </div>
                    </td>
                    <td class="px-4 py-4">
                      <span class="font-mono text-primary bg-primary/10 px-2 py-1 rounded text-sm">{aff.code}</span>
                    </td>
                    <td class="px-4 py-4 text-text-main">{aff.clicks.toLocaleString()}</td>
                    <td class="px-4 py-4 text-text-main">{aff.conversions}</td>
                    <td class="px-4 py-4 font-medium text-primary">{formatIDR(aff.earnings)}</td>
                    <td class="px-4 py-4">
                      <span class={aff.status === 'active' ? 'badge-success' : 'badge-warning'}>
                        {aff.status === 'active' ? 'Aktif' : 'Pending'}
                      </span>
                    </td>
                    <td class="px-4 py-4 text-right">
                      <div class="flex items-center justify-end gap-2">
                        <button class="p-2 hover:bg-background rounded-lg text-text-secondary hover:text-text-primary">
                          <Icon name="eye" size={16} />
                        </button>
                        <button class="p-2 hover:bg-background rounded-lg text-text-secondary hover:text-text-primary">
                          <Icon name="edit" size={16} />
                        </button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>
