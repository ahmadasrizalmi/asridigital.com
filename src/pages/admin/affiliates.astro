---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdminSidebar from '../../components/layout/AdminSidebar.astro';
import Icon from '../../components/ui/Icon.astro';
---

<BaseLayout title="Kelola Affiliate - Admin Asri Digital">
  <div class="flex min-h-screen">
    <AdminSidebar activePage="affiliates" />
    
    <main class="flex-1 bg-background">
      <header class="bg-surface border-b border-border px-4 md:px-6 py-4 sticky top-0 z-10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2 hover:bg-background rounded-lg mr-2" onclick="window.__openSidebar?.()">
              <Icon name="menu" size={24} class="text-text-secondary" />
            </button>
            <h1 class="text-xl font-bold text-text-primary">Kelola Affiliate</h1>
          </div>
          
          <button onclick="openModal()" class="btn-primary">
            <Icon name="plus" size={18} />
            <span class="hidden md:inline">Tambah Affiliate</span>
          </button>
        </div>
      </header>
      
      <div class="p-4 md:p-6">
        <!-- Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
          <div class="card p-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                <Icon name="users" size={20} class="text-blue-600" />
              </div>
              <div>
                <p class="text-sm text-text-muted">Total Affiliate</p>
                <p id="stat-affiliates" class="text-xl font-bold text-text-primary">-</p>
              </div>
            </div>
          </div>
          <div class="card p-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                <Icon name="dollar-sign" size={20} class="text-green-600" />
              </div>
              <div>
                <p class="text-sm text-text-muted">Total Komisi</p>
                <p id="stat-commission" class="text-xl font-bold text-text-primary">-</p>
              </div>
            </div>
          </div>
          <div class="card p-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center">
                <Icon name="link" size={20} class="text-amber-600" />
              </div>
              <div>
                <p class="text-sm text-text-muted">Total Transaksi</p>
                <p id="stat-transactions" class="text-xl font-bold text-text-primary">-</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Affiliates Table -->
        <div class="card">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border bg-background">
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Affiliate</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase hidden md:table-cell">Kode</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase hidden md:table-cell">Komisi (%)</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase hidden md:table-cell">Total Referral</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Total Komisi</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase hidden md:table-cell">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase">Aksi</th>
                </tr>
              </thead>
              <tbody id="affiliates-table" class="divide-y divide-border">
                <tr><td colspan="7" class="px-6 py-12 text-center text-text-muted">Memuat data affiliate...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Add Affiliate Modal -->
  <div id="affiliate-modal" class="fixed inset-0 bg-black/50 z-50 hidden">
    <div class="flex items-center justify-center min-h-screen p-4">
      <div class="bg-surface rounded-xl max-w-lg w-full max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-border">
          <div class="flex items-center justify-between">
            <h2 class="text-xl font-bold text-text-primary">Tambah Affiliate</h2>
            <button onclick="closeModal()" class="p-2 hover:bg-background rounded-lg">
              <Icon name="x" size={20} class="text-text-secondary" />
            </button>
          </div>
        </div>
        
        <form id="affiliate-form" class="p-6 space-y-4">
          <div>
            <label class="block text-sm font-medium text-text-main mb-2">Pilih User</label>
            <select class="input" id="affiliate-user" required>
              <option value="">Memuat daftar user...</option>
            </select>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-text-main mb-2">Komisi (%)</label>
            <input type="number" class="input" id="affiliate-commission" value="15" min="1" max="100" required />
          </div>
          
          <div class="flex justify-end gap-3 pt-4 border-t border-border">
            <button type="button" onclick="closeModal()" class="btn-tertiary">Batal</button>
            <button type="submit" class="btn-primary">Simpan</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="delete-modal" class="fixed inset-0 bg-black/50 z-50 hidden">
    <div class="flex items-center justify-center min-h-screen p-4">
      <div class="bg-surface rounded-xl max-w-md w-full p-6">
        <h2 class="text-xl font-bold text-text-primary mb-2">Hapus Affiliate?</h2>
        <p class="text-text-secondary mb-1">Anda yakin ingin menghapus affiliate <strong id="delete-affiliate-name"></strong>?</p>
        <p class="text-sm text-text-muted mb-6">Tindakan ini tidak dapat dibatalkan.</p>
        <div class="flex justify-end gap-3">
          <button onclick="closeDeleteModal()" class="btn-tertiary">Batal</button>
          <button id="confirm-delete-btn" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 font-medium">Hapus</button>
        </div>
      </div>
    </div>
  </div>


</BaseLayout>

<script is:inline src="/js/admin-utils.js?v=2"></script>
<script>
  const API_BASE = '/api';

  function getAdminToken(): string | null {
    return localStorage.getItem('admin_token');
  }

  function authHeaders(): Record<string, string> {
    const token = getAdminToken();
    return token ? { 'Authorization': `Bearer ${token}` } : {};
  }

  // --- Modal management ---
  function openModal() {
    document.getElementById('affiliate-modal')!.classList.remove('hidden');
    loadUsers();
  }
  (window as any).openModal = openModal;

  function closeModal() {
    document.getElementById('affiliate-modal')!.classList.add('hidden');
    const form = document.getElementById('affiliate-form') as HTMLFormElement;
    form?.reset();
    (document.getElementById('affiliate-commission') as HTMLInputElement)!.value = '15';
  }
  (window as any).closeModal = closeModal;

  function openDeleteModal(userId: number, name: string) {
    document.getElementById('delete-affiliate-name')!.textContent = name;
    document.getElementById('delete-modal')!.classList.remove('hidden');
    const confirmBtn = document.getElementById('confirm-delete-btn')!;
    const newBtn = confirmBtn.cloneNode(true) as HTMLElement;
    newBtn.addEventListener('click', () => deleteAffiliate(userId));
    confirmBtn.parentNode!.replaceChild(newBtn, confirmBtn);
  }
  (window as any).openDeleteModal = openDeleteModal;

  function closeDeleteModal() {
    document.getElementById('delete-modal')!.classList.add('hidden');
  }
  (window as any).closeDeleteModal = closeDeleteModal;

  // --- Copy referral code ---
  async function copyReferralCode(code: string) {
    try {
      await navigator.clipboard.writeText(code);
    } catch {
      const textarea = document.createElement('textarea');
      textarea.value = code;
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
    }
    showToast(`Kode referral "${code}" berhasil disalin!`);
  }
  (window as any).copyReferralCode = copyReferralCode;

  let allAffiliates: any[] = [];

  // --- Load affiliates from API ---
  async function loadAffiliates() {
    const table = document.getElementById('affiliates-table')!;
    try {
      const res = await adminFetch(`${API_BASE}/admin/affiliates`);
      if (res.status === 401 || res.status === 403) return;
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json() as any;

      allAffiliates = data.affiliates || [];
      const stats = data.stats || {};

      // Update stats from API response
      const statAffEl = document.getElementById('stat-affiliates');
      const statCommEl = document.getElementById('stat-commission');
      const statTransEl = document.getElementById('stat-transactions');

      if (statAffEl) statAffEl.textContent = (stats.total_affiliates ?? allAffiliates.length).toString();
      if (statCommEl) statCommEl.textContent = formatIDR(stats.total_commission ?? 0);
      if (statTransEl) statTransEl.textContent = (stats.total_transactions ?? 0).toString();

      renderAffiliateTable();
    } catch (error) {
      table.innerHTML = `<tr><td colspan="7" class="px-6 py-12 text-center text-red-500">Gagal memuat data affiliate.</td></tr>`;
    }
  }

  // --- Render affiliate table ---
  function renderAffiliateTable() {
    const table = document.getElementById('affiliates-table')!;

    if (allAffiliates.length === 0) {
      table.innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center gap-2">
              <p class="text-text-muted text-sm">Belum ada affiliate terdaftar.</p>
              <p class="text-text-muted text-xs">Klik "Tambah Affiliate" untuk menambahkan affiliate baru.</p>
            </div>
          </td>
        </tr>`;
      return;
    }

    table.innerHTML = allAffiliates.map((a: any) => {
      const name = a.user_name || a.name || '-';
      const email = a.user_email || a.email || '-';
      const code = a.referral_code || a.code || '-';
      const commission = a.commission_percent || a.commission || 0;
      const referrals = a.total_referrals ?? a.totalReferrals ?? 0;
      const totalComm = a.total_commission ?? a.totalCommission ?? 0;
      const userId = a.user_id || a.id;
      const isActive = a.is_active !== false;
      const badge = isActive
        ? '<span class="badge-success">Aktif</span>'
        : '<span class="badge-warning">Nonaktif</span>';

      const nameEsc = name.replace(/'/g, "\\'");

      return `
        <tr class="hover:bg-background/50">
          <td class="px-6 py-4">
            <div>
              <p class="font-medium text-text-primary">${name}</p>
              <p class="text-xs text-text-muted">${email}</p>
            </div>
          </td>
          <td class="px-6 py-4 hidden md:table-cell">
            <span class="font-mono text-sm bg-primary/10 text-primary px-2 py-1 rounded">${code}</span>
          </td>
          <td class="px-6 py-4 font-medium text-text-primary hidden md:table-cell">${commission}%</td>
          <td class="px-6 py-4 text-text-main hidden md:table-cell">${referrals}</td>
          <td class="px-6 py-4 font-medium text-green-600">${formatIDR(totalComm)}</td>
          <td class="px-6 py-4 hidden md:table-cell">${badge}</td>
          <td class="px-6 py-4">
            <div class="hidden md:flex items-center gap-2">
              <button onclick="copyReferralCode('${code}')" class="p-2.5 hover:bg-background rounded-lg text-text-secondary hover:text-primary" title="Salin kode">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
              </button>
              <button onclick="openDeleteModal(${userId}, '${nameEsc}')" class="p-2.5 hover:bg-background rounded-lg text-text-secondary hover:text-red-600" title="Hapus affiliate">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
              </button>
            </div>
            <div class="action-menu md:hidden">
              <button class="action-menu-btn p-2 hover:bg-background rounded-lg text-text-secondary" onclick="toggleActionMenu(event)"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg></button>
              <div class="action-dropdown">
                <button class="action-dropdown-item" onclick="copyReferralCode('${code}')">Salin Kode</button>
                <button class="action-dropdown-item text-red-600" onclick="openDeleteModal(${userId}, '${nameEsc}')">Hapus</button>
              </div>
            </div>
          </td>
        </tr>`;
    }).join('');
  }

  // --- Load users for dropdown ---
  async function loadUsers() {
    const select = document.getElementById('affiliate-user') as HTMLSelectElement;
    if (!select) return;

    select.innerHTML = '<option value="">Memuat daftar user...</option>';

    try {
      const res = await adminFetch(`${API_BASE}/admin/users`);
      if (res.status === 401 || res.status === 403) return;
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json() as any;
      const users: any[] = data.users || [];

      // Filter out users who are already affiliates
      const affiliateUserIds = new Set(allAffiliates.map((a: any) => a.user_id));
      const availableUsers = users.filter((u: any) => !affiliateUserIds.has(u.id));

      select.innerHTML = '<option value="">Pilih user...</option>';
      availableUsers.forEach((user: any) => {
        const option = document.createElement('option');
        option.value = user.id;
        option.textContent = `${user.name || user.email || 'User #' + user.id} (${user.email || '-'})`;
        select.appendChild(option);
      });

      if (availableUsers.length === 0) {
        select.innerHTML = '<option value="">Semua user sudah menjadi affiliate</option>';
      }
    } catch (error) {
      select.innerHTML = '<option value="">Gagal memuat daftar user</option>';
    }
  }

  // --- Delete affiliate ---
  async function deleteAffiliate(userId: number) {
    try {
      const res = await adminFetch(`${API_BASE}/admin/affiliates/${userId}`, {
        method: 'DELETE',
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({})) as any;
        throw new Error(data.error || `HTTP ${res.status}`);
      }

      closeDeleteModal();
      showToast('Affiliate berhasil dihapus!');
      loadAffiliates();
    } catch (error: any) {
      showToast(error.message || 'Gagal menghapus affiliate.', 'error');
    }
  }

  // --- Form submit handler ---
  document.getElementById('affiliate-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const userSelect = document.getElementById('affiliate-user') as HTMLSelectElement;
    const commissionInput = document.getElementById('affiliate-commission') as HTMLInputElement;

    const userId = userSelect?.value;
    const commission = commissionInput?.value;

    if (!userId) {
      showToast('Harap pilih user.', 'error');
      return;
    }
    try {
      const res = await adminFetch(`${API_BASE}/admin/affiliates`, {
        method: 'POST',
        body: JSON.stringify({
          user_id: Number(userId),
          commission_percent: Number(commission)
        })
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({})) as any;
        throw new Error(data.error || `HTTP ${res.status}`);
      }

      showToast('Affiliate berhasil ditambahkan!');
      closeModal();
      loadAffiliates();
    } catch (error: any) {
      showToast(error.message || 'Gagal menambahkan affiliate.', 'error');
    }
  });

  // --- Init ---
  const existingToken = getAdminToken();
  if (existingToken) {
    loadAffiliates();
  } else {
    window.location.href = '/admin/login';
  }
</script>
