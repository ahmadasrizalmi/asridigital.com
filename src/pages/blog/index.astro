---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Icon from '../../components/ui/Icon.astro';
---

<BaseLayout title="Blog - Asri Digital">
  <Header />
  
  <main class="flex-1 py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 rounded-full mb-4">
          <Icon name="file-text" size={16} class="text-primary" />
          <span class="text-sm text-primary font-medium">Blog</span>
        </div>
        <h1 class="text-4xl font-extrabold mb-4">
          Tips & <span class="text-gradient">Insight</span>
        </h1>
        <p class="text-text-secondary text-lg">
          Artikel seputar AI, productivity, dan digital marketing.
        </p>
      </div>
      
      <!-- Blog posts will be loaded here -->
      <div class="space-y-8">
        <article class="card-hover p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="badge-primary">AI</span>
            <span class="text-sm text-text-muted">17 Mei 2026</span>
          </div>
          <h2 class="text-2xl font-bold mb-3 hover:text-primary transition-colors">
            <a href="#">Cara Memaksimalkan Custom GPT untuk Bisnis</a>
          </h2>
          <p class="text-text-secondary mb-4">
            Pelajari bagaimana Custom GPT dapat meningkatkan produktivitas bisnis Anda hingga 10x lipat...
          </p>
          <a href="#" class="inline-flex items-center gap-2 text-primary font-medium hover:gap-3 transition-all">
            Baca selengkapnya <Icon name="arrow-right" size={16} />
          </a>
        </article>
        
        <article class="card-hover p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="badge-accent">Productivity</span>
            <span class="text-sm text-text-muted">15 Mei 2026</span>
          </div>
          <h2 class="text-2xl font-bold mb-3 hover:text-primary transition-colors">
            <a href="#">5 Tips Menggunakan AI untuk Content Creation</a>
          </h2>
          <p class="text-text-secondary mb-4">
            Content creation bisa lebih mudah dengan bantuan AI. Berikut 5 tips yang bisa Anda terapkan...
          </p>
          <a href="#" class="inline-flex items-center gap-2 text-primary font-medium hover:gap-3 transition-all">
            Baca selengkapnya <Icon name="arrow-right" size={16} />
          </a>
        </article>
      </div>
    </div>
  </main>
  
  <Footer />
</BaseLayout>
