---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Icon from '../../components/ui/Icon.astro';

const blogPosts = [
  {
    category: 'AI',
    categoryColor: 'badge-primary',
    date: '17 Mei 2026',
    title: 'Cara Memaksimalkan Custom GPT untuk Bisnis',
    excerpt: 'Pelajari bagaimana Custom GPT dapat meningkatkan produktivitas bisnis Anda hingga 10x lipat...',
    slug: '#',
  },
  {
    category: 'Productivity',
    categoryColor: 'badge-warning',
    date: '15 Mei 2026',
    title: '5 Tips Menggunakan AI untuk Content Creation',
    excerpt: 'Content creation bisa lebih mudah dengan bantuan AI. Berikut 5 tips yang bisa Anda terapkan...',
    slug: '#',
  },
  {
    category: 'Tutorial',
    categoryColor: 'badge-success',
    date: '12 Mei 2026',
    title: 'Panduan Lengkap Menggunakan All-Access Pass',
    excerpt: 'Dapatkan manfaat maksimal dari All-Access Pass dengan panduan lengkap ini...',
    slug: '#',
  },
];
---

<BaseLayout title="Blog - Asri Digital">
  <Header />
  
  <main class="flex-1 py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 rounded-full mb-4">
          <Icon name="file-text" size={16} class="text-primary" />
          <span class="text-sm text-primary font-medium">Blog</span>
        </div>
        <h1 class="text-4xl font-extrabold mb-4 text-text-primary">
          Tips & <span class="text-primary">Insight</span>
        </h1>
        <p class="text-text-secondary text-lg">
          Artikel seputar AI, productivity, dan digital marketing.
        </p>
      </div>
      
      <!-- Blog posts -->
      <div class="space-y-8">
        {blogPosts.map((post) => (
          <article class="card-hover p-6">
            <div class="flex items-center gap-3 mb-4">
              <span class={post.categoryColor}>{post.category}</span>
              <span class="text-sm text-text-muted">{post.date}</span>
            </div>
            <h2 class="text-2xl font-bold mb-3 text-text-primary hover:text-primary transition-colors">
              <a href={post.slug}>{post.title}</a>
            </h2>
            <p class="text-text-secondary mb-4">
              {post.excerpt}
            </p>
            <a href={post.slug} class="inline-flex items-center gap-2 text-primary font-medium hover:gap-3 transition-all">
              Baca selengkapnya <Icon name="arrow-right" size={16} />
            </a>
          </article>
        ))}
      </div>
    </div>
  </main>
  
  <Footer />
</BaseLayout>
