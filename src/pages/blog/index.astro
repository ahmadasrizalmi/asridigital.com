---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDB } from '../../db';
import { blogPosts } from '../../db/schema';
import { eq, desc } from 'drizzle-orm';
import { calculateReadingTime, timeAgo, parseTags } from '../../lib/utils';

const env = Astro.locals?.runtime?.env || {};
const db = getDB(env);

const posts = await db.select().from(blogPosts)
  .where(eq(blogPosts.isPublished, true))
  .orderBy(desc(blogPosts.publishedAt))
  .limit(20);

const categories = ['Semua', 'Tutorial', 'AI Tools', 'Marketing', 'Update'];
---

<BaseLayout title="Blog - Asri Digital" description="Tips, tutorial, dan insight seputar AI & GPT">
  {/* Blog Header */}
  <section class="bg-gradient-to-br from-background via-surface to-background py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 border border-primary/20 rounded-full mb-6">
        <span>📝</span>
        <span class="text-sm text-primary">Blog Asri Digital</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Blog</h1>
      <p class="text-lg text-text-secondary max-w-2xl mx-auto mb-8">
        Tips, tutorial, dan insight seputar AI & GPT untuk meningkatkan produktivitas Anda
      </p>
      
      {/* Search */}
      <div class="max-w-lg mx-auto">
        <div class="relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input type="text" placeholder="Cari artikel..." 
            class="w-full pl-12 pr-4 py-3 bg-surface border border-border rounded-xl focus:border-primary outline-none transition-colors" />
        </div>
      </div>
    </div>
  </section>

  {/* Categories */}
  <section class="border-b border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 py-4 overflow-x-auto">
        {categories.map((cat, i) => (
          <button class:list={[
            "px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap transition-colors",
            i === 0 ? "bg-primary text-white" : "bg-surface text-text-secondary hover:bg-border"
          ]}>
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  {/* Posts Grid */}
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post, i) => {
            const readingTime = calculateReadingTime(post.content);
            const tags = parseTags(post.tags);
            
            return (
              <article class:list={["group", i === 0 ? "md:col-span-2 lg:col-span-3" : ""]}>
                <a href={`/blog/${post.slug}`} class="block">
                  {/* Cover Image */}
                  <div class:list={[
                    "rounded-xl overflow-hidden mb-4 bg-surface",
                    i === 0 ? "h-64 md:h-96" : "h-48"
                  ]}>
                    {post.coverImage ? (
                      <img src={post.coverImage} alt={post.title} 
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center">
                        <svg class="w-16 h-16 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                        </svg>
                      </div>
                    )}
                  </div>

                  {/* Meta */}
                  <div class="flex items-center gap-3 mb-2">
                    {post.category && (
                      <span class="px-2.5 py-0.5 bg-primary/10 text-primary text-xs rounded-full">{post.category}</span>
                    )}
                    <span class="text-xs text-text-muted">⏱️ {readingTime} menit baca</span>
                  </div>

                  {/* Title */}
                  <h2 class:list={[
                    "font-bold group-hover:text-primary transition-colors",
                    i === 0 ? "text-2xl md:text-3xl" : "text-lg"
                  ]}>
                    {post.title}
                  </h2>

                  {/* Excerpt */}
                  {post.excerpt && (
                    <p class="text-text-muted mt-2 line-clamp-2">{post.excerpt}</p>
                  )}

                  {/* Date */}
                  <p class="text-sm text-text-muted mt-3">
                    {post.publishedAt ? timeAgo(post.publishedAt) : ''}
                  </p>
                </a>
              </article>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-20">
          <svg class="w-20 h-20 mx-auto text-text-muted mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
          <h2 class="text-xl font-semibold mb-2">Blog Segera Hadir</h2>
          <p class="text-text-muted">Kami sedang menyiapkan konten berkualitas untuk Anda</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
