---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Icon from '../../components/ui/Icon.astro';

// Fetch blog posts from API at build time
const apiBase = 'https://asridigital.com';
let posts = [];
try {
  const res = await fetch(`${apiBase}/api/blog/posts`);
  const data = await res.json();
  posts = data.posts || [];
} catch (e) {
  console.error('Failed to fetch blog posts:', e);
}

// Category metadata
const categoryMeta: Record<string, { label: string; color: string; bgColor: string }> = {
  'tips': { label: 'Tips & Trik', color: 'bg-primary text-white', bgColor: 'from-primary/20 to-primary/5' },
  'tutorial': { label: 'Tutorial', color: 'bg-blue-500 text-white', bgColor: 'from-blue-100 to-blue-50' },
  'studi-kasus': { label: 'Studi Kasus', color: 'bg-amber-500 text-white', bgColor: 'from-amber-100 to-amber-50' },
  'berita': { label: 'Berita', color: 'bg-purple-500 text-white', bgColor: 'from-purple-100 to-purple-50' },
  'ai': { label: 'AI', color: 'bg-primary text-white', bgColor: 'from-primary/20 to-primary/5' },
  'productivity': { label: 'Productivity', color: 'bg-blue-500 text-white', bgColor: 'from-blue-100 to-blue-50' },
  'general': { label: 'Umum', color: 'bg-gray-500 text-white', bgColor: 'from-gray-100 to-gray-50' },
};

const iconNames = ['sparkles', 'code', 'video', 'lightbulb', 'rocket', 'star', 'zap'];
const iconColors = ['text-primary', 'text-blue-500', 'text-amber-500', 'text-purple-500', 'text-emerald-500', 'text-rose-500', 'text-cyan-500'];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}

function getCategoryMeta(category: string) {
  const key = category?.toLowerCase() || 'general';
  return categoryMeta[key] || categoryMeta['general'];
}
---

<BaseLayout title="Blog - Asri Digital">
  <Header />
  
  <main class="flex-1 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Hero Section -->
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-extrabold text-text-primary mb-4">
          Blog & Tips AI 📚
        </h1>
        <p class="text-lg text-text-secondary max-w-2xl mx-auto">
          Artikel, tutorial, dan tips tentang cara menggunakan Custom GPT untuk meningkatkan produktivitas dan bisnis Anda.
        </p>
      </div>
      
      <!-- Category Filter -->
      <div class="flex flex-wrap justify-center gap-2 mb-8">
        <button data-category="all" class="px-4 py-2 rounded-full text-sm font-medium bg-primary text-white">
          Semua
        </button>
        <button data-category="tips" class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-text-secondary hover:text-primary hover:border-primary">
          Tips & Trik
        </button>
        <button data-category="tutorial" class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-text-secondary hover:text-primary hover:border-primary">
          Tutorial
        </button>
        <button data-category="studi-kasus" class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-text-secondary hover:text-primary hover:border-primary">
          Studi Kasus
        </button>
        <button data-category="berita" class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-text-secondary hover:text-primary hover:border-primary">
          Berita
        </button>
      </div>
      
      <!-- Blog Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="blog-grid">
        {posts.map((post: any, index: number) => {
          const meta = getCategoryMeta(post.category);
          const icon = iconNames[index % iconNames.length];
          const iconColor = iconColors[index % iconColors.length];
          
          return (
            <article class="card-hover overflow-hidden group" data-category={post.category?.toLowerCase() || 'general'}>
              <div class="relative overflow-hidden">
                <div class={`w-full h-48 bg-gradient-to-br ${meta.bgColor} flex items-center justify-center`}>
                  <Icon name={icon} size={48} class={iconColor} />
                </div>
                <div class="absolute top-3 left-3">
                  <span class={`px-3 py-1 ${meta.color} text-xs font-medium rounded-full`}>
                    {meta.label}
                  </span>
                </div>
              </div>
              
              <div class="p-5">
                <div class="flex items-center gap-3 text-sm text-text-muted mb-3">
                  <span class="flex items-center gap-1">
                    <Icon name="user" size={14} />
                    {post.author_name || 'Admin'}
                  </span>
                  <span>•</span>
                  <span class="flex items-center gap-1">
                    <Icon name="calendar" size={14} />
                    {formatDate(post.published_at)}
                  </span>
                </div>
                
                <h2 class="text-lg font-semibold text-text-primary mb-2 group-hover:text-primary transition-colors line-clamp-2">
                  {post.title}
                </h2>
                
                <p class="text-sm text-text-secondary mb-4 line-clamp-3">
                  {post.excerpt}
                </p>
                
                <a href={`/blog/${post.slug}/`} class="text-primary hover:underline font-medium text-sm flex items-center gap-1">
                  Baca Selengkapnya
                  <Icon name="arrow-right" size={16} />
                </a>
              </div>
            </article>
          );
        })}
      </div>
      
      <!-- Load More (hidden when all posts shown) -->
      {posts.length > 9 && (
        <div class="text-center mt-12">
          <button id="load-more" class="btn-tertiary">
            <Icon name="refresh-cw" size={18} />
            Muat Lebih Banyak
          </button>
        </div>
      )}
    </div>
  </main>
  
  <Footer />
</BaseLayout>

<script>
  // Blog filtering by category
  const articles = document.querySelectorAll('article[data-category]');
  const buttons = document.querySelectorAll('.flex.flex-wrap button');
  
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = (btn as HTMLElement).getAttribute('data-category') || 'all';
      
      // Update active state
      buttons.forEach(b => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('bg-surface', 'border', 'border-border', 'text-text-secondary');
      });
      btn.classList.remove('bg-surface', 'border', 'border-border', 'text-text-secondary');
      btn.classList.add('bg-primary', 'text-white');
      
      // Filter articles
      articles.forEach(article => {
        if (category === 'all' || (article as HTMLElement).getAttribute('data-category') === category) {
          (article as HTMLElement).style.display = '';
        } else {
          (article as HTMLElement).style.display = 'none';
        }
      });
    });
  });

  // Load more button handler
  document.getElementById('load-more')?.addEventListener('click', () => {
    const btn = document.getElementById('load-more');
    if (btn) {
      btn.textContent = 'Semua artikel sudah ditampilkan';
      (btn as HTMLButtonElement).disabled = true;
      btn.classList.add('opacity-50', 'cursor-not-allowed');
    }
  });
</script>
