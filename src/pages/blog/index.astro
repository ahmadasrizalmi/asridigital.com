---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Icon from '../../components/ui/Icon.astro';
---

<BaseLayout title="Blog - Asri Digital">
  <Header />
  
  <main class="flex-1 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Hero Section -->
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-extrabold text-text-primary mb-4">
          Blog & Tips AI 📚
        </h1>
        <p class="text-lg text-text-secondary max-w-2xl mx-auto">
          Artikel, tutorial, dan tips tentang cara menggunakan Custom GPT untuk meningkatkan produktivitas dan bisnis Anda.
        </p>
      </div>
      
      <!-- Category Filter -->
      <div class="flex flex-wrap justify-center gap-2 mb-8">
        <button data-category="all" class="px-4 py-2 rounded-full text-sm font-medium bg-primary text-white">
          Semua
        </button>
        <button data-category="tips" class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-text-secondary hover:text-primary hover:border-primary">
          Tips & Trik
        </button>
        <button data-category="tutorial" class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-text-secondary hover:text-primary hover:border-primary">
          Tutorial
        </button>
        <button data-category="studi-kasus" class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-text-secondary hover:text-primary hover:border-primary">
          Studi Kasus
        </button>
        <button data-category="berita" class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-text-secondary hover:text-primary hover:border-primary">
          Berita
        </button>
      </div>
      
      <!-- Blog Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="blog-grid">
        <!-- Blog Post 1 -->
        <article class="card-hover overflow-hidden group">
          <div class="relative overflow-hidden">
            <div class="w-full h-48 bg-gradient-to-br from-primary/20 to-primary/5 flex items-center justify-center">
              <Icon name="sparkles" size={48} class="text-primary" />
            </div>
            <div class="absolute top-3 left-3">
              <span class="px-3 py-1 bg-primary text-white text-xs font-medium rounded-full">
                Tips & Trik
              </span>
            </div>
          </div>
          
          <div class="p-5">
            <div class="flex items-center gap-3 text-sm text-text-muted mb-3">
              <span class="flex items-center gap-1">
                <Icon name="user" size={14} />
                Admin
              </span>
              <span>•</span>
              <span class="flex items-center gap-1">
                <Icon name="calendar" size={14} />
                14 Mei 2026
              </span>
            </div>
            
            <h2 class="text-lg font-semibold text-text-primary mb-2 group-hover:text-primary transition-colors line-clamp-2">
              5 Cara Custom GPT Meningkatkan Produktivitas Bisnis Anda
            </h2>
            
            <p class="text-sm text-text-secondary mb-4 line-clamp-3">
              Custom GPT bukan hanya chatbot biasa. Dengan instruksi yang tepat, ia bisa menjadi asisten virtual yang memahami kebutuhan spesifik bisnis Anda.
            </p>
            
            <a href="/blog/custom-gpt-untuk-bisnis/" class="text-primary hover:underline font-medium text-sm flex items-center gap-1">
              Baca Selengkapnya
              <Icon name="arrow-right" size={16} />
            </a>
          </div>
        </article>
        
        <!-- Blog Post 2 -->
        <article class="card-hover overflow-hidden group">
          <div class="relative overflow-hidden">
            <div class="w-full h-48 bg-gradient-to-br from-blue-100 to-blue-50 flex items-center justify-center">
              <Icon name="code" size={48} class="text-blue-500" />
            </div>
            <div class="absolute top-3 left-3">
              <span class="px-3 py-1 bg-blue-500 text-white text-xs font-medium rounded-full">
                Tutorial
              </span>
            </div>
          </div>
          
          <div class="p-5">
            <div class="flex items-center gap-3 text-sm text-text-muted mb-3">
              <span class="flex items-center gap-1">
                <Icon name="user" size={14} />
                Admin
              </span>
              <span>•</span>
              <span class="flex items-center gap-1">
                <Icon name="calendar" size={14} />
                12 Mei 2026
              </span>
            </div>
            
            <h2 class="text-lg font-semibold text-text-primary mb-2 group-hover:text-primary transition-colors line-clamp-2">
              Panduan Lengkap Menggunakan ChatGPT untuk Pemula
            </h2>
            
            <p class="text-sm text-text-secondary mb-4 line-clamp-3">
              Baru menggunakan ChatGPT? Artikel ini akan membantu Anda memahami dasar-dasar dan cara memaksimalkan penggunaannya.
            </p>
            
            <a href="/blog/cara-menggunakan-chatgpt/" class="text-primary hover:underline font-medium text-sm flex items-center gap-1">
              Baca Selengkapnya
              <Icon name="arrow-right" size={16} />
            </a>
          </div>
        </article>
        
        <!-- Blog Post 3 -->
        <article class="card-hover overflow-hidden group">
          <div class="relative overflow-hidden">
            <div class="w-full h-48 bg-gradient-to-br from-amber-100 to-amber-50 flex items-center justify-center">
              <Icon name="video" size={48} class="text-amber-500" />
            </div>
            <div class="absolute top-3 left-3">
              <span class="px-3 py-1 bg-amber-500 text-white text-xs font-medium rounded-full">
                Studi Kasus
              </span>
            </div>
          </div>
          
          <div class="p-5">
            <div class="flex items-center gap-3 text-sm text-text-muted mb-3">
              <span class="flex items-center gap-1">
                <Icon name="user" size={14} />
                Admin
              </span>
              <span>•</span>
              <span class="flex items-center gap-1">
                <Icon name="calendar" size={14} />
                10 Mei 2026
              </span>
            </div>
            
            <h2 class="text-lg font-semibold text-text-primary mb-2 group-hover:text-primary transition-colors line-clamp-2">
              Case Study: Membuat Konten YouTube 10x Lebih Cepat dengan AI
            </h2>
            
            <p class="text-sm text-text-secondary mb-4 line-clamp-3">
              Lihat bagaimana seorang content creator bisa menghasilkan 30 video per bulan menggunakan bantuan Custom GPT.
            </p>
            
            <a href="#" class="text-primary hover:underline font-medium text-sm flex items-center gap-1">
              Baca Selengkapnya
              <Icon name="arrow-right" size={16} />
            </a>
          </div>
        </article>
      </div>
      
      <!-- Load More -->
      <div class="text-center mt-12">
        <button id="load-more" class="btn-tertiary">
          <Icon name="refresh-cw" size={18} />
          Muat Lebih Banyak
        </button>
      </div>
    </div>
  </main>
  
  <Footer />
</BaseLayout>

<script>
  // Blog filtering by category
  const articles = document.querySelectorAll('article[data-category]');
  const buttons = document.querySelectorAll('.flex.flex-wrap button');
  
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category') || 'all';
      
      // Update active state
      buttons.forEach(b => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('bg-surface', 'border', 'border-border', 'text-text-secondary');
      });
      btn.classList.remove('bg-surface', 'border', 'border-border', 'text-text-secondary');
      btn.classList.add('bg-primary', 'text-white');
      
      // Filter articles
      articles.forEach(article => {
        if (category === 'all' || article.getAttribute('data-category') === category) {
          article.style.display = '';
        } else {
          article.style.display = 'none';
        }
      });
    });
  });

  // Load more - show message since all articles are displayed
  document.getElementById('load-more')?.addEventListener('click', () => {
    const btn = document.getElementById('load-more');
    if (btn) {
      btn.textContent = 'Semua artikel sudah ditampilkan';
      btn.disabled = true;
      btn.classList.add('opacity-50', 'cursor-not-allowed');
    }
  });
</script>
