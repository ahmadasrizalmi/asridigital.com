---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Icon from '../../components/ui/Icon.astro';

export async function getStaticPaths() {
  const apiBase = (import.meta.env.PUBLIC_APP_URL || 'https://asridigital.com').replace(/\/$/, '');
  try {
    const res = await fetch(`${apiBase}/api/blog/posts`);
    const data = await res.json();
    const posts = data.posts || [];
    return posts.map((post: any) => ({
      params: { slug: post.slug },
      props: {
        postTitle: post.title || 'Blog - Asri Digital',
        postExcerpt: post.excerpt || post.title || '',
        postImage: post.image_url || '',
      },
    }));
  } catch (e) {
    return [];
  }
}

const { slug } = Astro.params;
const { postTitle, postExcerpt, postImage } = Astro.props;
const blogCanonical = `https://asridigital.com/blog/${slug}`;
const blogOgImage = postImage ? (postImage.startsWith('http') ? postImage : `https://asridigital.com${postImage}`) : undefined;
---

<BaseLayout title={`${postTitle} - Blog Asri Digital`} description={postExcerpt} canonicalUrl={blogCanonical} ogImage={blogOgImage}>
  <Header />

  <!-- Reading Progress Bar -->
  <div id="reading-progress" style="position:fixed;top:0;left:0;height:3px;background:#10b981;z-index:9999;width:0;transition:width 0.1s;"></div>

  <main class="flex-1 pt-20">
    <!-- Loading State -->
    <div id="loading-state" class="text-center py-20 sm:py-40 px-4">
      <div class="animate-spin w-10 h-10 sm:w-12 sm:h-12 border-4 border-primary border-t-transparent rounded-full mx-auto mb-4"></div>
      <p class="text-text-muted text-sm sm:text-base">Memuat artikel...</p>
    </div>

    <!-- Article Content -->
    <div id="article-content" class="hidden">

      <!-- Hero Header -->
      <div id="hero-section" class="relative" style="min-height:200px;background-color:#f8fafc;background-image:radial-gradient(circle at 80% 0%, rgba(167,243,208,0.4) 0%, transparent 50%), radial-gradient(circle at 10% 100%, rgba(186,230,253,0.4) 0%, transparent 50%);">
        <div id="hero-bg-image" style="position:absolute;inset:0;opacity:0.15;"></div>
        <div style="position:relative;max-width:800px;margin:0 auto;padding:80px 16px 32px;">
          <!-- Breadcrumb -->
          <nav style="display:flex;align-items:center;gap:6px;font-size:13px;color:#94a3b8;margin-bottom:16px;flex-wrap:wrap;">
            <a href="/" style="color:#94a3b8;text-decoration:none;">Beranda</a>
            <span>›</span>
            <a href="/blog" style="color:#94a3b8;text-decoration:none;">Blog</a>
            <span>›</span>
            <span id="breadcrumb-title" style="color:#0f172a;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:200px;"></span>
          </nav>
          <!-- Category + Date + Reading Time removed per request -->
          <!-- Title -->
          <h1 id="post-title" style="font-size:clamp(1.5rem,5vw,2.25rem);font-weight:800;color:#0f172a;line-height:1.25;margin-bottom:16px;"></h1>
          <!-- Author -->
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:36px;height:36px;border-radius:999px;background:#e2e8f0;display:flex;align-items:center;justify-content:center;color:#475569;">
              <Icon name="user" size={16} />
            </div>
            <div>
              <p id="post-author" style="font-weight:600;color:#0f172a;font-size:14px;"></p>
              <p style="font-size:12px;color:#94a3b8;">Author</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Content Area with Sidebar -->
      <div class="blog-content-wrapper">

        <!-- Table of Contents - Desktop Sidebar -->
        <aside id="toc-sidebar" class="blog-toc-desktop">
          <div style="position:sticky;top:80px;">
            <p style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#64748b;margin-bottom:16px;">Daftar Isi</p>
            <nav id="toc-list" style="display:flex;flex-direction:column;gap:4px;"></nav>
          </div>
        </aside>

        <!-- Main Article -->
        <article class="blog-article">

          <!-- TOC - Mobile Collapsible -->
          <details id="toc-mobile" class="blog-toc-mobile">
            <summary style="padding:14px 16px;font-weight:600;font-size:14px;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;">
              <span><Icon name="list" size={16} class="inline align-text-bottom" /> Daftar Isi</span>
              <span id="toc-arrow" style="transition:transform 0.2s;font-size:12px;">▼</span>
            </summary>
            <nav id="toc-mobile-list" style="padding:0 16px 14px;display:flex;flex-direction:column;gap:6px;"></nav>
          </details>

          <!-- Featured Image -->
          <div id="post-image-container" style="margin-bottom:24px;border-radius:12px;overflow:hidden;display:none;">
            <img id="post-image" style="width:100%;height:auto;" alt="" loading="lazy" />
          </div>

          <!-- Content -->
          <div id="post-content" class="prose"></div>

          <!-- Stat Highlight Cards (auto-generated) -->
          <div id="stat-cards" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin:24px 0;"></div>

          <!-- Tags -->
          <div id="post-tags" style="display:flex;flex-wrap:wrap;gap:8px;margin:24px 0;"></div>

          <!-- Share Bar -->
          <div class="blog-share-bar">
            <span style="font-size:13px;font-weight:600;color:#475569;margin-bottom:4px;">Bagikan:</span>
            <div class="blog-share-buttons">
              <a id="share-whatsapp" href="#" target="_blank" rel="noopener noreferrer" class="blog-share-btn blog-share-wa">
                <Icon name="whatsapp" size={14} class="inline" /> WhatsApp
              </a>
              <a id="share-twitter" href="#" target="_blank" rel="noopener noreferrer" class="blog-share-btn blog-share-tw">
                <Icon name="twitter" size={14} class="inline" /> Twitter
              </a>
              <a id="share-facebook" href="#" target="_blank" rel="noopener noreferrer" class="blog-share-btn blog-share-fb">
                <Icon name="globe" size={14} class="inline" /> Facebook
              </a>
              <button id="share-copy" class="blog-share-btn blog-share-copy">
                <Icon name="copy" size={14} class="inline" /> Salin Link
              </button>
            </div>
          </div>

          <!-- Author Box -->
          <div class="blog-author-box">
            <div class="blog-author-avatar">
              <Icon name="user" size={24} />
            </div>
            <div class="blog-author-info">
              <p id="author-box-name" class="blog-author-name"></p>
              <p class="blog-author-role">Content Writer di Asri Digital</p>
              <p class="blog-author-bio">Menulis tentang AI, teknologi, dan produktivitas untuk membantu profesional Indonesia berkembang di era digital.</p>
            </div>
          </div>

          <!-- Related Posts -->
          <div id="related-posts" style="margin-top:40px;display:none;">
            <h2 style="font-size:1.25rem;font-weight:700;color:#171717;margin-bottom:20px;"><Icon name="book-open" size={20} class="inline align-text-bottom" /> Artikel Terkait</h2>
            <div id="related-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;"></div>
          </div>
        </article>
      </div>

      <!-- Floating Share - Desktop Only -->
      <div id="floating-share" class="blog-floating-share">
        <a id="float-whatsapp" href="#" target="_blank" rel="noopener noreferrer" class="blog-float-btn blog-share-wa" title="Share WhatsApp"><Icon name="whatsapp" size={16} /></a>
        <a id="float-twitter" href="#" target="_blank" rel="noopener noreferrer" class="blog-float-btn blog-share-tw" title="Share Twitter"><Icon name="twitter" size={16} /></a>
        <a id="float-facebook" href="#" target="_blank" rel="noopener noreferrer" class="blog-float-btn blog-share-fb" title="Share Facebook"><Icon name="globe" size={16} /></a>
        <button id="float-copy" class="blog-float-btn blog-share-copy" title="Salin Link"><Icon name="copy" size={16} /></button>
      </div>
    </div>

    <!-- Error State -->
    <div id="error-state" class="text-center py-20 px-4 hidden">
      <Icon name="alert-circle" size={48} />
      <h2 style="font-size:1.25rem;font-weight:700;color:#171717;margin:16px 0 8px;">Artikel Tidak Ditemukan</h2>
      <p style="color:#64748b;margin-bottom:24px;">Maaf, artikel yang Anda cari tidak tersedia.</p>
      <a href="/blog" class="btn-primary">← Kembali ke Blog</a>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.6/dist/purify.min.js" defer></script>
<script define:vars={{ slug }}>
  const API_BASE = '/api';

  function optimizeImg(url, w, h) {
    if (!url || !url.includes('res.cloudinary.com') || url.includes('/upload/w_')) return url;
    const t = [];
    if (w) t.push('w_' + w);
    if (h) t.push('h_' + h);
    if (t.length) t.push('c_fill');
    return url.replace('/upload/', '/upload/' + t.join(',') + '/');
  }

  function formatDate(dateStr) {
    return new Date(dateStr).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  function calcReadingTime(text) {
    const words = text.trim().split(/\s+/).length;
    const minutes = Math.ceil(words / 200);
    return `${minutes} menit baca`;
  }

  const categoryColors = {
    'tips': { bg: 'rgba(16,185,129,0.15)', color: '#10b981' },
    'tutorial': { bg: 'rgba(59,130,246,0.15)', color: '#3b82f6' },
    'studi-kasus': { bg: 'rgba(168,85,247,0.15)', color: '#a855f7' },
    'berita': { bg: 'rgba(249,115,22,0.15)', color: '#f97316' },
    'news': { bg: 'rgba(249,115,22,0.15)', color: '#f97316' },
  };

  async function waitForDependencies(maxWait = 5000) {
    const start = Date.now();
    while ((typeof marked === 'undefined' || typeof DOMPurify === 'undefined') && Date.now() - start < maxWait) {
      await new Promise(r => setTimeout(r, 100));
    }
    return typeof marked !== 'undefined' && typeof DOMPurify !== 'undefined';
  }

  // Custom renderer for special blocks
  function renderMarkdown(content) {
    if (typeof marked === 'undefined') {
      return content.replace(/\n/g, '<br>');
    }
    marked.setOptions({ breaks: true, gfm: true });

    // Pre-process: convert [!TIP], [!WARNING], [!INFO] blocks
    content = content.replace(/>\s*\[!TIP\]\s*\n([\s\S]*?)(?=\n[^>]|\n$)/g, (_, text) => {
      return `<div class="callout callout-tip"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline align-text-bottom"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2z"/></svg> <strong>Tips:</strong>${text}</div>`;
    });
    content = content.replace(/>\s*\[!WARNING\]\s*\n([\s\S]*?)(?=\n[^>]|\n$)/g, (_, text) => {
      return `<div class="callout callout-warning"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline align-text-bottom"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg> <strong>Peringatan:</strong>${text}</div>`;
    });
    content = content.replace(/>\s*\[!INFO\]\s*\n([\s\S]*?)(?=\n[^>]|\n$)/g, (_, text) => {
      return `<div class="callout callout-info"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline align-text-bottom"><path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"/><path d="M12 16V12"/><path d="M12 8H12.01"/></svg> <strong>Info:</strong>${text}</div>`;
    });

    // Pre-process: highlight stats like **67%** or **10x** into stat cards
    content = content.replace(/\*\*(\d+[%xX]?(?:\s*(?:perusahaan|juta|ribu|miliar|triliun))?)\*\*\s*([^\n<]+)/g, (_, num, desc) => {
      return `<span class="stat-highlight"><span class="stat-number">${num}</span><span class="stat-desc">${desc.trim()}</span></span>`;
    });

    try {
      return marked.parse(content);
    } catch (e) {
      console.error('Markdown parse error:', e);
      return content.replace(/\n/g, '<br>');
    }
  }

  function generateTOC() {
    const headings = document.querySelectorAll('#post-content h2, #post-content h3');
    const tocList = document.getElementById('toc-list');
    const tocMobileList = document.getElementById('toc-mobile-list');
    if (headings.length < 3) return;

    let html = '';
    headings.forEach((h, i) => {
      const id = `heading-${i}`;
      h.id = id;
      const isH3 = h.tagName === 'H3';
      const style = isH3 ? 'padding-left:16px;font-size:13px;' : 'font-size:14px;font-weight:600;';
      html += `<a href="#${id}" style="${style}color:#525252;text-decoration:none;padding:6px 0;display:block;border-radius:6px;transition:color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='#525252'">${h.textContent}</a>`;
    });
    if (tocList) tocList.innerHTML = html;
    if (tocMobileList) tocMobileList.innerHTML = html;

    document.getElementById('toc-sidebar').classList.add('toc-ready');
    document.getElementById('toc-mobile').classList.add('toc-ready');
  }

  function setupReadingProgress() {
    const bar = document.getElementById('reading-progress');
    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      bar.style.width = `${Math.min(progress, 100)}%`;
    });
  }

  function setupShareLinks(post) {
    const postUrl = window.location.href;
    const title = encodeURIComponent(post.title);
    const waUrl = `https://api.whatsapp.com/send?text=${title}%20${encodeURIComponent(postUrl)}`;
    const twUrl = `https://twitter.com/intent/tweet?text=${title}&url=${encodeURIComponent(postUrl)}`;
    const fbUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(postUrl)}`;

    ['share-whatsapp', 'float-whatsapp'].forEach(id => { const el = document.getElementById(id); if (el) el.href = waUrl; });
    ['share-twitter', 'float-twitter'].forEach(id => { const el = document.getElementById(id); if (el) el.href = twUrl; });
    ['share-facebook', 'float-facebook'].forEach(id => { const el = document.getElementById(id); if (el) el.href = fbUrl; });

    const copyHandler = () => {
      navigator.clipboard.writeText(postUrl).then(() => {
        const btns = ['share-copy', 'float-copy'];
        btns.forEach(id => {
          const btn = document.getElementById(id);
          if (btn) { btn.textContent = 'Tersalin!'; setTimeout(() => { btn.textContent = id === 'share-copy' ? 'Salin Link' : ''; }, 2000); }
        });
      });
    };
    const copyBtn = document.getElementById('share-copy');
    const floatCopyBtn = document.getElementById('float-copy');
    if (copyBtn) copyBtn.addEventListener('click', copyHandler);
    if (floatCopyBtn) floatCopyBtn.addEventListener('click', copyHandler);
  }

  function setupFloatingShare() {
    const floating = document.getElementById('floating-share');
    if (window.innerWidth >= 1280) {
      floating.style.display = 'flex';
    }
  }

  async function loadBlogPost() {
    try {
      await waitForDependencies();
      const response = await fetch(`${API_BASE}/blog/${slug}`);
      const data = await response.json();
      if (!data.post) throw new Error('Post not found');

      const post = data.post;
      const relatedPosts = data.relatedPosts || [];

      document.title = `${post.title} - Blog Asri Digital`;

      // Update meta tags for SEO/social sharing
      const setMeta = (attr, key, val) => {
        if (!val) return;
        let el = document.querySelector(`meta[${attr}="${key}"]`);
        if (!el) { el = document.createElement('meta'); el.setAttribute(attr, key); document.head.appendChild(el); }
        el.setAttribute('content', val);
      };
      const desc = post.excerpt || post.title;
      const img = post.image_url || '';
      const postUrl = window.location.href;
      setMeta('property', 'og:title', post.title);
      setMeta('property', 'og:description', desc);
      setMeta('property', 'og:image', img);
      setMeta('property', 'og:url', postUrl);
      setMeta('property', 'og:type', 'article');
      setMeta('name', 'twitter:title', post.title);
      setMeta('name', 'twitter:description', desc);
      setMeta('name', 'twitter:image', img);
      setMeta('name', 'description', desc);

      // Inject JSON-LD Article schema
      const existingLd = document.getElementById('blog-article-jsonld');
      if (existingLd) existingLd.remove();
      const ldScript = document.createElement('script');
      ldScript.id = 'blog-article-jsonld';
      ldScript.type = 'application/ld+json';
      ldScript.textContent = JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: post.title,
        description: post.excerpt || '',
        image: post.image_url || '',
        author: { '@type': 'Person', name: post.author_name || 'Admin Asri Digital' },
        datePublished: post.published_at || '',
        publisher: { '@type': 'Organization', name: 'Asri Digital' }
      });
      document.head.appendChild(ldScript);
      document.getElementById('breadcrumb-title').textContent = post.title;

      document.getElementById('post-title').textContent = post.title;
      document.getElementById('post-author').textContent = post.author_name || 'Admin Asri Digital';
      document.getElementById('author-box-name').textContent = post.author_name || 'Admin Asri Digital';

      if (post.image_url) {
        // Set hero background image
        const heroBg = document.getElementById('hero-bg-image');
        if (heroBg) {
          heroBg.style.background = `url('${optimizeImg(post.image_url, 1200, 400)}') center/cover`;
        }
        const container = document.getElementById('post-image-container');
        const img = document.getElementById('post-image');
        img.src = optimizeImg(post.image_url, 1200, 630);
        img.alt = post.title;
        container.style.display = 'block';
      }

      // Render content
      const contentEl = document.getElementById('post-content');
      contentEl.innerHTML = DOMPurify.sanitize(renderMarkdown(post.content));

      // Wrap tables for horizontal scroll
      contentEl.querySelectorAll('table').forEach(table => {
        const wrapper = document.createElement('div');
        wrapper.className = 'table-wrapper';
        table.parentNode.insertBefore(wrapper, table);
        wrapper.appendChild(table);
      });

      // Generate TOC
      generateTOC();

      // Tags
      if (post.tags) {
        try {
          const tags = JSON.parse(post.tags);
          document.getElementById('post-tags').innerHTML = DOMPurify.sanitize(tags.map(t =>
            `<span style="padding:4px 12px;background:#f5f5f5;border-radius:999px;font-size:12px;color:#525252;">#${t}</span>`
          ).join(''));
        } catch(e) {}
      }

      // Share links
      setupShareLinks(post);
      setupFloatingShare();

      // Related posts
      if (relatedPosts.length > 0) {
        const grid = document.getElementById('related-grid');
        grid.innerHTML = DOMPurify.sanitize(relatedPosts.map(r => `
          <a href="/blog/${r.slug}" style="border:1px solid #e5e5e5;border-radius:12px;overflow:hidden;text-decoration:none;transition:transform 0.2s,box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
            <div style="height:120px;background:linear-gradient(135deg,#10b981 0%,#059669 100%);display:flex;align-items:center;justify-content:center;">
              <span style="font-size:2.5rem;"><svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#10b981"><path d="M17 3A2.83 2.83 0 1 1 20 6L7.5 18.5L2 20L3.5 14.5L17 3Z"/></svg></span>
            </div>
            <div style="padding:14px;">
              <p style="font-size:11px;color:#64748b;margin-bottom:4px;">${r.category || ''}</p>
              <h3 style="font-size:14px;font-weight:600;color:#171717;margin-bottom:6px;line-height:1.4;">${r.title}</h3>
              <p style="font-size:12px;color:#64748b;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${r.excerpt || ''}</p>
            </div>
          </a>
        `).join(''), { ADD_ATTR: ['onmouseover', 'onmouseout'] });
        document.getElementById('related-posts').style.display = 'block';
      }

      // Show
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('article-content').classList.remove('hidden');
      setupReadingProgress();

    } catch (error) {
      console.error('Error:', error);
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('error-state').classList.remove('hidden');
    }
  }

  loadBlogPost();
</script>

<style is:global>
  /* ===== Content Layout ===== */
  .blog-content-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 16px;
    display: flex;
    gap: 40px;
  }

  .blog-article {
    flex: 1;
    min-width: 0;
    max-width: 760px;
  }

  /* ===== TOC Desktop ===== */
  .blog-toc-desktop {
    width: 220px;
    flex-shrink: 0;
    display: none;
  }

  .blog-toc-desktop.toc-ready {
    display: block;
  }

  /* ===== TOC Mobile ===== */
  .blog-toc-mobile {
    margin-bottom: 24px;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    padding: 0;
    display: none;
  }

  .blog-toc-mobile.toc-ready {
    display: block;
  }

  /* ===== Table Wrapper ===== */
  .table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-bottom: 1.25rem;
    border-radius: 8px;
    border: 1px solid #e5e5e5;
  }

  .table-wrapper table {
    margin-bottom: 0;
    min-width: 500px;
  }

  /* ===== Share Bar ===== */
  .blog-share-bar {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 20px 0;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    margin: 24px 0;
  }

  .blog-share-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .blog-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
  }

