---
import BlogLayout from '../../layouts/BlogLayout.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDB } from '../../db';
import { blogPosts, products } from '../../db/schema';
import { eq, and, ne } from 'drizzle-orm';
import { calculateReadingTime, parseTags, formatIDR } from '../../lib/utils';

const { slug } = Astro.params;
const env = Astro.locals?.runtime?.env || {};

if (!slug) {
  return Astro.redirect('/blog');
}

const db = getDB(env);

const posts = await db.select().from(blogPosts)
  .where(and(
    eq(blogPosts.slug, slug),
    eq(blogPosts.isPublished, true)
  ))
  .limit(1);

if (!posts[0]) {
  return Astro.redirect('/blog');
}

const post = posts[0];
const readingTime = calculateReadingTime(post.content);
const tags = parseTags(post.tags);

// Get related posts
const relatedPosts = await db.select().from(blogPosts)
  .where(and(
    eq(blogPosts.isPublished, true),
    ne(blogPosts.id, post.id)
  ))
  .limit(3);

// Increment view count
await db.update(blogPosts)
  .set({ viewCount: (post.viewCount || 0) + 1 })
  .where(eq(blogPosts.id, post.id));
---

<BlogLayout 
  title={post.title}
  description={post.excerpt || undefined}
  coverImage={post.coverImage || undefined}
  publishedAt={post.publishedAt || undefined}
  authorName={post.authorName || undefined}
  category={post.category || undefined}
  readingTime={readingTime}
>
  <div set:html={post.content} />

  {/* Related Products */}
  <div class="mt-12 p-6 bg-surface border border-border rounded-xl">
    <h3 class="font-semibold mb-4">💡 Produk Terkait</h3>
    <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-lg font-medium">
      Lihat Semua Produk →
    </a>
  </div>

  {/* Related Posts */}
  {relatedPosts.length > 0 && (
    <div class="mt-12">
      <h3 class="text-xl font-bold mb-6">Artikel Lainnya</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {relatedPosts.map(related => (
          <a href={`/blog/${related.slug}`} class="group">
            <div class="h-40 bg-surface rounded-xl mb-3 overflow-hidden">
              {related.coverImage ? (
                <img src={related.coverImage} alt={related.title} 
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy" />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <svg class="w-10 h-10 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                  </svg>
                </div>
              )}
            </div>
            <h4 class="font-medium group-hover:text-primary transition-colors line-clamp-2">{related.title}</h4>
          </a>
        ))}
      </div>
    </div>
  )}

  {/* Newsletter CTA */}
  <div class="mt-12 p-8 bg-gradient-to-r from-primary/10 to-secondary/10 border border-primary/20 rounded-xl text-center">
    <h3 class="text-xl font-bold mb-2">Dapatkan Update Artikel Terbaru!</h3>
    <p class="text-text-muted mb-6">Subscribe dan dapatkan tips AI & GPT langsung di inbox Anda</p>
    <div class="flex gap-2 max-w-md mx-auto">
      <input type="email" placeholder="email@anda.com" 
        class="flex-1 px-4 py-3 bg-background border border-border rounded-lg focus:border-primary outline-none" />
      <button class="px-6 py-3 bg-primary text-white rounded-lg font-medium hover:bg-primary-hover transition-colors">
        Subscribe
      </button>
    </div>
  </div>
</BlogLayout>
