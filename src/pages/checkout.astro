---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDB } from '../db';
import { products, coupons } from '../db/schema';
import { eq, and, gt, lt } from 'drizzle-orm';
import { formatIDR, calculateDiscount, generateId } from '../lib/utils';

const productSlug = Astro.url.searchParams.get('product');
const env = Astro.locals?.runtime?.env || {};

let product: any = null;
let allProducts: any[] = [];

try {
  const db = getDB(env);
  
  if (productSlug) {
    const result = await db.select().from(products).where(eq(products.slug, productSlug)).limit(1);
    product = result[0] || null;
  }
  
  // Get all active products for selection
  allProducts = await db.select().from(products).where(eq(products.isActive, true));
} catch (e) {
  console.error('Checkout DB error:', e);
}

if (!product && allProducts.length > 0) {
  product = allProducts[0];
}
---

<BaseLayout title="Checkout - Asri Digital" noFOMO>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="mb-8">
      <a href="/" class="inline-flex items-center gap-2 text-text-muted hover:text-primary transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Kembali
      </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {/* Checkout Form */}
      <div class="lg:col-span-2">
        <div class="bg-surface border border-border rounded-xl p-6 md:p-8">
          <h1 class="text-2xl font-bold mb-8">Checkout</h1>
          
          <form id="checkout-form" class="space-y-6">
            {/* Customer Info */}
            <div>
              <h2 class="text-lg font-semibold mb-4">Informasi Pembeli</h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-text-secondary mb-2">Nama Lengkap *</label>
                  <input type="text" name="customerName" required 
                    class="w-full px-4 py-3 bg-background border border-border rounded-lg focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                    placeholder="Nama Anda" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-text-secondary mb-2">Email *</label>
                  <input type="email" name="customerEmail" required 
                    class="w-full px-4 py-3 bg-background border border-border rounded-lg focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                    placeholder="email@anda.com" />
                </div>
                <div class="md:col-span-2">
                  <label class="block text-sm font-medium text-text-secondary mb-2">No. WhatsApp</label>
                  <input type="tel" name="customerPhone" 
                    class="w-full px-4 py-3 bg-background border border-border rounded-lg focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                    placeholder="08xxxxxxxxxx" />
                </div>
              </div>
            </div>

            {/* Payment Method */}
            <div>
              <h2 class="text-lg font-semibold mb-4">Metode Pembayaran</h2>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                <label class="payment-method-option">
                  <input type="radio" name="paymentMethod" value="QRIS" class="hidden peer" checked />
                  <div class="p-4 border border-border rounded-lg cursor-pointer peer-checked:border-primary peer-checked:bg-primary/10 transition-all text-center hover:border-primary/50">
                    <div class="text-2xl mb-1">📱</div>
                    <div class="text-sm font-medium">QRIS</div>
                    <div class="text-xs text-primary">Direkomendasikan</div>
                  </div>
                </label>
                <label class="payment-method-option">
                  <input type="radio" name="paymentMethod" value="VA_BCA" class="hidden peer" />
                  <div class="p-4 border border-border rounded-lg cursor-pointer peer-checked:border-primary peer-checked:bg-primary/10 transition-all text-center hover:border-primary/50">
                    <div class="text-2xl mb-1">🏦</div>
                    <div class="text-sm font-medium">BCA VA</div>
                  </div>
                </label>
                <label class="payment-method-option">
                  <input type="radio" name="paymentMethod" value="VA_MANDIRI" class="hidden peer" />
                  <div class="p-4 border border-border rounded-lg cursor-pointer peer-checked:border-primary peer-checked:bg-primary/10 transition-all text-center hover:border-primary/50">
                    <div class="text-2xl mb-1">🏦</div>
                    <div class="text-sm font-medium">Mandiri VA</div>
                  </div>
                </label>
                <label class="payment-method-option">
                  <input type="radio" name="paymentMethod" value="VA_BNI" class="hidden peer" />
                  <div class="p-4 border border-border rounded-lg cursor-pointer peer-checked:border-primary peer-checked:bg-primary/10 transition-all text-center hover:border-primary/50">
                    <div class="text-2xl mb-1">🏦</div>
                    <div class="text-sm font-medium">BNI VA</div>
                  </div>
                </label>
                <label class="payment-method-option">
                  <input type="radio" name="paymentMethod" value="GOPAY" class="hidden peer" />
                  <div class="p-4 border border-border rounded-lg cursor-pointer peer-checked:border-primary peer-checked:bg-primary/10 transition-all text-center hover:border-primary/50">
                    <div class="text-2xl mb-1">💚</div>
                    <div class="text-sm font-medium">GoPay</div>
                  </div>
                </label>
                <label class="payment-method-option">
                  <input type="radio" name="paymentMethod" value="DANA" class="hidden peer" />
                  <div class="p-4 border border-border rounded-lg cursor-pointer peer-checked:border-primary peer-checked:bg-primary/10 transition-all text-center hover:border-primary/50">
                    <div class="text-2xl mb-1">🔵</div>
                    <div class="text-sm font-medium">DANA</div>
                  </div>
                </label>
              </div>
            </div>

            <button type="submit" id="submit-btn"
              class="w-full py-4 bg-gradient-to-r from-primary to-secondary text-white rounded-xl font-bold text-lg hover:opacity-90 transition-opacity flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
              </svg>
              Bayar Sekarang
            </button>

            <p class="text-center text-sm text-text-muted flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
              Pembayaran aman via DompetX
            </p>
          </form>
        </div>
      </div>

      {/* Order Summary */}
      <div>
        <div class="bg-surface border border-border rounded-xl p-6 sticky top-24">
          <h2 class="text-lg font-semibold mb-4">Ringkasan Pesanan</h2>
          
          {product && (
            <div id="order-summary">
              <div class="flex gap-4 p-4 bg-background rounded-lg mb-4">
                <div class="w-16 h-16 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-medium">{product.title}</h3>
                  <p class="text-sm text-text-muted">{formatIDR(product.price)}</p>
                </div>
              </div>

              {/* Coupon */}
              <div class="mb-4">
                <label class="block text-sm font-medium text-text-secondary mb-2">Kode Kupon</label>
                <div class="flex gap-2">
                  <input type="text" id="coupon-input" placeholder="Masukkan kode"
                    class="flex-1 px-4 py-2.5 bg-background border border-border rounded-lg focus:border-primary outline-none transition-colors" />
                  <button type="button" id="apply-coupon" class="px-4 py-2.5 bg-surface border border-border rounded-lg hover:bg-border transition-colors text-sm font-medium">
                    Pakai
                  </button>
                </div>
                <p id="coupon-message" class="text-sm mt-2 hidden"></p>
              </div>

              {/* Price Breakdown */}
              <div class="border-t border-border pt-4 space-y-3">
                <div class="flex justify-between text-sm">
                  <span class="text-text-muted">Subtotal</span>
                  <span id="subtotal">{formatIDR(product.price)}</span>
                </div>
                <div id="discount-row" class="flex justify-between text-sm hidden">
                  <span class="text-text-muted">Diskon</span>
                  <span id="discount-amount" class="text-success">-{formatIDR(0)}</span>
                </div>
                <div class="flex justify-between text-lg font-bold pt-3 border-t border-border">
                  <span>Total</span>
                  <span id="total-price" class="text-primary">{formatIDR(product.price)}</span>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  {/* Hidden data */}
  <input type="hidden" id="product-id" value={product?.id || ''} />
  <input type="hidden" id="product-price" value={product?.price || 0} />

  <script>
    const form = document.getElementById('checkout-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const couponInput = document.getElementById('coupon-input') as HTMLInputElement;
    const applyCouponBtn = document.getElementById('apply-coupon') as HTMLButtonElement;
    const couponMessage = document.getElementById('coupon-message') as HTMLElement;
    const subtotalEl = document.getElementById('subtotal') as HTMLElement;
    const discountRow = document.getElementById('discount-row') as HTMLElement;
    const discountAmountEl = document.getElementById('discount-amount') as HTMLElement;
    const totalPriceEl = document.getElementById('total-price') as HTMLElement;
    const productIdInput = document.getElementById('product-id') as HTMLInputElement;
    const productPriceInput = document.getElementById('product-price') as HTMLInputElement;

    let appliedCoupon: { code: string; discountPercent: number } | null = null;

    function formatIDR(amount: number): string {
      return new Intl.NumberFormat('id-ID', {
        style: 'currency',
        currency: 'IDR',
        minimumFractionDigits: 0
      }).format(amount);
    }

    function updatePrice() {
      const price = parseInt(productPriceInput.value);
      if (appliedCoupon) {
        const discount = Math.round(price * (appliedCoupon.discountPercent / 100));
        const total = price - discount;
        
        discountRow.classList.remove('hidden');
        discountAmountEl.textContent = `-${formatIDR(discount)}`;
        totalPriceEl.textContent = formatIDR(total);
      } else {
        discountRow.classList.add('hidden');
        totalPriceEl.textContent = formatIDR(price);
      }
    }

    // Coupon handling
    applyCouponBtn?.addEventListener('click', async () => {
      const code = couponInput.value.trim();
      if (!code) return;

      try {
        const response = await fetch(`/api/coupon?code=${encodeURIComponent(code)}`);
        const data = await response.json();

        if (data.valid) {
          appliedCoupon = { code: data.code, discountPercent: data.discountPercent };
          couponMessage.textContent = `Kupon "${code}" berhasil! Diskon ${data.discountPercent}%`;
          couponMessage.className = 'text-sm mt-2 text-success';
          updatePrice();
        } else {
          appliedCoupon = null;
          couponMessage.textContent = data.message || 'Kupon tidak valid';
          couponMessage.className = 'text-sm mt-2 text-danger';
          updatePrice();
        }
      } catch {
        couponMessage.textContent = 'Gagal memeriksa kupon';
        couponMessage.className = 'text-sm mt-2 text-danger';
      }
    });

    // Form submission
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Memproses...';

      const formData = new FormData(form);
      
      // Get referral from cookie
      const refCookie = document.cookie.split(';').find(c => c.trim().startsWith('asri_ref='));
      const referredBy = refCookie ? refCookie.split('=')[1] : undefined;

      try {
        const response = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            productId: productIdInput.value,
            customerName: formData.get('customerName'),
            customerEmail: formData.get('customerEmail'),
            customerPhone: formData.get('customerPhone'),
            paymentMethod: formData.get('paymentMethod'),
            couponCode: appliedCoupon?.code,
            referredBy,
          }),
        });

        const data = await response.json();

        if (data.success) {
          if (data.paymentUrl) {
            window.location.href = data.paymentUrl;
          } else {
            window.location.href = `/success?order=${data.orderId}`;
          }
        } else {
          alert(data.error || 'Gagal membuat pesanan');
          submitBtn.disabled = false;
          submitBtn.innerHTML = '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" /></svg> Bayar Sekarang';
        }
      } catch (error) {
        alert('Terjadi kesalahan jaringan');
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" /></svg> Bayar Sekarang';
      }
    });
  </script>
</BaseLayout>
