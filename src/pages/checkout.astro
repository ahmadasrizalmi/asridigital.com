---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Icon from '../components/ui/Icon.astro';
import { formatIDR } from '../lib/utils';

const product = {
  title: 'Memuat produk...',
  price: 0,
  description: 'Mengambil detail produk...',
  short_description: 'Mengambil detail produk...',
};

const productSlug = 'loading';
---

<BaseLayout title={`Checkout - ${product?.title || 'Produk'}`}>
  <Header />

  <main class="flex-1 py-8 sm:py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-sm text-text-muted mb-6 sm:mb-8 flex-wrap">
        <a href="/" class="hover:text-primary transition-colors">Beranda</a>
        <Icon name="chevron-right" size={14} />
        <a href="/#produk" class="hover:text-primary transition-colors">Produk</a>
        <Icon name="chevron-right" size={14} />
        <span id="breadcrumb-product-title" class="text-text-main truncate max-w-[150px]">Memuat produk...</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
        <!-- Checkout Form -->
        <div class="lg:col-span-2">
          <div class="card p-4 sm:p-6 md:p-8">
            <h1 class="text-xl sm:text-2xl font-bold text-text-primary mb-4 sm:mb-6 flex items-center gap-3">
              <Icon name="shopping-cart" size={24} class="text-primary" />
              Checkout
            </h1>

            <form id="checkout-form" class="space-y-5 sm:space-y-6">
              <!-- Personal Info -->
              <div>
                <h2 class="text-base sm:text-lg font-semibold text-text-primary mb-3 sm:mb-4 flex items-center gap-2">
                  <Icon name="user" size={18} class="text-text-muted" />
                  Informasi Pembeli
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 sm:gap-4">
                  <div>
                    <label for="name" class="block text-sm font-medium text-text-main mb-2">
                      Nama Lengkap <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      class="input"
                      placeholder="John Doe"
                    />
                  </div>

                  <div>
                    <label for="email" class="block text-sm font-medium text-text-main mb-2">
                      Email <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      class="input"
                      placeholder="john@example.com"
                    />
                  </div>

                  <div class="md:col-span-2">
                    <label for="phone" class="block text-sm font-medium text-text-main mb-2">
                      No. WhatsApp <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="tel"
                      id="phone"
                      name="phone"
                      required
                      class="input"
                      placeholder="08123456789"
                    />
                    <p class="text-xs text-text-muted mt-1">Untuk pengiriman link produk & support</p>
                  </div>
                </div>
              </div>

              <hr class="border-border" />

              <!-- Coupon -->
              <div>
                <h2 class="text-base sm:text-lg font-semibold text-text-primary mb-3 sm:mb-4 flex items-center gap-2">
                  <Icon name="tag" size={18} class="text-text-muted" />
                  Kode Kupon
                  <span class="text-sm font-normal text-text-muted">(Opsional)</span>
                </h2>

                <div class="flex gap-2 sm:gap-3">
                  <input
                    type="text"
                    id="coupon"
                    name="coupon"
                    class="input flex-1"
                    placeholder="Masukkan kode kupon"
                  />
                  <button
                    type="button"
                    id="apply-coupon"
                    class="btn-tertiary whitespace-nowrap px-3 sm:px-4"
                  >
                    Gunakan
                  </button>
                </div>

                <div id="coupon-message" class="mt-2 text-sm hidden"></div>
              </div>

              <hr class="border-border" />

              <!-- Payment Method -->
              <div>
                <h2 class="text-base sm:text-lg font-semibold text-text-primary mb-3 sm:mb-4 flex items-center gap-2">
                  <Icon name="credit-card" size={18} class="text-text-muted" />
                  Metode Pembayaran
                </h2>

                <div class="space-y-2 sm:space-y-3">
                  <!-- QRIS -->
                  <label class="flex items-center gap-3 sm:gap-4 p-3 sm:p-4 border-2 border-primary rounded-xl cursor-pointer bg-primary/5">
                    <input type="radio" name="payment_method" value="qris" checked class="text-primary focus:ring-primary" />
                    <div class="flex items-center gap-2 sm:gap-3 flex-1 min-w-0">
                      <div class="w-10 h-7 sm:w-12 sm:h-8 bg-white rounded flex items-center justify-center border border-border shrink-0">
                        <span class="text-[10px] sm:text-xs font-bold text-primary">QRIS</span>
                      </div>
                      <div class="min-w-0">
                        <div class="font-medium text-text-primary text-sm sm:text-base">QRIS</div>
                        <div class="text-xs text-text-muted">Scan QR untuk bayar</div>
                      </div>
                    </div>
                    <Icon name="check-circle" size={18} class="text-primary shrink-0" />
                  </label>

                  <!-- Transfer Bank -->
                  <label class="flex items-center gap-3 sm:gap-4 p-3 sm:p-4 border-2 border-border rounded-xl cursor-pointer hover:border-text-muted transition-colors">
                    <input type="radio" name="payment_method" value="bank_transfer" class="text-primary focus:ring-primary" />
                    <div class="flex items-center gap-2 sm:gap-3 flex-1 min-w-0">
                      <div class="w-10 h-7 sm:w-12 sm:h-8 bg-white rounded flex items-center justify-center border border-border shrink-0">
                        <span class="text-[10px] sm:text-xs font-bold text-text-main">Bank</span>
                      </div>
                      <div class="min-w-0">
                        <div class="font-medium text-text-primary text-sm sm:text-base">Transfer Bank</div>
                        <div class="text-xs text-text-muted">BCA, Mandiri, BNI, BRI</div>
                      </div>
                    </div>
                  </label>

                  <!-- E-Wallet -->
                  <label class="flex items-center gap-3 sm:gap-4 p-3 sm:p-4 border-2 border-border rounded-xl cursor-pointer hover:border-text-muted transition-colors">
                    <input type="radio" name="payment_method" value="ewallet" class="text-primary focus:ring-primary" />
                    <div class="flex items-center gap-2 sm:gap-3 flex-1 min-w-0">
                      <div class="w-10 h-7 sm:w-12 sm:h-8 bg-white rounded flex items-center justify-center border border-border shrink-0">
                        <span class="text-[10px] sm:text-xs font-bold text-text-main">eWallet</span>
                      </div>
                      <div class="min-w-0">
                        <div class="font-medium text-text-primary text-sm sm:text-base">E-Wallet</div>
                        <div class="text-xs text-text-muted">GoPay, OVO, DANA, ShopeePay</div>
                      </div>
                    </div>
                  </label>
                </div>
              </div>

              <!-- Submit Button -->
              <button
                type="submit"
                id="submit-btn"
                class="btn-primary w-full py-3 sm:py-4 text-base sm:text-lg"
              >
                <Icon name="lock" size={18} />
                Bayar Sekarang - <span id="btn-price">Memuat...</span>
              </button>

              <p class="text-xs text-text-muted text-center">
                Dengan melanjutkan, Anda menyetujui <a href="/terms" class="text-primary hover:underline">Syarat & Ketentuan</a> kami.
              </p>
            </form>
          </div>
        </div>

        <!-- Order Summary -->
        <div class="lg:col-span-1">
          <div class="card p-4 sm:p-6 sticky top-20 lg:top-24">
            <h2 class="text-base sm:text-lg font-semibold text-text-primary mb-3 sm:mb-4">Ringkasan Pesanan</h2>

            <div class="space-y-3 sm:space-y-4">
              <!-- Product -->
              <div class="flex items-start gap-3 sm:gap-4">
                <div class="w-12 h-12 sm:w-16 sm:h-16 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
                  <Icon name="sparkles" size={18} class="text-primary sm:size-6" />
                </div>
                <div class="min-w-0 flex-1">
                  <h3 id="summary-product-title" class="font-medium text-text-primary text-sm sm:text-base line-clamp-2">Memuat produk...</h3>
                  <p id="summary-product-description" class="text-xs sm:text-sm text-text-muted mt-1 line-clamp-2">Mengambil detail produk...</p>
                </div>
              </div>

              <hr class="border-border" />

              <!-- Price Breakdown -->
              <div class="space-y-2">
                <div class="flex justify-between text-sm">
                  <span class="text-text-secondary">Harga</span>
                  <span class="text-text-main"><span id="summary-price">Memuat...</span></span>
                </div>
                <div id="discount-row" class="flex justify-between text-sm hidden">
                  <span class="text-green-600">Diskon</span>
                  <span class="text-green-600">-{formatIDR(0)}</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-text-secondary">Biaya Admin</span>
                  <span class="text-green-600">Gratis</span>
                </div>
              </div>

              <hr class="border-border" />

              <!-- Total -->
              <div class="flex justify-between items-center">
                <span class="font-semibold text-text-primary text-sm sm:text-base">Total</span>
                <span id="total-price" class="text-xl sm:text-2xl font-bold text-primary">Memuat...</span>
              </div>
            </div>

            <!-- Security Badges -->
            <div class="mt-4 sm:mt-6 pt-4 sm:pt-6 border-t border-border space-y-2 sm:space-y-3">
              <div class="flex items-center gap-2 text-xs sm:text-sm text-text-muted">
                <Icon name="shield" size={14} class="text-primary" />
                <span>Pembayaran 100% aman</span>
              </div>
              <div class="flex items-center gap-2 text-xs sm:text-sm text-text-muted">
                <Icon name="lock" size={14} class="text-primary" />
                <span>SSL Encrypted</span>
              </div>
              <div class="flex items-center gap-2 text-xs sm:text-sm text-text-muted">
                <Icon name="refresh-cw" size={14} class="text-primary" />
                <span>Garansi 7 hari uang kembali</span>
              </div>
            </div>

            <!-- Payment Logos -->
            <div class="mt-4 sm:mt-6 pt-4 sm:pt-6 border-t border-border">
              <p class="text-[10px] sm:text-xs text-text-muted text-center mb-2 sm:mb-3">Metode pembayaran yang tersedia</p>
              <div class="flex items-center justify-center gap-2 sm:gap-3 flex-wrap">
                <div class="px-2 sm:px-3 py-1 sm:py-1.5 bg-background rounded border border-border text-[10px] sm:text-xs font-medium">QRIS</div>
                <div class="px-2 sm:px-3 py-1 sm:py-1.5 bg-background rounded border border-border text-[10px] sm:text-xs font-medium">BCA</div>
                <div class="px-2 sm:px-3 py-1 sm:py-1.5 bg-background rounded border border-border text-[10px] sm:text-xs font-medium">Mandiri</div>
                <div class="px-2 sm:px-3 py-1 sm:py-1.5 bg-background rounded border border-border text-[10px] sm:text-xs font-medium">GoPay</div>
                <div class="px-2 sm:px-3 py-1 sm:py-1.5 bg-background rounded border border-border text-[10px] sm:text-xs font-medium">OVO</div>
                <div class="px-2 sm:px-3 py-1 sm:py-1.5 bg-background rounded border border-border text-[10px] sm:text-xs font-medium">DANA</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  const form = document.getElementById('checkout-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const couponInput = document.getElementById('coupon') as HTMLInputElement;
  const applyCouponBtn = document.getElementById('apply-coupon') as HTMLButtonElement;
  const couponMessage = document.getElementById('coupon-message') as HTMLDivElement;
  const discountRow = document.getElementById('discount-row') as HTMLDivElement;
  const totalPrice = document.getElementById('total-price') as HTMLSpanElement;
  const btnPrice = document.getElementById('btn-price') as HTMLSpanElement;
  const summaryPrice = document.getElementById('summary-price') as HTMLSpanElement;
  const breadcrumbProductTitle = document.getElementById('breadcrumb-product-title') as HTMLSpanElement;
  const summaryProductTitle = document.getElementById('summary-product-title') as HTMLHeadingElement;
  const summaryProductDescription = document.getElementById('summary-product-description') as HTMLParagraphElement;

  let productSlug = new URLSearchParams(window.location.search).get('product') || 'lifetime-all-access-pass';
  let discount = 0;
  let couponApplied = false;
  let basePrice = 0;

  submitBtn.disabled = true;
  applyCouponBtn.disabled = true;

  // Helper to format IDR
  function formatIDR(amount: number): string {
    return new Intl.NumberFormat('id-ID', {
      style: 'currency',
      currency: 'IDR',
      minimumFractionDigits: 0
    }).format(amount);
  }

  function normalizeProduct(raw: any) {
    return {
      title: raw?.title || 'Produk',
      slug: raw?.slug || productSlug,
      price: Number(raw?.price || 0),
      description: raw?.short_description || raw?.shortDescription || raw?.description || '',
    };
  }

  async function loadCheckoutProduct() {
    try {
      const response = await fetch('/api/products/' + encodeURIComponent(productSlug));
      if (!response.ok) throw new Error('Produk tidak ditemukan');

      const data = await response.json() as any;
      const loadedProduct = normalizeProduct(data.product);
      basePrice = loadedProduct.price;
      productSlug = loadedProduct.slug;

      document.title = 'Checkout - ' + loadedProduct.title;
      breadcrumbProductTitle.textContent = loadedProduct.title;
      summaryProductTitle.textContent = loadedProduct.title;
      summaryProductDescription.textContent = loadedProduct.description;

      const formattedPrice = formatIDR(basePrice);
      summaryPrice.textContent = formattedPrice;
      totalPrice.textContent = formattedPrice;
      btnPrice.textContent = formattedPrice;
      submitBtn.disabled = false;
      applyCouponBtn.disabled = false;
    } catch (error) {
      breadcrumbProductTitle.textContent = 'Produk tidak ditemukan';
      summaryProductTitle.textContent = 'Produk tidak ditemukan';
      summaryProductDescription.textContent = 'Silakan kembali ke katalog dan pilih produk yang tersedia.';
      summaryPrice.textContent = '-';
      totalPrice.textContent = '-';
      btnPrice.textContent = '-';
      submitBtn.disabled = true;
      applyCouponBtn.disabled = true;
    }
  }

  await loadCheckoutProduct();

  // Apply Coupon
  applyCouponBtn?.addEventListener('click', async () => {
    const code = couponInput?.value.trim();
    if (!code) return;

    applyCouponBtn.disabled = true;
    applyCouponBtn.textContent = 'Memeriksa...';

    try {
      const response = await fetch('/api/coupon/validate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code, productSlug }),
      });
      const data = await response.json() as any;

      if (data.valid) {
        if (data.coupon.type === 'PERCENTAGE') {
          discount = Math.round(basePrice * (data.coupon.value / 100));
        } else if (data.coupon.type === 'FIXED') {
          discount = data.coupon.value;
        }
        couponApplied = true;

        couponMessage.className = 'mt-2 text-sm text-green-600';
        couponMessage.textContent = '✓ Kupon berhasil digunakan!';
        couponMessage.classList.remove('hidden');

        discountRow.classList.remove('hidden');
        discountRow.querySelector('span:last-child')!.textContent = `-${formatIDR(discount)}`;

        const newTotal = basePrice - discount;
        const formattedTotal = formatIDR(newTotal);
        totalPrice.textContent = formattedTotal;
        btnPrice.textContent = formattedTotal;
        submitBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 11H5C3.89543 11 3 11.8945 3 13V20C3 21.1055 3.89543 22 5 22H19C20.1055 22 21 21.1055 21 20V13C21 11.8945 20.1055 11 19 11Z M7 11V7C7 5.67392 7.52678 4.40215 8.46447 3.46447C9.40215 2.52678 10.6739 2 12 2C13.3261 2 14.5979 2.52678 15.5355 3.46447C16.4732 4.40215 17 5.67392 17 7V11"></path></svg> Bayar Sekarang - <span class="price-text">${formattedTotal}</span>`;
      } else {
        couponMessage.className = 'mt-2 text-sm text-red-600';
        couponMessage.textContent = data.message || 'Kupon tidak valid';
        couponMessage.classList.remove('hidden');
      }
    } catch (error) {
      couponMessage.className = 'mt-2 text-sm text-red-600';
      couponMessage.textContent = 'Terjadi kesalahan. Coba lagi.';
      couponMessage.classList.remove('hidden');
    } finally {
      applyCouponBtn.disabled = false;
      applyCouponBtn.textContent = 'Gunakan';
    }
  });

  function getCookie(name: string) {
    const value = `; ${document.cookie}`;
    const parts = value.split(`; ${name}=`);
    if (parts.length === 2) return parts.pop()?.split(';').shift();
    return null;
  }

  const urlParams = new URLSearchParams(window.location.search);
  const refParam = urlParams.get('ref');
  if (refParam) {
    document.cookie = `asri_ref=${refParam};max-age=${30*24*60*60};path=/;SameSite=Lax`;
    fetch('/api/affiliate/click', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ referralCode: refParam, page: '/checkout' })
    }).catch(() => {});
  }

  let csrfToken = '';
  try {
    const csrfResponse = await fetch('/api/csrf-token');
    const csrfData = await csrfResponse.json();
    csrfToken = csrfData.token;
  } catch (e) {
    console.log('CSRF token fetch failed');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const referredBy = getCookie('asri_ref');
    const data = {
      customerName: formData.get('name'),
      customerEmail: formData.get('email'),
      customerPhone: formData.get('phone'),
      productSlug: productSlug,
      paymentMethod: formData.get('payment_method'),
      couponCode: couponApplied ? couponInput?.value : null,
      referredBy: referredBy || null,
      csrfToken: csrfToken,
    };

    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="animate-spin">⏳</span> Memproses...';

    try {
      const response = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await response.json() as any;

      if (result.success) {
        if (result.paymentUrl) {
          window.location.href = result.paymentUrl;
        } else {
          window.location.href = `/success?order=${result.orderId}`;
        }
      } else {
        alert(result.error || 'Terjadi kesalahan');
      }
    } catch (error) {
      alert('Terjadi kesalahan. Silakan coba lagi.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 11H5C3.89543 11 3 11.8945 3 13V20C3 21.1055 3.89543 22 5 22H19C20.1055 22 21 21.1055 21 20V13C21 11.8945 20.1055 11 19 11Z M7 11V7C7 5.67392 7.52678 4.40215 8.46447 3.46447C9.40215 2.52678 10.6739 2 12 2C13.3261 2 14.5979 2.52678 15.5355 3.46447C16.4732 4.40215 17 5.67392 17 7V11"></path></svg> Bayar Sekarang - <span class="price-text">${btnPrice.textContent}</span>`;
    }
  });

  document.querySelectorAll('input[name="payment_method"]').forEach(radio => {
    radio.addEventListener('change', (e) => {
      document.querySelectorAll('input[name="payment_method"]').forEach(r => {
        const label = r.closest('label');
        if (label) {
          label.classList.remove('border-primary', 'bg-primary/5');
          label.classList.add('border-border');
        }
      });

      const selected = (e.target as HTMLInputElement).closest('label');
      if (selected) {
        selected.classList.remove('border-border');
        selected.classList.add('border-primary', 'bg-primary/5');
      }
    });
  });
</script>