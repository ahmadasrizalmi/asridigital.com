---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Icon from '../components/ui/Icon.astro';
---

<BaseLayout
  title="Kontak Kami - Asri Digital"
  description="Hubungi tim Asri Digital untuk pertanyaan, dukungan, atau kerjasama. Kami siap membantu Anda dalam 24-48 jam."
  canonicalUrl="https://asridigital.com/contact"
>
  <Header />

  <main class="flex-1">
    {/* BREADCRUMB */}
    <nav class="bg-surface border-b border-border py-3">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <ol class="flex items-center gap-2 text-sm text-text-secondary">
          <li><a href="/" class="hover:text-primary transition-colors">Beranda</a></li>
          <li><Icon name="chevron-right" size={14} /></li>
          <li class="text-text-primary font-medium">Kontak</li>
        </ol>
      </div>
    </nav>

    {/* HERO */}
    <section class="py-20 bg-surface">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 rounded-full mb-6">
          <Icon name="message-square" size={16} class="text-primary" />
          <span class="text-sm text-primary font-medium">Hubungi Kami</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6 text-text-primary">
          Ada yang Bisa <span class="text-primary">Kami Bantu?</span>
        </h1>
        <p class="text-xl text-text-secondary max-w-2xl mx-auto">
          Kami senang mendengar dari Anda. Kirim pertanyaan, saran, atau permintaan kerjasama.
        </p>
      </div>
    </section>

    {/* KONTAK SECTION */}
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
          {/* FORM */}
          <div class="lg:col-span-3">
            <div class="card p-8">
              <h2 class="text-2xl font-bold mb-6 text-text-primary">Kirim Pesan</h2>
              <form id="contact-form" class="space-y-5">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                  <div>
                    <label for="name" class="block text-sm font-medium text-text-main mb-1.5">Nama Lengkap</label>
                    <input type="text" id="name" name="name" required class="input" placeholder="Masukkan nama Anda" />
                  </div>
                  <div>
                    <label for="email" class="block text-sm font-medium text-text-main mb-1.5">Email</label>
                    <input type="email" id="email" name="email" required class="input" placeholder="email@contoh.com" />
                  </div>
                </div>
                <div>
                  <label for="subject" class="block text-sm font-medium text-text-main mb-1.5">Subjek</label>
                  <select id="subject" name="subject" required class="input">
                    <option value="">Pilih subjek...</option>
                    <option value="umum">Pertanyaan Umum</option>
                    <option value="produk">Informasi Produk</option>
                    <option value="teknis">Dukungan Teknis</option>
                    <option value="kerjasama">Kerjasama / Partnership</option>
                    <option value="refund">Permintaan Refund</option>
                    <option value="lainnya">Lainnya</option>
                  </select>
                </div>
                <div>
                  <label for="message" class="block text-sm font-medium text-text-main mb-1.5">Pesan</label>
                  <textarea id="message" name="message" rows="5" required class="input resize-none" placeholder="Tulis pesan Anda di sini..."></textarea>
                </div>
                <button type="submit" class="btn-primary text-base px-8 py-3 w-full sm:w-auto">
                  <Icon name="send" size={18} />
                  <span>Kirim Pesan</span>
                </button>
              </form>
              <div id="form-success" class="hidden mt-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700">
                <div class="flex items-center gap-2">
                  <Icon name="check-circle" size={20} />
                  <span class="font-medium">Pesan berhasil dikirim! Kami akan merespons dalam 24-48 jam.</span>
                </div>
              </div>
              <div id="form-error" class="hidden mt-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700">
                <div class="flex items-center gap-2">
                  <Icon name="alert-circle" size={20} />
                  <span id="form-error-msg" class="font-medium">Terjadi kesalahan. Silakan coba lagi.</span>
                </div>
              </div>
            </div>
          </div>

          {/* INFO PANEL */}
          <div class="lg:col-span-2 space-y-6">
            <div class="card p-6">
              <h3 class="font-bold text-lg mb-4 text-text-primary">Informasi Kontak</h3>
              <div class="space-y-4">
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                    <Icon name="mail" size={20} class="text-primary" />
                  </div>
                  <div>
                    <div class="font-medium text-text-primary">Email</div>
                    <a href="mailto:support@asridigital.com" class="text-primary hover:underline">support@asridigital.com</a>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                    <Icon name="clock" size={20} class="text-primary" />
                  </div>
                  <div>
                    <div class="font-medium text-text-primary">Waktu Respons</div>
                    <p class="text-text-secondary text-sm">24 - 48 jam di hari kerja</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="card p-6">
              <h3 class="font-bold text-lg mb-4 text-text-primary">Media Sosial</h3>
              <div class="space-y-3">
                {[
                  { name: 'Instagram', icon: 'camera', url: '#' },
                  { name: 'Twitter / X', icon: 'twitter', url: '#' },
                  { name: 'YouTube', icon: 'play', url: '#' },
                  { name: 'TikTok', icon: 'music', url: '#' },
                ].map((social) => (
                  <a href={social.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg hover:bg-background transition-colors group">
                    <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center group-hover:bg-primary/20 transition-colors">
                      <Icon name={social.icon} size={18} class="text-primary" />
                    </div>
                    <span class="font-medium text-text-main group-hover:text-primary transition-colors">{social.name}</span>
                    <Icon name="external-link" size={14} class="ml-auto text-text-muted" />
                  </a>
                ))}
              </div>
              <p class="text-xs text-text-muted mt-4">Ikuti kami untuk tips, update produk, dan promo menarik.</p>
            </div>

            <div class="card p-6 bg-primary/5 border-primary/20">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                  <Icon name="help-circle" size={20} class="text-primary" />
                </div>
                <div>
                  <div class="font-medium text-text-primary mb-1">Punya pertanyaan cepat?</div>
                  <p class="text-text-secondary text-sm mb-3">Cek halaman FAQ kami untuk jawaban instan atas pertanyaan umum.</p>
                  <a href="/faq" class="text-primary font-medium text-sm hover:underline">Lihat FAQ →</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="py-20 bg-surface">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-extrabold mb-4 text-text-primary">Jelajahi Produk Kami</h2>
        <p class="text-text-secondary text-lg mb-8 max-w-xl mx-auto">
          Temukan Custom GPT yang tepat untuk kebutuhan profesional Anda.
        </p>
        <a href="/#produk" class="btn-primary text-lg px-8 py-4">
          <Icon name="sparkles" size={20} />
          <span>Lihat Semua Produk</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  const errorDiv = document.getElementById('form-error');
  const errorMsg = document.getElementById('form-error-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = 'Mengirim...';
    errorDiv?.classList.add('hidden');

    const formData = new FormData(form);
    const body = {
      name: formData.get('name') as string,
      email: formData.get('email') as string,
      subject: formData.get('subject') as string,
      message: formData.get('message') as string,
    };

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json();

      if (res.ok && data.success) {
        form.classList.add('hidden');
        success?.classList.remove('hidden');
      } else {
        if (errorMsg) errorMsg.textContent = data.message || 'Terjadi kesalahan. Silakan coba lagi.';
        errorDiv?.classList.remove('hidden');
        btn.disabled = false;
        btn.innerHTML = originalHTML;
      }
    } catch (err) {
      if (errorMsg) errorMsg.textContent = 'Tidak dapat menghubungi server. Periksa koneksi Anda.';
      errorDiv?.classList.remove('hidden');
      btn.disabled = false;
      btn.innerHTML = originalHTML;
    }
  });
</script>
