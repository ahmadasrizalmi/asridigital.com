---
// Client-side cookie setter for admin token
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Set Admin Cookie</title>
  </head>
  <body>
    <p>Memproses login admin...</p>

    <script is:inline>
      const token = localStorage.getItem('auth_token');

      if (token) {
        document.cookie = 'token=' + encodeURIComponent(token) + ';path=/;max-age=86400;SameSite=Lax';

        const urlParams = new URLSearchParams(window.location.search);
        const redirect = urlParams.get('redirect') || '/admin';
        window.location.href = redirect;
      } else {
        window.location.href = '/dashboard';
      }
    </script>
  </body>
</html>
