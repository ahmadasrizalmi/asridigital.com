// Set admin cookie script
// Run this after login to set the cookie

const token = localStorage.getItem('auth_token');
if (token) {
  // Set cookie with 24 hour expiry
  document.cookie = `token=${encodeURIComponent(token)};path=/;max-age=86400;SameSite=Lax`;
  // Redirect to admin
  const urlParams = new URLSearchParams(window.location.search);
  const redirect = urlParams.get('redirect') || '/admin';
  window.location.href = redirect;
} else {
  // No token found, go to login
  window.location.href = '/dashboard';
}