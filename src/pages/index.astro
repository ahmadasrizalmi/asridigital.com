---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ProductCard from '../components/marketing/ProductCard.astro';
import FOMOPopup from '../components/marketing/FOMOPopup.astro';
import Icon from '../components/ui/Icon.astro';
import { formatIDR } from '../lib/utils';
import type { Product } from '../types/index';

// Fallback product data; production tries DB/API first.
const allAccessProduct: Product = {
  id: 'ALL-ACCESS',
  title: 'Lifetime All-Access Pass',
  slug: 'lifetime-all-access-pass',
  description: 'Akses seluruh Custom GPT yang ada saat ini dan semua update di masa depan.',
  shortDescription: 'Akses unlimited ke semua Custom GPT. Sekali bayar, seumur hidup.',
  price: 299000,
  compareAtPrice: 599000,
  gptUrl: null,
  imageIcon: '/images/all-access-banner.jpg',
  category: 'membership',
  tags: ['all-access', 'premium', 'best-value'],
  isActive: true,
  isFeatured: true,
  sortOrder: 0,
};

let products: Product[] = [
  {
    id: 'gpt-animasi-muslim',
    title: 'Animasi Muslim Kids Studio',
    slug: 'animasi-muslim-kids-studio',
    description: 'GPT khusus untuk membuat konten animasi Islami untuk anak-anak.',
    shortDescription: 'Buat konten animasi Islami untuk anak-anak dengan AI',
    price: 99000,
    compareAtPrice: 149000,
    gptUrl: null,
    imageIcon: '/images/animasi-muslim.jpg',
    category: 'kreatif',
    tags: ['animasi', 'islami', 'anak'],
    isActive: true,
    isFeatured: true,
    sortOrder: 1,
  },
  {
    id: 'gpt-sahabat-guru',
    title: 'Sahabat Guru PAUD Islami',
    slug: 'sahabat-guru-paud-islami',
    description: 'GPT asisten untuk guru PAUD Islami.',
    shortDescription: 'Asisten AI untuk guru PAUD Islami',
    price: 79000,
    compareAtPrice: null,
    gptUrl: null,
    imageIcon: '/images/sahabat-guru.jpg',
    category: 'pendidikan',
    tags: ['guru', 'paud', 'islami', 'pendidikan'],
    isActive: true,
    isFeatured: false,
    sortOrder: 2,
  },
  {
    id: 'gpt-content-creator',
    title: 'Content Creator Pro',
    slug: 'content-creator-pro',
    description: 'GPT untuk membuat konten marketing yang engaging.',
    shortDescription: 'Buat konten marketing viral dengan AI',
    price: 89000,
    compareAtPrice: 129000,
    gptUrl: null,
    imageIcon: '/images/content-creator.jpg',
    category: 'marketing',
    tags: ['content', 'marketing', 'social-media'],
    isActive: true,
    isFeatured: false,
    sortOrder: 3,
  },
];

function normalizeProduct(raw: any): Product {
  return {
    id: raw.id,
    title: raw.title,
    slug: raw.slug,
    description: raw.description || '',
    shortDescription: raw.shortDescription ?? raw.short_description ?? null,
    price: Number(raw.price || 0),
    compareAtPrice: raw.compareAtPrice ?? raw.compare_at_price ?? null,
    gptUrl: null,  // API no longer returns gpt_url for security
    imageIcon: raw.imageIcon ?? raw.image_icon ?? null,
    galleryImages: raw.galleryImages ?? raw.gallery_images ?? null,
    galleryVideos: raw.galleryVideos ?? raw.gallery_videos ?? null,
    videoEmbedUrl: raw.videoEmbedUrl ?? raw.video_embed_url ?? null,
    features: raw.features ?? null,
    specs: raw.specs ?? null,
    faq: raw.faq ?? null,
    category: raw.category || 'produk',
    tags: Array.isArray(raw.tags) ? raw.tags : (() => { try { return JSON.parse(raw.tags || '[]'); } catch { return []; } })(),
    isActive: Boolean(raw.isActive ?? raw.is_active ?? true),
    isFeatured: Boolean(raw.isFeatured ?? raw.is_featured ?? false),
    sortOrder: Number(raw.sortOrder ?? raw.sort_order ?? 0),
  };
}

try {
  const apiBase = (import.meta.env.PUBLIC_APP_URL || 'https://asridigital.com').replace(/\/$/, '');
  const response = await fetch(`${apiBase}/api/products?limit=12`);
  if (response.ok) {
    const data = await response.json() as any;
    const dbProducts = (data.products || [])
      .filter((p: any) => p.slug !== allAccessProduct.slug)
      .map(normalizeProduct);

    if (dbProducts.length > 0) {
      products = dbProducts;
    }
  }
} catch (error) {
  console.warn('Using fallback products because API products failed:', error);
}

const features = [
  { icon: 'zap', title: 'Instant Akses', description: 'Langsung bisa pakai setelah bayar' },
  { icon: 'lock', title: 'Aman Bayar', description: 'Pembayaran terenkripsi & aman' },
  { icon: 'message-square', title: 'Bahasa Indonesia', description: 'Semua GPT berbahasa Indonesia' },
  { icon: 'refresh-cw', title: 'Update Gratis', description: 'Dapat update terbaru otomatis' },
];

// TODO: These stats should be fetched dynamically from /api/settings or database
// For now using hardcoded values that can be updated via admin panel
const stats = [
  { value: '500+', label: 'Pengguna Aktif', icon: 'users' },
  { value: '1,000+', label: 'Produk Terjual', icon: 'trending-up' },
  { value: '4.9/5', label: 'Rating', icon: 'star' },
  { value: '10+', label: 'Custom GPT', icon: 'sparkles' },
];
---

<BaseLayout structuredData={
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Asri Digital",
    "url": "https://asridigital.com",
    "description": "Custom GPT Marketplace untuk Profesional Indonesia",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://asridigital.com/blog?search={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
}>
  <Header />
  
  <main class="flex-1">
    {/* HERO SECTION */}
    <section class="relative py-20 lg:py-32 bg-surface overflow-hidden">
      {/* Subtle Background Decoration */}
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-40 -right-40 w-80 h-80 bg-primary/5 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-primary/5 rounded-full blur-3xl"></div>
      </div>
      
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-4xl mx-auto">
          {/* Announcement Badge */}
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 rounded-full mb-8 animate-fade-in">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
            </span>
            <span class="text-sm text-primary font-medium">🚀 Promo Launching - Diskon 50%</span>
          </div>
          
          {/* Main Heading */}
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold mb-6 animate-slide-up text-text-primary">
            Custom GPT untuk
            <span class="text-primary">Profesional Indonesia</span>
          </h1>
          
          {/* Subheading */}
          <p class="text-xl text-text-secondary mb-10 max-w-2xl mx-auto animate-slide-up" style="animation-delay: 0.1s">
            Akses berbagai Custom GPT siap pakai untuk marketing, coding, bisnis, dan banyak lagi. 
            <strong class="text-text-main">Bayar sekali, akses seumur hidup.</strong>
          </p>
          
          {/* CTA Buttons */}
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 mb-10 sm:mb-12 animate-slide-up" style="animation-delay: 0.2s">
            <a 
              href="#all-access" 
              class="btn-primary text-base sm:text-lg px-6 sm:px-8 py-3 sm:py-4 w-full sm:w-auto justify-center"
            >
              <Icon name="crown" size={18} class="sm:w-5" />
              <span>Beli All-Access Pass</span>
            </a>
            <a 
              href="#produk" 
              class="btn-secondary text-base sm:text-lg px-6 sm:px-8 py-3 sm:py-4 w-full sm:w-auto justify-center"
            >
              <Icon name="eye" size={18} class="sm:w-5" />
              <span>Lihat Produk</span>
            </a>
          </div>
          
          {/* Price Preview */}
          <div class="inline-flex flex-wrap items-center justify-center gap-2 sm:gap-3 text-text-muted animate-slide-up text-xs sm:text-sm" style="animation-delay: 0.3s">
            <span class="flex items-center gap-1.5">
              <Icon name="shield" size={14} class="text-primary" />
              Garansi 7 hari
            </span>
            <span class="hidden sm:inline">•</span>
            <span class="flex items-center gap-1.5">
              <Icon name="lock" size={14} class="text-primary" />
              Pembayaran aman
            </span>
            <span class="hidden sm:inline">•</span>
            <span class="flex items-center gap-1.5">
              <Icon name="zap" size={14} class="text-primary" />
              Akses instant
            </span>
          </div>
        </div>
      </div>
    </section>

    {/* SOCIAL PROOF BAR */}
    <section class="py-6 border-y border-border bg-background">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {stats.map((stat) => (
            <div class="flex items-center gap-3 justify-center">
              <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
                <Icon name={stat.icon} size={20} class="text-primary" />
              </div>
              <div>
                <div class="text-lg font-bold text-text-primary">{stat.value}</div>
                <div class="text-xs text-text-muted">{stat.label}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ALL-ACCESS PASS */}
    <section id="all-access" class="py-20 scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="relative card overflow-hidden">
          {/* Subtle Gradient */}
          <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-primary/5"></div>
          
          <div class="relative p-6 sm:p-8 md:p-12 lg:p-16">
            <div class="flex flex-col lg:flex-row items-start gap-6 sm:gap-8 lg:gap-12">
              {/* Left Content */}
              <div class="flex-1 min-w-0">
                <div class="inline-flex items-center gap-1.5 sm:gap-2 px-3 sm:px-4 py-1.5 sm:py-2 bg-amber-50 text-amber-700 rounded-full font-semibold mb-4 sm:mb-6 text-xs sm:text-sm">
                  <Icon name="crown" size={14} class="sm:w-4" />
                  <span>BEST VALUE</span>
                </div>

                <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold mb-4 sm:mb-6 text-text-primary leading-tight">
                  Lifetime
                  <span class="text-primary block sm:inline"> All-Access Pass</span>
                </h2>

                <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-4 mb-6 sm:mb-8">
                  <span class="text-4xl sm:text-5xl font-extrabold text-text-primary">{formatIDR(allAccessProduct.price)}</span>
                  <span class="text-xl sm:text-2xl text-text-muted line-through">{formatIDR(allAccessProduct.compareAtPrice!)}</span>
                  <span class="badge-danger text-sm sm:text-lg px-2 sm:px-3 py-1 sm:py-1.5 inline-flex items-center whitespace-nowrap">
                    HEMAT 50%
                  </span>
                </div>
                
                <ul class="space-y-3 sm:space-y-4 mb-6 sm:mb-10">
                  {[
                    'Akses SEMUA GPT yang ada & akan datang',
                    'Update lifetime gratis',
                    'Prioritas support',
                    'Komunitas eksklusif',
                  ].map((feature) => (
                    <li class="flex items-start gap-2 sm:gap-3 text-text-main text-sm sm:text-base">
                      <div class="w-5 h-5 sm:w-6 sm:h-6 rounded-full bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
                        <Icon name="check" size={10} class="sm:w-3.5 text-primary" />
                      </div>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
                
                <a 
                  href={`/checkout?product=${allAccessProduct.slug}`}
                  class="btn-primary text-base sm:text-lg px-6 sm:px-10 py-3 sm:py-4 inline-flex w-full sm:w-auto justify-center"
                >
                  <Icon name="zap" size={18} class="sm:w-5" />
                  <span class="whitespace-nowrap">Dapatkan All-Access Sekarang</span>
                </a>
                
                <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 mt-4 sm:mt-6 text-xs sm:text-sm text-text-muted text-center sm:text-left">
                  <div class="flex items-center gap-1.5 sm:gap-2 justify-center">
                    <Icon name="shield" size={14} class="text-primary" />
                    <span>Garansi 7 hari</span>
                  </div>
                  <span class="hidden sm:inline">•</span>
                  <div class="flex items-center gap-1.5 sm:gap-2 justify-center">
                    <Icon name="lock" size={14} class="text-primary" />
                    <span>Sekali bayar, akses seumur hidup</span>
                  </div>
                </div>
              </div>
              
              {/* Right Visual */}
              <div class="hidden lg:block w-80 shrink-0">
                <div class="card p-6 text-center">
                  <div class="w-20 h-20 mx-auto mb-4 bg-amber-100 rounded-2xl flex items-center justify-center">
                    <Icon name="crown" size={40} class="text-amber-600" />
                  </div>
                  <h3 class="text-xl font-bold mb-2 text-text-primary">VIP Member</h3>
                  <p class="text-sm text-text-secondary mb-4">Akses unlimited ke semua produk</p>
                  <div class="space-y-2">
                    {products.map((p) => (
                      <div class="flex items-center gap-2 text-sm text-text-secondary">
                        <Icon name="check-circle" size={16} class="text-primary" />
                        <span class="truncate">{p.title}</span>
                      </div>
                    ))}
                    <div class="flex items-center gap-2 text-sm text-text-muted">
                      <Icon name="plus" size={16} />
                      <span>Dan produk lainnya...</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* PRODUCT GRID */}
    <section id="produk" class="py-20 bg-surface scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 rounded-full mb-4">
            <Icon name="sparkles" size={16} class="text-primary" />
            <span class="text-sm text-primary font-medium">Koleksi GPT</span>
          </div>
          <h2 class="text-4xl font-extrabold mb-4 text-text-primary">
            Pilih GPT Sesuai <span class="text-primary">Kebutuhan</span>
          </h2>
          <p class="text-text-secondary text-lg max-w-2xl mx-auto">
            Setiap Custom GPT dirancang khusus untuk membantu produktivitas Anda.
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {products.map((product, i) => (
            <div class="animate-slide-up" style={`animation-delay: ${i * 0.1}s`}>
              <ProductCard product={product} />
            </div>
          ))}
        </div>
        
        {/* CTA Below Products */}
        <div class="text-center mt-12">
          <p class="text-text-muted mb-4">Ingin akses semua produk di atas?</p>
          <a href="#all-access" class="btn-secondary">
            <Icon name="crown" size={18} />
            Dapatkan All-Access Pass
          </a>
        </div>
      </div>
    </section>

    {/* FEATURES GRID */}
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {features.map((feature, i) => (
            <div class="card-hover p-6 text-center animate-slide-up" style={`animation-delay: ${i * 0.1}s`}>
              <div class="w-14 h-14 mx-auto mb-4 rounded-xl bg-primary/10 flex items-center justify-center">
                <Icon name={feature.icon} size={28} class="text-primary" />
              </div>
              <h3 class="font-semibold text-lg mb-2 text-text-primary">{feature.title}</h3>
              <p class="text-sm text-text-secondary">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* TESTIMONIAL */}
    <section class="py-20 bg-surface">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="card p-12">
          <div class="flex justify-center gap-1 mb-6">
            {[1,2,3,4,5].map(() => (
              <Icon name="star" size={24} class="text-amber-400 fill-amber-400" />
            ))}
          </div>
          
          <blockquote class="text-2xl font-medium mb-6 text-text-main">
            "GPT dari Asri Digital sangat membantu pekerjaan saya. 
            Investasi terbaik untuk produktivitas!"
          </blockquote>
          
          <div class="flex items-center justify-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-lg font-bold text-primary">
              S
            </div>
            <div class="text-left">
              <div class="font-semibold text-text-primary">S***</div>
              <div class="text-sm text-text-muted">Marketing Manager</div>
            </div>
          </div>
          
          <a href="#produk" class="btn-primary text-lg px-8 py-4">
            <Icon name="shopping-cart" size={20} />
            Mulai Belanja Sekarang
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <FOMOPopup />
</BaseLayout>

<script>
  // Track affiliate click if ref parameter exists
  const urlParams = new URLSearchParams(window.location.search);
  const ref = urlParams.get('ref');
  
  if (ref) {
    // Set cookie
    document.cookie = `asri_ref=${ref};max-age=${30*24*60*60};path=/;SameSite=Lax`;
    
    // Track click
    fetch('/api/affiliate/click', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        referralCode: ref,
        page: window.location.pathname
      })
    }).catch(err => console.log('Click tracking failed:', err));
    
    // Clean URL
    const cleanUrl = window.location.pathname;
    window.history.replaceState({}, document.title, cleanUrl);
  }
</script>
