---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import HeroSlider from '../components/marketing/HeroSlider.astro';
import PromoCard from '../components/marketing/PromoCard.astro';
import FOMOPopup from '../components/marketing/FOMOPopup.astro';
import HotReleaseSlider from '../components/marketing/HotReleaseSlider.astro';

// All-Access product excluded from homepage grid
const ALL_ACCESS_SLUG = 'lifetime-all-access-pass';
---


<BaseLayout structuredData={{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Asri Digital",
  "url": "https://asridigital.com",
  "description": "Solusi Bisnis Digital & AI untuk Profesional Indonesia",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://asridigital.com/blog?search={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}}>
  <Header />

  <main class="flex-1">
    {/* HERO SLIDER */}
    <HeroSlider />

    {/* SOCIAL PROOF BAR */}
    {/* SOCIAL PROOF — from site_settings */}
    <section id="social-proof" class="border-b border-slate-100 bg-white py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 text-center" id="stats-container">
          <div class="text-slate-400 text-sm">Loading...</div>
        </div>
      </div>
    </section>

    {/* HOT RELEASE — only shows when is_hot products exist */}
    <HotReleaseSlider />

    {/* PRODUCT SECTION */}
    <section id="produk" class="py-24 bg-slate-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <h2 id="catalog-title" class="text-3xl font-extrabold text-slate-900 tracking-tight mb-4">Eksplorasi Katalog Digital</h2>
          <p id="catalog-desc" class="text-slate-500">Temukan tools dan aset digital yang dirancang khusus untuk mempercepat alur kerja dan riset pasar Anda.</p>
        </div>

        {/* Search + Filter Tabs — categories from D1 */}
        <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-4">
          <div class="relative w-full md:w-96">
            <input type="text" id="product-search" placeholder="Cari aplikasi, data, atau asisten AI..." class="w-full pl-12 pr-4 py-3 bg-white border border-slate-200 rounded-full text-sm focus:outline-none focus:border-slate-400 focus:ring-1 focus:ring-slate-400 shadow-soft transition-shadow" />
            <svg class="absolute left-4 top-3.5 w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
          <div class="flex space-x-2 overflow-x-auto pb-2 md:pb-0 w-full md:w-auto scrollbar-hide" id="filter-tabs">
            <button class="filter-tab active px-5 py-2 rounded-full text-sm font-semibold transition-colors whitespace-nowrap" data-filter="all">Semua</button>
          </div>
        </div>

        {/* Product Grid */}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="product-grid">
          {/* Loading skeletons — replaced by JS after fetch */}
          <div class="product-skeleton bg-white rounded-2xl border border-slate-100 overflow-hidden">
            <div class="w-full aspect-square bg-slate-200 animate-pulse"></div>
            <div class="p-6 space-y-3">
              <div class="h-5 w-3/4 bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-full bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-2/3 bg-slate-200 rounded animate-pulse"></div>
              <div class="h-6 w-1/3 bg-slate-200 rounded animate-pulse mt-4"></div>
            </div>
          </div>
          <div class="product-skeleton hidden md:block bg-white rounded-2xl border border-slate-100 overflow-hidden">
            <div class="w-full aspect-square bg-slate-200 animate-pulse"></div>
            <div class="p-6 space-y-3">
              <div class="h-5 w-3/4 bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-full bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-2/3 bg-slate-200 rounded animate-pulse"></div>
              <div class="h-6 w-1/3 bg-slate-200 rounded animate-pulse mt-4"></div>
            </div>
          </div>
          <div class="product-skeleton hidden lg:block bg-white rounded-2xl border border-slate-100 overflow-hidden">
            <div class="w-full aspect-square bg-slate-200 animate-pulse"></div>
            <div class="p-6 space-y-3">
              <div class="h-5 w-3/4 bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-full bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-2/3 bg-slate-200 rounded animate-pulse"></div>
              <div class="h-6 w-1/3 bg-slate-200 rounded animate-pulse mt-4"></div>
            </div>
          </div>
        </div>

        {/* Empty State */}
        <div id="no-results" class="hidden text-center py-12">
          <p class="text-slate-500 text-lg">Maaf, produk tidak ditemukan. Coba kata kunci lain.</p>
        </div>

        {/* Lihat Semua link */}
        <div class="text-center mt-10">
          <a href="/products" class="inline-flex items-center gap-2 text-emerald-600 hover:text-emerald-700 font-semibold text-base transition-colors">
            Lihat Semua Produk
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </a>
        </div>
      </div>
    </section>

    {/* ALL-ACCESS PASS */}
    <PromoCard />

    {/* FEATURES — from site_settings */}
    <section class="py-16 bg-white border-b border-slate-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center" id="features-container">
          <div class="col-span-full text-slate-400 text-sm">Loading...</div>
        </div>
      </div>
    </section>

    {/* ARTIKEL TERBARU — Latest Blog Posts */}
    <section id="artikel-terbaru" class="py-24 bg-slate-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight mb-4">Artikel Terbaru</h2>
          <p class="text-slate-500">Tips, tutorial, dan insight tentang AI & digital tools</p>
        </div>

        {/* Blog Posts Grid */}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="blog-posts-grid">
          {/* Loading skeletons */}
          <div class="blog-skeleton bg-white rounded-2xl border border-slate-100 overflow-hidden">
            <div class="w-full aspect-video bg-slate-200 animate-pulse"></div>
            <div class="p-5 space-y-3">
              <div class="h-5 w-20 bg-slate-200 rounded-full animate-pulse"></div>
              <div class="h-5 w-3/4 bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-full bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-2/3 bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-1/3 bg-slate-200 rounded animate-pulse pt-2"></div>
            </div>
          </div>
          <div class="blog-skeleton hidden md:block bg-white rounded-2xl border border-slate-100 overflow-hidden">
            <div class="w-full aspect-video bg-slate-200 animate-pulse"></div>
            <div class="p-5 space-y-3">
              <div class="h-5 w-20 bg-slate-200 rounded-full animate-pulse"></div>
              <div class="h-5 w-3/4 bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-full bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-2/3 bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-1/3 bg-slate-200 rounded animate-pulse pt-2"></div>
            </div>
          </div>
          <div class="blog-skeleton hidden lg:block bg-white rounded-2xl border border-slate-100 overflow-hidden">
            <div class="w-full aspect-video bg-slate-200 animate-pulse"></div>
            <div class="p-5 space-y-3">
              <div class="h-5 w-20 bg-slate-200 rounded-full animate-pulse"></div>
              <div class="h-5 w-3/4 bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-full bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-2/3 bg-slate-200 rounded animate-pulse"></div>
              <div class="h-4 w-1/3 bg-slate-200 rounded animate-pulse pt-2"></div>
            </div>
          </div>
        </div>

        {/* View All Button */}
        <div class="text-center mt-12" id="blog-view-all" style="display:none;">
          <a href="/blog" class="inline-flex items-center gap-2 px-8 py-3 bg-gradient-to-r from-emerald-600 to-emerald-500 text-white font-semibold rounded-full hover:from-emerald-700 hover:to-emerald-600 transition-all shadow-md hover:shadow-lg">
            Lihat Semua Artikel
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <FOMOPopup />
</BaseLayout>

<script>
  // ===== DYNAMIC DATA FROM D1 VIA API =====

  function optimizeImg(url, w, h) {
    if (!url || !url.includes('res.cloudinary.com') || url.includes('/upload/w_')) return url;
    const t = [];
    if (w) t.push('w_' + w);
    if (h) t.push('h_' + h);
    if (t.length) t.push('c_fill');
    return url.replace('/upload/', '/upload/' + t.join(',') + '/');
  }

  const ICON_MAP: Record<string, string> = {
    'zap': '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>',
    'lock': '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>',
    'message-square': '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path></svg>',
    'refresh-cw': '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>',
  };

  async function loadDynamicContent() {
    try {
      const [settingsRes, categoriesRes] = await Promise.all([
        fetch('/api/site-settings?keys=catalog_section_title,catalog_section_description,stat_active_users,stat_active_users_label,stat_products_sold,stat_products_sold_label,stat_rating,stat_rating_label,feature_1_title,feature_1_description,feature_1_icon,feature_2_title,feature_2_description,feature_2_icon,feature_3_title,feature_3_description,feature_3_icon,feature_4_title,feature_4_description,feature_4_icon'),
        fetch('/api/categories')
      ]);

      const settings = await settingsRes.json();
      const catData = await categoriesRes.json();

      // Catalog section title
      if (settings.catalog_section_title) document.getElementById('catalog-title')!.textContent = settings.catalog_section_title;
      if (settings.catalog_section_description) document.getElementById('catalog-desc')!.textContent = settings.catalog_section_description;

      // Stats
      const statsContainer = document.getElementById('stats-container')!;
      const statsHtml = [
        { value: settings.stat_active_users || '500+', label: settings.stat_active_users_label || 'Pengguna Aktif' },
        { value: settings.stat_products_sold || '1,000+', label: settings.stat_products_sold_label || 'Produk Terjual' },
        { value: settings.stat_rating || '4.9/5', label: settings.stat_rating_label || 'Rating Kepuasan', hasStar: true },
      ].map((s, i) => `
        ${i > 0 ? '<div class="hidden sm:block w-px h-8 bg-slate-200"></div>' : ''}
        <div>
          <p class="text-2xl font-extrabold text-slate-900 tracking-tight flex items-center justify-center">${s.value}${s.hasStar ? ' <svg class="w-5 h-5 text-yellow-400 ml-1 mb-1" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>' : ''}</p>
          <p class="text-xs text-slate-500 font-medium uppercase tracking-wider mt-1">${s.label}</p>
        </div>
      `).join('');
      statsContainer.innerHTML = statsHtml;

      // Filter tabs from categories
      const tabsContainer = document.getElementById('filter-tabs')!;
      const categories = catData.categories || [];
      if (categories.length > 0) {
        tabsContainer.innerHTML = `<button class="filter-tab active px-5 py-2 rounded-full text-sm font-semibold transition-colors whitespace-nowrap" data-filter="all">Semua</button>` +
            `<button class="filter-tab px-5 py-2 rounded-full text-sm font-semibold transition-colors bg-white text-slate-600 border border-slate-200 hover:bg-slate-100 whitespace-nowrap" data-filter="hot">🔥 Hot</button>` +
          categories.map((cat: any) =>
            `<button class="filter-tab px-5 py-2 rounded-full text-sm font-semibold transition-colors bg-white text-slate-600 border border-slate-200 hover:bg-slate-100 whitespace-nowrap" data-filter="${cat.slug}">${cat.name}</button>`
          ).join('');
        // Re-bind filter click events
        bindFilterTabs();
      }

      // Features
      const featuresContainer = document.getElementById('features-container')!;
      const featureKeys = ['feature_1', 'feature_2', 'feature_3', 'feature_4'];
      const featuresHtml = featureKeys.map(key => {
        const title = settings[`${key}_title`];
        const desc = settings[`${key}_description`];
        const icon = settings[`${key}_icon`] || 'zap';
        if (!title) return '';
        return `
          <div>
            <div class="w-12 h-12 mx-auto bg-slate-50 rounded-full flex items-center justify-center mb-4 text-emerald-600">${ICON_MAP[icon] || ICON_MAP['zap']}</div>
            <h4 class="font-bold text-slate-900 mb-2">${title}</h4>
            <p class="text-sm text-slate-500">${desc || ''}</p>
          </div>`;
      }).filter(Boolean).join('');
      if (featuresHtml) featuresContainer.innerHTML = featuresHtml;

    } catch (err) {
      console.error('Dynamic content load failed:', err);
    }
  }

  // ===== LATEST BLOG POSTS =====
  const CATEGORY_META: Record<string, { label: string; color: string; bgColor: string }> = {
    'tips': { label: 'Tips & Trik', color: 'bg-emerald-500 text-white', bgColor: 'from-emerald-100 to-emerald-50' },
    'tutorial': { label: 'Tutorial', color: 'bg-blue-500 text-white', bgColor: 'from-blue-100 to-blue-50' },
    'studi-kasus': { label: 'Studi Kasus', color: 'bg-amber-500 text-white', bgColor: 'from-amber-100 to-amber-50' },
    'berita': { label: 'Berita', color: 'bg-purple-500 text-white', bgColor: 'from-purple-100 to-purple-50' },
    'ai': { label: 'AI', color: 'bg-emerald-600 text-white', bgColor: 'from-emerald-100 to-emerald-50' },
    'productivity': { label: 'Productivity', color: 'bg-blue-500 text-white', bgColor: 'from-blue-100 to-blue-50' },
    'general': { label: 'Umum', color: 'bg-gray-500 text-white', bgColor: 'from-gray-100 to-gray-50' },
  };

  function getBlogCategoryMeta(category: string) {
    const key = category?.toLowerCase() || 'general';
    return CATEGORY_META[key] || CATEGORY_META['general'];
  }

  function formatBlogDate(dateStr: string) {
    return new Date(dateStr).toLocaleDateString('id-ID', {
      day: 'numeric', month: 'long', year: 'numeric'
    });
  }

  async function loadLatestBlogPosts() {
    const grid = document.getElementById('blog-posts-grid');
    const viewAll = document.getElementById('blog-view-all');
    if (!grid) return;

    try {
      const res = await fetch('/api/blog/posts?limit=3');
      const data = await res.json();
      const posts = (data.posts || []).slice(0, 3);

      if (posts.length === 0) {
        grid.innerHTML = '<div class="col-span-full text-center py-12 text-slate-400">Belum ada artikel tersedia.</div>';
        return;
      }

      grid.innerHTML = posts.map((post: any) => {
        const catKey = post.category?.toLowerCase() || 'general';
        const meta = getBlogCategoryMeta(catKey);
        const pubDate = formatBlogDate(post.published_at);
        const imgSrc = post.image_url ? optimizeImg(post.image_url, 400, 210) : '';

        return `
          <article class="bg-white rounded-2xl border border-slate-100 overflow-hidden shadow-sm hover:shadow-lg transition-shadow group">
            <a href="/blog/${post.slug}/" class="block">
              <div class="relative overflow-hidden">
                ${imgSrc
                  ? `<img src="${imgSrc}" alt="${post.title}" class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />`
                  : `<div class="w-full aspect-video bg-gradient-to-br ${meta.bgColor} flex items-center justify-center">
                       <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
                     </div>`
                }
                <div class="absolute top-3 left-3">
                  <span class="px-3 py-1 ${meta.color} text-xs font-medium rounded-full">${meta.label}</span>
                </div>
              </div>
            </a>
            <div class="p-5">
              <a href="/blog/${post.slug}/" class="block">
                <h3 class="text-lg font-bold text-slate-900 mb-2 group-hover:text-emerald-600 transition-colors line-clamp-2">${post.title}</h3>
              </a>
              <p class="text-sm text-slate-500 mb-4 line-clamp-2">${post.excerpt || ''}</p>
              <div class="flex items-center justify-between">
                <span class="text-xs text-slate-400">${pubDate}</span>
                <a href="/blog/${post.slug}/" class="text-emerald-600 hover:text-emerald-700 font-semibold text-sm flex items-center gap-1 transition-colors">
                  Baca Artikel
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </a>
              </div>
            </div>
          </article>
        `;
      }).join('');

      if (viewAll) viewAll.style.display = 'block';
    } catch (err) {
      console.error('Failed to load blog posts:', err);
      grid.innerHTML = '<div class="col-span-full text-center py-12 text-slate-400">Gagal memuat artikel.</div>';
    }
  }

  // ===== PRODUCTS — loaded client-side from API =====
  const PRODUCT_CAT_MAP: Record<string, string> = {
    marketing: 'ai', coding: 'ai', kreatif: 'tools', pendidikan: 'data', membership: 'ai'
  };

  function formatIDRClient(amount: number): string {
    return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(amount);
  }

  function createProductCard(product: any): HTMLElement {
    const catKey = (product.category || 'tools').toLowerCase();
    const filterCat = PRODUCT_CAT_MAP[catKey] || 'tools';
    const title = product.title || '';
    const slug = product.slug || '';
    const imgSrc = optimizeImg(product.image_icon || product.imageIcon || '/images/placeholder.jpg', 400, 400);
    const shortDesc = product.short_description || product.shortDescription || product.description || '';
    const price = Number(product.price || 0);
    const compareAt = product.compare_at_price || product.compareAtPrice || null;
    const hasDiscount = compareAt && Number(compareAt) > price;
    const isFree = price === 0;
    const discount = hasDiscount ? Math.round((1 - price / Number(compareAt)) * 100) : 0;
    const isFeatured = Boolean(product.is_featured || product.isFeatured);
    const isHot = Boolean(product.is_hot || product.isHot);

    const safeTitle = title.replace(/[<>"'&]/g, c => ({'<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;','&':'&amp;'}[c] as string));
    const safeDesc = shortDesc.replace(/[<>"'&]/g, c => ({'<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;','&':'&amp;'}[c] as string));

    const a = document.createElement('a');
    a.href = '/product/' + slug;
    a.className = 'product-card bg-white rounded-2xl overflow-hidden border border-slate-200 shadow-card hover:shadow-float hover:-translate-y-1 transition-all duration-300 group flex flex-col h-full';
    a.setAttribute('data-category', filterCat);
    a.setAttribute('data-title', title.toLowerCase());
    a.setAttribute('data-slug', slug);
    if (isHot) a.setAttribute('data-hot', 'true');

    let badgeHtml = '';
    if (hasDiscount && !isFree) badgeHtml = '<div class="absolute top-3 left-3"><span class="inline-flex items-center px-2.5 py-1 rounded-md bg-red-500 text-white text-xs font-bold shadow-sm">-' + discount + '%</span></div>';
    else if (isFree) badgeHtml = '<div class="absolute top-3 left-3"><span class="inline-flex items-center px-2.5 py-1 rounded-md bg-green-500 text-white text-xs font-bold shadow-sm">GRATIS</span></div>';
    const featuredBadge = isFeatured ? '<div class="absolute top-3 right-3"><span class="inline-flex items-center gap-0.5 px-2 py-1 rounded-md bg-amber-400 text-amber-900 text-xs font-bold shadow-sm">Best Seller</span></div>' : '';
    const hotBadge = isHot ? '<div class="absolute top-3 right-3"><span class="inline-flex items-center gap-0.5 px-2 py-1 rounded-md bg-red-500 text-white text-xs font-bold shadow-sm">🔥 Hot</span></div>' : '';

    let priceHtml = '';
    if (isFree) {
      priceHtml = '<span class="text-xl font-bold text-slate-900">Gratis</span>';
    } else {
      const discountLine = hasDiscount ? '<span class="text-xs text-slate-400 line-through block mb-0.5">' + formatIDRClient(Number(compareAt)) + '</span>' : '';
      priceHtml = '<div>' + discountLine + '<span class="text-xl font-bold text-slate-900">' + formatIDRClient(price) + '</span></div>';
    }

    a.innerHTML = '<div class="relative overflow-hidden aspect-square bg-slate-50">' +
      '<img src="' + imgSrc + '" alt="' + safeTitle + '" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />' +
      badgeHtml + (isHot ? hotBadge : featuredBadge) +
      '</div>' +
      '<div class="p-6 flex flex-col flex-grow">' +
      '<h3 class="text-lg font-bold text-slate-900 mb-2 transition-colors">' + safeTitle + '</h3>' +
      '<p class="text-slate-500 text-sm mb-6 flex-grow leading-relaxed line-clamp-2">' + safeDesc + '</p>' +
      '<div class="flex items-center justify-between mt-auto pt-4 border-t border-slate-300">' +
      priceHtml +
      '<button class="buy-btn bg-slate-100 text-slate-900 px-4 py-2 rounded-lg text-sm font-semibold group-hover:bg-gradient-to-r group-hover:from-emerald-300 group-hover:to-yellow-100 group-hover:text-slate-800 transition-all duration-300">Lihat Detail</button>' +
      '</div></div>';

    return a;
  }

  async function loadProducts() {
    const grid = document.getElementById('product-grid');
    if (!grid) return;
    try {
      const res = await fetch('/api/products?limit=6');
      const data = await res.json();
      const allAccessSlug = 'lifetime-all-access-pass';
      const apiProducts = (data.products || []).filter((p: any) => p.slug !== allAccessSlug);

      if (apiProducts.length > 0) {
        grid.innerHTML = '';
        apiProducts.forEach((product: any) => {
          grid.appendChild(createProductCard(product));
        });
        // Re-bind filter after products are rendered
        filterProducts();
      } else {
        grid.innerHTML = '<div class="col-span-full text-center py-12 text-slate-400">Belum ada produk tersedia.</div>';
      }
    } catch (err) {
      console.error('Failed to load products:', err);
      // Keep skeletons visible as fallback
    }
  }

  loadDynamicContent();
  loadLatestBlogPosts();
  loadProducts();
  bindFilterTabs(); // Bind initial "Semua" tab

  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('shadow-soft');
    } else {
      navbar?.classList.remove('shadow-soft');
    }
  });

  // Product filtering & search
  const filterTabs = document.querySelectorAll('.filter-tab');
  const searchInput = document.getElementById('product-search') as HTMLInputElement;
  const noResults = document.getElementById('no-results');

  function filterProducts() {
    // Re-query DOM each time — products are loaded dynamically via API
    const productCards = document.querySelectorAll('.product-card');
    const searchTerm = (searchInput?.value || '').toLowerCase();
    const activeTab = document.querySelector('.filter-tab.active') as HTMLElement;
    const activeCategory = activeTab?.dataset.filter || 'all';
    let visibleCount = 0;

    productCards.forEach(card => {
      const el = card as HTMLElement;
      const title = el.dataset.title || '';
      const category = el.dataset.category || '';
      const isHot = el.dataset.hot === 'true';
      const matchesSearch = title.includes(searchTerm);
      let matchesCategory: boolean;
      if (activeCategory === 'hot') {
        matchesCategory = isHot;
      } else if (activeCategory === 'all') {
        matchesCategory = true;
      } else {
        matchesCategory = category === activeCategory;
      }

      if (matchesSearch && matchesCategory) {
        el.style.display = 'flex';
        visibleCount++;
      } else {
        el.style.display = 'none';
      }
    });

    if (noResults) noResults.style.display = visibleCount === 0 ? 'block' : 'none';
  }

  function bindFilterTabs() {
    const tabs = document.querySelectorAll('.filter-tab');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => {
          t.classList.remove('active', 'bg-carbon', 'text-white');
          t.classList.add('bg-white', 'text-slate-600');
        });
        tab.classList.add('active', 'bg-carbon', 'text-white');
        tab.classList.remove('bg-white', 'text-slate-600');
        filterProducts();
      });
    });
  }

  searchInput?.addEventListener('input', filterProducts);

  // Affiliate tracking
  const urlParams = new URLSearchParams(window.location.search);
  const ref = urlParams.get('ref');
  if (ref) {
    document.cookie = `asri_ref=${ref};max-age=${30*24*60*60};path=/;SameSite=Lax`;
    fetch('/api/affiliate/click', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ referralCode: ref, page: window.location.pathname })
    }).catch(() => {});
    window.history.replaceState({}, document.title, window.location.pathname);
  }
</script>
