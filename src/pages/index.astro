---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ProductCard from '../components/marketing/ProductCard.astro';
import HeroSlider from '../components/marketing/HeroSlider.astro';
import PromoCard from '../components/marketing/PromoCard.astro';
import FOMOPopup from '../components/marketing/FOMOPopup.astro';
import { formatIDR } from '../lib/utils';
import type { Product } from '../types/index';

const allAccessProduct: Product = {
  id: 'ALL-ACCESS',
  title: 'Lifetime All-Access Pass',
  slug: 'lifetime-all-access-pass',
  description: 'Akses seluruh Custom GPT yang ada saat ini dan semua update di masa depan.',
  shortDescription: 'Akses unlimited ke semua Custom GPT. Sekali bayar, seumur hidup.',
  price: 299000,
  compareAtPrice: 599000,
  gptUrl: null,
  imageIcon: '/images/all-access-banner.jpg',
  category: 'membership',
  tags: ['all-access', 'premium', 'best-value'],
  isActive: true,
  isFeatured: true,
  sortOrder: 0,
};

let products: Product[] = [
  { id: 'gpt-animasi-muslim', title: 'Animasi Muslim Kids Studio', slug: 'animasi-muslim-kids-studio', description: 'GPT khusus untuk membuat konten animasi Islami untuk anak-anak.', shortDescription: 'Buat konten animasi Islami untuk anak-anak dengan AI', price: 99000, compareAtPrice: 149000, gptUrl: null, imageIcon: '/images/animasi-muslim.jpg', category: 'kreatif', tags: ['animasi', 'islami', 'anak'], isActive: true, isFeatured: true, sortOrder: 1 },
  { id: 'gpt-sahabat-guru', title: 'Sahabat Guru PAUD Islami', slug: 'sahabat-guru-paud-islami', description: 'GPT asisten untuk guru PAUD Islami.', shortDescription: 'Asisten AI untuk guru PAUD Islami', price: 79000, compareAtPrice: null, gptUrl: null, imageIcon: '/images/sahabat-guru.jpg', category: 'pendidikan', tags: ['guru', 'paud', 'islami', 'pendidikan'], isActive: true, isFeatured: false, sortOrder: 2 },
  { id: 'gpt-content-creator', title: 'Content Creator Pro', slug: 'content-creator-pro', description: 'GPT untuk membuat konten marketing yang engaging.', shortDescription: 'Buat konten marketing viral dengan AI', price: 89000, compareAtPrice: 129000, gptUrl: null, imageIcon: '/images/content-creator.jpg', category: 'marketing', tags: ['content', 'marketing', 'social-media'], isActive: true, isFeatured: false, sortOrder: 3 },
];

function normalizeProduct(raw: any): Product {
  return {
    id: raw.id, title: raw.title, slug: raw.slug,
    description: raw.description || '',
    shortDescription: raw.shortDescription ?? raw.short_description ?? null,
    price: Number(raw.price || 0),
    compareAtPrice: raw.compareAtPrice ?? raw.compare_at_price ?? null,
    gptUrl: null,
    imageIcon: raw.imageIcon ?? raw.image_icon ?? null,
    galleryImages: raw.galleryImages ?? raw.gallery_images ?? null,
    galleryVideos: raw.galleryVideos ?? raw.gallery_videos ?? null,
    videoEmbedUrl: raw.videoEmbedUrl ?? raw.video_embed_url ?? null,
    features: raw.features ?? null, specs: raw.specs ?? null, faq: raw.faq ?? null,
    category: raw.category || 'produk',
    tags: Array.isArray(raw.tags) ? raw.tags : (() => { try { return JSON.parse(raw.tags || '[]'); } catch { return []; } })(),
    isActive: Boolean(raw.isActive ?? raw.is_active ?? true),
    isFeatured: Boolean(raw.isFeatured ?? raw.is_featured ?? false),
    sortOrder: Number(raw.sortOrder ?? raw.sort_order ?? 0),
  };
}

try {
  const apiBase = (import.meta.env.PUBLIC_APP_URL || 'https://asridigital.com').replace(/\/$/, '');
  const response = await fetch(`${apiBase}/api/products?limit=100`);
  if (response.ok) {
    const data = await response.json() as any;
    const dbProducts = (data.products || [])
      .filter((p: any) => p.slug !== allAccessProduct.slug)
      .map(normalizeProduct);
    if (dbProducts.length > 0) products = dbProducts;
  }
} catch (error) {
  console.warn('Using fallback products because API products failed:', error);
}
---

<BaseLayout structuredData={{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Asri Digital",
  "url": "https://asridigital.com",
  "description": "Solusi Bisnis Digital & AI untuk Profesional Indonesia",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://asridigital.com/blog?search={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}}>
  <Header />

  <main class="flex-1">
    {/* HERO SLIDER */}
    <HeroSlider />

    {/* SOCIAL PROOF BAR */}
    <section class="border-b border-slate-100 bg-white py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 text-center">
          <div>
            <p class="text-2xl font-extrabold text-slate-900 tracking-tight">500+</p>
            <p class="text-xs text-slate-500 font-medium uppercase tracking-wider mt-1">Pengguna Aktif</p>
          </div>
          <div class="hidden sm:block w-px h-8 bg-slate-200"></div>
          <div>
            <p class="text-2xl font-extrabold text-slate-900 tracking-tight">1,000+</p>
            <p class="text-xs text-slate-500 font-medium uppercase tracking-wider mt-1">Produk Terjual</p>
          </div>
          <div class="hidden sm:block w-px h-8 bg-slate-200"></div>
          <div>
            <p class="text-2xl font-extrabold text-slate-900 tracking-tight flex items-center justify-center">
              4.9/5 <svg class="w-5 h-5 text-yellow-400 ml-1 mb-1" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
            </p>
            <p class="text-xs text-slate-500 font-medium uppercase tracking-wider mt-1">Rating Kepuasan</p>
          </div>
        </div>
      </div>
    </section>

    {/* PRODUCT SECTION */}
    <section id="produk" class="py-24 bg-slate-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight mb-4">Eksplorasi Katalog Digital</h2>
          <p class="text-slate-500">Temukan tools dan aset digital yang dirancang khusus untuk mempercepat alur kerja dan riset pasar Anda.</p>
        </div>

        {/* Search + Filter Tabs */}
        <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-4">
          <div class="relative w-full md:w-96">
            <input type="text" id="product-search" placeholder="Cari aplikasi, data, atau asisten AI..." class="w-full pl-12 pr-4 py-3 bg-white border border-slate-200 rounded-full text-sm focus:outline-none focus:border-slate-400 focus:ring-1 focus:ring-slate-400 shadow-soft transition-shadow" />
            <svg class="absolute left-4 top-3.5 w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
          <div class="flex space-x-2 overflow-x-auto pb-2 md:pb-0 w-full md:w-auto scrollbar-hide">
            <button class="filter-tab active px-5 py-2 rounded-full text-sm font-semibold transition-colors whitespace-nowrap" data-filter="all">Semua</button>
            <button class="filter-tab px-5 py-2 rounded-full text-sm font-semibold transition-colors bg-white text-slate-600 border border-slate-200 hover:bg-slate-100 whitespace-nowrap" data-filter="tools">Aplikasi</button>
            <button class="filter-tab px-5 py-2 rounded-full text-sm font-semibold transition-colors bg-white text-slate-600 border border-slate-200 hover:bg-slate-100 whitespace-nowrap" data-filter="data">Data & Riset</button>
            <button class="filter-tab px-5 py-2 rounded-full text-sm font-semibold transition-colors bg-white text-slate-600 border border-slate-200 hover:bg-slate-100 whitespace-nowrap" data-filter="ai">Asisten AI</button>
          </div>
        </div>

        {/* Product Grid */}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="product-grid">
          {products.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>

        {/* Empty State */}
        <div id="no-results" class="hidden text-center py-12">
          <p class="text-slate-500 text-lg">Maaf, produk tidak ditemukan. Coba kata kunci lain.</p>
        </div>
      </div>
    </section>

    {/* ALL-ACCESS PASS */}
    <PromoCard />

    {/* FEATURES SECTION */}
    <section class="py-16 bg-white border-b border-slate-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          <div>
            <div class="w-12 h-12 mx-auto bg-slate-50 rounded-full flex items-center justify-center mb-4 text-emerald-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h4 class="font-bold text-slate-900 mb-2">Akses Instan</h4>
            <p class="text-sm text-slate-500">File langsung dapat diunduh setelah pembayaran.</p>
          </div>
          <div>
            <div class="w-12 h-12 mx-auto bg-slate-50 rounded-full flex items-center justify-center mb-4 text-emerald-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            </div>
            <h4 class="font-bold text-slate-900 mb-2">Pembayaran Aman</h4>
            <p class="text-sm text-slate-500">Dienkripsi dan diproses oleh payment gateway terpercaya.</p>
          </div>
          <div>
            <div class="w-12 h-12 mx-auto bg-slate-50 rounded-full flex items-center justify-center mb-4 text-emerald-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path></svg>
            </div>
            <h4 class="font-bold text-slate-900 mb-2">Dukungan Lokal</h4>
            <p class="text-sm text-slate-500">Produk dirancang khusus untuk pasar & bahasa Indonesia.</p>
          </div>
          <div>
            <div class="w-12 h-12 mx-auto bg-slate-50 rounded-full flex items-center justify-center mb-4 text-emerald-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
            </div>
            <h4 class="font-bold text-slate-900 mb-2">Update Gratis</h4>
            <p class="text-sm text-slate-500">Dapatkan versi terbaru dari produk yang Anda beli selamanya.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <FOMOPopup />
</BaseLayout>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('shadow-soft');
    } else {
      navbar?.classList.remove('shadow-soft');
    }
  });

  // Product filtering & search
  const filterTabs = document.querySelectorAll('.filter-tab');
  const productCards = document.querySelectorAll('.product-card');
  const searchInput = document.getElementById('product-search') as HTMLInputElement;
  const noResults = document.getElementById('no-results');

  function filterProducts() {
    const searchTerm = searchInput.value.toLowerCase();
    const activeTab = document.querySelector('.filter-tab.active') as HTMLElement;
    const activeCategory = activeTab?.dataset.filter || 'all';
    let visibleCount = 0;

    productCards.forEach(card => {
      const el = card as HTMLElement;
      const title = el.dataset.title || '';
      const category = el.dataset.category || '';
      const matchesSearch = title.includes(searchTerm);
      const matchesCategory = (activeCategory === 'all' || category === activeCategory);

      if (matchesSearch && matchesCategory) {
        el.style.display = 'flex';
        visibleCount++;
      } else {
        el.style.display = 'none';
      }
    });

    if (noResults) noResults.style.display = visibleCount === 0 ? 'block' : 'none';
  }

  filterTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      filterTabs.forEach(t => {
        t.classList.remove('active', 'bg-carbon', 'text-white');
        t.classList.add('bg-white', 'text-slate-600');
      });
      tab.classList.add('active', 'bg-carbon', 'text-white');
      tab.classList.remove('bg-white', 'text-slate-600');
      filterProducts();
    });
  });

  searchInput?.addEventListener('input', filterProducts);

  // Affiliate tracking
  const urlParams = new URLSearchParams(window.location.search);
  const ref = urlParams.get('ref');
  if (ref) {
    document.cookie = `asri_ref=${ref};max-age=${30*24*60*60};path=/;SameSite=Lax`;
    fetch('/api/affiliate/click', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ referralCode: ref, page: window.location.pathname })
    }).catch(() => {});
    window.history.replaceState({}, document.title, window.location.pathname);
  }
</script>
