---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/marketing/ProductCard.astro';
import { getDB } from '../db';
import { products, siteSettings } from '../db/schema';
import { eq, asc } from 'drizzle-orm';
import { formatIDR, parseTags } from '../lib/utils';

// Get runtime env
const env = Astro.locals?.runtime?.env || {};

let dbProducts: any[] = [];
let settings: any = null;

try {
  const db = getDB(env);
  dbProducts = await db.select()
    .from(products)
    .where(eq(products.isActive, true))
    .orderBy(asc(products.sortOrder));
  
  const settingsResult = await db.select().from(siteSettings).limit(1);
  settings = settingsResult[0] || null;
} catch (e) {
  console.error('DB error:', e);
}

// Separate all-access from regular products
const allAccessProduct = dbProducts.find(p => p.id === 'ALL-ACCESS');
const regularProducts = dbProducts.filter(p => p.id !== 'ALL-ACCESS');

const siteName = settings?.siteName || 'Asri Digital';
const siteTagline = settings?.siteTagline || 'Custom GPT untuk Profesional Indonesia';
---

<BaseLayout>
  {/* Hero Section */}
  <section class="relative bg-gradient-to-br from-background via-surface to-background py-20 lg:py-32">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-secondary/10 rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 border border-primary/20 rounded-full mb-6 animate-fade-in">
          <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
          <span class="text-sm text-primary">Produk Digital • Akses Instant</span>
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 animate-fade-in" style="animation-delay: 0.1s">
          🚀 {siteName}
        </h1>
        
        <p class="text-lg md:text-xl text-text-secondary mb-8 animate-fade-in" style="animation-delay: 0.2s">
          {siteTagline}. Akses berbagai Custom GPT siap pakai untuk marketing, coding, bisnis, dan banyak lagi.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8 animate-fade-in" style="animation-delay: 0.3s">
          <a 
            href="#all-access" 
            class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-primary to-secondary text-white rounded-xl font-bold text-lg hover:opacity-90 transition-opacity pulse-glow"
          >
            🛒 Beli All-Access Pass - {allAccessProduct ? formatIDR(allAccessProduct.price) : 'Rp 299.000'}
          </a>
        </div>
        
        <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-text-muted animate-fade-in" style="animation-delay: 0.4s">
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Akses 10+ GPT
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Update lifetime
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Support prioritas
          </span>
        </div>
      </div>
    </div>
  </section>

  {/* Social Proof Bar */}
  <section class="py-8 border-y border-border bg-surface/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-center gap-8 text-center">
        <div class="flex items-center gap-2">
          <span class="text-accent text-xl">⭐</span>
          <span class="text-text-secondary">4.9/5 dari <strong class="text-text-primary">500+</strong> pengguna</span>
        </div>
        <div class="hidden sm:block w-px h-6 bg-border"></div>
        <div class="flex items-center gap-2">
          <span class="text-xl">💰</span>
          <span class="text-text-secondary"><strong class="text-text-primary">1,000+</strong> produk terjual</span>
        </div>
        <div class="hidden sm:block w-px h-6 bg-border"></div>
        <div class="flex items-center gap-2">
          <span class="text-xl">🔒</span>
          <span class="text-text-secondary">Pembayaran <strong class="text-text-primary">100% aman</strong></span>
        </div>
      </div>
    </div>
  </section>

  {/* All-Access Banner */}
  {allAccessProduct && (
    <section id="all-access" class="py-16 scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="relative rounded-2xl border border-primary/30 bg-gradient-to-br from-primary/10 via-surface to-secondary/10 overflow-hidden">
          {/* Decorative */}
          <div class="absolute top-0 right-0 w-64 h-64 bg-primary/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
          
          <div class="relative p-8 md:p-12">
            <div class="flex flex-col md:flex-row items-start md:items-center gap-8">
              <div class="flex-1">
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-accent/20 text-accent rounded-full text-sm font-bold mb-4">
                  🏆 BEST VALUE
                </div>
                
                <h2 class="text-3xl md:text-4xl font-extrabold mb-4">
                  Lifetime All-Access Pass
                </h2>
                
                <div class="flex items-baseline gap-3 mb-6">
                  <span class="text-4xl font-extrabold text-primary">{formatIDR(allAccessProduct.price)}</span>
                  {allAccessProduct.compareAtPrice && (
                    <>
                      <span class="text-xl text-text-muted line-through">{formatIDR(allAccessProduct.compareAtPrice)}</span>
                      <span class="px-2 py-1 bg-danger/20 text-danger rounded-lg text-sm font-bold">
                        HEMAT {Math.round((1 - allAccessProduct.price / allAccessProduct.compareAtPrice) * 100)}%
                      </span>
                    </>
                  )}
                </div>
                
                <ul class="space-y-3 mb-8">
                  <li class="flex items-center gap-3 text-text-secondary">
                    <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    Akses SEMUA GPT yang ada & akan datang
                  </li>
                  <li class="flex items-center gap-3 text-text-secondary">
                    <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    Update lifetime gratis
                  </li>
                  <li class="flex items-center gap-3 text-text-secondary">
                    <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    Prioritas support
                  </li>
                  <li class="flex items-center gap-3 text-text-secondary">
                    <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    Komunitas eksklusif
                  </li>
                </ul>
                
                <a 
                  href={`/checkout?product=${allAccessProduct.slug}`}
                  class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-primary to-secondary text-white rounded-xl font-bold text-lg hover:opacity-90 transition-opacity shimmer-button"
                >
                  🚀 Dapatkan All-Access Sekarang
                </a>
              </div>
            </div>
            
            <p class="flex items-center gap-2 text-sm text-text-muted mt-6">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              Garansi 7 hari uang kembali • Sekali bayar, akses seumur hidup
            </p>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* Product Grid */}
  <section id="produk" class="py-16 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-4">Pilih GPT Sesuai Kebutuhan</h2>
        <p class="text-text-secondary max-w-2xl mx-auto">
          Setiap Custom GPT dirancang khusus untuk membantu produktivitas Anda. Beli satuan atau dapatkan semua dengan All-Access Pass.
        </p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {regularProducts.map((product, i) => (
          <div class="animate-fade-in" style={`animation-delay: ${i * 0.1}s`}>
            <ProductCard product={{
              ...product,
              tags: parseTags(product.tags),
            }} />
          </div>
        ))}
      </div>
      
      {regularProducts.length === 0 && (
        <div class="text-center py-16 border border-dashed border-border rounded-xl">
          <svg class="w-16 h-16 mx-auto text-text-muted mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
          <p class="text-text-muted">Produk akan segera tersedia</p>
        </div>
      )}
    </div>
  </section>

  {/* Features Section */}
  <section class="py-16 bg-surface/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-xl bg-primary/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-semibold mb-2">⚡ Instant Akses</h3>
          <p class="text-sm text-text-muted">Langsung bisa pakai setelah bayar</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-xl bg-success/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="font-semibold mb-2">🔒 Aman Bayar</h3>
          <p class="text-sm text-text-muted">Pembayaran terenkripsi & aman</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-xl bg-info/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-info" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          <h3 class="font-semibold mb-2">💬 Bahasa Indonesia</h3>
          <p class="text-sm text-text-muted">Semua GPT berbahasa Indonesia</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-xl bg-accent/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </div>
          <h3 class="font-semibold mb-2">🔄 Update Gratis</h3>
          <p class="text-sm text-text-muted">Dapat update terbaru otomatis</p>
        </div>
      </div>
    </div>
  </section>

  {/* CTA Section */}
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Siap Meningkatkan Produktivitas dengan AI?
      </h2>
      <p class="text-lg text-text-secondary mb-8 max-w-2xl mx-auto">
        Bergabung dengan ribuan profesional Indonesia yang sudah menggunakan Custom GPT kami untuk pekerjaan sehari-hari.
      </p>
      <a 
        href="#all-access" 
        class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-primary to-secondary text-white rounded-xl font-bold text-lg hover:opacity-90 transition-opacity"
      >
        🚀 Mulai Sekarang
      </a>
    </div>
  </section>
</BaseLayout>
