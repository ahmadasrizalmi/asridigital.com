---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { formatIDR } from '../../lib/utils';

export async function getStaticPaths() {
  const apiBase = (import.meta.env.PUBLIC_APP_URL || 'https://asridigital.com').replace(/\/$/, '');
  try {
    const res = await fetch(`${apiBase}/api/products`);
    const data = await res.json() as any;
    return (data.products || []).map((p: any) => ({ params: { slug: p.slug } }));
  } catch { return []; }
}

const productSlug = Astro.params.slug || '';
const apiBase = (import.meta.env.PUBLIC_APP_URL || 'https://asridigital.com').replace(/\/$/, '');

let product: any = null;
let relatedProducts: any[] = [];

try {
  const res = await fetch(`${apiBase}/api/products/${productSlug}`);
  if (res.ok) {
    const data = await res.json();
    product = data.product;
    if (product?.category) {
      const relRes = await fetch(`${apiBase}/api/products?category=${product.category}&limit=4`);
      if (relRes.ok) {
        const relData = await relRes.json();
        relatedProducts = (relData.products || []).filter((p: any) => p.id !== product.id).slice(0, 3);
      }
    }
  }
} catch (e) { console.error('Product fetch error:', e); }

if (!product) return Astro.redirect('/#produk');

// Parse fields from D1
const galleryImages: string[] = product.gallery_images
  ? (typeof product.gallery_images === 'string' ? JSON.parse(product.gallery_images) : product.gallery_images)
  : (product.image_icon ? [product.image_icon] : []);

const hasDiscount = product.compare_at_price && product.compare_at_price > product.price;
const isFree = product.price === 0;
const discount = hasDiscount ? Math.round((1 - product.price / product.compare_at_price) * 100) : 0;

// Build features list from product.features or generate from description
const features: Array<{title: string; description: string}> = product.features
  ? (typeof product.features === 'string' ? JSON.parse(product.features) : product.features)
  : [];

// Build specs from product.specs
const specs: Record<string, string> = product.specs
  ? (typeof product.specs === 'string' ? JSON.parse(product.specs) : product.specs)
  : {};

// Build FAQ from product.faq
const faqs: Array<{question: string; answer: string}> = product.faq
  ? (typeof product.faq === 'string' ? JSON.parse(product.faq) : product.faq)
  : [];

// Category badge text
const categoryBadge: Record<string, string> = {
  marketing: 'MARKETING', coding: 'CODE', kreatif: 'KREATIF',
  pendidikan: 'PENDIDIKAN', membership: 'ALL-ACCESS', tools: 'TOOLS',
  data: 'DATA', ai: 'AI',
};
const badgeText = categoryBadge[product.category?.toLowerCase()] || (product.category || 'DIGITAL').toUpperCase();
---

<BaseLayout title={`${product.title} - Asri Digital`} description={product.short_description || product.description}>
  <Header />

  <main class="pt-28 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav class="flex text-sm text-slate-500 mb-8" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3 flex-wrap">
          <li class="inline-flex items-center">
            <a href="/" class="hover:text-slate-900 transition-colors">Beranda</a>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="w-3 h-3 mx-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
              <a href="/#produk" class="hover:text-slate-900 transition-colors ml-1 md:ml-2">Katalog Produk</a>
            </div>
          </li>
          <li aria-current="page">
            <div class="flex items-center">
              <svg class="w-3 h-3 mx-1 text-slate-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
              <span class="ml-1 md:ml-2 text-slate-800 font-medium">{product.title}</span>
            </div>
          </li>
        </ol>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- LEFT: Image Gallery -->
        <div class="space-y-4">
          <div class="aspect-square rounded-2xl overflow-hidden border border-slate-200 bg-slate-50 relative group">
            <span class="absolute top-4 left-4 z-10 bg-white/90 backdrop-blur text-slate-800 text-xs font-bold px-3 py-1.5 rounded-full shadow-sm border border-slate-100">{badgeText}</span>
            {hasDiscount && !isFree && (
              <span class="absolute top-4 right-4 z-10 bg-red-500 text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-sm">-{discount}%</span>
            )}
            {isFree && (
              <span class="absolute top-4 right-4 z-10 bg-green-500 text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-sm">GRATIS</span>
            )}
            <img id="main-image" src={galleryImages[0] || product.image_icon || '/images/placeholder.jpg'} alt={product.title} class="w-full h-full object-cover" />
          </div>
          {galleryImages.length > 1 && (
            <div class="grid grid-cols-4 gap-4">
              {galleryImages.map((img: string, i: number) => (
                <button class={`aspect-square rounded-xl overflow-hidden bg-slate-50 transition-all ${i === 0 ? 'border-2 border-slate-900' : 'border border-slate-200 opacity-60 hover:opacity-100'}`} onclick={`changeMainImage('${img}', ${i})`}>
                  <img src={img} alt={`${product.title} ${i + 1}`} class="w-full h-full object-cover" />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- RIGHT: Product Details -->
        <div class="flex flex-col">
          <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mb-4 tracking-tight">{product.title}</h1>

          <div class="flex items-center space-x-4 mb-6">
            <div class="flex items-center text-yellow-400">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
              <span class="ml-1 text-sm font-medium text-slate-700">4.9 (120+ Review)</span>
            </div>
            <span class="text-slate-300">|</span>
            <span class="text-sm font-medium text-green-700 bg-green-50 px-2.5 py-0.5 rounded">Tersedia Instan</span>
          </div>

          <p class="text-slate-600 text-base leading-relaxed mb-8">
            {product.short_description || product.description}
          </p>

          <!-- Price Block -->
          <div class="bg-slate-50 border border-slate-200 rounded-2xl p-6 mb-8">
            {isFree ? (
              <>
                <div class="flex items-end mb-4">
                  <span class="text-4xl font-extrabold text-green-600 tracking-tight">Gratis</span>
                </div>
              </>
            ) : (
              <>
                {hasDiscount && (
                  <p class="text-sm text-slate-500 font-medium mb-1 line-through">Harga Normal: {formatIDR(product.compare_at_price)}</p>
                )}
                <div class="flex items-end mb-4">
                  <span class="text-4xl font-extrabold text-slate-900 tracking-tight">{formatIDR(product.price)}</span>
                  {hasDiscount && (
                    <span class="ml-3 mb-1 text-xs font-bold bg-red-100 text-red-600 px-2 py-1 rounded">Diskon {discount}%</span>
                  )}
                </div>
              </>
            )}

            <div class="space-y-3 mb-6">
              <div class="flex items-center text-sm text-slate-600">
                <svg class="w-5 h-5 text-emerald-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>Akses instan setelah pembayaran</span>
              </div>
              <div class="flex items-center text-sm text-slate-600">
                <svg class="w-5 h-5 text-emerald-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>Lisensi seumur hidup</span>
              </div>
              <div class="flex items-center text-sm text-slate-600">
                <svg class="w-5 h-5 text-emerald-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>Gratis update versi mendatang</span>
              </div>
              {features.length > 0 && features.slice(0, 3).map((f: {title: string}) => (
                <div class="flex items-center text-sm text-slate-600">
                  <svg class="w-5 h-5 text-emerald-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                  <span>{f.title}</span>
                </div>
              ))}
            </div>

            <a id="buy-button" href={`/checkout?product=${product.slug}`} class="w-full bg-gradient-to-r from-emerald-300 to-yellow-100 text-slate-800 py-4 rounded-xl font-bold text-lg transition-all shadow-sm hover:shadow-md hover:from-emerald-400 hover:to-yellow-200 transform hover:-translate-y-0.5 flex items-center justify-center">
              <svg class="w-5 h-5 mr-2 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
              {isFree ? 'Download Gratis' : 'Beli & Download Instan'}
            </a>
            <p class="text-center text-xs text-slate-400 mt-4 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
              Pembayaran dijamin aman via Payment Gateway
            </p>
          </div>

          <!-- All-Access Badge -->
          <div class="flex items-center gap-3 p-4 bg-slate-50 rounded-xl border border-slate-200">
            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-slate-900">Tersedia di All-Access Pass</p>
              <p class="text-xs text-slate-500">Bayar sekali Rp 299.000, akses semua produk seumur hidup</p>
            </div>
            <a href="/checkout?product=lifetime-all-access-pass" class="text-emerald-600 text-sm font-semibold hover:underline shrink-0">Lihat →</a>
          </div>
        </div>
      </div>

      <!-- Description -->
      <div class="mt-20 border-t border-slate-200 pt-12">
        <div class="max-w-3xl">
          <h3 class="text-2xl font-bold text-slate-900 mb-6">Deskripsi Lengkap</h3>
          <div class="prose prose-slate text-slate-600 space-y-4">
            <p>{product.description}</p>
          </div>
        </div>
      </div>

      <!-- Features Section -->
      {features.length > 0 && (
        <section class="mt-12">
          <div class="max-w-3xl">
            <h3 class="text-2xl font-bold text-slate-900 mb-6">Fitur Utama</h3>
            <div class="space-y-4">
              {features.map((feature: {title: string; description: string}) => (
                <div class="flex items-start gap-4 p-4 bg-white border border-slate-100 rounded-xl hover:shadow-float transition-all">
                  <div class="w-10 h-10 bg-emerald-50 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                  </div>
                  <div>
                    <h4 class="font-semibold text-slate-900 mb-1">{feature.title}</h4>
                    <p class="text-sm text-slate-500">{feature.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- Specifications -->
      {Object.keys(specs).length > 0 && (
        <section class="mt-12">
          <div class="max-w-3xl">
            <h3 class="text-2xl font-bold text-slate-900 mb-6">Spesifikasi</h3>
            <div class="border border-slate-200 rounded-2xl overflow-hidden">
              {Object.entries(specs).map(([key, value], i) => (
                <div class={`flex ${i > 0 ? 'border-t border-slate-100' : ''}`}>
                  <div class="w-1/3 px-6 py-4 bg-slate-50 font-medium text-slate-900 text-sm">{key}</div>
                  <div class="flex-1 px-6 py-4 text-slate-600 text-sm">{value}</div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- FAQ -->
      {faqs.length > 0 && (
        <section class="mt-12">
          <div class="max-w-3xl">
            <h3 class="text-2xl font-bold text-slate-900 mb-6">Pertanyaan Umum</h3>
            <div class="space-y-3">
              {faqs.map((faq: {question: string; answer: string}, index: number) => (
                <div class="border border-slate-200 rounded-xl overflow-hidden">
                  <button onclick={`toggleFaq(${index})`} class="w-full px-6 py-4 flex items-center justify-between text-left hover:bg-slate-50 transition-colors">
                    <span class="font-semibold text-slate-900 text-sm pr-4">{faq.question}</span>
                    <svg id={`faq-icon-${index}`} class="w-5 h-5 text-slate-400 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                  </button>
                  <div id={`faq-content-${index}`} class="hidden px-6 pb-4">
                    <p class="text-sm text-slate-600 leading-relaxed">{faq.answer}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- Related Products -->
      {relatedProducts.length > 0 && (
        <section class="mt-20 border-t border-slate-200 pt-12">
          <h3 class="text-2xl font-bold text-slate-900 mb-8 text-center">Produk Lainnya</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedProducts.map((rp: any) => (
              <a href={`/product/${rp.slug}`} class="bg-white rounded-2xl overflow-hidden border border-slate-100 hover:shadow-float hover:-translate-y-1 transition-all duration-300 group">
                <div class="overflow-hidden aspect-square bg-slate-50">
                  <img src={rp.image_icon || '/images/placeholder.jpg'} alt={rp.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                </div>
                <div class="p-5">
                  <h4 class="font-bold text-slate-900 mb-2 line-clamp-1">{rp.title}</h4>
                  <p class="text-sm text-slate-500 mb-4 line-clamp-2">{rp.short_description || rp.description}</p>
                  <div class="flex items-center justify-between pt-3 border-t border-slate-50">
                    {rp.price === 0 ? (
                      <span class="text-lg font-bold text-slate-900">Gratis</span>
                    ) : (
                      <span class="text-lg font-bold text-slate-900">{formatIDR(rp.price)}</span>
                    )}
                    <span class="bg-slate-100 text-slate-900 px-4 py-2 rounded-lg text-sm font-semibold group-hover:bg-gradient-to-r group-hover:from-emerald-300 group-hover:to-yellow-100 group-hover:text-slate-800 transition-all">Detail</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>

<script define:vars={{ galleryImages }}>
  function changeMainImage(src, index) {
    const mainImage = document.getElementById('main-image');
    if (mainImage) mainImage.src = src;
    const thumbnails = document.querySelectorAll('button[onclick^="changeMainImage"]');
    thumbnails.forEach((thumb, i) => {
      if (i === index) {
        thumb.classList.remove('border-slate-200', 'opacity-60');
        thumb.classList.add('border-2', 'border-slate-900', 'opacity-100');
      } else {
        thumb.classList.remove('border-2', 'border-slate-900', 'opacity-100');
        thumb.classList.add('border-slate-200', 'opacity-60');
      }
    });
  }

  function toggleFaq(index) {
    const content = document.getElementById('faq-content-' + index);
    const icon = document.getElementById('faq-icon-' + index);
    if (content) content.classList.toggle('hidden');
    if (icon) icon.classList.toggle('rotate-180');
  }

  window.changeMainImage = changeMainImage;
  window.toggleFaq = toggleFaq;

  // Tracking: ViewContent
  if (typeof window.trackEvent === 'function') {
    window.trackEvent('view_content', {
      content_name: document.title,
      content_type: 'product',
      content_ids: [window.location.pathname.split('/').filter(Boolean).pop()]
    });
  }

  // Check product access
  (async function checkProductAccess() {
    const token = localStorage.getItem('auth_token');
    if (!token) return;
    try {
      const res = await fetch('/api/user/products', { headers: { 'Authorization': 'Bearer ' + token } });
      if (!res.ok) return;
      const data = await res.json();
      const slug = window.location.pathname.split('/').filter(Boolean).pop();
      const owned = (data.products || []).find((p) => p.slug === slug);
      if (owned) {
        const btn = document.getElementById('buy-button');
        if (btn) {
          btn.classList.remove('from-emerald-300', 'to-yellow-100');
          btn.classList.add('bg-white', 'border-2', 'border-slate-200', 'hover:border-slate-400');
          btn.innerHTML = '<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 3H19A2 2 0 0 1 21 5V19A2 2 0 0 1 19 21H15"/><path d="M10 17L15 12L10 7"/><path d="M15 12H3"/></svg> Akses Produk';
          btn.setAttribute('href', '/dashboard');
        }
      }
    } catch {}
  })();
</script>
